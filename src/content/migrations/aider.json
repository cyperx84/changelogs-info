{
  "harness": "aider",
  "migrations": [
    {
      "from": "0.50",
      "to": "0.60",
      "breaking": false,
      "description": "Enhanced chat modes and improved diff formatting",
      "steps": [
        {
          "title": "Enable architect mode",
          "description": "New mode for large refactoring tasks",
          "before": "aider --edit-format whole",
          "after": "aider --architect",
          "notes": "Architect mode uses planning before implementation"
        },
        {
          "title": "Configure model settings file",
          "description": "Persistent model configuration",
          "before": "aider --model gpt-4 --no-stream",
          "after": "# .aider.model.settings.yml\nmodel: gpt-4\nstream: false",
          "notes": "Reduces repetitive CLI flags"
        }
      ]
    },
    {
      "from": "0.40",
      "to": "0.50",
      "breaking": true,
      "description": "Git integration improvements and breaking config changes",
      "steps": [
        {
          "title": "Update auto-commits flag",
          "description": "Flag renamed for clarity",
          "before": "aider --no-auto-commit",
          "after": "aider --no-auto-commits",
          "notes": "Plural form for consistency"
        },
        {
          "title": "Migrate diff format",
          "description": "Default diff format changed",
          "before": "# Used whole file diffs by default",
          "after": "aider --edit-format udiff",
          "notes": "udiff is now default. Use --edit-format whole for old behavior."
        }
      ]
    }
  ]
}
