{
  "harness": "goose",
  "migrations": [
    {
      "from": "python",
      "to": "rust",
      "title": "Goose Python to Rust migration",
      "description": "Block rewrote Goose in Rust. Python version is deprecated.",
      "breaking": true,
      "steps": [
        {
          "title": "Uninstall Python",
          "description": "Remove old Python installation",
          "before": "pip install goose-ai",
          "after": "pip uninstall goose-ai",
          "notes": "Python plugins are not compatible"
        },
        {
          "title": "Install Rust",
          "description": "Install Rust-based Goose",
          "before": null,
          "after": "brew install block/tap/goose",
          "notes": "Or cargo install from source"
        },
        {
          "title": "Config",
          "description": "Config format changed from TOML to YAML",
          "before": "[providers]\ndefault = \"openai\"",
          "after": "provider: anthropic\nmodel: claude-sonnet-4-5",
          "notes": "Run goose configure for interactive setup"
        }
      ]
    }
  ]
}