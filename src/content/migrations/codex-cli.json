{
  "harness": "codex-cli",
  "migrations": [
    {
      "from": "0.9",
      "to": "1.0",
      "breaking": true,
      "description": "Stable release with config file standardization",
      "steps": [
        {
          "title": "Rename config file",
          "description": "Configuration moved to standard location",
          "before": "~/.codex/config.yaml",
          "after": "~/.config/codex/config.yaml",
          "notes": "Follows XDG Base Directory specification"
        },
        {
          "title": "Update API key environment variable",
          "description": "Standardized environment variable naming",
          "before": "export OPENAI_KEY=sk-...",
          "after": "export CODEX_API_KEY=sk-...",
          "notes": "Tool-specific env var to avoid conflicts"
        },
        {
          "title": "Migrate model selection syntax",
          "description": "New model specification format",
          "before": "codex --model gpt-4",
          "after": "codex --model openai:gpt-4",
          "notes": "Provider prefix now required for clarity"
        }
      ]
    }
  ]
}
