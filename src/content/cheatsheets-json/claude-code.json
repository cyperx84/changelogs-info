  "workflows": [
    {
      "title": "Quick Code Review",
      "description": "Review staged changes and auto-commit with AI message",
      "steps": [
        "Make code changes in your editor",
        "Stage changes with git",
        "Run `/review` to get AI feedback",
        "Run `/simplify` to optimize code",
        "Run `/commit` to create AI-generated commit message"
      ]
    },
    {
      "title": "Feature Development",
      "description": "Plan, implement, and test a new feature using plan mode",
      "steps": [
        "Start Claude Code session",
        "Run `/plan` to enter plan mode",
        "Describe feature and review architecture plan",
        "Approve plan",
        "Implementation begins automatically",
        "Run tests and review output",
        "Run `/pr` to create pull request"
      ]
    },
    {
      "title": "Multi-Agent Parallel Work",
      "description": "Coordinate multiple agents to work on different parts of a task",
      "steps": [
        "Use `TeamCreate` to form a team",
        "Create tasks with `TaskCreate`",
        "Spawn teammates with `Agent` tool",
        "Assign tasks with `TaskUpdate`",
        "Teammates communicate via `SendMessage`",
        "Monitor progress with task list",
        "Shutdown with `shutdown_request` when complete"
      ]
    },
    {
      "title": "Remote Task Dispatch",
      "description": "Dispatch autonomous work to Anthropic cloud",
      "steps": [
        "Run `claude --remote \"task description\"`",
        "Claude executes task on Anthropic servers",
        "Monitor progress from local terminal",
        "Results returned to local environment",
        "Use `/teleport` to move session to claude.ai/code if needed"
      ]
    },
    {
      "title": "Worktree Experimentation",
      "description": "Test risky changes in isolated worktrees",
      "steps": [
        "User requests: 'work in a worktree'",
        "Claude creates isolated branch in .claude/worktrees/",
        "Make experimental changes",
        "Test thoroughly",
        "Exit worktree with option to keep or remove"
      ]
    }
  ],
  "proTips": [
    "Use `/plan` mode before major refactors to get architecture approval first",
    "Use `--max-turns` to prevent runaway agentic loops",
    "Use `/compact` to compress context when approaching token limits",
    "Prefer `Explore` agent over `general-purpose` for read-only tasks to save tokens",
    "Create .claude/CLAUDE.md in projects for team-shared instructions",
    "Use hooks to enforce code style (prettier, eslint) automatically",
    "Set `--fallback-model` to ensure work continues if primary model is overloaded",
    "Use `/stats` to debug token usage and understand what's consuming context",
    "Configure `.claude/keybindings.json` to match your editor (vim, emacs, etc)",
    "Commit `.claude/CLAUDE.md` to version control for team consistency",
    "Use `--dangerously-skip-permissions` only in trusted, isolated environments",
    "Review `.claude/sessions/` transcripts to understand agent decision-making"
  ],
