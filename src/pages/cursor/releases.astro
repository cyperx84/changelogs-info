---
import CursorLayout from "../../layouts/CursorLayout.astro";
import { getToolReleases, formatDate } from "../../lib/releases";
import "../../styles/releases-shared.css";

const data = await getToolReleases("cursor");
const releases = data?.releases || [];
const stableReleases = releases.filter((r) => !r.prerelease);
const latestStable = stableReleases[0];

function isBreaking(body: string = ""): boolean {
  return body.toLowerCase().includes("breaking");
}

const INITIAL_LOAD = 12;
---

<CursorLayout
  title="Cursor Releases — changelogs.info"
  description="All Cursor releases. Version history and iteration log."
  currentPage="releases"
>
  <div class="rl-wrapper">

    <header class="rl-header">
      <div>
        <h1 class="cu-headline rl-header__title">Releases</h1>
        <p class="cu-headline rl-header__sub">Version History &amp; Iteration Log</p>
      </div>
      <div class="rl-header__stats">
        {latestStable && (
          <div class="rl-stat-box">
            <span class="rl-stat-box__label">Latest Stable</span>
            <span class="cu-headline rl-stat-box__value">{latestStable.version}</span>
          </div>
        )}
        <div class="rl-stat-box">
          <span class="rl-stat-box__label">Total</span>
          <span class="cu-headline rl-stat-box__value rl-stat-box__value--neutral">{releases.length}</span>
        </div>
      </div>
    </header>

    {releases.length > 6 && (
      <div class="rl-filters">
        <span class="rl-filters__label">Filter:</span>
        {["all", "stable", "breaking", "prerelease"].map((f) => (
          <button
            class="cu-headline rl-filter-btn releases-filter-btn"
            data-filter={f}
            data-active={f === "all" ? "true" : "false"}
          >
            {f === "prerelease" ? "Pre" : f.charAt(0).toUpperCase() + f.slice(1)}
          </button>
        ))}
        <input id="releases-search" type="text" placeholder="Search..." class="rl-search" />
      </div>
    )}

    {releases.length > 0 ? (
      <div id="releases-grid" class="rl-grid">
        {releases.map((release, idx) => {
          const breaking = isBreaking(release.body);
          return (
            <div
              class={`rl-card ${breaking ? 'rl-card--breaking' : 'rl-card--normal'} release-card`}
              data-version={release.version.toLowerCase()}
              data-name={(release.name || "").toLowerCase()}
              data-prerelease={String(release.prerelease)}
              data-breaking={String(breaking)}
              data-hidden-init={idx >= INITIAL_LOAD ? "true" : "false"}
            >
              <div class="rl-card__top">
                <div>
                  <span class="cu-headline rl-card__version">{release.version}</span>
                  <span class="rl-card__date">{formatDate(release.date)}</span>
                </div>
                <div class="rl-card__badges">
                  {breaking && <span class="rl-badge rl-badge--breaking">BREAKING</span>}
                  {release.prerelease && <span class="rl-badge rl-badge--pre">PRE</span>}
                </div>
              </div>

              {release.name && (
                <p class="cu-headline rl-card__name">
                  {release.name.replace(/cursor\s+/i, "")}
                </p>
              )}

              <a href={release.url} target="_blank" rel="noopener noreferrer" class="rl-card__link">
                ↗ View on GitHub
              </a>
            </div>
          );
        })}
      </div>
    ) : (
      <div class="rl-empty">
        <p>$ no releases tracked yet</p>
      </div>
    )}

    {releases.length > INITIAL_LOAD && (
      <div class="rl-load-more">
        <button id="load-more-releases" class="cu-headline rl-load-more-btn">Load More ▼</button>
      </div>
    )}
  </div>

  <script>
    const cards = Array.from(document.querySelectorAll('.release-card')) as HTMLElement[];
    cards.forEach(card => {
      if (card.dataset.hiddenInit === 'true') card.style.display = 'none';
    });

    const filterBtns = Array.from(document.querySelectorAll('.releases-filter-btn')) as HTMLElement[];
    const searchInput = document.getElementById('releases-search') as HTMLInputElement;
    const loadMoreBtn = document.getElementById('load-more-releases');
    let activeFilter = 'all';
    let searchQuery = '';
    let allLoaded = false;

    filterBtns.find(b => b.dataset.filter === 'all')?.classList.add('is-active');

    function applyFilters() {
      cards.forEach((card) => {
        const version = card.dataset.version || '';
        const name = card.dataset.name || '';
        const prerelease = card.dataset.prerelease === 'true';
        const breaking = card.dataset.breaking === 'true';
        const matchesSearch = !searchQuery || version.includes(searchQuery) || name.includes(searchQuery);
        const matchesFilter =
          activeFilter === 'all' ||
          (activeFilter === 'stable' && !prerelease) ||
          (activeFilter === 'breaking' && breaking) ||
          (activeFilter === 'prerelease' && prerelease);
        const withinLimit = allLoaded || card.dataset.hiddenInit !== 'true';
        card.style.display = (matchesSearch && matchesFilter && withinLimit) ? '' : 'none';
      });
    }

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        activeFilter = btn.dataset.filter || 'all';
        filterBtns.forEach(b => b.classList.remove('is-active'));
        btn.classList.add('is-active');
        applyFilters();
      });
    });

    searchInput?.addEventListener('input', () => {
      searchQuery = searchInput.value.toLowerCase().trim();
      if (searchQuery) allLoaded = true;
      applyFilters();
    });

    loadMoreBtn?.addEventListener('click', () => {
      allLoaded = true;
      loadMoreBtn.style.display = 'none';
      cards.forEach(card => { if (card.dataset.hiddenInit === 'true') card.style.display = ''; });
      applyFilters();
    });
  </script>
</CursorLayout>
