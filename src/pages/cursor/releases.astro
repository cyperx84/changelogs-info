---
import CursorLayout from "../../layouts/CursorLayout.astro";
import { getToolReleases, formatDate } from "../../lib/releases";

const data = await getToolReleases("cursor");
const releases = data?.releases || [];
const stableReleases = releases.filter((r) => !r.prerelease);
const latestStable = stableReleases[0];

function isBreaking(body: string = ""): boolean {
  return body.toLowerCase().includes("breaking");
}

const INITIAL_LOAD = 12;
---

<CursorLayout
  title="Cursor Releases — changelogs.info"
  description="All Cursor releases. Version history and iteration log."
  currentPage="releases"
>
  <div style="max-width: 1280px; margin: 0 auto; padding: 2rem 1.5rem 0;">
    <header style="margin-bottom: 2.5rem; display: flex; flex-wrap: wrap; align-items: end; justify-content: space-between; gap: 1rem;">
      <div>
        <div style="font-family: var(--cu-font-mono); font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--cu-primary-bright); margin-bottom: 0.45rem;">Release log</div>
        <h1 class="cu-headline" style="margin: 0 0 0.35rem; font-size: clamp(3rem, 8vw, 5.8rem); line-height: 0.92; letter-spacing: -0.05em;">Releases</h1>
        <p style="margin: 0; color: var(--cu-text-dim);">Version history and release tracking for Cursor.</p>
      </div>

      <div style="display: flex; gap: 0.8rem; flex-wrap: wrap;">
        <div style="padding: 0.95rem 1.15rem; border-radius: 18px; border: 1px solid var(--cu-border-dim); background: rgba(13,26,49,0.88);">
          <div style="font-family: var(--cu-font-mono); font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--cu-text-muted); margin-bottom: 0.35rem;">Latest stable</div>
          <div class="cu-headline" style="font-size: 1.4rem;">{latestStable?.version || "Pending"}</div>
        </div>
        <div style="padding: 0.95rem 1.15rem; border-radius: 18px; border: 1px solid var(--cu-border-dim); background: rgba(13,26,49,0.88);">
          <div style="font-family: var(--cu-font-mono); font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--cu-text-muted); margin-bottom: 0.35rem;">Tracked releases</div>
          <div class="cu-headline" style="font-size: 1.4rem;">{releases.length}</div>
        </div>
      </div>
    </header>

    {releases.length > 6 && (
      <div style="display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 1.4rem; align-items: center;">
        <span style="font-family: var(--cu-font-mono); font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--cu-text-muted);">Filter</span>
        {["all", "stable", "breaking", "prerelease"].map((f) => (
          <button
            class="cu-headline releases-filter-btn"
            data-filter={f}
            style={`border: 1px solid ${f === "all" ? "var(--cu-primary)" : "var(--cu-border-dim)"}; padding: 0.42rem 0.9rem; border-radius: 999px; font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.08em; cursor: pointer; background: ${f === "all" ? "var(--cu-primary)" : "transparent"}; color: ${f === "all" ? "#fff" : "var(--cu-text-muted)"};`}
          >
            {f === "prerelease" ? "Pre-release" : f}
          </button>
        ))}
        <input
          id="releases-search"
          type="text"
          placeholder="Search..."
          style="margin-left: auto; min-width: 220px; border-radius: 999px; border: 1px solid var(--cu-border-dim); background: rgba(13,26,49,0.9); padding: 0.55rem 0.9rem; color: var(--cu-text); font-family: var(--cu-font-mono);"
        />
      </div>
    )}

    {releases.length > 0 ? (
      <div id="releases-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1rem; margin-bottom: 2rem;">
        {releases.map((release, idx) => {
          const breaking = isBreaking(release.body);
          return (
            <article
              class="release-card"
              data-version={release.version.toLowerCase()}
              data-name={(release.name || "").toLowerCase()}
              data-prerelease={String(release.prerelease)}
              data-breaking={String(breaking)}
              data-hidden-init={idx >= INITIAL_LOAD ? "true" : "false"}
              style={`padding: 1.35rem; border-radius: 22px; border: 1px solid ${breaking ? "var(--cu-primary)" : "var(--cu-border-dim)"}; background: ${breaking ? "rgba(20,110,245,0.12)" : "rgba(13,26,49,0.9)"}; box-shadow: var(--cu-shadow-sm);`}
            >
              <div style="display: flex; justify-content: space-between; gap: 0.75rem; align-items: start; margin-bottom: 0.75rem;">
                <div>
                  <div class="cu-headline" style="font-size: 1.45rem;">{release.version}</div>
                  <div style="font-family: var(--cu-font-mono); font-size: 0.68rem; color: var(--cu-text-muted);">{formatDate(release.date)}</div>
                </div>
                <div style="display: grid; gap: 0.35rem; justify-items: end;">
                  {breaking && <span style="padding: 0.2rem 0.5rem; border-radius: 999px; background: var(--cu-primary); color: #fff; font-family: var(--cu-font-mono); font-size: 0.6rem;">BREAKING</span>}
                  {release.prerelease && <span style="padding: 0.2rem 0.5rem; border-radius: 999px; border: 1px solid var(--cu-border); color: var(--cu-primary-bright); font-family: var(--cu-font-mono); font-size: 0.6rem;">PRE</span>}
                </div>
              </div>

              {release.name && (
                <p style="margin: 0 0 0.9rem; color: var(--cu-text-dim); line-height: 1.55;">{release.name}</p>
              )}

              <a
                href={release.url}
                target="_blank"
                rel="noopener noreferrer"
                style="display: inline-flex; align-items: center; gap: 0.35rem; text-decoration: none; color: var(--cu-primary-bright); font-family: var(--cu-font-mono); font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.08em;"
              >
                ↗ View source
              </a>
            </article>
          );
        })}
      </div>
    ) : (
      <div style="padding: 3rem 1.5rem; border-radius: 24px; border: 1px dashed var(--cu-border-dim); background: rgba(13,26,49,0.6); color: var(--cu-text-dim); margin-bottom: 2rem;">
        Cursor is registered for release tracking, but no releases have been indexed yet.
      </div>
    )}

    {releases.length > INITIAL_LOAD && (
      <div style="text-align: center;">
        <button
          id="load-more-releases"
          class="cu-headline"
          style="border-radius: 999px; border: 1px solid var(--cu-border); background: transparent; color: var(--cu-text); padding: 0.85rem 1.5rem; cursor: pointer; text-transform: uppercase; letter-spacing: 0.08em;"
        >
          Load more ▼
        </button>
      </div>
    )}
  </div>

  <script>
    const cards = Array.from(document.querySelectorAll(".release-card"));
    cards.forEach((card) => {
      if (card.dataset.hiddenInit === "true") card.style.display = "none";
    });

    const filterBtns = Array.from(document.querySelectorAll(".releases-filter-btn"));
    const searchInput = document.getElementById("releases-search");
    const loadMoreBtn = document.getElementById("load-more-releases");
    let activeFilter = "all";
    let searchQuery = "";
    let allLoaded = false;

    function applyFilters() {
      cards.forEach((card) => {
        const version = card.dataset.version || "";
        const name = card.dataset.name || "";
        const prerelease = card.dataset.prerelease === "true";
        const breaking = card.dataset.breaking === "true";

        const matchesSearch = !searchQuery || version.includes(searchQuery) || name.includes(searchQuery);
        const matchesFilter =
          activeFilter === "all"
          || (activeFilter === "stable" && !prerelease)
          || (activeFilter === "breaking" && breaking)
          || (activeFilter === "prerelease" && prerelease);

        const withinLimit = allLoaded || card.dataset.hiddenInit !== "true";
        card.style.display = matchesSearch && matchesFilter && withinLimit ? "" : "none";
      });
    }

    filterBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        activeFilter = btn.dataset.filter || "all";
        filterBtns.forEach((b) => {
          b.style.background = "transparent";
          b.style.color = "var(--cu-text-muted)";
          b.style.borderColor = "var(--cu-border-dim)";
        });
        btn.style.background = "var(--cu-primary)";
        btn.style.color = "#fff";
        btn.style.borderColor = "var(--cu-primary)";
        applyFilters();
      });
    });

    searchInput?.addEventListener("input", (event) => {
      searchQuery = event.target.value.toLowerCase().trim();
      if (searchQuery) allLoaded = true;
      applyFilters();
    });

    loadMoreBtn?.addEventListener("click", () => {
      allLoaded = true;
      loadMoreBtn.style.display = "none";
      applyFilters();
    });
  </script>
</CursorLayout>
