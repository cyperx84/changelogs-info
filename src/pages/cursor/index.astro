---
import CursorLayout from "../../layouts/CursorLayout.astro";
import { getToolById, getToolReleases, formatDate, relativeTime } from "../../lib/releases";
import { readFileSync } from "node:fs";
import { join } from "node:path";

const tool = getToolById("cursor");
const data = await getToolReleases("cursor");
const releases = data?.releases || [];
const stableReleases = releases.filter((r) => !r.prerelease);
const latestStable = stableReleases[0];
const latestRelease = releases[0];
const lastUpdatedAgo = data?.lastUpdated ? relativeTime(data.lastUpdated) : null;

let cs: any = {};
try {
  const raw = readFileSync(join(process.cwd(), "src/content/cheatsheets-json/cursor.json"), "utf-8");
  cs = JSON.parse(raw);
} catch {}

const features = [
  {
    title: "Tab autocomplete",
    copy: "Multi-line completions that keep the current flow going instead of just finishing one token at a time.",
  },
  {
    title: "Agent mode",
    copy: "Cursor agents inspect the repo, edit multiple files, run commands, and iterate toward a finished feature.",
  },
  {
    title: "Composer",
    copy: "Kick off larger multi-file changes from a single prompt and let Cursor coordinate the edit sequence.",
  },
  {
    title: "Codebase chat",
    copy: "Ask about architecture, implementation details, or a specific bug with repo-aware context already loaded.",
  },
];

const cheatsheet = [
  { key: "Cmd+K", label: "Inline edit", note: "Rewrite selected code without leaving the editor." },
  { key: "Cmd+L", label: "Chat", note: "Open the chat panel for repo-aware Q&A." },
  { key: "Cmd+I", label: "Composer", note: "Start larger multi-file work from the AI panel." },
  { key: "@", label: "Reference files", note: "Pull files, symbols, and folders into the prompt context." },
  { key: "Agent mode", label: "Default worker", note: "Let Cursor plan, edit, and verify a broader task." },
];
---

<CursorLayout
  title="Cursor Changelog, Cheatsheet, and Releases | changelogs.info"
  description="The AI-first code editor. Tab completes your thoughts, agents write entire features, chat knows your codebase."
  currentPage="home"
>
  <div class="cu-dotgrid" style="position: fixed; inset: 0; opacity: 0.22; pointer-events: none;"></div>

  <div style="max-width: 1280px; margin: 0 auto; padding: 2rem 1.5rem 0; position: relative;">
    <section style="display: grid; grid-template-columns: minmax(0, 1.3fr) minmax(300px, 0.9fr); gap: 2rem; align-items: stretch; margin-bottom: 2rem;" class="cu-home-grid">
      <div style="padding: 2.4rem; border: 1px solid var(--cu-border); background: linear-gradient(180deg, rgba(20,110,245,0.16), rgba(18,37,69,0.92)); box-shadow: var(--cu-shadow); border-radius: 24px;">
        <div style="display: inline-flex; align-items: center; gap: 0.6rem; padding: 0.45rem 0.8rem; border: 1px solid var(--cu-border-dim); border-radius: 999px; background: rgba(255,255,255,0.04); margin-bottom: 1rem;">
          <span class="cu-pulse-dot" style="width: 0.55rem; height: 0.55rem; border-radius: 999px; background: var(--cu-primary-bright);"></span>
          <span style="font-family: var(--cu-font-mono); font-size: 0.72rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--cu-text-dim);">
            Cursor section
          </span>
        </div>

        <h1 class="cu-headline" style="margin: 0 0 1rem; font-size: clamp(3rem, 8vw, 5.8rem); line-height: 0.92; letter-spacing: -0.05em;">
          The best way to code with AI
        </h1>

        <p style="margin: 0 0 1.5rem; max-width: 42rem; font-size: 1.08rem; line-height: 1.7; color: var(--cu-text-dim);">
          The AI-first code editor. Tab completes your thoughts, agents write entire features, chat knows your codebase.
        </p>

        <div style="display: flex; flex-wrap: wrap; gap: 0.9rem; margin-bottom: 1.4rem;">
          <a href="/cursor/changelog/" class="cu-cta-btn cu-headline" style="display: inline-flex; align-items: center; justify-content: center; padding: 0.95rem 1.3rem; border-radius: 14px; text-decoration: none; background: var(--cu-primary); color: #fff; letter-spacing: 0.08em; text-transform: uppercase; font-size: 0.78rem;">
            View changelog
          </a>
          <a href="/cursor/cheatsheet/" class="cu-cta-btn cu-headline" style="display: inline-flex; align-items: center; justify-content: center; padding: 0.95rem 1.3rem; border-radius: 14px; text-decoration: none; background: transparent; color: var(--cu-text); border: 1px solid var(--cu-border); letter-spacing: 0.08em; text-transform: uppercase; font-size: 0.78rem;">
            Open cheatsheet
          </a>
        </div>

        <div style="display: flex; flex-wrap: wrap; gap: 0.75rem;">
          {features.map((feature) => (
            <span style="padding: 0.55rem 0.8rem; border-radius: 999px; background: rgba(255,255,255,0.05); border: 1px solid var(--cu-border-dim); font-family: var(--cu-font-mono); font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--cu-text-dim);">
              {feature.title}
            </span>
          ))}
        </div>
      </div>

      <aside style="padding: 1.5rem; border: 1px solid var(--cu-border-dim); background: rgba(13, 26, 49, 0.9); border-radius: 24px; box-shadow: var(--cu-shadow-sm); display: grid; gap: 1rem;">
        <div style="display: flex; justify-content: space-between; align-items: center; gap: 1rem; padding-bottom: 0.9rem; border-bottom: 1px solid var(--cu-border-dim);">
          <div>
            <div style="font-family: var(--cu-font-mono); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--cu-text-muted);">Cursor status</div>
            <div class="cu-headline" style="font-size: 1.55rem;">{latestStable?.version || latestRelease?.version || "No tracked release"}</div>
          </div>
          <div style="font-family: var(--cu-font-mono); font-size: 0.72rem; color: var(--cu-primary-bright);">
            {lastUpdatedAgo || "waiting"}
          </div>
        </div>

        <div style="font-family: var(--cu-font-mono); font-size: 0.82rem; color: var(--cu-text-dim); line-height: 1.9;">
          <div><span style="color: var(--cu-primary-bright);">$</span> tool: {tool?.name || "Cursor"}</div>
          <div><span style="color: var(--cu-primary-bright);">$</span> category: {tool?.category || "ide"}</div>
          <div><span style="color: var(--cu-primary-bright);">$</span> releases tracked: {releases.length}</div>
          <div><span style="color: var(--cu-primary-bright);">$</span> last updated: {data?.lastUpdated ? formatDate(data.lastUpdated) : "pending"}</div>
          <div><span style="color: var(--cu-primary-bright);">$</span> source: cursor.com <span class="cu-cursor">_</span></div>
        </div>

        <div style="display: grid; gap: 0.75rem;">
          <a href="/cursor/configs/" class="cu-quick-link" style="display: flex; justify-content: space-between; gap: 1rem; align-items: center; text-decoration: none; color: var(--cu-text); padding: 0.9rem 1rem; border-radius: 16px; border: 1px solid var(--cu-border-dim); background: var(--cu-bg-soft);">
          <span>⚙️ Configs</span><span>→</span>
        </a>
        <a href="/cursor/releases/" class="cu-quick-link" style="display: flex; justify-content: space-between; gap: 1rem; align-items: center; text-decoration: none; color: var(--cu-text); padding: 0.9rem 1rem; border-radius: 16px; border: 1px solid var(--cu-border-dim); background: var(--cu-bg-soft);">
            <span>Browse all releases</span>
            <span style="color: var(--cu-primary-bright);">↗</span>
          </a>
          <a href="https://cursor.com" target="_blank" rel="noopener noreferrer" class="cu-quick-link" style="display: flex; justify-content: space-between; gap: 1rem; align-items: center; text-decoration: none; color: var(--cu-text); padding: 0.9rem 1rem; border-radius: 16px; border: 1px solid var(--cu-border-dim); background: var(--cu-bg-soft);">
            <span>Official site</span>
            <span style="color: var(--cu-primary-bright);">↗</span>
          </a>
        </div>
      </aside>
    </section>

    <section class="cu-section-reveal cu-stats-grid" style="display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 1rem; margin-bottom: 2.5rem;">
      {[
        { label: "Tracked releases", value: String(releases.length) },
        { label: "Stable releases", value: String(stableReleases.length) },
        { label: "Latest stable", value: latestStable?.version || "Pending" },
        { label: "Cheatsheet updated", value: cs.lastUpdated || "Pending" },
      ].map((stat) => (
        <div class="cu-stats-cell" style="padding: 1.2rem; border-radius: 18px; border: 1px solid var(--cu-border-dim); background: rgba(13,26,49,0.78); box-shadow: var(--cu-shadow-sm);">
          <div style="font-family: var(--cu-font-mono); font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--cu-text-muted); margin-bottom: 0.5rem;">
            {stat.label}
          </div>
          <div class="cu-headline" style="font-size: 1.55rem; line-height: 1;">{stat.value}</div>
        </div>
      ))}
    </section>

    <section style="margin-bottom: 2.8rem;">
      <div style="display: flex; justify-content: space-between; gap: 1rem; align-items: end; margin-bottom: 1rem; flex-wrap: wrap;">
        <div>
          <div style="font-family: var(--cu-font-mono); font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--cu-primary-bright); margin-bottom: 0.4rem;">Features</div>
          <h2 class="cu-headline" style="margin: 0; font-size: clamp(2rem, 4vw, 3rem);">Built for AI-native development</h2>
        </div>
        <a href="/cursor/releases/" style="text-decoration: none; color: var(--cu-text-dim); font-family: var(--cu-font-mono); font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.08em;">Release history ↗</a>
      </div>

      <div style="display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 1rem;" class="cu-feature-grid">
        {features.map((feature, i) => (
          <article style={`padding: 1.4rem; border-radius: 22px; border: 1px solid var(--cu-border-dim); background: linear-gradient(180deg, rgba(20,110,245,${0.12 + i * 0.02}), rgba(13,26,49,0.94)); box-shadow: var(--cu-shadow-sm);`}>
            <div style="font-family: var(--cu-font-mono); font-size: 0.72rem; color: var(--cu-primary-bright); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.8rem;">
              0{i + 1}
            </div>
            <h3 class="cu-headline" style="margin: 0 0 0.65rem; font-size: 1.25rem;">{feature.title}</h3>
            <p style="margin: 0; color: var(--cu-text-dim); line-height: 1.65; font-size: 0.94rem;">{feature.copy}</p>
          </article>
        ))}
      </div>
    </section>

    <section style="display: grid; grid-template-columns: minmax(0, 1.1fr) minmax(280px, 0.9fr); gap: 1rem; margin-bottom: 2.8rem;" class="cu-cheatsheet-grid">
      <div style="padding: 1.5rem; border-radius: 24px; border: 1px solid var(--cu-border); background: linear-gradient(180deg, rgba(20,110,245,0.18), rgba(13,26,49,0.92)); box-shadow: var(--cu-shadow);">
        <div style="font-family: var(--cu-font-mono); font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--cu-primary-bright); margin-bottom: 0.5rem;">
          Cheatsheet
        </div>
        <h2 class="cu-headline" style="margin: 0 0 1rem; font-size: clamp(2rem, 4vw, 3rem);">Shortcuts worth memorizing</h2>

        <div style="display: grid; gap: 0.85rem;">
          {cheatsheet.map((item) => (
            <div style="display: grid; grid-template-columns: 140px minmax(0, 1fr); gap: 1rem; align-items: center; padding: 0.95rem 1rem; border-radius: 18px; background: rgba(7,17,31,0.42); border: 1px solid var(--cu-border-dim);">
              <div class="cu-headline" style="font-size: 1rem; color: var(--cu-primary-bright);">{item.key}</div>
              <div>
                <div style="font-family: var(--cu-font-headline); font-weight: 700; margin-bottom: 0.2rem;">{item.label}</div>
                <div style="font-size: 0.9rem; color: var(--cu-text-dim); line-height: 1.5;">{item.note}</div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <aside style="padding: 1.5rem; border-radius: 24px; border: 1px solid var(--cu-border-dim); background: rgba(13,26,49,0.92); box-shadow: var(--cu-shadow-sm);">
        <div style="font-family: var(--cu-font-mono); font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--cu-primary-bright); margin-bottom: 0.5rem;">Quick start</div>
        <h3 class="cu-headline" style="margin: 0 0 1rem; font-size: 1.5rem;">30-second setup</h3>
        <ol style="margin: 0; padding-left: 1.15rem; display: grid; gap: 0.8rem; color: var(--cu-text-dim); line-height: 1.6;">
          {(cs.quickStart?.steps || []).slice(0, 5).map((step: string) => (
            <li>{step}</li>
          ))}
        </ol>
      </aside>
    </section>

    <section style="padding: 1.5rem; border-radius: 24px; border: 1px solid var(--cu-border-dim); background: rgba(13,26,49,0.88); box-shadow: var(--cu-shadow-sm);">
      <div style="display: flex; justify-content: space-between; gap: 1rem; align-items: center; flex-wrap: wrap; margin-bottom: 0.9rem;">
        <h2 class="cu-headline" style="margin: 0; font-size: 1.7rem;">Release tracking</h2>
        <a href="/cursor/changelog/" style="text-decoration: none; color: var(--cu-primary-bright); font-family: var(--cu-font-mono); font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.08em;">
          Full changelog ↗
        </a>
      </div>

      {latestRelease ? (
        <div style="display: grid; gap: 0.6rem;">
          <div style="font-family: var(--cu-font-mono); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--cu-text-muted);">
            Latest tracked release
          </div>
          <div class="cu-headline" style="font-size: 1.8rem;">{latestRelease.version}</div>
          <div style="color: var(--cu-text-dim);">{latestRelease.name || "Cursor release"}</div>
        </div>
      ) : (
        <p style="margin: 0; color: var(--cu-text-dim); line-height: 1.7;">
          Cursor is wired into the site, but there are no release entries indexed yet. The changelog and releases pages are ready as soon as release data lands.
        </p>
      )}
    </section>
  </div>

  <style>
    @media (max-width: 1080px) {
      .cu-home-grid,
      .cu-cheatsheet-grid,
      .cu-feature-grid,
      .cu-stats-grid {
        grid-template-columns: 1fr !important;
      }
    }
  </style>
</CursorLayout>
