---
import BaseLayout from "../layouts/BaseLayout.astro";
import { readdir, readFile } from "fs/promises";
import { join } from "path";

interface Model {
  name: string;
  id: string;
  released: string;
  type: "frontier" | "balanced" | "fast" | "reasoning";
  context: string;
  notes: string;
}

interface ModelProvider {
  provider: string;
  models: Model[];
}

// Load all model data files
const modelsDir = join(process.cwd(), "src/content/models");
const modelFiles = await readdir(modelsDir);
const providers: ModelProvider[] = [];

for (const file of modelFiles) {
  if (file.endsWith(".json")) {
    const content = await readFile(join(modelsDir, file), "utf-8");
    const data = JSON.parse(content);
    providers.push(data);
  }
}

// Sort providers alphabetically
providers.sort((a, b) => a.provider.localeCompare(b.provider));

// Get all models sorted by date for timeline
const allModels = providers.flatMap((p) =>
  p.models.map((m) => ({ ...m, provider: p.provider }))
);
allModels.sort((a, b) => new Date(b.released).getTime() - new Date(a.released).getTime());

// Type badge color mapping
const typeColors: Record<string, string> = {
  frontier: "text-purple bg-purple/10 border-purple",
  balanced: "text-cyan bg-cyan/10 border-cyan",
  fast: "text-green bg-green/10 border-green",
  reasoning: "text-yellow bg-yellow/10 border-yellow",
};
---

<BaseLayout title="AI Models — changelogs.info">
  <!-- Terminal Hero -->
  <section class="border-b border-border bg-bg-secondary/30">
    <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 sm:py-16">
      <div class="max-w-3xl">
        <div class="mb-6 font-mono">
<h1 class="mt-2 text-2xl font-bold text-green sm:text-3xl md:text-4xl">
            <span class="text-green">&gt;</span> ai models
          </h1>
        </div>
        <p class="font-mono text-xs leading-relaxed text-text-secondary sm:text-sm md:text-base">
          <span class="text-green">#</span> tracking the models that power ai coding agents
        </p>
        <div class="mt-4 flex flex-wrap gap-3 font-mono text-xs text-text-muted sm:text-sm">
          <span><span class="text-green">[</span>{providers.length} providers<span class="text-green">]</span></span>
          <span><span class="text-green">[</span>{allModels.length} models<span class="text-green">]</span></span>
        </div>
      </div>
    </div>
  </section>

  <!-- Timeline View -->
  <section class="mx-auto max-w-6xl px-4 py-8 sm:px-6 sm:py-12">
    <h2 class="mb-4 font-mono text-base font-semibold text-green sm:mb-6 sm:text-lg">
      <span class="text-green">/</span>timeline
    </h2>
    <div class="rounded-lg border border-border bg-bg-card">
      <div class="border-b border-border px-3 py-2 font-mono text-xs text-text-muted sm:px-4">
        <span class="text-green">●●●</span> <span class="ml-2">releases.log</span>
      </div>
      <div class="space-y-0 p-2 sm:p-3">
        {allModels.slice(0, 15).map((model) => {
          const date = new Date(model.released);
          const timestamp = date.toLocaleDateString("en-US", {
            year: "numeric",
            month: "short",
            day: "2-digit"
          });
          return (
            <div class="block rounded border border-transparent px-2 py-2 font-mono text-xs transition-all hover:border-green hover:bg-bg-tertiary/50 sm:px-3 sm:text-sm">
              <span class="text-text-muted">[{timestamp}]</span>
              <span class="ml-2 text-cyan">{model.provider}</span>
              <span class="ml-2 text-green">{model.name}</span>
              <span class={`ml-2 inline-block rounded border px-1.5 py-0.5 text-[10px] font-medium ${typeColors[model.type]}`}>
                {model.type}
              </span>
              <span class="ml-2 hidden text-text-muted sm:inline">
                ━━ {model.context} ctx
              </span>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Models by Provider -->
  <section class="mx-auto max-w-6xl px-4 pb-12 sm:px-6 sm:pb-16">
    <h2 class="mb-4 font-mono text-base font-semibold text-green sm:mb-6 sm:text-lg">
      <span class="text-green">/</span>by_provider
    </h2>

    <div class="space-y-6">
      {providers.map((provider) => (
        <div class="rounded-lg border border-border bg-bg-card">
          <div class="border-b border-border px-3 py-2 font-mono text-xs sm:px-4">
            <span class="text-green">●●●</span>
            <span class="ml-2 text-text-muted">{provider.provider.toLowerCase()}.json</span>
          </div>
          <div class="p-3 sm:p-4">
            <h3 class="mb-3 font-mono text-base font-semibold text-cyan sm:text-lg">
              {provider.provider}
            </h3>
            <div class="space-y-3">
              {provider.models
                .sort((a, b) => new Date(b.released).getTime() - new Date(a.released).getTime())
                .map((model) => {
                  const date = new Date(model.released);
                  const timestamp = date.toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "short",
                    day: "2-digit"
                  });
                  return (
                    <div class="rounded border border-border bg-bg-tertiary/30 p-3 transition-all hover:border-green">
                      <div class="flex flex-wrap items-center gap-2">
                        <span class="font-mono text-sm font-semibold text-green sm:text-base">
                          {model.name}
                        </span>
                        <span class={`inline-block rounded border px-1.5 py-0.5 text-[10px] font-medium ${typeColors[model.type]}`}>
                          {model.type}
                        </span>
                        <span class="font-mono text-xs text-text-muted">
                          {model.context} ctx
                        </span>
                      </div>
                      <div class="mt-2 flex flex-wrap gap-4 text-xs text-text-secondary">
                        <span class="font-mono">
                          <span class="text-text-muted">released:</span> {timestamp}
                        </span>
                        <span class="font-mono">
                          <span class="text-text-muted">id:</span> {model.id}
                        </span>
                      </div>
                      <p class="mt-2 font-mono text-xs text-text-secondary">
                        <span class="text-text-muted">//</span> {model.notes}
                      </p>
                    </div>
                  );
                })}
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
