---
import BaseLayout from "../layouts/BaseLayout.astro";
import { readFile } from "fs/promises";
import { join } from "path";

const raw = await readFile(join(process.cwd(), "src/content/compatibility.json"), "utf-8");
const data = JSON.parse(raw);
const models = data.models;
const harnessEntries = Object.entries(data.harnesses) as [string, any][];
---

<BaseLayout title="Compatibility — changelogs.info" description="Model compatibility across AI coding harnesses.">
  <section class="mx-auto max-w-7xl px-4 py-10 sm:px-6">
    <h1 class="font-mono text-2xl font-bold text-green sm:text-3xl"><span class="text-green">/</span>compatibility</h1>
    <p class="mt-2 font-mono text-sm text-text-secondary"><span class="text-green">#</span> which models each harness supports</p>

    <div class="mt-8 overflow-x-auto rounded-lg border border-border bg-bg-card">
      <table class="w-full min-w-[980px] border-collapse font-mono text-xs">
        <thead>
          <tr class="border-b border-border">
            <th class="sticky left-0 bg-bg-card p-3 text-left text-cyan">harness</th>
            {models.map((m) => <th class="p-3 text-left text-text-secondary">{m.name}</th>)}
            <th class="p-3 text-left text-text-secondary">default</th>
          </tr>
        </thead>
        <tbody>
          {harnessEntries.map(([name, info]) => (
            <tr class="border-b border-border/60">
              <td class="sticky left-0 bg-bg-card p-3 text-green">{name}</td>
              {models.map((m) => (
                <td class="p-3">{info.supported.includes(m.id) ? <span class="text-green">✓</span> : <span class="text-text-muted">—</span>}</td>
              ))}
              <td class="p-3 text-cyan">{info.default}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
</BaseLayout>
