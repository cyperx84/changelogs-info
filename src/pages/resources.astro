---
import BaseLayout from "../layouts/BaseLayout.astro";

const links = [
  { href: "/migrations", title: "Migration Guides", desc: "Version-to-version config migrations with before/after snippets." },
  { href: "/compatibility", title: "Compatibility Matrix", desc: "Which models each harness supports and recommended defaults." },
  { href: "/deprecations", title: "Deprecation Radar", desc: "Upcoming removals and migration actions you should take." },
  { href: "/recommendations", title: "Recommended Actions", desc: "High-impact settings/features to enable right now." }
];
---

<BaseLayout title="Resources — changelogs.info" description="Migration guides, model compatibility, deprecations, and recommended actions.">
  <section class="mx-auto max-w-5xl px-4 py-10 sm:px-6">
    <h1 class="font-mono text-2xl font-bold text-green sm:text-3xl"><span class="text-green">/</span>resources</h1>
    <p class="mt-2 font-mono text-sm text-text-secondary"><span class="text-green">#</span> operational guidance for keeping configs current</p>



    <div class="mt-8 rounded-lg border border-green/30 bg-green/[0.03] p-4 sm:p-5">
      <p class="font-mono text-xs text-text-muted"><span class="text-green">#</span> most used harnesses</p>
      <div class="mt-3 grid gap-3 sm:grid-cols-2">
        <a href="/tools/claude-code" class="rounded border border-green/30 bg-bg-card px-3 py-3 font-mono text-sm text-green transition-all hover:border-green">Claude Code →</a>
        <a href="/tools/openclaw" class="rounded border border-green/30 bg-bg-card px-3 py-3 font-mono text-sm text-green transition-all hover:border-green">OpenClaw →</a>
      </div>
    </div>

    <div class="mt-8 grid gap-4 sm:grid-cols-2">
      {links.map((item) => (
        <a href={item.href} class="rounded-lg border border-border bg-bg-card p-4 transition-all hover:border-green hover:shadow-[0_0_12px_rgba(51,255,51,0.15)]">
          <h2 class="font-mono text-base font-semibold text-cyan">{item.title}</h2>
          <p class="mt-2 font-mono text-xs text-text-secondary">{item.desc}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
