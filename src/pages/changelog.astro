---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Changelog — changelogs.info" description="Release history for changelogs.info and clwatch.">
  <div class="mx-auto max-w-4xl px-6 py-12">

    <!-- Hero -->
    <a href="/" class="mb-8 inline-flex items-center gap-1 font-mono text-sm text-text-muted transition-colors hover:text-green">
      <span class="text-green">&lt;</span> cd ..
    </a>

    <header class="mb-12">
      <h1 class="text-glow-green font-mono text-3xl font-bold text-green sm:text-4xl">changelog</h1>
      <p class="mt-3 font-sans text-sm leading-relaxed text-text-secondary sm:text-base">
        Release history for changelogs.info and clwatch.
      </p>
    </header>

    <!-- changelogs.info releases -->
    <section class="mb-12">
      <h2 class="mb-6 font-mono text-lg font-semibold text-green"><span class="text-green">/</span>changelogs.info</h2>
      
      <div class="space-y-6">
        <!-- v1.1.0 -->
        <article class="relative border-l-2 border-green/40 pl-6 pb-6">
          <div class="absolute -left-[5px] top-1 h-2 w-2 rounded-sm bg-green"></div>
          <div class="mb-2 flex flex-wrap items-center gap-3">
            <span class="font-mono text-lg font-bold text-green">v1.1.0</span>
            <span class="font-mono text-xs text-text-muted">2026-03-14</span>
          </div>
          <div class="font-sans text-sm text-text-secondary space-y-2">
            <p class="text-text-primary font-medium">Performance & SEO pass</p>
            <ul class="list-disc pl-5 space-y-1 text-text-muted">
              <li>Moved "how it works" section after "get clwatch" for better flow</li>
              <li>Added Organization schema + meta keywords for SEO</li>
              <li>content-visibility:auto on below-fold sections for paint perf</li>
              <li>preconnect/dns-prefetch for external resources</li>
              <li>Subtle card lift (translateY -1px) on hover</li>
              <li>CRT overlay containment to avoid repaint thrash</li>
            </ul>
          </div>
        </article>

        <!-- v1.0.0 -->
        <article class="relative border-l-2 border-green/40 pl-6 pb-6">
          <div class="absolute -left-[5px] top-1 h-2 w-2 rounded-sm bg-green"></div>
          <div class="mb-2 flex flex-wrap items-center gap-3">
            <span class="font-mono text-lg font-bold text-green">v1.0.0</span>
            <span class="font-mono text-xs text-text-muted">2026-03-13</span>
          </div>
          <div class="font-sans text-sm text-text-secondary space-y-2">
            <p class="text-text-primary font-medium">Initial launch</p>
            <ul class="list-disc pl-5 space-y-1 text-text-muted">
              <li>Homepage with hero, ticker, latest changes, tools grid</li>
              <li>10 core AI coding tools tracked (OpenClaw, Claude Code, Codex CLI, etc.)</li>
              <li>Newsletter subscription via Cloudflare Pages Functions + KV</li>
              <li>Full-text search with Pagefind (558 pages indexed)</li>
              <li>OG/Twitter social images for link previews</li>
              <li>RSS feed for all releases</li>
              <li>Tool pages with changelog timeline + cheatsheets</li>
              <li>/clwatch docs page</li>
              <li>Dark theme + light theme toggle</li>
              <li>Three.js matrix rain hero (lazy loaded, mobile-friendly)</li>
            </ul>
          </div>
        </article>
      </div>
    </section>

    <!-- clwatch releases -->
    <section class="mb-12">
      <h2 class="mb-6 font-mono text-lg font-semibold text-cyan"><span class="text-cyan">/</span>clwatch</h2>
      
      <div class="space-y-6">
        <!-- v0.2.0 -->
        <article class="relative border-l-2 border-cyan/40 pl-6 pb-6">
          <div class="absolute -left-[5px] top-1 h-2 w-2 rounded-sm bg-cyan"></div>
          <div class="mb-2 flex flex-wrap items-center gap-3">
            <span class="font-mono text-lg font-bold text-cyan">v0.2.0</span>
            <span class="font-mono text-xs text-text-muted">2026-03-10</span>
          </div>
          <div class="font-sans text-sm text-text-secondary space-y-2">
            <p class="text-text-primary font-medium">Tier system + agent skill</p>
            <ul class="list-disc pl-5 space-y-1 text-text-muted">
              <li>Two-tier change classification (config patch vs knowledge refresh)</li>
              <li>clwatch init — install skill into any agent workspace</li>
              <li>clwatch refresh — update agent reference files</li>
              <li>JSON output mode for agent consumption</li>
              <li>Support for OpenCode, Gemini CLI in addition to Claude Code</li>
            </ul>
          </div>
        </article>

        <!-- v0.1.0 -->
        <article class="relative border-l-2 border-cyan/40 pl-6 pb-6">
          <div class="absolute -left-[5px] top-1 h-2 w-2 rounded-sm bg-cyan"></div>
          <div class="mb-2 flex flex-wrap items-center gap-3">
            <span class="font-mono text-lg font-bold text-cyan">v0.1.0</span>
            <span class="font-mono text-xs text-text-muted">2026-03-01</span>
          </div>
          <div class="font-sans text-sm text-text-secondary space-y-2">
            <p class="text-text-primary font-medium">Initial release</p>
            <ul class="list-disc pl-5 space-y-1 text-text-muted">
              <li>clwatch diff — show what changed in tracked tools</li>
              <li>clwatch list — show tracked tools + versions</li>
              <li>Homebrew + npm install support</li>
              <li>npx/uvx zero-install support</li>
              <li>Claude Code + Codex CLI tracking</li>
            </ul>
          </div>
        </article>
      </div>
    </section>

    <!-- Footer CTA -->
    <div class="text-center">
      <a href="/clwatch" class="font-mono text-sm text-text-muted transition-colors hover:text-cyan">
        clwatch docs &rarr;
      </a>
    </div>
  </div>
</BaseLayout>
