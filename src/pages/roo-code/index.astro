---
import RooCodeLayout from "../../layouts/RooCodeLayout.astro";
import { getToolById, getToolReleases, formatDate, relativeTime } from "../../lib/releases";
import { readFileSync } from "node:fs";
import { join } from "node:path";

const tool = getToolById("roo-code");
const data = await getToolReleases("roo-code");
const releases = data?.releases || [];
const stableReleases = releases.filter((r) => !r.prerelease);
const latestStable = stableReleases[0] || releases[0];
const lastUpdatedAgo = data?.lastUpdated ? relativeTime(data.lastUpdated) : null;

let cheatsheet: any = {};
try {
  const raw = readFileSync(join(process.cwd(), "src/content/cheatsheets-json/roo-code.json"), "utf-8");
  cheatsheet = JSON.parse(raw);
} catch {}

const modeCommands = ["/code", "/architect", "/ask", "/debug"];
const featureCards = [
  {
    title: "Mode-specialized workflows",
    copy: "Switch between Code, Architect, Ask, and Debug depending on whether you need execution, planning, read-only context, or troubleshooting.",
  },
  {
    title: "Custom system prompts per mode",
    copy: "Each mode can carry distinct instructions, model preferences, and tool access so the assistant behaves differently for different jobs.",
  },
  {
    title: "MCP-ready integrations",
    copy: "Project and global MCP configs let Roo pull in docs, APIs, databases, and internal tooling without leaving VS Code.",
  },
];

const cheatsheetHighlights = [
  { label: "Mode switching", value: "/code /architect /ask /debug" },
  { label: ".rooignore", value: "Exclude noisy files and generated output from context" },
  { label: "Custom instructions", value: "Tune per-mode behavior with project rules and custom modes" },
  { label: "Model per mode", value: "Use Sticky Models to keep a preferred model for each mode" },
];

const recentReleases = releases.slice(0, 6);
---

<RooCodeLayout
  title="Roo Code — changelogs.info"
  description="AI coding assistant with multiple agent modes — Code, Architect, Ask, Debug. Open source VS Code extension with deep customization."
>
  <div class="rc-page">
    <section class="rc-hero">
      <div class="rc-hero__copy">
        <div class="rc-hero__eyebrow">VS Code extension • RooVet fork of Cline</div>
        <h1 class="rc-headline rc-hero__title">AI coding with multiple modes</h1>
        <p class="rc-hero__text">
          Roo Code gives you dedicated modes for implementation, planning, read-only exploration, and debugging,
          with deep control over prompts, permissions, models, and MCP tooling.
        </p>
        <div class="rc-hero__chips">
          <span class="rc-chip">Code / Architect / Ask / Debug</span>
          <span class="rc-chip">Brand color #{tool?.color?.replace("#", "") || "FB923C"}</span>
          {latestStable && <span class="rc-chip">Latest stable {latestStable.version}</span>}
          {lastUpdatedAgo && <span class="rc-chip">Updated {lastUpdatedAgo}</span>}
        </div>
        <div class="rc-hero__actions">
          <a href="/roo-code/changelog/" class="rc-hero__cta rc-hero__cta--primary">Read changelog</a>
          <a href="/roo-code/cheatsheet/" class="rc-hero__cta">Open cheatsheet</a>
        </div>
      </div>

      <aside class="rc-card rc-terminal">
        <div class="rc-terminal__bar">
          <span></span><span></span><span></span>
        </div>
        <div class="rc-terminal__body">
          <div><span class="rc-terminal__prompt">$</span> roo mode</div>
          <div class="rc-terminal__line">active: <strong>code</strong></div>
          <div class="rc-terminal__line">available: {modeCommands.join(" · ")}</div>
          <div class="rc-terminal__line">sticky models: enabled</div>
          <div class="rc-terminal__line">mcp: project + global</div>
          <div class="rc-terminal__line rc-terminal__muted">customize prompts, permissions, and commands per mode</div>
        </div>
      </aside>
    </section>

    <section class="rc-section">
      <div class="rc-section__header">
        <h2 class="rc-headline">What matters in Roo Code</h2>
        <p>Core capabilities surfaced on changelogs.info.</p>
      </div>

      <div class="rc-grid rc-grid--features">
        {featureCards.map((card) => (
          <article class="rc-card rc-feature">
            <h3 class="rc-headline">{card.title}</h3>
            <p>{card.copy}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="rc-section rc-section--split">
      <div class="rc-card rc-cheatsheet">
        <div class="rc-section__header">
          <h2 class="rc-headline">Cheatsheet focus</h2>
          <p>Fast reminders for the things people actually forget.</p>
        </div>

        <div class="rc-cheatsheet__grid">
          {cheatsheetHighlights.map((item) => (
            <div class="rc-card-soft rc-cheatsheet__item">
              <div class="rc-cheatsheet__label">{item.label}</div>
              <div class="rc-cheatsheet__value">{item.value}</div>
            </div>
          ))}
        </div>

        {cheatsheet.quickStart?.steps?.length > 0 && (
          <div class="rc-cheatsheet__quickstart">
            <div class="rc-cheatsheet__label">Quick start</div>
            <ol>
              {cheatsheet.quickStart.steps.slice(0, 4).map((step: string) => <li>{step}</li>)}
            </ol>
          </div>
        )}
      </div>

      <div class="rc-card rc-release-panel">
        <div class="rc-section__header">
          <h2 class="rc-headline">Recent releases</h2>
          <p>Stable extension builds plus CLI prereleases.</p>
        </div>

        <div class="rc-release-panel__list">
          {recentReleases.map((release) => (
            <a href={release.url} target="_blank" rel="noopener noreferrer" class="rc-release-panel__row">
              <div>
                <div class="rc-release-panel__version">{release.version}</div>
                <div class="rc-release-panel__name">{release.name || release.version}</div>
              </div>
              <div class="rc-release-panel__meta">
                <span>{formatDate(release.date)}</span>
                <span>{release.prerelease ? "Pre-release" : "Stable"}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="rc-section">
      <div class="rc-section__header">
        <h2 class="rc-headline">Jump to the dedicated Roo Code section</h2>
        <p>Changelog, cheatsheet, and release history under the same orange theme.</p>
      </div>

      <div class="rc-grid rc-grid--links">
        {[
          { href: "/roo-code/changelog/", title: "Changelog", sub: "Release notes and breaking changes" },
          { href: "/roo-code/cheatsheet/", title: "Cheatsheet", sub: "Modes, MCP, custom instructions, and gotchas" },
          { href: "/roo-code/releases/", title: "Releases", sub: `${releases.length} tracked releases` },
        ].map((item) => (
          <a href={item.href} class="rc-card rc-link-card">
            <span class="rc-link-card__eyebrow">{item.href}</span>
            <h3 class="rc-headline">{item.title}</h3>
            <p>{item.sub}</p>
          </a>
        ))}
      </div>
    </section>
  </div>

  <style>
    .rc-hero {
      display: grid;
      grid-template-columns: minmax(0, 1.35fr) minmax(320px, 0.9fr);
      gap: 2rem;
      align-items: stretch;
      padding: 1rem 0 2rem;
    }
    .rc-hero__eyebrow,
    .rc-cheatsheet__label,
    .rc-link-card__eyebrow {
      font-family: var(--rc-font-mono);
      font-size: 0.72rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--rc-primary-bright);
    }
    .rc-hero__title {
      margin: 0.9rem 0 1rem;
      font-size: clamp(3rem, 7.5vw, 6rem);
      line-height: 0.92;
      letter-spacing: -0.04em;
    }
    .rc-hero__text,
    .rc-section__header p,
    .rc-feature p,
    .rc-link-card p,
    .rc-release-panel__name,
    .rc-terminal__line,
    .rc-cheatsheet__quickstart li {
      color: var(--rc-text-dim);
      line-height: 1.65;
    }
    .rc-hero__chips,
    .rc-hero__actions,
    .rc-grid,
    .rc-cheatsheet__grid {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
    }
    .rc-hero__actions {
      margin-top: 1.25rem;
    }
    .rc-hero__cta {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.9rem 1.2rem;
      border: 3px solid var(--rc-border);
      background: transparent;
      color: var(--rc-text);
      text-decoration: none;
      font-family: var(--rc-font-mono);
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      box-shadow: var(--rc-shadow-sm);
    }
    .rc-hero__cta--primary {
      background: var(--rc-primary);
      color: #fff;
    }
    .rc-terminal {
      padding: 1rem;
      align-self: center;
    }
    .rc-terminal__bar {
      display: flex;
      gap: 0.45rem;
      margin-bottom: 1rem;
    }
    .rc-terminal__bar span {
      width: 0.8rem;
      height: 0.8rem;
      border-radius: 999px;
      background: var(--rc-primary);
    }
    .rc-terminal__body {
      font-family: var(--rc-font-mono);
      font-size: 0.8rem;
      display: grid;
      gap: 0.65rem;
    }
    .rc-terminal__prompt {
      color: var(--rc-primary-bright);
      margin-right: 0.45rem;
    }
    .rc-terminal__muted {
      color: var(--rc-text-muted);
    }
    .rc-section {
      margin-top: 3rem;
    }
    .rc-section--split {
      display: grid;
      grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
      gap: 2rem;
    }
    .rc-section__header h2 {
      margin: 0 0 0.45rem;
      font-size: clamp(1.7rem, 3vw, 2.4rem);
    }
    .rc-grid--features {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
    .rc-feature,
    .rc-cheatsheet,
    .rc-release-panel,
    .rc-link-card {
      padding: 1.5rem;
    }
    .rc-feature h3,
    .rc-link-card h3 {
      margin: 0 0 0.6rem;
      font-size: 1.15rem;
    }
    .rc-cheatsheet__grid,
    .rc-grid--links {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }
    .rc-cheatsheet__item {
      padding: 1rem;
    }
    .rc-cheatsheet__value {
      margin-top: 0.4rem;
      font-family: var(--rc-font-body);
      line-height: 1.5;
    }
    .rc-cheatsheet__quickstart {
      margin-top: 1.25rem;
      padding-top: 1rem;
      border-top: 2px solid var(--rc-border-dim);
    }
    .rc-cheatsheet__quickstart ol {
      margin: 0.7rem 0 0;
      padding-left: 1.25rem;
    }
    .rc-release-panel__list {
      display: grid;
      gap: 0.9rem;
    }
    .rc-release-panel__row {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      padding: 1rem;
      border: 2px solid var(--rc-border-dim);
      background: var(--rc-bg-surface);
      text-decoration: none;
    }
    .rc-release-panel__version {
      font-family: var(--rc-font-mono);
      font-size: 0.8rem;
      color: var(--rc-primary-bright);
      text-transform: uppercase;
    }
    .rc-release-panel__meta {
      display: grid;
      justify-items: end;
      gap: 0.2rem;
      font-family: var(--rc-font-mono);
      font-size: 0.7rem;
      color: var(--rc-text-muted);
      text-transform: uppercase;
    }
    .rc-grid--links {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
    .rc-link-card {
      color: inherit;
      text-decoration: none;
    }
    @media (max-width: 960px) {
      .rc-hero,
      .rc-section--split,
      .rc-grid--features,
      .rc-grid--links,
      .rc-cheatsheet__grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</RooCodeLayout>
