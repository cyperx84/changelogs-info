---
import RooCodeLayout from "../../layouts/RooCodeLayout.astro";
import { getToolReleases, formatDate } from "../../lib/releases";
import "../../styles/changelog-shared.css";
import { marked } from "marked";

const data = await getToolReleases("roo-code");
const releases = data?.releases || [];

function isBreaking(body: string = ""): boolean {
  return body.toLowerCase().includes("breaking");
}

function renderBody(body: string): string {
  if (!body) return "";
  marked.setOptions({ gfm: true, breaks: false });
  return marked.parse(body) as string;
}
---

<RooCodeLayout
  title="Roo Code Changelog — changelogs.info"
  description="Full changelog for Roo Code. Releases, stable builds, CLI prereleases, and notable notes."
  currentPage="changelog"
>
  <div class="rc-page">
    <section class="rc-changelog-hero">
      <div>
        <div class="rc-changelog-hero__eyebrow">Roo Code release log</div>
        <h1 class="rc-headline rc-changelog-hero__title">Changelog</h1>
      </div>
      <p class="rc-changelog-hero__text">
        Every tracked Roo Code release in one place, including extension releases and the CLI prerelease stream.
      </p>
    </section>

    {releases.length > 0 ? (
      <div class="rc-timeline">
        {releases.map((release) => {
          const breaking = isBreaking(release.body);
          return (
            <article class={`rc-card rc-entry ${breaking ? "rc-entry--breaking" : ""}`}>
              <div class="rc-entry__meta">
                <div>
                  <div class="rc-entry__version">{release.version}</div>
                  <div class="rc-entry__date">{formatDate(release.date)}</div>
                </div>
                <div class="rc-entry__badges">
                  {breaking && <span class="rc-entry__badge rc-entry__badge--breaking">Breaking</span>}
                  {release.prerelease && <span class="rc-entry__badge">Pre-release</span>}
                </div>
              </div>

              <h2 class="rc-headline rc-entry__title">{release.name || release.version}</h2>

              <div class="changelog-body rc-entry__body" set:html={renderBody(release.body || "")} />

              <div class="rc-entry__footer">
                <a href={release.url} target="_blank" rel="noopener noreferrer" class="rc-link">
                  View on GitHub ↗
                </a>
              </div>
            </article>
          );
        })}
      </div>
    ) : (
      <div class="rc-card rc-empty">$ no releases tracked yet</div>
    )}
  </div>

</RooCodeLayout>
