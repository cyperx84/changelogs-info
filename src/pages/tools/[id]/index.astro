---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ReleaseEntry from "../../../components/ReleaseEntry.astro";
import { getTools, getToolReleases, getCategoryLabel, formatDate, relativeTime } from "../../../lib/releases";
import type { Tool, Release, ToolReleases } from "../../../lib/releases";
import { existsSync } from "node:fs";
import { join } from "node:path";

import referrals from "../../../data/referrals.json";

export function getStaticPaths() {
  const tools = getTools();
  return tools.map((tool) => ({
    params: { id: tool.id },
    props: { tool },
  }));
}

interface Props {
  tool: Tool;
}

const { tool } = Astro.props;

// Quick Start data per tool
const quickStartData: Record<string, { install: string; firstCmd: string; docsUrl: string }> = {
  "openclaw": {
    install: "npm install -g openclaw",
    firstCmd: "openclaw onboard --install-daemon",
    docsUrl: "https://github.com/openclaw/openclaw",
  },
  "claude-code": {
    install: "npm install -g @anthropic-ai/claude-code",
    firstCmd: 'claude -p "explain this codebase"',
    docsUrl: "https://docs.anthropic.com/en/docs/claude-code",
  },
  "codex-cli": {
    install: "npm install -g @openai/codex",
    firstCmd: 'codex --full-auto "fix the failing test"',
    docsUrl: "https://github.com/openai/codex",
  },
  "gemini-cli": {
    install: "npm install -g @google/gemini-cli",
    firstCmd: 'gemini -p "summarize this repo"',
    docsUrl: "https://github.com/google-gemini/gemini-cli",
  },
  "opencode": {
    install: "npm install -g opencode-ai",
    firstCmd: "opencode",
    docsUrl: "https://opencode.ai/docs",
  },
  "cursor": {
    install: "# Download from cursor.com/download",
    firstCmd: "cursor .  # open project, then Cmd+I",
    docsUrl: "https://docs.cursor.com",
  },
  "cline": {
    install: "# Install 'Cline' from VS Code marketplace",
    firstCmd: "# Open VS Code → Extensions → search 'Cline'",
    docsUrl: "https://github.com/cline/cline",
  },
  "roo-code": {
    install: "# Install 'Roo Code' from VS Code marketplace",
    firstCmd: "# Open VS Code → Extensions → search 'Roo Code'",
    docsUrl: "https://github.com/RooVeterinaryInc/roo-cline",
  },
  "continue": {
    install: "# Install 'Continue' from VS Code marketplace",
    firstCmd: "# Open VS Code → Extensions → search 'Continue'",
    docsUrl: "https://docs.continue.dev",
  },
  "windsurf": {
    install: "# Download from codeium.com/windsurf",
    firstCmd: "windsurf .  # open project, then Cmd+L for Cascade",
    docsUrl: "https://docs.codeium.com/windsurf",
  },
};
const quickStart = quickStartData[tool.id];

let releases: Release[] = [];
let lastUpdated = "";

const data = await getToolReleases(tool.id);
if (data) {
  releases = data.releases;
  lastUpdated = data.lastUpdated;
}

const stableReleases = releases.filter((r) => !r.prerelease);
const prereleases = releases.filter((r) => r.prerelease);
const latestStable = stableReleases[0];
const hasCheatsheet = existsSync(join(process.cwd(), `src/content/cheatsheets/${tool.id}.md`));

// Tier heuristic: check if latest release body suggests a deep refresh
const latestBody = (latestStable?.body || releases[0]?.body || "").toLowerCase();
const isTier2 = /\b(agent|feature|new|add)\b/.test(latestBody);
const hasConfig = existsSync(join(process.cwd(), `src/content/configs/${tool.id}.json`));
const hasMigration = existsSync(join(process.cwd(), `src/content/migrations/${tool.id}.json`));
---

<BaseLayout
  title={`${tool.name} changelog — changelogs.info`}
  description={`Track ${tool.name} releases, breaking changes, and config updates.`}
>
  <div class="mx-auto max-w-4xl px-6 py-12">
    <!-- Back link -->
    <a href="/" class="mb-8 inline-flex items-center gap-1 font-mono text-sm text-text-muted transition-colors hover:text-green">
      <span class="text-green">&lt;</span> cd ..
    </a>

    <!-- Tool header -->
    <header class="mb-10">
      <div class="relative flex flex-wrap items-start justify-between gap-4">
        {/* Subtle radial glow behind tool name */}
        <div class="pointer-events-none absolute -left-8 -top-8 h-32 w-48 rounded-full bg-green/[0.04] blur-3xl"></div>
        <div class="relative">
          <h1 class="text-glow-green font-mono text-3xl font-bold text-green sm:text-4xl">{tool.name}</h1>
          <p class="mt-2 font-mono text-sm text-text-muted">
            <span class="text-green">~/</span>{tool.repo}
          </p>
        </div>
        <div class="flex flex-wrap items-center gap-2 sm:gap-3">
          <span class="rounded border border-border bg-bg-tertiary px-3 py-1 font-mono text-xs text-text-secondary">
            --{tool.category}
          </span>
          <a
            href={`https://github.com/${tool.repo}`}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded border border-border bg-bg-tertiary px-3 py-1.5 font-mono text-xs text-text-secondary transition-all hover:border-green hover:text-green sm:px-4 sm:text-sm"
          >
            github
          </a>
          {tool.website && (
            <a
              href={tool.website}
              target="_blank"
              rel="noopener noreferrer"
              class="rounded border border-border bg-bg-tertiary px-3 py-1.5 font-mono text-xs text-text-secondary transition-all hover:border-green hover:text-green sm:px-4 sm:text-sm"
            >
              web
            </a>
          )}
          {(() => {
            const ref = (referrals as any)[tool.id];
            if (!ref) return null;
            return (
              <span class="rounded border border-green/20 bg-green/5 px-3 py-1 font-mono text-[10px] text-green sm:text-xs">
                {ref.pricing?.hasFreeTier ? '✓ free tier' : ref.pricing?.paid || ''}
              </span>
            );
          })()}
        </div>
      </div>

      <p class="mt-4 font-sans leading-relaxed text-text-secondary">{tool.description}</p>

      <!-- Cheatsheet CTA (if available) -->
      {hasCheatsheet && (
        <a
          href={`/tools/${tool.id}/cheatsheet`}
          class="reveal mt-5 inline-flex items-center gap-2 rounded-lg border border-cyan/40 bg-cyan/10 px-4 py-2.5 font-mono text-sm text-cyan transition-all hover:border-cyan hover:bg-cyan/20"
        >
          <span>📋</span>
          <span>view cheatsheet</span>
          <span class="text-cyan/60">→</span>
        </a>
      )}

      {/* Get started CTA */}
      {(() => {
        const ref = (referrals as any)[tool.id];
        if (!ref) return null;
        const url = ref.referral || ref.website;
        const label = ref.referral ? ref.refLabel : ref.label;
        return (
          <a
            href={url}
            target="_blank"
            rel="noopener noreferrer"
            class="reveal mt-3 inline-flex items-center gap-2 rounded-lg border border-green/40 bg-green/10 px-4 py-2.5 font-mono text-sm text-green transition-all hover:border-green hover:bg-green/20"
          >
            <span>⚡</span>
            <span>{label}</span>
            <span class="text-green/60">→</span>
          </a>
        );
      })()}

      <!-- Stats bar -->
      {releases.length > 0 && (
        <div class="reveal mt-6 grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-6">
          {latestStable && (
            <div class="rounded-lg border border-border bg-bg-card px-4 py-3">
              <p class="font-mono text-[10px] uppercase tracking-wider text-text-muted">latest</p>
              <p class="mt-1 font-mono text-base font-bold text-green">{latestStable.version}</p>
            </div>
          )}
          <div class="rounded-lg border border-border bg-bg-card px-4 py-3">
            <p class="font-mono text-[10px] uppercase tracking-wider text-text-muted">total</p>
            <p class="mt-1 font-mono text-base font-bold text-cyan">{releases.length}</p>
          </div>
          <div class="rounded-lg border border-border bg-bg-card px-4 py-3">
            <p class="font-mono text-[10px] uppercase tracking-wider text-text-muted">stable</p>
            <p class="mt-1 font-mono text-base font-bold text-text-primary">{stableReleases.length}</p>
          </div>
          {prereleases.length > 0 && (
            <div class="rounded-lg border border-border bg-bg-card px-4 py-3">
              <p class="font-mono text-[10px] uppercase tracking-wider text-text-muted">pre</p>
              <p class="mt-1 font-mono text-base font-bold text-amber">{prereleases.length}</p>
            </div>
          )}
          {releases.length > 0 && (
            <div class="rounded-lg border border-border bg-bg-card px-4 py-3">
              <p class="font-mono text-[10px] uppercase tracking-wider text-text-muted">first tracked</p>
              <p class="mt-1 font-mono text-xs text-text-secondary">{formatDate(releases[releases.length - 1].date)}</p>
            </div>
          )}
          {lastUpdated && (
            <div class="rounded-lg border border-border bg-bg-card px-4 py-3">
              <p class="font-mono text-[10px] uppercase tracking-wider text-text-muted">updated</p>
              <p class="mt-1 font-mono text-xs text-text-secondary">{relativeTime(lastUpdated)}</p>
            </div>
          )}
        </div>
      )}

      <!-- Freshness status row -->
      {lastUpdated && (
        <div class="reveal mt-4 flex flex-wrap items-center gap-3 font-mono text-xs">
          <span class="text-text-muted">last checked: <span class="text-text-secondary">{relativeTime(lastUpdated)}</span></span>
          <span class="text-text-muted">│</span>
          {isTier2 ? (
            <span class="inline-flex items-center gap-1.5 rounded-full border border-cyan/30 bg-cyan/10 px-3 py-0.5 text-cyan">
              <span class="inline-block h-1.5 w-1.5 rounded-full bg-cyan"></span>
              Tier 2 refresh
            </span>
          ) : (
            <span class="inline-flex items-center gap-1.5 rounded-full border border-green/30 bg-green/10 px-3 py-0.5 text-green">
              <span class="inline-block h-1.5 w-1.5 rounded-full bg-green"></span>
              Tier 1 patch
            </span>
          )}
        </div>
      )}

      <!-- Tags -->
      {tool.tags.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-2">
          {tool.tags.map((tag) => (
            <span class="rounded border border-border/50 bg-bg-tertiary px-2 py-0.5 font-mono text-xs text-text-muted">
              #{tag}
            </span>
          ))}
        </div>
      )}

      <!-- clwatch CTA -->
      <div class="card-hover reveal mt-6 rounded-lg border border-green/20 bg-bg-card shadow-[0_0_8px_rgba(51,255,51,0.04)]">
        <div class="border-b border-border px-4 py-2 font-mono text-xs text-text-muted">
          <span class="text-green">●●●</span> <span class="ml-2">clwatch</span>
        </div>
        <div class="p-4">
          <p class="font-mono text-xs text-text-muted">Check if your agent is current:</p>
          <pre class="mt-2 rounded bg-bg-tertiary px-3 py-2 font-mono text-xs text-text-secondary"><span class="text-green">$</span> clwatch diff {tool.id}</pre>
          <pre class="mt-1 rounded bg-bg-tertiary px-3 py-2 font-mono text-xs text-text-secondary"><span class="text-green">$</span> clwatch refresh {tool.id}</pre>
          <p class="mt-2 font-mono text-[10px] text-text-muted">
            <a href="/clwatch" class="text-cyan transition-colors hover:text-cyan/80">learn more about clwatch &rarr;</a>
          </p>
        </div>
      </div>
    </header>

    <!-- Quick Start section -->
    {quickStart && (
      <section class="reveal mb-10">
        <div class="rounded-lg border border-green/30 bg-bg-card shadow-[0_0_12px_rgba(51,255,51,0.04)]">
          <div class="flex items-center justify-between border-b border-border px-4 py-2 font-mono text-xs">
            <span><span class="text-green">●●●</span> <span class="ml-2 text-text-muted">quick start</span></span>
            <span class="text-text-muted">// get running in 60s</span>
          </div>
          <div class="grid gap-4 p-4 sm:grid-cols-2">
            <!-- Install -->
            <div>
              <p class="mb-1.5 font-mono text-[10px] uppercase tracking-wider text-text-muted">install</p>
              <div class="group relative">
                <pre class="rounded bg-bg-tertiary px-3 py-2.5 font-mono text-xs text-text-secondary overflow-x-auto"><span class="text-green">$</span> {quickStart.install}</pre>
                <button
                  class="copy-btn absolute right-2 top-1.5 rounded border border-border bg-bg-tertiary px-2 py-0.5 font-mono text-[10px] text-text-muted opacity-0 transition-opacity group-hover:opacity-100 hover:border-green hover:text-green"
                  data-copy={quickStart.install}
                >copy</button>
              </div>
            </div>
            <!-- First command -->
            <div>
              <p class="mb-1.5 font-mono text-[10px] uppercase tracking-wider text-text-muted">first command</p>
              <div class="group relative">
                <pre class="rounded bg-bg-tertiary px-3 py-2.5 font-mono text-xs text-text-secondary overflow-x-auto"><span class="text-cyan">$</span> {quickStart.firstCmd}</pre>
                <button
                  class="copy-btn absolute right-2 top-1.5 rounded border border-border bg-bg-tertiary px-2 py-0.5 font-mono text-[10px] text-text-muted opacity-0 transition-opacity group-hover:opacity-100 hover:border-cyan hover:text-cyan"
                  data-copy={quickStart.firstCmd}
                >copy</button>
              </div>
            </div>
          </div>
          <!-- Links row -->
          <div class="flex flex-wrap gap-3 border-t border-border px-4 py-3">
            {hasCheatsheet && (
              <a
                href={`/tools/${tool.id}/cheatsheet`}
                class="inline-flex items-center gap-1.5 font-mono text-xs text-cyan transition-colors hover:text-cyan/80"
              >
                <span>📋</span> cheatsheet →
              </a>
            )}
            <a
              href={quickStart.docsUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 font-mono text-xs text-text-secondary transition-colors hover:text-green"
            >
              <span>📖</span> official docs →
            </a>
            {tool.website && tool.website !== quickStart.docsUrl && (
              <a
                href={tool.website}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 font-mono text-xs text-text-secondary transition-colors hover:text-green"
              >
                <span>🌐</span> website →
              </a>
            )}
          </div>
        </div>
      </section>
    )}

    <!-- Releases timeline -->
    <section>
      <div class="reveal mb-6 flex flex-wrap items-center justify-between gap-3">
        <h2 class="font-mono text-lg font-semibold text-green sm:text-xl">
          <span class="text-green">/</span>changelog
        </h2>
        {releases.length > 5 && (
          <div class="flex items-center gap-2">
            <input
              type="text"
              id="release-filter"
              placeholder="filter releases..."
              class="w-48 rounded border border-border bg-bg-tertiary px-3 py-1.5 font-mono text-xs text-text-primary outline-none transition-all focus:border-green focus:shadow-[0_0_6px_rgba(51,255,51,0.15)] sm:w-56"
            />
            <div class="flex gap-1">
              <button id="filter-stable" class="release-filter-btn rounded border border-border bg-bg-tertiary px-2 py-1 font-mono text-[10px] text-text-muted transition-all hover:border-green hover:text-green" data-filter="stable">stable</button>
              <button id="filter-breaking" class="release-filter-btn rounded border border-border bg-bg-tertiary px-2 py-1 font-mono text-[10px] text-text-muted transition-all hover:border-red hover:text-red" data-filter="breaking">breaking</button>
            </div>
          </div>
        )}
      </div>

      {releases.length > 0 ? (
        <div id="releases-list">
          {releases.map((release) => (
            <div class="release-item" data-version={release.version} data-name={release.name?.toLowerCase()} data-prerelease={release.prerelease} data-body={release.body?.toLowerCase().slice(0, 500)}>
              <ReleaseEntry release={release} toolId={tool.id} />
            </div>
          ))}
        </div>
      ) : (
        <div class="rounded-lg border border-dashed border-green/20 bg-bg-card p-8 text-center sm:p-12">
          <p class="mb-2 font-mono text-sm text-green">> no releases tracked yet.</p>
          <p class="mb-4 font-sans text-sm text-text-secondary">We track this tool — data coming soon.</p>
          {tool.website && (
            <a
              href={tool.website}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 rounded border border-border bg-bg-tertiary px-3 py-1.5 font-mono text-xs text-text-secondary transition-all hover:border-green hover:text-green"
            >
              visit {tool.name} →
            </a>
          )}
        </div>
      )}
    </section>

    <script>
      const filter = document.getElementById('release-filter') as HTMLInputElement;
      const items = document.querySelectorAll('.release-item');
      const stableBtn = document.getElementById('filter-stable');
      const breakingBtn = document.getElementById('filter-breaking');
      let activeFilter = '';

      function applyFilters() {
        const query = (filter?.value || '').toLowerCase();
        items.forEach((el) => {
          const version = el.getAttribute('data-version') || '';
          const name = el.getAttribute('data-name') || '';
          const body = el.getAttribute('data-body') || '';
          const prerelease = el.getAttribute('data-prerelease') === 'true';
          const textMatch = !query || version.includes(query) || name.includes(query) || body.includes(query);
          let filterMatch = true;
          if (activeFilter === 'stable') filterMatch = !prerelease;
          if (activeFilter === 'breaking') filterMatch = body.includes('breaking') || body.includes('BREAKING');
          (el as HTMLElement).style.display = textMatch && filterMatch ? '' : 'none';
        });
      }

      // Copy buttons
      document.querySelectorAll('.copy-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          const text = btn.getAttribute('data-copy') || '';
          navigator.clipboard.writeText(text).then(() => {
            const orig = btn.textContent;
            btn.textContent = 'copied!';
            setTimeout(() => { btn.textContent = orig; }, 1500);
          });
        });
      });

      filter?.addEventListener('input', applyFilters);

      [stableBtn, breakingBtn].forEach((btn) => {
        btn?.addEventListener('click', () => {
          const f = btn.getAttribute('data-filter') || '';
          if (activeFilter === f) {
            activeFilter = '';
            btn.classList.remove('border-green', 'text-green', 'border-red', 'text-red');
          } else {
            activeFilter = f;
            document.querySelectorAll('.release-filter-btn').forEach((b) => b.classList.remove('border-green', 'text-green', 'border-red', 'text-red'));
            if (f === 'stable') btn.classList.add('border-green', 'text-green');
            if (f === 'breaking') btn.classList.add('border-red', 'text-red');
          }
          applyFilters();
        });
      });
    </script>
  </div>
</BaseLayout>
