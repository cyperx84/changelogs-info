---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ReleaseEntry from "../../../components/ReleaseEntry.astro";
import { getTools, getToolReleases, getCategoryLabel, formatDate, relativeTime } from "../../../lib/releases";
import type { Tool, Release, ToolReleases } from "../../../lib/releases";
import { existsSync } from "node:fs";
import { join } from "node:path";

export function getStaticPaths() {
  const tools = getTools();
  return tools.map((tool) => ({
    params: { id: tool.id },
    props: { tool },
  }));
}

interface Props {
  tool: Tool;
}

const { tool } = Astro.props;

let releases: Release[] = [];
let lastUpdated = "";

const data = await getToolReleases(tool.id);
if (data) {
  releases = data.releases;
  lastUpdated = data.lastUpdated;
}

const stableReleases = releases.filter((r) => !r.prerelease);
const prereleases = releases.filter((r) => r.prerelease);
const latestStable = stableReleases[0];
const hasCheatsheet = existsSync(join(process.cwd(), `src/content/cheatsheets/${tool.id}.md`));
---

<BaseLayout
  title={`${tool.name} Changelog — changelogs.info`}
  description={`Track all releases and changelogs for ${tool.name} (${tool.repo}). ${tool.description}`}
>
  <div class="mx-auto max-w-4xl px-6 py-12">
    <!-- Back link -->
    <a href="/" class="mb-8 inline-flex items-center gap-1 text-sm text-text-muted transition-colors hover:text-accent">
      &larr; All tools
    </a>

    <!-- Tool header -->
    <header class="mb-10">
      <div class="flex flex-wrap items-start justify-between gap-4">
        <div>
          <h1 class="text-3xl font-bold">{tool.name}</h1>
          <p class="mt-1 font-mono text-sm text-text-muted">{tool.repo}</p>
        </div>
        <div class="flex items-center gap-3">
          <span class="rounded-full border border-border bg-bg-tertiary px-3 py-1 text-xs text-text-secondary">
            {getCategoryLabel(tool.category)}
          </span>
          <a
            href={`https://github.com/${tool.repo}`}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-lg border border-border bg-bg-tertiary px-4 py-1.5 text-sm text-text-secondary transition-colors hover:border-border-hover hover:text-text-primary"
          >
            GitHub
          </a>
          {tool.website && (
            <a
              href={tool.website}
              target="_blank"
              rel="noopener noreferrer"
              class="rounded-lg border border-accent bg-accent/10 px-4 py-1.5 text-sm text-accent transition-colors hover:bg-accent/20"
            >
              Website
            </a>
          )}
          {hasCheatsheet && (
            <a
              href={`/tools/${tool.id}/cheatsheet`}
              class="rounded-lg border border-border bg-bg-tertiary px-4 py-1.5 text-sm text-text-secondary transition-colors hover:border-border-hover hover:text-text-primary"
            >
              Cheat Sheet
            </a>
          )}
        </div>
      </div>

      <p class="mt-4 text-text-secondary leading-relaxed">{tool.description}</p>

      <!-- Stats bar -->
      {releases.length > 0 && (
        <div class="mt-6 flex flex-wrap gap-6 rounded-xl border border-border bg-bg-card p-4">
          {latestStable && (
            <div>
              <p class="text-xs text-text-muted">Latest</p>
              <p class="font-mono text-sm font-semibold text-green">{latestStable.version}</p>
            </div>
          )}
          <div>
            <p class="text-xs text-text-muted">Total Releases</p>
            <p class="text-sm font-semibold">{releases.length}</p>
          </div>
          <div>
            <p class="text-xs text-text-muted">Stable</p>
            <p class="text-sm font-semibold">{stableReleases.length}</p>
          </div>
          {prereleases.length > 0 && (
            <div>
              <p class="text-xs text-text-muted">Pre-release</p>
              <p class="text-sm font-semibold text-amber">{prereleases.length}</p>
            </div>
          )}
          {lastUpdated && (
            <div class="ml-auto">
              <p class="text-xs text-text-muted">Last scraped</p>
              <p class="text-xs text-text-muted">{formatDate(lastUpdated)}</p>
            </div>
          )}
        </div>
      )}

      <!-- Tags -->
      {tool.tags.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-2">
          {tool.tags.map((tag) => (
            <span class="rounded-md bg-bg-tertiary px-2 py-0.5 text-xs text-text-muted">
              {tag}
            </span>
          ))}
        </div>
      )}
    </header>

    <!-- Releases timeline -->
    <section>
      <h2 class="mb-6 text-xl font-semibold">Changelog</h2>

      {releases.length > 0 ? (
        <div>
          {releases.map((release) => (
            <ReleaseEntry release={release} toolId={tool.id} />
          ))}
        </div>
      ) : (
        <div class="rounded-xl border border-dashed border-border p-12 text-center">
          <p class="mb-2 font-mono text-sm text-text-muted">&gt; no release data</p>
          <p class="text-sm text-text-secondary">
            Run the scraper to fetch releases for {tool.name}:
          </p>
          <code class="mt-3 inline-block rounded-lg bg-bg-tertiary px-4 py-2 font-mono text-sm text-accent">
            npx tsx scrapers/github-releases.ts
          </code>
        </div>
      )}
    </section>
  </div>
</BaseLayout>
