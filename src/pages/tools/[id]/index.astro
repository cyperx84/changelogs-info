---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ReleaseEntry from "../../../components/ReleaseEntry.astro";
import { getTools, getToolReleases, getCategoryLabel, formatDate, relativeTime, isFeatured } from "../../../lib/releases";
import type { Tool, Release, ToolReleases } from "../../../lib/releases";
import { existsSync } from "node:fs";
import { join } from "node:path";

export function getStaticPaths() {
  const tools = getTools();
  return tools.map((tool) => ({
    params: { id: tool.id },
    props: { tool },
  }));
}

interface Props {
  tool: Tool;
}

const { tool } = Astro.props;

let releases: Release[] = [];
let lastUpdated = "";

const data = await getToolReleases(tool.id);
if (data) {
  releases = data.releases;
  lastUpdated = data.lastUpdated;
}

const stableReleases = releases.filter((r) => !r.prerelease);
const prereleases = releases.filter((r) => r.prerelease);
const latestStable = stableReleases[0];
const featured = isFeatured(tool.id);
const hasCheatsheet = existsSync(join(process.cwd(), `src/content/cheatsheets/${tool.id}.md`));
const hasConfig = existsSync(join(process.cwd(), `src/content/configs/${tool.id}.json`));
const hasMigration = existsSync(join(process.cwd(), `src/content/migrations/${tool.id}.json`));
---

<BaseLayout
  title={`${tool.name} Changelog — changelogs.info`}
  description={`Track all releases and changelogs for ${tool.name} (${tool.repo}). ${tool.description}`}
>
  <div class="mx-auto max-w-4xl px-6 py-12">
    <!-- Back link -->
    <a href="/" class="mb-8 inline-flex items-center gap-1 font-mono text-sm text-text-muted transition-colors hover:text-green">
      <span class="text-green">&lt;</span> cd ..
    </a>

    <!-- Tool header -->
    <header class="mb-10">
      <div class="flex flex-wrap items-start justify-between gap-4">
        <div>
          <h1 class="font-mono text-2xl font-bold text-green sm:text-3xl">{tool.name}</h1>
          {featured && <span class="ml-2 inline-block rounded border border-green/30 bg-green/10 px-2 py-0.5 align-middle font-mono text-xs text-green">★ featured</span>}
          <p class="mt-2 font-mono text-sm text-text-muted">
            <span class="text-green">~/</span>{tool.repo}
          </p>
        </div>
        <div class="flex flex-wrap items-center gap-2 sm:gap-3">
          <span class="rounded border border-border bg-bg-tertiary px-3 py-1 font-mono text-xs text-text-secondary">
            --{tool.category}
          </span>
          <a
            href={`https://github.com/${tool.repo}`}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded border border-border bg-bg-tertiary px-3 py-1.5 font-mono text-xs text-text-secondary transition-all hover:border-green hover:text-green sm:px-4 sm:text-sm"
          >
            github
          </a>
          {tool.website && (
            <a
              href={tool.website}
              target="_blank"
              rel="noopener noreferrer"
              class="rounded border border-accent bg-accent/10 px-3 py-1.5 font-mono text-xs text-accent transition-all hover:bg-accent/20 sm:px-4 sm:text-sm"
            >
              web
            </a>
          )}
          {hasCheatsheet && (
            <a
              href={`/tools/${tool.id}/cheatsheet`}
              class="rounded border border-cyan bg-cyan/10 px-3 py-1.5 font-mono text-xs text-cyan transition-all hover:bg-cyan/20 sm:px-4 sm:text-sm"
            >
              cheatsheet
            </a>
          )}
        </div>
      </div>

      <p class="mt-4 font-sans leading-relaxed text-text-secondary">{tool.description}</p>

      <!-- Stats bar -->
      {releases.length > 0 && (
        <div class="reveal mt-6 rounded-lg border border-border bg-bg-card">
          <div class="border-b border-border px-3 py-2 font-mono text-xs text-text-muted sm:px-4">
            <span class="text-green">●●●</span>
            <span class="ml-2">stats.json</span>
          </div>
          <div class="flex flex-wrap gap-6 p-4">
            {latestStable && (
              <div>
                <p class="font-mono text-xs text-text-muted">latest</p>
                <p class="font-mono text-sm font-semibold text-green">{latestStable.version}</p>
              </div>
            )}
            <div>
              <p class="font-mono text-xs text-text-muted">total</p>
              <p class="font-mono text-sm font-semibold text-cyan">{releases.length}</p>
            </div>
            <div>
              <p class="font-mono text-xs text-text-muted">stable</p>
              <p class="font-mono text-sm font-semibold text-text-primary">{stableReleases.length}</p>
            </div>
            {prereleases.length > 0 && (
              <div>
                <p class="font-mono text-xs text-text-muted">pre</p>
                <p class="font-mono text-sm font-semibold text-amber">{prereleases.length}</p>
              </div>
            )}
            {releases.length > 0 && (
              <div>
                <p class="font-mono text-xs text-text-muted">first tracked</p>
                <p class="font-mono text-xs text-text-muted">{formatDate(releases[releases.length - 1].date)}</p>
              </div>
            )}
            {lastUpdated && (
              <div class="ml-auto">
                <p class="font-mono text-xs text-text-muted">updated</p>
                <p class="font-mono text-xs text-text-muted">{relativeTime(lastUpdated)}</p>
              </div>
            )}
          </div>
        </div>
      )}

      <!-- Tags -->
      {tool.tags.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-2">
          {tool.tags.map((tag) => (
            <span class="rounded border border-border/50 bg-bg-tertiary px-2 py-0.5 font-mono text-xs text-text-muted">
              #{tag}
            </span>
          ))}
        </div>
      )}

      <!-- Quick links to related content -->
      {(hasCheatsheet || hasConfig || hasMigration) && (
        <div class="reveal mt-6 grid gap-2 sm:grid-cols-3">
          {hasCheatsheet && (
            <a href={`/tools/${tool.id}/cheatsheet`} class="rounded-lg border border-border bg-bg-card px-4 py-3 font-mono text-xs transition-all hover:border-cyan hover:shadow-[0_0_8px_rgba(0,212,255,0.15)]">
              <span class="text-cyan">📋</span> <span class="text-text-secondary">cheatsheet</span>
            </a>
          )}
          {hasConfig && (
            <a href="/configs" class="rounded-lg border border-border bg-bg-card px-4 py-3 font-mono text-xs transition-all hover:border-green hover:shadow-[0_0_8px_rgba(51,255,51,0.15)]">
              <span class="text-green">⚙️</span> <span class="text-text-secondary">config templates</span>
            </a>
          )}
          {hasMigration && (
            <a href="/migrations" class="rounded-lg border border-border bg-bg-card px-4 py-3 font-mono text-xs transition-all hover:border-amber hover:shadow-[0_0_8px_rgba(255,184,0,0.15)]">
              <span class="text-amber">🔄</span> <span class="text-text-secondary">migration guides</span>
            </a>
          )}
        </div>
      )}

    </header>

    <!-- Releases timeline -->
    <section>
      <div class="reveal mb-6 flex flex-wrap items-center justify-between gap-3">
        <h2 class="font-mono text-lg font-semibold text-green sm:text-xl">
          <span class="text-green">/</span>changelog
        </h2>
        {releases.length > 5 && (
          <div class="flex items-center gap-2">
            <input
              type="text"
              id="release-filter"
              placeholder="filter releases..."
              class="w-48 rounded border border-border bg-bg-tertiary px-3 py-1.5 font-mono text-xs text-text-primary outline-none transition-all focus:border-green focus:shadow-[0_0_6px_rgba(51,255,51,0.15)] sm:w-56"
            />
            <div class="flex gap-1">
              <button id="filter-stable" class="release-filter-btn rounded border border-border bg-bg-tertiary px-2 py-1 font-mono text-[10px] text-text-muted transition-all hover:border-green hover:text-green" data-filter="stable">stable</button>
              <button id="filter-breaking" class="release-filter-btn rounded border border-border bg-bg-tertiary px-2 py-1 font-mono text-[10px] text-text-muted transition-all hover:border-red hover:text-red" data-filter="breaking">breaking</button>
            </div>
          </div>
        )}
      </div>

      {releases.length > 0 ? (
        <div id="releases-list">
          {releases.map((release) => (
            <div class="release-item" data-version={release.version} data-name={release.name?.toLowerCase()} data-prerelease={release.prerelease} data-body={release.body?.toLowerCase().slice(0, 500)}>
              <ReleaseEntry release={release} toolId={tool.id} />
            </div>
          ))}
        </div>
      ) : (
        <div class="rounded-lg border border-dashed border-border bg-bg-card p-8 text-center sm:p-12">
          <p class="mb-3 font-mono text-sm text-red">ERROR: no release data</p>
          <p class="font-mono text-xs text-text-secondary sm:text-sm">
            Release data syncs automatically. Check back soon.
          </p>
        </div>
      )}
    </section>

    <script>
      const filter = document.getElementById('release-filter') as HTMLInputElement;
      const items = document.querySelectorAll('.release-item');
      const stableBtn = document.getElementById('filter-stable');
      const breakingBtn = document.getElementById('filter-breaking');
      let activeFilter = '';

      function applyFilters() {
        const query = (filter?.value || '').toLowerCase();
        items.forEach((el) => {
          const version = el.getAttribute('data-version') || '';
          const name = el.getAttribute('data-name') || '';
          const body = el.getAttribute('data-body') || '';
          const prerelease = el.getAttribute('data-prerelease') === 'true';
          const textMatch = !query || version.includes(query) || name.includes(query) || body.includes(query);
          let filterMatch = true;
          if (activeFilter === 'stable') filterMatch = !prerelease;
          if (activeFilter === 'breaking') filterMatch = body.includes('breaking') || body.includes('BREAKING');
          (el as HTMLElement).style.display = textMatch && filterMatch ? '' : 'none';
        });
      }

      filter?.addEventListener('input', applyFilters);

      [stableBtn, breakingBtn].forEach((btn) => {
        btn?.addEventListener('click', () => {
          const f = btn.getAttribute('data-filter') || '';
          if (activeFilter === f) {
            activeFilter = '';
            btn.classList.remove('border-green', 'text-green', 'border-red', 'text-red');
          } else {
            activeFilter = f;
            document.querySelectorAll('.release-filter-btn').forEach((b) => b.classList.remove('border-green', 'text-green', 'border-red', 'text-red'));
            if (f === 'stable') btn.classList.add('border-green', 'text-green');
            if (f === 'breaking') btn.classList.add('border-red', 'text-red');
          }
          applyFilters();
        });
      });
    </script>
  </div>
</BaseLayout>
