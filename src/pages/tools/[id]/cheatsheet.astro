---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getTools } from "../../../lib/releases";
import { readFileSync } from "node:fs";
import { join } from "node:path";

export function getStaticPaths() {
  const cheatsheetsDir = join(process.cwd(), "src/content/cheatsheets");
  const tools = getTools();
  return tools
    .filter((t) => {
      try {
        readFileSync(join(cheatsheetsDir, `${t.id}.md`), "utf-8");
        return true;
      } catch {
        return false;
      }
    })
    .map((t) => ({ params: { id: t.id }, props: { tool: t } }));
}

const { tool } = Astro.props;
const cheatsheetsDir = join(process.cwd(), "src/content/cheatsheets");
const raw = readFileSync(join(cheatsheetsDir, `${tool.id}.md`), "utf-8");
const content = raw.replace(/^---[\s\S]*?---\n*/, "");

function cheatsheetMd(md: string): string {
  let html = md
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;");

  // code blocks
  html = html.replace(/```(\w*)\n([\s\S]*?)```/g, (_m, _lang, code) => {
    return `<pre><code>${code.trim()}</code></pre>`;
  });

  // tables
  html = html.replace(
    /^(\|.+\|)\n(\|[\s:|-]+\|)\n((?:\|.+\|\n?)+)/gm,
    (_m, header, _sep, body) => {
      const ths = header.split("|").filter(Boolean).map((c: string) => `<th>${c.trim()}</th>`).join("");
      const rows = body.trim().split("\n").map((row: string) => {
        const tds = row.split("|").filter(Boolean).map((c: string) => `<td>${c.trim()}</td>`).join("");
        return `<tr>${tds}</tr>`;
      }).join("");
      return `<table><thead><tr>${ths}</tr></thead><tbody>${rows}</tbody></table>`;
    }
  );

  // inline code (after tables so backticks in table cells work)
  html = html.replace(/`([^`]+)`/g, "<code>$1</code>");

  // headers
  html = html.replace(/^### (.+)$/gm, "<h3>$1</h3>");
  html = html.replace(/^## (.+)$/gm, "<h2>$1</h2>");
  html = html.replace(/^# (.+)$/gm, "<h1>$1</h1>");

  // bold/italic
  html = html.replace(/\*\*(.+?)\*\*/g, "<strong>$1</strong>");
  html = html.replace(/\*(.+?)\*/g, "<em>$1</em>");

  // lists
  html = html.replace(/^[-*] (.+)$/gm, "<li>$1</li>");
  html = html.replace(/((?:<li>.*<\/li>\n?)+)/g, "<ul>$1</ul>");

  // paragraphs
  html = html
    .split("\n\n")
    .map((block) => {
      const t = block.trim();
      if (!t) return "";
      if (/^<[a-z]/.test(t)) return t;
      return `<p>${t}</p>`;
    })
    .join("\n");

  html = html
    .replace(/<p><(h[1-3]|ul|ol|pre|blockquote|hr|table)/g, "<$1")
    .replace(/<\/(h[1-3]|ul|ol|pre|blockquote|table)><\/p>/g, "</$1>");

  return html;
}

const bodyHtml = cheatsheetMd(content);
---

<BaseLayout
  title={`${tool.name} Cheat Sheet — changelogs.info`}
  description={`Quick reference cheat sheet for ${tool.name}`}
>
  <div class="mx-auto max-w-4xl px-6 py-12">
    <div class="mb-8 flex flex-wrap items-center justify-between gap-4">
      <a href={`/tools/${tool.id}`} class="inline-flex items-center gap-1 text-sm text-text-muted transition-colors hover:text-accent">
        &larr; {tool.name}
      </a>
      <div class="flex gap-2">
        <button
          id="copy-btn"
          class="rounded border border-border bg-bg-tertiary px-3 py-2 font-mono text-xs text-text-secondary transition-all hover:border-green hover:text-green"
          data-content={content}
        >
          <span id="copy-label">copy markdown</span>
        </button>
        <a
          href={`/cheatsheets/${tool.id}.md`}
          download={`${tool.id}-cheatsheet.md`}
          class="rounded border border-border bg-bg-tertiary px-3 py-2 font-mono text-xs text-text-secondary transition-all hover:border-green hover:text-green"
        >
          download .md
        </a>
      </div>
    </div>

    <div class="cheatsheet-body" set:html={bodyHtml} />
  </div>
</BaseLayout>


<script>
  const btn = document.getElementById('copy-btn');
  const label = document.getElementById('copy-label');
  if (btn && label) {
    btn.addEventListener('click', async () => {
      const md = btn.getAttribute('data-content') || '';
      try {
        await navigator.clipboard.writeText(md);
        label.textContent = 'copied!';
        btn.classList.add('border-green', 'text-green');
        setTimeout(() => {
          label.textContent = 'copy markdown';
          btn.classList.remove('border-green', 'text-green');
        }, 2000);
      } catch {
        label.textContent = 'failed';
        setTimeout(() => { label.textContent = 'copy markdown'; }, 2000);
      }
    });
  }
</script>

<style is:global>
  .cheatsheet-body h1 { font-size: 2rem; font-weight: 700; margin-bottom: 1rem; color: var(--color-text-primary); }
  .cheatsheet-body h2 { font-size: 1.25rem; font-weight: 600; margin-top: 2rem; margin-bottom: 0.75rem; color: var(--color-text-primary); }
  .cheatsheet-body h3 { font-size: 1.1rem; font-weight: 600; margin-top: 1.25rem; margin-bottom: 0.5rem; color: var(--color-text-primary); }
  .cheatsheet-body p { margin-bottom: 0.75rem; line-height: 1.7; color: var(--color-text-secondary); }
  .cheatsheet-body table { width: 100%; border-collapse: collapse; margin-bottom: 1rem; }
  .cheatsheet-body th { text-align: left; padding: 0.5rem 0.75rem; border-bottom: 2px solid var(--color-border); color: var(--color-text-primary); font-size: 0.875rem; }
  .cheatsheet-body td { padding: 0.5rem 0.75rem; border-bottom: 1px solid var(--color-border); color: var(--color-text-secondary); font-size: 0.875rem; }
  .cheatsheet-body tr:hover td { background: var(--color-bg-tertiary); }
  .cheatsheet-body code { background: var(--color-bg-tertiary); padding: 0.15em 0.4em; border-radius: 4px; font-family: var(--font-mono); font-size: 0.875em; }
  .cheatsheet-body pre { background: var(--color-bg-tertiary); padding: 1rem; border-radius: 8px; overflow-x: auto; margin-bottom: 1rem; }
  .cheatsheet-body pre code { background: none; padding: 0; }
  .cheatsheet-body ul { list-style: disc; padding-left: 1.5rem; margin-bottom: 0.75rem; }
  .cheatsheet-body li { margin-bottom: 0.25rem; line-height: 1.6; color: var(--color-text-secondary); }
</style>
