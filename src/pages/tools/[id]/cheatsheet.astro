---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getTools } from "../../../lib/releases";
import { readFileSync } from "node:fs";
import { join } from "node:path";

export function getStaticPaths() {
  const cheatsheetsDir = join(process.cwd(), "src/content/cheatsheets-json");
  const tools = getTools();
  return tools
    .filter((t) => {
      try {
        readFileSync(join(cheatsheetsDir, `${t.id}.json`), "utf-8");
        return true;
      } catch {
        return false;
      }
    })
    .map((t) => ({ params: { id: t.id }, props: { tool: t } }));
}

const { tool } = Astro.props;
const cheatsheetsDir = join(process.cwd(), "src/content/cheatsheets-json");
const raw = readFileSync(join(cheatsheetsDir, `${tool.id}.json`), "utf-8");
const cs = JSON.parse(raw);

const dailyWorkflows = cs.dailyWorkflows || [];
const powerMoves = cs.powerMoves || [];
const gotchas = cs.gotchas || [];
const cliFlags = cs.cliFlags || [];
const slashCommands = cs.slashCommands || [];
const config = cs.config || [];
const proTips = cs.proTips || [];
const resources = cs.resources || [];
const quickStart = cs.quickStart || null;
---

<BaseLayout
  title={`${tool.name} Cheat Sheet — changelogs.info`}
  description={`The actually useful ${tool.name} cheat sheet. Daily workflows, power moves, gotchas, and pro tips.`}
>
  <div class="mx-auto max-w-4xl px-6 py-12">

    <!-- Nav -->
    <div class="mb-8 flex flex-wrap items-center justify-between gap-4">
      <a href={`/tools/${tool.id}`} class="inline-flex items-center gap-1 font-mono text-sm text-text-muted transition-colors hover:text-green">
        <span class="text-green">&lt;</span> {tool.name}
      </a>
      <div class="flex gap-2">
        <button
          id="copy-btn"
          class="rounded border border-border bg-bg-tertiary px-3 py-2 font-mono text-xs text-text-secondary transition-all hover:border-green hover:text-green"
          data-content={raw}
        >
          <span id="copy-label">copy JSON</span>
        </button>
        <a
          href={`/cheatsheets/${tool.id}.json`}
          download={`${tool.id}-cheatsheet.json`}
          class="rounded border border-border bg-bg-tertiary px-3 py-2 font-mono text-xs text-text-secondary transition-all hover:border-green hover:text-green"
        >
          download
        </a>
      </div>
    </div>

    <!-- Header -->
    <header class="mb-10">
      <h1 class="text-glow-green font-mono text-2xl font-bold text-green sm:text-3xl">{tool.name} cheat sheet</h1>
      <p class="mt-2 font-sans text-sm text-text-muted">The stuff you actually need. Updated {cs.lastUpdated}.</p>
    </header>

    <!-- Quick Start -->
    {quickStart && (
      <section class="mb-10 rounded-lg border-2 border-green/40 bg-green/[0.03] p-5">
        <h2 class="mb-3 font-mono text-sm font-bold text-green">🚀 {quickStart.title}</h2>
        <ol class="space-y-2">
          {quickStart.steps.map((step: string, i: number) => (
            <li class="flex gap-3 font-mono text-xs text-text-secondary">
              <span class="shrink-0 text-green">{i + 1}.</span>
              <span>{step}</span>
            </li>
          ))}
        </ol>
      </section>
    )}

    <!-- Daily Workflows -->
    {dailyWorkflows.length > 0 && (
      <section class="mb-10">
        <h2 class="mb-4 font-mono text-base font-semibold text-green"><span class="text-green">//</span> daily_workflows</h2>
        <p class="mb-4 font-sans text-xs text-text-muted">The things you'll actually do every day.</p>
        <div class="space-y-3">
          {dailyWorkflows.map((wf: any) => (
            <div class="group rounded-lg border border-border bg-bg-card p-4 transition-all hover:border-green/40">
              <div class="mb-2 flex flex-wrap items-center gap-2">
                <h3 class="font-mono text-sm font-semibold text-text-primary">{wf.title}</h3>
                {(wf.tags || []).map((tag: string) => (
                  <span class="rounded bg-bg-tertiary px-1.5 py-0.5 font-mono text-[10px] text-text-muted">{tag}</span>
                ))}
              </div>
              <p class="mb-2 font-sans text-xs text-text-muted">{wf.description}</p>
              {wf.command && (
                <div class="flex items-center justify-between gap-2 rounded bg-bg-tertiary px-3 py-2 overflow-x-auto">
                  <code class="font-mono text-xs text-green break-all">{wf.command}</code>
                  <button class="copy-btn shrink-0 rounded px-2 py-1 font-mono text-[10px] text-text-muted opacity-0 transition-all hover:text-green group-hover:opacity-100" data-copy={wf.command}>copy</button>
                </div>
              )}
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Power Moves -->
    {powerMoves.length > 0 && (
      <section class="mb-10">
        <h2 class="mb-4 font-mono text-base font-semibold text-amber"><span class="text-amber">⚡</span> power_moves</h2>
        <p class="mb-4 font-sans text-xs text-text-muted">Stuff most people don't know about.</p>
        <div class="grid gap-3 sm:grid-cols-2">
          {powerMoves.map((pm: any) => (
            <div class="group rounded-lg border border-border bg-bg-card p-4 transition-all hover:border-amber/40">
              <h3 class="mb-1 font-mono text-sm font-semibold text-text-primary">{pm.title}</h3>
              <p class="mb-2 font-sans text-xs text-text-muted">{pm.description}</p>
              {pm.command && (
                <div class="mb-2 flex items-center justify-between gap-2 rounded bg-bg-tertiary px-3 py-2 overflow-x-auto">
                  <code class="font-mono text-[11px] text-amber break-all">{pm.command}</code>
                  <button class="copy-btn shrink-0 rounded px-2 py-1 font-mono text-[10px] text-text-muted opacity-0 transition-all hover:text-amber group-hover:opacity-100" data-copy={pm.command}>copy</button>
                </div>
              )}
              {pm.why && (
                <p class="font-sans text-[11px] text-text-muted italic">{pm.why}</p>
              )}
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Gotchas -->
    {gotchas.length > 0 && (
      <section class="mb-10">
        <h2 class="mb-4 font-mono text-base font-semibold text-red-400"><span class="text-red-400">🔥</span> common_gotchas</h2>
        <p class="mb-4 font-sans text-xs text-text-muted">Save yourself 30 minutes of debugging.</p>
        <div class="space-y-3">
          {gotchas.map((g: any) => (
            <div class="rounded-lg border border-red-400/20 bg-red-400/[0.03] p-4">
              <div class="mb-2 flex items-start gap-2">
                <span class="shrink-0 rounded px-1.5 py-0.5 font-mono text-[10px] font-medium" class:list={[
                  g.severity === 'blocking' ? 'bg-red-400/20 text-red-400' :
                  g.severity === 'annoying' ? 'bg-amber/20 text-amber' :
                  'bg-cyan/20 text-cyan'
                ]}>{g.severity || 'gotcha'}</span>
                <h3 class="font-mono text-sm font-semibold text-text-primary">{g.problem}</h3>
              </div>
              <p class="pl-[calc(3rem+0.5rem)] font-sans text-xs text-text-secondary">{g.solution}</p>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- CLI Flags Reference -->
    {cliFlags.length > 0 && (
      <section class="mb-10">
        <h2 class="mb-4 font-mono text-base font-semibold text-green"><span class="text-green">📋</span> cli_flags</h2>
        <input
          type="text"
          id="flag-search"
          placeholder="search flags..."
          class="mb-3 w-full rounded border border-border bg-bg-tertiary px-3 py-2 font-mono text-xs text-text-primary outline-none transition-colors focus:border-green"
        />
        <div class="rounded-lg border border-border bg-bg-card overflow-hidden overflow-x-auto">
          <div id="flags-list" class="divide-y divide-border/30 min-w-full">
            {cliFlags.map((f: any) => (
              <div class="flag-row flex flex-col gap-1 px-4 py-2.5 transition-all hover:bg-bg-tertiary/30 sm:flex-row sm:items-start sm:gap-4 min-w-0" data-search={`${f.flag} ${f.shorthand || ''} ${f.description} ${f.useCase || ''}`}>
                <code class="shrink-0 font-mono text-xs font-semibold text-green sm:w-48">
                  --{f.flag}{f.shorthand ? `, -${f.shorthand}` : ''}
                </code>
                <div class="flex-1">
                  <p class="font-sans text-xs text-text-secondary">{f.description}</p>
                  {f.useCase && <p class="mt-1 font-sans text-[11px] text-text-muted italic">{f.useCase}</p>}
                  {f.example && (
                    <div class="group mt-1.5 flex items-center justify-between gap-2 rounded bg-bg-tertiary/50 px-2 py-1 overflow-x-auto">
                      <code class="font-mono text-[11px] text-text-muted break-all">{f.example}</code>
                      <button class="copy-btn shrink-0 rounded px-1.5 py-0.5 font-mono text-[10px] text-text-muted opacity-0 transition-all hover:text-green group-hover:opacity-100" data-copy={f.example}>copy</button>
                    </div>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Slash Commands -->
    {slashCommands.length > 0 && (
      <section class="mb-10">
        <h2 class="mb-4 font-mono text-base font-semibold text-cyan"><span class="text-cyan">/</span> commands</h2>
        <div class="grid gap-2 sm:grid-cols-2">
          {slashCommands.map((cmd: any) => (
            <div class="group rounded border border-border bg-bg-card px-4 py-3 transition-all hover:border-cyan/40">
              <code class="font-mono text-sm font-semibold text-cyan">{cmd.command}</code>
              <p class="mt-1 font-sans text-xs text-text-muted">{cmd.description}</p>
              {cmd.tip && <p class="mt-1 font-sans text-[11px] text-cyan/70 italic">💡 {cmd.tip}</p>}
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Pro Tips -->
    {proTips.length > 0 && (
      <section class="mb-10">
        <h2 class="mb-4 font-mono text-base font-semibold text-amber"><span class="text-amber">💡</span> pro_tips</h2>
        <div class="rounded-lg border border-amber/20 bg-amber/[0.03] p-5">
          <ul class="grid gap-2 sm:grid-cols-2">
            {proTips.map((tip: string) => (
              <li class="flex gap-2 font-sans text-xs text-text-secondary">
                <span class="shrink-0 text-amber">›</span>
                <span>{tip}</span>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )}

    <!-- Config -->
    {config.length > 0 && (
      <section class="mb-10">
        <h2 class="mb-4 font-mono text-base font-semibold text-text-primary">⚙️ configuration</h2>
        <div class="rounded-lg border border-border bg-bg-card overflow-hidden overflow-x-auto divide-y divide-border/30">
          {config.map((c: any) => (
            <div class="flex flex-col gap-1 px-4 py-2.5 sm:flex-row sm:items-start sm:gap-4 min-w-0">
              <code class="shrink-0 font-mono text-xs font-semibold text-green sm:w-56">{c.key}</code>
              <div class="flex-1">
                <p class="font-sans text-xs text-text-secondary">{c.description}</p>
                {c.default && <p class="mt-0.5 font-mono text-[11px] text-text-muted">default: {c.default}</p>}
                {c.recommended && <p class="mt-0.5 font-mono text-[11px] text-cyan">recommended: {c.recommended}</p>}
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- Resources -->
    {resources.length > 0 && (
      <section class="mb-10">
        <h2 class="mb-4 font-mono text-base font-semibold text-text-primary">📚 resources</h2>
        <div class="flex flex-wrap gap-2">
          {resources.map((r: any) => (
            <a href={r.url} target="_blank" rel="noopener" class="rounded border border-border bg-bg-card px-3 py-1.5 font-mono text-xs text-text-secondary transition-all hover:border-green hover:text-green">
              {r.title} →
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- All cheatsheets link -->
    <div class="text-center">
      <a href="/cheatsheets" class="font-mono text-sm text-text-muted transition-colors hover:text-green">
        all cheatsheets →
      </a>
    </div>
  </div>

  <script>
    // Copy buttons
    document.querySelectorAll('.copy-btn, #copy-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const text = btn.getAttribute('data-copy') || btn.getAttribute('data-content') || '';
        if (!text) return;
        navigator.clipboard.writeText(text).then(() => {
          const label = btn.querySelector('#copy-label') || btn;
          const original = label.textContent;
          label.textContent = '✓ copied';
          if (btn.classList) btn.classList.add('text-green');
          setTimeout(() => {
            label.textContent = original;
            btn.classList.remove('text-green');
          }, 1500);
        });
      });
    });

    // Flag search
    const searchInput = document.getElementById('flag-search') as HTMLInputElement;
    const flagRows = document.querySelectorAll('.flag-row');
    if (searchInput && flagRows.length) {
      searchInput.addEventListener('input', () => {
        const query = searchInput.value.toLowerCase();
        flagRows.forEach((row) => {
          const searchText = (row as HTMLElement).dataset.search?.toLowerCase() || '';
          (row as HTMLElement).style.display = searchText.includes(query) ? '' : 'none';
        });
      });
    }
  </script>
</BaseLayout>
