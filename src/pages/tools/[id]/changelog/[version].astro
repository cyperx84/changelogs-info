---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import { getTools, getToolReleases, formatDate, relativeTime } from "../../../../lib/releases";
import { markdownToHtml } from "../../../../lib/markdown";

export async function getStaticPaths() {
  const tools = getTools();
  const paths = [];

  for (const tool of tools) {
    const data = await getToolReleases(tool.id);
    if (!data) continue;

    const releases = data.releases;

    for (let i = 0; i < releases.length; i++) {
      const release = releases[i];
      const slug = encodeURIComponent(release.version.replace(/^v/, ""));
      // releases[0] is newest; prev = newer (i-1), next = older (i+1)
      const prevRelease = i > 0 ? releases[i - 1] : null;
      const nextRelease = i < releases.length - 1 ? releases[i + 1] : null;

      paths.push({
        params: { id: tool.id, version: slug },
        props: { tool, release, prevRelease, nextRelease, releaseIndex: i, totalReleases: releases.length },
      });
    }
  }

  return paths;
}

const { tool, release, prevRelease, nextRelease } = Astro.props;
const bodyHtml = release.body ? markdownToHtml(release.body) : "";

function versionSlug(v: string) {
  return encodeURIComponent(v.replace(/^v/, ""));
}
---

<BaseLayout
  title={`${tool.name} ${release.version} — changelogs.info`}
  description={`Release notes for ${tool.name} ${release.version}: ${release.name || ""}`}
>
  <div class="mx-auto max-w-4xl px-4 py-10 sm:px-6 sm:py-12">

    <!-- Breadcrumb -->
    <nav class="mb-8 flex items-center gap-2 font-mono text-xs text-text-muted">
      <a href="/" class="transition-colors hover:text-green">changelogs.info</a>
      <span class="text-green">/</span>
      <a href={`/tools/${tool.id}`} class="transition-colors hover:text-green">{tool.name}</a>
      <span class="text-green">/</span>
      <span class="text-text-secondary">{release.version}</span>
    </nav>

    <!-- Header -->
    <header class="mb-10 rounded-lg border border-border bg-bg-card p-5 sm:p-6">
      <div class="flex flex-wrap items-start justify-between gap-4">
        <div>
          <div class="flex flex-wrap items-center gap-3">
            <h1 class="font-mono text-2xl font-bold text-green sm:text-3xl">{release.version}</h1>
            {release.prerelease && (
              <span class="rounded-full border border-amber/30 bg-amber/10 px-2.5 py-0.5 font-mono text-xs text-amber">
                pre-release
              </span>
            )}
          </div>
          {release.name && release.name !== release.version && (
            <p class="mt-2 font-sans text-base text-text-secondary sm:text-lg">{release.name}</p>
          )}
          <div class="mt-3 flex flex-wrap items-center gap-3 font-mono text-xs text-text-muted sm:gap-4 sm:text-sm">
            <span>{formatDate(release.date)}</span>
            <span class="text-green opacity-40">·</span>
            <span>{relativeTime(release.date)}</span>
          </div>
        </div>
        <a
          href={release.url}
          target="_blank"
          rel="noopener noreferrer"
          class="shrink-0 rounded border border-border bg-bg-tertiary px-3 py-1.5 font-mono text-xs text-text-muted transition-all hover:border-green hover:text-green sm:px-4 sm:text-sm"
        >
          GitHub →
        </a>
      </div>
    </header>

    <!-- Release body -->
    {bodyHtml ? (
      <article class="changelog-body mb-12" set:html={bodyHtml} />
    ) : (
      <div class="mb-12 rounded-lg border border-dashed border-border p-6 text-center font-mono text-sm text-text-muted">
        No release notes provided for this version.
      </div>
    )}

    <!-- Prev / Next navigation -->
    <nav class="grid gap-3 sm:grid-cols-2" aria-label="Release navigation">
      <!-- Newer release (prev in array = newer) -->
      {prevRelease ? (
        <a
          href={`/tools/${tool.id}/changelog/${versionSlug(prevRelease.version)}`}
          class="group flex flex-col rounded-lg border border-border bg-bg-card p-4 transition-all hover:border-green hover:shadow-[0_0_10px_rgba(51,255,51,0.08)]"
        >
          <span class="mb-1 font-mono text-[10px] uppercase tracking-widest text-text-muted">← newer</span>
          <span class="font-mono text-sm font-semibold text-green group-hover:text-green-bright">
            {prevRelease.version}
          </span>
          {prevRelease.name && prevRelease.name !== prevRelease.version && (
            <span class="mt-0.5 truncate font-mono text-xs text-text-muted">{prevRelease.name}</span>
          )}
          <span class="mt-1 font-mono text-xs text-text-muted">{formatDate(prevRelease.date)}</span>
        </a>
      ) : (
        <div class="rounded-lg border border-dashed border-border/40 p-4">
          <span class="font-mono text-xs text-text-muted opacity-40">no newer release</span>
        </div>
      )}

      <!-- Older release (next in array = older) -->
      {nextRelease ? (
        <a
          href={`/tools/${tool.id}/changelog/${versionSlug(nextRelease.version)}`}
          class="group flex flex-col rounded-lg border border-border bg-bg-card p-4 text-right transition-all hover:border-green hover:shadow-[0_0_10px_rgba(51,255,51,0.08)] sm:col-start-2"
        >
          <span class="mb-1 font-mono text-[10px] uppercase tracking-widest text-text-muted">older →</span>
          <span class="font-mono text-sm font-semibold text-green group-hover:text-green-bright">
            {nextRelease.version}
          </span>
          {nextRelease.name && nextRelease.name !== nextRelease.version && (
            <span class="mt-0.5 truncate font-mono text-xs text-text-muted">{nextRelease.name}</span>
          )}
          <span class="mt-1 font-mono text-xs text-text-muted">{formatDate(nextRelease.date)}</span>
        </a>
      ) : (
        <div class="rounded-lg border border-dashed border-border/40 p-4 text-right sm:col-start-2">
          <span class="font-mono text-xs text-text-muted opacity-40">no older release</span>
        </div>
      )}
    </nav>

    <!-- Back link -->
    <div class="mt-6">
      <a
        href={`/tools/${tool.id}`}
        class="inline-flex items-center gap-1 font-mono text-sm text-text-muted transition-colors hover:text-green"
      >
        <span class="text-green">&lt;</span> all {tool.name} releases
      </a>
    </div>
  </div>
</BaseLayout>

<style>
  /* Release body markdown styles */
  .changelog-body {
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
  }

  .changelog-body :global(h1),
  .changelog-body :global(h2),
  .changelog-body :global(h3),
  .changelog-body :global(h4) {
    font-family: var(--font-mono);
    font-weight: 600;
    color: var(--color-text-primary);
    margin-top: 1.75rem;
    margin-bottom: 0.75rem;
  }

  .changelog-body :global(h2) { font-size: 1.125rem; border-bottom: 1px solid var(--color-border); padding-bottom: 0.375rem; }
  .changelog-body :global(h3) { font-size: 1rem; color: var(--color-green); }
  .changelog-body :global(h4) { font-size: 0.875rem; }

  .changelog-body :global(p) {
    margin-bottom: 1rem;
  }

  .changelog-body :global(ul),
  .changelog-body :global(ol) {
    margin: 0.75rem 0 1rem 1.25rem;
  }
  .changelog-body :global(ul) { list-style-type: disc; }
  .changelog-body :global(ol) { list-style-type: decimal; }

  .changelog-body :global(li) {
    margin-bottom: 0.25rem;
    padding-left: 0.25rem;
  }

  .changelog-body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    background: var(--color-bg-tertiary);
    border: 1px solid var(--color-border);
    border-radius: 0.25rem;
    padding: 0.1em 0.4em;
    color: var(--color-text-primary);
  }

  .changelog-body :global(pre) {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    padding: 1rem 1.25rem;
    overflow-x: auto;
    margin: 1rem 0;
  }

  .changelog-body :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
  }

  .changelog-body :global(blockquote) {
    border-left: 3px solid var(--color-green);
    padding-left: 1rem;
    margin: 1rem 0;
    color: var(--color-text-muted);
    font-style: italic;
  }

  .changelog-body :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 1.5rem 0;
  }

  .changelog-body :global(a) {
    color: var(--color-green);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 150ms ease;
  }

  .changelog-body :global(a:hover) {
    border-bottom-color: var(--color-green);
  }

  .changelog-body :global(strong) {
    color: var(--color-text-primary);
    font-weight: 600;
  }

  .changelog-body :global(del) {
    opacity: 0.5;
    text-decoration: line-through;
  }
</style>
