---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import { getTools, getToolReleases, formatDate, relativeTime } from "../../../../lib/releases";
import { markdownToHtml } from "../../../../lib/markdown";

export async function getStaticPaths() {
  const tools = getTools();
  const paths = [];

  for (const tool of tools) {
    const data = await getToolReleases(tool.id);
    if (!data) continue;

    for (const release of data.releases) {
      const slug = release.version.replace(/^v/, "");
      paths.push({
        params: { id: tool.id, version: slug },
        props: { tool, release },
      });
    }
  }

  return paths;
}

const { tool, release } = Astro.props;
const bodyHtml = release.body ? markdownToHtml(release.body) : "";
---

<BaseLayout
  title={`${tool.name} ${release.version} — changelogs.info`}
  description={`Release notes for ${tool.name} ${release.version}`}
>
  <div class="mx-auto max-w-4xl px-6 py-12">
    <a href={`/tools/${tool.id}`} class="mb-8 inline-flex items-center gap-1 text-sm text-text-muted transition-colors hover:text-accent">
      &larr; {tool.name} Changelog
    </a>

    <header class="mb-8">
      <div class="flex flex-wrap items-center gap-3">
        <h1 class="text-3xl font-bold font-mono text-green">{release.version}</h1>
        {release.prerelease && (
          <span class="rounded-full border border-amber/30 bg-amber/10 px-2.5 py-0.5 text-xs text-amber">
            pre-release
          </span>
        )}
      </div>

      {release.name && release.name !== release.version && (
        <p class="mt-2 text-lg text-text-secondary">{release.name}</p>
      )}

      <div class="mt-3 flex items-center gap-4 text-sm text-text-muted">
        <span>{formatDate(release.date)} ({relativeTime(release.date)})</span>
        <a
          href={release.url}
          target="_blank"
          rel="noopener noreferrer"
          class="transition-colors hover:text-accent"
        >
          View on GitHub &rarr;
        </a>
      </div>
    </header>

    {bodyHtml ? (
      <div class="changelog-body" set:html={bodyHtml} />
    ) : (
      <p class="text-text-muted">No release notes provided.</p>
    )}
  </div>
</BaseLayout>
