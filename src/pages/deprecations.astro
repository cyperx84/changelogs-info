---
import BaseLayout from "../layouts/BaseLayout.astro";
import { readFile } from "fs/promises";
import { join } from "path";

const FEATURED = ["openclaw", "claude-code"];
const items = JSON.parse(await readFile(join(process.cwd(), "src/content/deprecations.json"), "utf-8"));
items.sort((a: any, b: any) => {
  const aF = FEATURED.indexOf(a.harness);
  const bF = FEATURED.indexOf(b.harness);
  if (aF !== -1 && bF !== -1) return aF - bF;
  if (aF !== -1) return -1;
  if (bF !== -1) return 1;
  const da = a.removal ? new Date(a.removal).getTime() : Number.MAX_SAFE_INTEGER;
  const db = b.removal ? new Date(b.removal).getTime() : Number.MAX_SAFE_INTEGER;
  return da - db;
});

function daysLeft(date?: string) {
  if (!date) return null;
  return Math.ceil((new Date(date).getTime() - Date.now()) / 86400000);
}
---

<BaseLayout title="Deprecations — changelogs.info" description="Deprecation radar for AI coding harnesses.">
  <section class="mx-auto max-w-5xl px-4 py-10 sm:px-6">
    <h1 class="font-mono text-2xl font-bold text-green sm:text-3xl"><span class="text-green">/</span>deprecations</h1>
    <p class="mt-2 font-mono text-sm text-text-secondary"><span class="text-green">#</span> what is going away and when</p>

    <div class="mt-8 space-y-4">
      {items.map((d: any) => (
        <article class="rounded-lg border border-border bg-bg-card p-4">
          <div class="flex flex-wrap items-center gap-2 font-mono text-xs">
            <span class="text-cyan">{d.harness}</span>{FEATURED.includes(d.harness) && <span class="rounded border border-green/30 bg-green/10 px-1.5 py-0.5 text-[10px] text-green">featured</span>}
            <span class="text-text-muted">/</span>
            <span class="text-text-primary">{d.item}</span>
            <span class={`ml-auto ${d.severity === 'critical' ? 'text-red' : d.severity === 'warning' ? 'text-amber' : 'text-cyan'}`}>{d.severity}</span>
          </div>
          <p class="mt-2 font-mono text-xs text-text-secondary">deprecated: {d.deprecated}{d.removal ? ` • removal: ${d.removal}` : ""}</p>
          {d.removal && <p class="font-mono text-xs text-text-muted">countdown: {daysLeft(d.removal)} days</p>}
          <p class="mt-2 font-mono text-xs text-green">→ {d.migration}</p>
          <p class="mt-1 font-mono text-xs text-text-muted">affects: {d.affects}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
