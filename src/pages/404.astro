---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404 — changelogs.info">
  <section class="mx-auto max-w-4xl px-4 py-20 text-center sm:px-6">
    <div class="rounded-lg border border-border bg-bg-card p-8 sm:p-12">
      <div class="border-b border-border px-3 py-2 font-mono text-xs text-text-muted">
        <span class="text-green">●●●</span> <span class="ml-2">error.log</span>
      </div>
      <div class="p-6 sm:p-8">
        <p class="font-mono text-6xl font-bold text-red sm:text-8xl">404</p>
        <p class="mt-4 font-mono text-sm text-text-secondary sm:text-base">
          <span class="text-red">ERROR:</span> path not found in release tree
        </p>
        <p class="mt-2 font-mono text-xs text-text-muted">
          The page you are looking for does not exist or has been moved.
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-3">
          <a href="/" class="rounded border border-green bg-green/10 px-5 py-2.5 font-mono text-sm text-green transition-all hover:bg-green/20">
            cd /
          </a>
          <a href="/" class="rounded border border-border bg-bg-tertiary px-5 py-2.5 font-mono text-sm text-text-secondary transition-all hover:border-green hover:text-green">
            /tools
          </a>
          <a href="/clwatch" class="rounded border border-border bg-bg-tertiary px-5 py-2.5 font-mono text-sm text-text-secondary transition-all hover:border-green hover:text-green">
            /clwatch
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
