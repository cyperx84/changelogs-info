---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404 — changelogs.info">
  <section class="mx-auto max-w-4xl px-4 py-16 sm:px-6 sm:py-24">
    <div class="rounded-lg border border-border bg-bg-card">
      <div class="border-b border-border px-3 py-2 font-mono text-xs text-text-muted">
        <span class="text-red">●</span><span class="text-amber">●</span><span class="text-green">●</span>
        <span class="ml-2">error.log</span>
      </div>
      <div class="p-6 sm:p-10">
        <!-- ASCII 404 -->
        <pre class="text-glow-green font-mono text-2xl font-bold leading-tight text-green sm:text-4xl">
 █  █   ████   █  █
 █  █  ██  ██  █  █
 ████  ██  ██  ████
    █  ██  ██     █
    █   ████      █</pre>

        <div class="mt-6 space-y-1 font-mono text-xs text-text-secondary sm:text-sm">
          <p>
            <span class="text-red">Error:</span> Route not found
          </p>
          <p class="text-text-muted">
            &nbsp;&nbsp;at changelogs.info/<span class="text-amber">&#91;path&#93;</span>
          </p>
          <p class="text-text-muted">
            &nbsp;&nbsp;Expected: <span class="text-green">a real page</span>
          </p>
          <p class="text-text-muted">
            &nbsp;&nbsp;Got: <span class="text-red">nothing</span>
          </p>
        </div>

        <p class="mt-6 font-mono text-sm text-text-muted">
          <span class="text-green">$</span> The page you requested does not exist or has been moved.<span class="terminal-cursor"></span>
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/" class="rounded border border-green bg-green/10 px-5 py-2.5 font-mono text-sm font-medium text-green transition-all hover:bg-green/20 hover:shadow-[0_0_12px_rgba(51,255,51,0.15)]">
            cd /
          </a>
          <a href="/#all-tools" class="rounded border border-border bg-transparent px-5 py-2.5 font-mono text-sm text-text-secondary transition-all hover:border-green/50 hover:text-green">
            /tools
          </a>
          <a href="/clwatch" class="rounded border border-border bg-transparent px-5 py-2.5 font-mono text-sm text-text-secondary transition-all hover:border-green/50 hover:text-green">
            /clwatch
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
