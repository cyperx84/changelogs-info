---
import BaseLayout from "../layouts/BaseLayout.astro";
import referralsData from "../data/referrals.json";

// Extract tools from referrals.json
const tools = Object.entries(referralsData).map(([id, data]) => ({
  id,
  name: id.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' '),
  pricing: data.pricing,
  referral: data.referral,
  label: data.label,
}));

// Usage scenarios with estimated monthly token usage
const scenarios = [
  {
    id: 'light',
    name: 'Light',
    description: 'Occasional use, small projects',
    icon: '◐',
    tokens: 500_000, // 0.5M tokens/month
    sessions: 20, // sessions per month
  },
  {
    id: 'daily',
    name: 'Daily',
    description: 'Regular daily coding',
    icon: '●',
    tokens: 2_000_000, // 2M tokens/month
    sessions: 60,
  },
  {
    id: 'power',
    name: 'Power',
    description: 'Heavy usage, large codebases',
    icon: '◉',
    tokens: 8_000_000, // 8M tokens/month
    sessions: 150,
  },
  {
    id: 'team',
    name: 'Team',
    description: 'Multiple developers',
    icon: '⬡',
    tokens: 25_000_000, // 25M tokens/month
    sessions: 400,
    multiplier: 3, // team size
  },
];

// Pricing models (approximate)
const toolPricing = {
  'openclaw': { free: true, subscription: 0, perToken: 0 },
  'claude-code': { free: false, subscription: 10, perToken: 3 }, // $3/1M tokens avg
  'codex-cli': { free: false, subscription: 10, perToken: 2.5 },
  'gemini-cli': { free: true, subscription: 0, perToken: 0 },
  'opencode': { free: true, subscription: 0, perToken: 0 },
  'cursor': { free: false, subscription: 20, perToken: 0 },
  'cline': { free: true, subscription: 0, perToken: 3 },
  'roo-code': { free: true, subscription: 0, perToken: 3 },
  'continue': { free: true, subscription: 0, perToken: 0 },
  'windsurf': { free: false, subscription: 15, perToken: 0 },
};
---

<BaseLayout title="Cost Calculator — changelogs.info">
  <section class="relative overflow-hidden border-b border-border bg-bg-secondary/30">
    <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 sm:py-16">
      <div class="max-w-3xl">
        <h1 class="font-mono text-2xl font-bold text-green sm:text-3xl md:text-4xl">
          <span class="text-green">&gt;</span> Cost Calculator
        </h1>
        <p class="mt-4 font-sans text-sm leading-relaxed text-text-secondary sm:text-base">
          Estimate your monthly costs for AI coding tools. Pick your usage scenario and the tools you use to see estimated costs.
        </p>
      </div>
    </div>
  </section>

  <div class="green-divider"></div>

  <section class="mx-auto max-w-6xl px-4 py-8 sm:px-6 sm:py-12">
    <!-- Step 1: Usage Scenario -->
    <div class="mb-8">
      <h2 class="mb-4 flex items-center gap-2 font-mono text-base font-semibold text-text-primary sm:text-lg">
        <span class="text-green">[1]</span> Pick your usage scenario
      </h2>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4" id="scenario-picker">
        {scenarios.map((scenario) => (
          <button
            class="scenario-btn group rounded-lg border border-border bg-bg-card p-4 text-left transition-all hover:border-green/40"
            data-scenario={scenario.id}
            data-tokens={scenario.tokens}
            data-sessions={scenario.sessions}
            data-multiplier={scenario.multiplier || 1}
          >
            <div class="mb-2 flex items-center justify-between">
              <span class="font-mono text-2xl text-green">{scenario.icon}</span>
              <span class="scenario-check hidden rounded-full bg-green/20 p-1 text-green">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
              </span>
            </div>
            <h3 class="font-mono text-sm font-semibold text-text-primary">{scenario.name}</h3>
            <p class="mt-1 font-mono text-xs text-text-muted">{scenario.description}</p>
            <div class="mt-3 border-t border-border pt-3">
              <p class="font-mono text-xs text-text-secondary">
                <span class="text-cyan">{(scenario.tokens / 1_000_000).toFixed(1)}M</span> tokens/mo
              </p>
            </div>
          </button>
        ))}
      </div>
    </div>

    <div class="green-divider"></div>

    <!-- Step 2: Tool Selection -->
    <div class="mb-8">
      <h2 class="mb-4 flex items-center gap-2 font-mono text-base font-semibold text-text-primary sm:text-lg">
        <span class="text-green">[2]</span> Select your tools
      </h2>
      <p class="mb-4 font-mono text-xs text-text-muted">
        Click to toggle. Green = selected.
      </p>
      <div class="flex flex-wrap gap-2" id="tool-picker">
        {tools.map((tool) => {
          const pricing = toolPricing[tool.id] || { free: true, subscription: 0, perToken: 0 };
          return (
            <button
              class="tool-btn rounded border border-border bg-bg-card px-3 py-2 font-mono text-xs text-text-muted transition-all hover:border-green/40"
              data-tool={tool.id}
              data-free={pricing.free}
              data-subscription={pricing.subscription}
              data-per-token={pricing.perToken}
            >
              <span class="tool-name">{tool.name}</span>
              <span class="tool-price ml-1.5 text-text-muted">
                {pricing.free ? (
                  <span class="text-green">free</span>
                ) : pricing.subscription > 0 ? (
                  <span>${pricing.subscription}/mo</span>
                ) : (
                  <span class="text-amber">BYOK</span>
                )}
              </span>
            </button>
          );
        })}
      </div>
      <div class="mt-3 flex gap-3">
        <button id="select-all-tools" class="rounded border border-border bg-bg-tertiary px-3 py-1.5 font-mono text-xs text-text-muted transition-all hover:border-green hover:text-green">
          select all
        </button>
        <button id="clear-tools" class="rounded border border-border bg-bg-tertiary px-3 py-1.5 font-mono text-xs text-text-muted transition-all hover:border-red hover:text-red">
          clear all
        </button>
      </div>
    </div>

    <div class="green-divider"></div>

    <!-- Step 3: Results -->
    <div class="mb-8">
      <h2 class="mb-4 flex items-center gap-2 font-mono text-base font-semibold text-text-primary sm:text-lg">
        <span class="text-green">[3]</span> Estimated monthly cost
      </h2>

      <!-- Summary Card -->
      <div class="rounded-lg border border-border bg-bg-card">
        <div class="border-b border-border px-4 py-2 font-mono text-xs text-text-muted">
          <span class="text-green">●●●</span> <span class="ml-2">cost_summary.json</span>
        </div>
        <div class="p-4 sm:p-6">
          <div class="mb-6 grid gap-4 sm:grid-cols-3">
            <div class="rounded-lg border border-border bg-bg-tertiary p-4">
              <p class="font-mono text-xs text-text-muted">Subscription Total</p>
              <p class="mt-1 font-mono text-2xl font-bold text-green" id="subscription-total">$0</p>
              <p class="mt-1 font-mono text-xs text-text-muted">/month</p>
            </div>
            <div class="rounded-lg border border-border bg-bg-tertiary p-4">
              <p class="font-mono text-xs text-text-muted">Token Cost Estimate</p>
              <p class="mt-1 font-mono text-2xl font-bold text-cyan" id="token-total">$0</p>
              <p class="mt-1 font-mono text-xs text-text-muted">based on usage</p>
            </div>
            <div class="rounded-lg border border-green/30 bg-green/5 p-4">
              <p class="font-mono text-xs text-text-muted">Total Estimate</p>
              <p class="mt-1 font-mono text-2xl font-bold text-green" id="grand-total">$0</p>
              <p class="mt-1 font-mono text-xs text-text-muted">per month</p>
            </div>
          </div>

          <!-- Breakdown -->
          <div class="rounded-lg border border-border bg-bg-tertiary">
            <div class="border-b border-border px-3 py-2 font-mono text-xs text-text-muted">
              breakdown by tool
            </div>
            <div class="divide-y divide-border" id="cost-breakdown">
              <div class="px-4 py-3 font-mono text-xs text-text-muted">
                Select tools above to see breakdown
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Scenario Info -->
      <div class="mt-6 rounded-lg border border-border bg-bg-card">
        <div class="border-b border-border px-4 py-2 font-mono text-xs text-text-muted">
          <span class="text-cyan">●●●</span> <span class="ml-2">scenario_info.md</span>
        </div>
        <div class="p-4">
          <div id="scenario-details" class="font-mono text-xs text-text-secondary">
            <p class="text-text-muted">Select a scenario to see details</p>
          </div>
        </div>
      </div>
    </div>

    <div class="green-divider"></div>

    <!-- Tips Section -->
    <div class="rounded-lg border border-border bg-bg-card">
      <div class="border-b border-border px-4 py-2 font-mono text-xs text-text-muted">
        <span class="text-amber">●●●</span> <span class="ml-2">cost_tips.sh</span>
      </div>
      <div class="space-y-0 p-4">
        <div class="group flex items-start gap-3 rounded px-2 py-2 hover:bg-bg-tertiary/50">
          <span class="text-green">$</span>
          <div class="font-mono text-xs">
            <span class="text-text-muted"># Free tier: </span>
            <span class="text-text-secondary">OpenClaw, Gemini CLI, Continue, and Cline are free (bring your own API keys)</span>
          </div>
        </div>
        <div class="group flex items-start gap-3 rounded px-2 py-2 hover:bg-bg-tertiary/50">
          <span class="text-green">$</span>
          <div class="font-mono text-xs">
            <span class="text-text-muted"># BYOK: </span>
            <span class="text-text-secondary">"Bring Your Own Key" tools charge API usage directly — no subscription</span>
          </div>
        </div>
        <div class="group flex items-start gap-3 rounded px-2 py-2 hover:bg-bg-tertiary/50">
          <span class="text-green">$</span>
          <div class="font-mono text-xs">
            <span class="text-text-muted"># GLM Plan: </span>
            <span class="text-text-secondary">$10/mo covers Claude Code, Codex CLI, Cline, Roo Code + 20 more tools</span>
          </div>
        </div>
        <div class="group flex items-start gap-3 rounded px-2 py-2 hover:bg-bg-tertiary/50">
          <span class="text-green">$</span>
          <div class="font-mono text-xs">
            <span class="text-text-muted"># Token costs: </span>
            <span class="text-text-secondary">Estimates based on typical model pricing (~$2-4 per 1M tokens)</span>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // State
  let selectedScenario: string | null = null;
  let selectedTools = new Set<string>();
  
  // Tool pricing data (from server)
  const toolData: Record<string, { free: boolean; subscription: number; perToken: number }> = {};
  document.querySelectorAll('.tool-btn').forEach(btn => {
    const id = btn.getAttribute('data-tool')!;
    toolData[id] = {
      free: btn.getAttribute('data-free') === 'true',
      subscription: parseFloat(btn.getAttribute('data-subscription') || '0'),
      perToken: parseFloat(btn.getAttribute('data-per-token') || '0'),
    };
  });

  // Scenario selection
  document.querySelectorAll('.scenario-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      // Update UI
      document.querySelectorAll('.scenario-btn').forEach(b => {
        b.classList.remove('border-green', 'bg-green/5');
        b.querySelector('.scenario-check')?.classList.add('hidden');
      });
      btn.classList.add('border-green', 'bg-green/5');
      btn.querySelector('.scenario-check')?.classList.remove('hidden');
      
      // Store selection
      selectedScenario = btn.getAttribute('data-scenario');
      
      // Update details
      const tokens = parseInt(btn.getAttribute('data-tokens') || '0');
      const sessions = parseInt(btn.getAttribute('data-sessions') || '0');
      const multiplier = parseInt(btn.getAttribute('data-multiplier') || '1');
      
      const details = document.getElementById('scenario-details');
      if (details) {
        details.innerHTML = `
          <p><span class="text-green">Scenario:</span> <span class="text-text-primary">${btn.querySelector('h3')?.textContent}</span></p>
          <p class="mt-2"><span class="text-cyan">Tokens/month:</span> <span class="text-text-primary">${(tokens / 1_000_000).toFixed(1)}M</span></p>
          <p class="mt-1"><span class="text-cyan">Sessions/month:</span> <span class="text-text-primary">~${sessions}</span></p>
          ${multiplier > 1 ? `<p class="mt-1"><span class="text-amber">Team size:</span> <span class="text-text-primary">${multiplier} developers</span></p>` : ''}
        `;
      }
      
      calculateCosts();
    });
  });

  // Tool selection
  document.querySelectorAll('.tool-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const toolId = btn.getAttribute('data-tool')!;
      
      if (selectedTools.has(toolId)) {
        selectedTools.delete(toolId);
        btn.classList.remove('border-green', 'bg-green/10', 'text-green');
        btn.classList.add('border-border', 'text-text-muted');
      } else {
        selectedTools.add(toolId);
        btn.classList.remove('border-border', 'text-text-muted');
        btn.classList.add('border-green', 'bg-green/10', 'text-green');
      }
      
      calculateCosts();
    });
  });

  // Select all / Clear
  document.getElementById('select-all-tools')?.addEventListener('click', () => {
    document.querySelectorAll('.tool-btn').forEach(btn => {
      const toolId = btn.getAttribute('data-tool')!;
      selectedTools.add(toolId);
      btn.classList.remove('border-border', 'text-text-muted');
      btn.classList.add('border-green', 'bg-green/10', 'text-green');
    });
    calculateCosts();
  });

  document.getElementById('clear-tools')?.addEventListener('click', () => {
    selectedTools.clear();
    document.querySelectorAll('.tool-btn').forEach(btn => {
      btn.classList.remove('border-green', 'bg-green/10', 'text-green');
      btn.classList.add('border-border', 'text-text-muted');
    });
    calculateCosts();
  });

  // Calculate costs
  function calculateCosts() {
    let subscriptionTotal = 0;
    let tokenTotal = 0;
    const breakdown: { tool: string; subscription: number; tokens: number; free: boolean }[] = [];

    // Get scenario tokens
    const scenarioBtn = document.querySelector('.scenario-btn.border-green');
    const tokensPerMonth = scenarioBtn ? parseInt(scenarioBtn.getAttribute('data-tokens') || '2000000') : 2000000;
    const multiplier = scenarioBtn ? parseInt(scenarioBtn.getAttribute('data-multiplier') || '1') : 1;

    // Check for GLM plan (shared subscription for multiple tools)
    const glmTools = ['claude-code', 'codex-cli', 'cline', 'roo-code', 'openclaw'];
    const hasGlmPlan = glmTools.some(t => selectedTools.has(t));
    const glmPrice = 10; // $10/mo

    // If using GLM tools, count subscription once
    if (hasGlmPlan) {
      subscriptionTotal += glmPrice;
    }

    selectedTools.forEach(toolId => {
      const data = toolData[toolId];
      if (!data) return;

      let subCost = 0;
      let tokenCost = 0;

      // Subscription cost (skip if covered by GLM)
      if (!data.free && data.subscription > 0 && !glmTools.includes(toolId)) {
        subCost = data.subscription;
        subscriptionTotal += subCost;
      }

      // Token cost (for BYOK tools)
      if (data.perToken > 0) {
        tokenCost = (tokensPerMonth / 1_000_000) * data.perToken * multiplier;
        tokenTotal += tokenCost;
      }

      breakdown.push({
        tool: toolId.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' '),
        subscription: subCost,
        tokens: tokenCost,
        free: data.free,
      });
    });

    // Update UI
    const subEl = document.getElementById('subscription-total');
    const tokenEl = document.getElementById('token-total');
    const grandEl = document.getElementById('grand-total');
    const breakdownEl = document.getElementById('cost-breakdown');

    if (subEl) subEl.textContent = `$${subscriptionTotal.toFixed(0)}`;
    if (tokenEl) tokenEl.textContent = `$${tokenTotal.toFixed(0)}`;
    if (grandEl) grandEl.textContent = `$${(subscriptionTotal + tokenTotal).toFixed(0)}`;

    // Update breakdown
    if (breakdownEl) {
      if (breakdown.length === 0) {
        breakdownEl.innerHTML = `
          <div class="px-4 py-3 font-mono text-xs text-text-muted">
            Select tools above to see breakdown
          </div>
        `;
      } else {
        breakdownEl.innerHTML = breakdown.map(item => `
          <div class="flex items-center justify-between px-4 py-2 font-mono text-xs">
            <span class="${item.free ? 'text-green' : 'text-text-primary'}">${item.tool}</span>
            <span class="text-text-muted">
              ${item.free ? '<span class="text-green">free</span>' : ''}
              ${item.subscription > 0 ? `<span class="text-amber">$${item.subscription}/mo</span>` : ''}
              ${item.tokens > 0 ? `<span class="text-cyan ml-2">~$${item.tokens.toFixed(0)} tokens</span>` : ''}
              ${!item.free && item.subscription === 0 && item.tokens === 0 ? '<span class="text-text-muted">BYOK</span>' : ''}
            </span>
          </div>
        `).join('');

        // Add GLM note if applicable
        if (hasGlmPlan) {
          breakdownEl.innerHTML += `
            <div class="px-4 py-2 font-mono text-xs text-text-muted border-t border-border">
              <span class="text-green">*</span> GLM Coding Plan ($10/mo) covers: Claude Code, Codex CLI, Cline, Roo Code, OpenClaw + 20 more tools
            </div>
          `;
        }
      }
    }
  }

  // Default: select "Daily" scenario
  document.querySelector('[data-scenario="daily"]')?.dispatchEvent(new Event('click'));
</script>

<style>
  .scenario-btn.border-green {
    border-color: var(--color-green);
    background: rgba(51, 255, 51, 0.05);
  }
  
  .tool-btn.border-green {
    border-color: var(--color-green);
    background: rgba(51, 255, 51, 0.1);
    color: var(--color-green);
  }
</style>
