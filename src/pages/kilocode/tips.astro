---
import KilocodeLayout from "../../layouts/KilocodeLayout.astro";
import "../../styles/cheatsheet-shared.css";
---

<KilocodeLayout
  title="Kilo Code Tips & Tricks — changelogs.info"
  description="Power-user tips, hidden features, and common mistakes for Kilo Code."
  currentPage="tips"
>
  <div class="cs-wrapper">
    <section class="cs-hero">
      <div class="cs-hero__emoji">💡</div>
      <h1 class="kc-headline cs-hero__title">
        Tips &<span class="cs-hero__accent"> Tricks</span>
      </h1>
      <p class="cs-hero__sub">Power-user knowledge for Kilo Code</p>
    </section>

    <div class="cs-grid">
      <div class="cs-two-col">
        <!-- Quick Wins panel -->
        <div class="cs-panel">
          <h2 class="kc-headline cs-panel__title cs-panel__title--accent">⚡ Quick Wins</h2>
          <div class="cs-item-list">
            <div class="cs-item">
              <div class="cs-item__title">Select code before starting</div>
              <p class="cs-item__desc">That selection becomes your context anchor for the task.</p>
            </div>
            <div class="cs-item">
              <div class="cs-item__title">Task history is persistent</div>
              <p class="cs-item__desc">Reopen old tasks to continue or reference previous work.</p>
            </div>
            <div class="cs-item">
              <div class="cs-item__title">Watch the token budget</div>
              <p class="cs-item__desc">When it gets low, start a new task rather than continuing.</p>
            </div>
            <div class="cs-item">
              <div class="cs-item__title">Set up MCP tools first</div>
              <p class="cs-item__desc">They multiply what Kilo can do for your specific stack.</p>
            </div>
            <div class="cs-item">
              <div class="cs-item__title">Multiple concurrent tasks</div>
              <p class="cs-item__desc">Run a refactor in one task while reviewing docs in another.</p>
            </div>
          </div>
        </div>

        <!-- Hidden Features panel -->
        <div class="cs-panel cs-panel--accent">
          <h2 class="kc-headline cs-panel__title">🔮 Hidden Features</h2>
          <div class="cs-item-list">
            <div class="cs-item">
              <div class="cs-item__title">Checkpoint saves</div>
              <p class="cs-item__desc">Let you revert Kilo edits cleanly — always use before risky operations.</p>
            </div>
            <div class="cs-item">
              <div class="cs-item__title">Workspace settings as context</div>
              <p class="cs-item__desc">Kilo reads VS Code workspace settings for additional context.</p>
            </div>
            <div class="cs-item">
              <div class="cs-item__title">Scoped auto-approve</div>
              <p class="cs-item__desc">Restrict auto-approve to specific file types/patterns in settings.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Common Mistakes panel -->
      <div class="cs-panel cs-panel--warning">
        <h2 class="kc-headline cs-panel__title">⚠ Common Mistakes</h2>
        <div class="cs-gotcha-list">
          <div class="cs-gotcha-item">
            <div class="cs-gotcha-item__title">Not selecting relevant code</div>
            <p class="cs-gotcha-item__desc">Kilo guesses your intent without it — results suffer.</p>
          </div>
          <div class="cs-gotcha-item">
            <div class="cs-gotcha-item__title">Auto-approve on architecture changes</div>
            <p class="cs-gotcha-item__desc">Dangerous in unfamiliar codebases.</p>
          </div>
          <div class="cs-gotcha-item">
            <div class="cs-gotcha-item__title">Ignoring token budget indicator</div>
            <p class="cs-gotcha-item__desc">Continuing past the limit degrades response quality.</p>
          </div>
        </div>
      </div>

      <!-- Workflow Combos panel -->
      <div class="cs-panel cs-panel--surface">
        <h2 class="kc-headline cs-panel__title">🔗 Workflow Combos</h2>
        <div class="cs-item-list">
          <div class="cs-item">
            <div class="cs-item__title">Explain-then-edit</div>
            <p class="cs-item__desc">First explain the code, then modify based on understanding. Use Cmd+Shift+P → "Explain Selection" first, then start a new task for the edit.</p>
          </div>
          <div class="cs-item">
            <div class="cs-item__title">Multi-task workflow</div>
            <p class="cs-item__desc">One task for research/planning, another for implementation. Keep tasks focused and single-purpose.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</KilocodeLayout>
