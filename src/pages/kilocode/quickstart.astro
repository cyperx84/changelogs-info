---
import KilocodeLayout from "../../layouts/KilocodeLayout.astro";
import "../../styles/cheatsheet-shared.css";
---

<KilocodeLayout
  title="Kilo Code Quickstart — changelogs.info"
  description="Get up and running with Kilo Code in 10 minutes. Install, first run, first real task."
  currentPage="quickstart"
>
  <div class="cs-wrapper">
    <section class="cs-hero">
      <div class="cs-hero__emoji">🚀</div>
      <h1 class="kc-headline cs-hero__title">
        Quick<span class="cs-hero__accent">Start</span>
      </h1>
      <p class="cs-hero__sub">Up and running in 10 minutes</p>
      <p class="cs-hero__meta">VS Code extension for AI-assisted coding with MCP tool support and task history</p>
    </section>

    <div class="cs-grid">

      <div class="cs-panel">
        <h2 class="kc-headline cs-panel__title">Prerequisites</h2>
        <div class="cs-item-list">
          <div class="cs-item">
            <div class="cs-item__title">VS Code 1.85+</div>
            <p class="cs-item__desc">Required editor. Check with <code>code --version</code>.</p>
          </div>
        </div>
      </div>

      <div class="cs-panel cs-panel--accent">
        <h2 class="kc-headline cs-panel__title">Install</h2>
        <div class="cs-item-list">
          <div class="cs-item">
            <div class="cs-item__title">Via VS Code Extensions</div>
            <p class="cs-item__desc">Open Extensions sidebar → search "Kilo Code" → Install.</p>
          </div>
        </div>
      </div>

      <div class="cs-panel">
        <h2 class="kc-headline cs-panel__title">First Run</h2>
        <div class="cs-item-list">
          <div class="cs-item">
            <div class="cs-item__title">Open the command palette</div>
            <p class="cs-item__desc">Launch Kilo Code from the command palette.</p>
            <div class="cs-item__cmd"><span class="cs-step-cmd__prompt">⌘</span> Cmd+Shift+P → "Kilo Code: New Task"</div>
          </div>
          <div class="cs-item">
            <div class="cs-item__title">Type what you want</div>
            <p class="cs-item__desc">Describe the task in natural language. Kilo Code reads your workspace context automatically.</p>
          </div>
        </div>
      </div>

      <div class="cs-panel cs-panel--accent">
        <h2 class="kc-headline cs-panel__title">⚡ First Real Task</h2>
        <div class="cs-item-list">
          <div class="cs-item">
            <div class="cs-item__title">Explain a selection</div>
            <p class="cs-item__desc">Select a function in the editor, then use the command palette.</p>
            <div class="cs-item__cmd"><span class="cs-step-cmd__prompt">⌘</span> Cmd+Shift+P → "Kilo Code: Explain Selection"</div>
          </div>
          <div class="cs-item">
            <div class="cs-item__title">Set up MCP tools</div>
            <p class="cs-item__desc">Connect external tools via Model Context Protocol for richer capabilities.</p>
          </div>
          <div class="cs-item">
            <div class="cs-item__title">Enable auto-approve</div>
            <p class="cs-item__desc">Skip confirmation for routine edits. Configure in Kilo Code settings.</p>
          </div>
        </div>
      </div>

      <div class="cs-panel cs-panel--surface">
        <h2 class="kc-headline cs-panel__title">What Next?</h2>
        <div class="cs-flag-grid">
          <div class="cs-flag-item">
            <a href="/kilocode/cheatsheet/" class="cs-flag-item__key" style="text-decoration:none;">Cheat Sheet →</a>
            <div class="cs-flag-item__desc">Daily commands and power moves</div>
          </div>
          <div class="cs-flag-item">
            <a href="/kilocode/changelog/" class="cs-flag-item__key" style="text-decoration:none;">Changelog →</a>
            <div class="cs-flag-item__desc">Latest updates and release notes</div>
          </div>
          <div class="cs-flag-item">
            <a href="/kilocode/configs/" class="cs-flag-item__key" style="text-decoration:none;">Configs →</a>
            <div class="cs-flag-item__desc">Configuration reference and examples</div>
          </div>
        </div>
      </div>

    </div>
  </div>
</KilocodeLayout>
