---
import OpenCodeLayout from "../../layouts/OpenCodeLayout.astro";
import { getToolReleases, formatDate } from "../../lib/releases";

const data = await getToolReleases("opencode");
const releases = data?.releases || [];
const stableReleases = releases.filter((r) => !r.prerelease);
const latestStable = stableReleases[0] || releases[0];
const latestThree = releases.slice(0, 3);

function getTldr(body: string): string {
  if (!body) return "No summary available.";
  const lines = body.split("\n").filter((l) => l.trim() && !l.includes("<!--"));
  const bullets = lines.filter((l) => /^[-•*]/.test(l.trim()));
  if (bullets.length === 0) return body.slice(0, 120) + "…";
  return bullets.slice(0, 2).map((l) => l.replace(/^[-•*]\s*/, "").replace(/`([^`]+)`/g, "$1")).join(" · ") + ".";
}
---

<OpenCodeLayout
  title="OpenCode — changelogs.info"
  description="Open source AI coding agent. Multi-session, 75+ LLM providers, LSP support. Track every release."
>
  <!-- Hero -->
  <section class="op-hero-section" style="max-width: 1280px; margin: 0 auto; padding: 4rem 1.5rem 2rem; display: grid; grid-template-columns: 1fr auto; gap: 3rem; align-items: center;" class="op-hero-grid">
    <div>
      <div style="display: inline-flex; align-items: center; gap: 0.5rem; font-family: var(--op-font-mono); font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--op-text-muted); border: 2px solid var(--op-border-dim); padding: 0.3rem 0.75rem; margin-bottom: 1.5rem;">
        <span class="op-pulse-dot" style="width: 7px; height: 7px; background: var(--op-primary); border-radius: 50%; display: inline-block;"></span>
        TRACKING {releases.length} RELEASES
      </div>

      <h1 class="op-hero-title" style="font-family: var(--op-font-headline); font-size: clamp(3rem, 8vw, 6rem); font-weight: 900; text-transform: uppercase; letter-spacing: -0.03em; line-height: 0.92; margin: 0 0 1.5rem; color: var(--op-text);">
        The open source<br />
        <span style="color: var(--op-primary-bright);">AI coding</span><br />
        agent
      </h1>

      <p style="font-family: var(--op-font-body); font-size: 1.1rem; color: var(--op-text-dim); line-height: 1.6; max-width: 36rem; margin: 0 0 2rem;">
        Multi-session, 75+ LLM providers, LSP support, GitHub Copilot login, share links, and a beautiful TUI. Run it in the terminal, IDE, or desktop.
      </p>

      <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
        <a
          href="/opencode/changelog/"
          class="op-cta-btn"
          style="background: var(--op-primary); color: white; font-family: var(--op-font-mono); font-weight: 900; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.08em; padding: 0.85rem 1.75rem; text-decoration: none; box-shadow: var(--op-shadow); display: inline-block;"
        >
          View Changelog ↗
        </a>
        <a
          href="https://github.com/sst/opencode"
          target="_blank"
          rel="noopener noreferrer"
          class="op-cta-btn"
          style="background: transparent; color: var(--op-text); font-family: var(--op-font-mono); font-weight: 700; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.08em; padding: 0.85rem 1.75rem; text-decoration: none; border: 4px solid var(--op-border); box-shadow: var(--op-shadow); display: inline-block;"
        >
          GitHub ↗
        </a>
      </div>
    </div>

    <!-- Terminal card -->
    <div class="op-terminal-card" style="background: var(--op-bg-card); border: 4px solid var(--op-border); box-shadow: var(--op-shadow); padding: 1.5rem; width: 340px; max-width: 100%;">
      <div style="font-family: var(--op-font-mono); font-size: 0.65rem; color: var(--op-text-muted); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem;">
        <span style="color: var(--op-primary);">○</span> TERMINAL
      </div>
      <div style="font-family: var(--op-font-mono); font-size: 0.82rem; line-height: 1.8; color: var(--op-text);">
        <div><span style="color: var(--op-text-muted);">$</span> <span style="color: var(--op-primary-bright);">opencode</span></div>
        <div style="color: var(--op-text-dim); padding-left: 1rem;">┌ opencode v{latestStable?.version || "…"}</div>
        <div style="color: var(--op-text-dim); padding-left: 1rem;">│ multi-session TUI ready</div>
        <div style="color: var(--op-text-dim); padding-left: 1rem;">└ 75+ providers loaded</div>
        <div style="margin-top: 0.5rem;"><span style="color: var(--op-text-muted);">$</span> <span style="color: var(--op-primary-bright);">opencode --help</span></div>
        <div style="margin-top: 0.5rem;"><span style="color: var(--op-text-muted);">$</span> <span style="color: var(--op-primary-bright);">opencode --model anthropic/claude-sonnet-4-5</span></div>
        <div style="color: var(--op-text-muted); padding-left: 1rem;">switched model</div>
        <span class="op-cursor" style="color: var(--op-primary);">█</span>
      </div>
    </div>
  </section>

  <!-- Stats bar -->
  <div class="op-section-reveal" style="background: var(--op-bg-surface); border-top: 4px solid var(--op-border-dim); border-bottom: 4px solid var(--op-border-dim); margin: 0 0 4rem;">
    <div style="max-width: 1280px; margin: 0 auto; padding: 0 1.5rem; display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));">
      {[
        { label: "Total Releases", value: String(releases.length) },
        { label: "Stable", value: String(stableReleases.length) },
        { label: "Latest", value: latestStable?.version || "—" },
        { label: "Providers", value: "75+" },
        { label: "Sessions", value: "Multi" },
        { label: "LSP", value: "✓" },
      ].map((stat) => (
        <div class="op-stats-cell" style="padding: 1.25rem 1rem; border-right: 2px solid var(--op-border-dim); text-align: center;">
          <div style="font-family: var(--op-font-mono); font-size: 1.4rem; font-weight: 900; color: var(--op-primary-bright);">{stat.value}</div>
          <div style="font-family: var(--op-font-mono); font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--op-text-muted); margin-top: 0.25rem;">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>

  <!-- Latest Release TL;DR -->
  {latestStable && (
    <section style="max-width: 1280px; margin: 0 auto 4rem; padding: 0 1.5rem;">
      <div style="font-family: var(--op-font-mono); font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.15em; color: var(--op-primary); margin-bottom: 1rem;">
        ▸ LATEST RELEASE
      </div>
      <div style="border: 4px solid var(--op-border); background: var(--op-bg-card); padding: 2rem; box-shadow: var(--op-shadow);">
        <div style="display: flex; flex-wrap: wrap; align-items: baseline; gap: 1rem; margin-bottom: 1rem;">
          <span style="font-family: var(--op-font-mono); font-size: 2.5rem; font-weight: 900; font-style: italic; letter-spacing: -0.02em; color: var(--op-text);">{latestStable.version}</span>
          <span style="font-family: var(--op-font-mono); font-size: 0.75rem; font-weight: 700; text-transform: uppercase; color: var(--op-text-muted); letter-spacing: 0.08em;">{formatDate(latestStable.date)}</span>
        </div>
        <p style="font-family: var(--op-font-body); font-size: 0.95rem; color: var(--op-text-dim); line-height: 1.7; margin: 0 0 1rem; max-width: 56rem;">
          {getTldr(latestStable.body)}
        </p>
        <a href="/opencode/changelog/" style="font-family: var(--op-font-mono); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--op-primary-bright); text-decoration: none; border-bottom: 2px solid var(--op-primary); padding-bottom: 1px; transition: color 150ms;">
          Read full changelog →
        </a>
      </div>
    </section>
  )}

  <!-- Cheatsheet quick reference -->
  <section style="max-width: 1280px; margin: 0 auto 4rem; padding: 0 1.5rem;">
    <div style="font-family: var(--op-font-mono); font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.15em; color: var(--op-primary); margin-bottom: 1.5rem;">
      ▸ QUICK REFERENCE
    </div>
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.25rem;">
      {[
        { cmd: "opencode", desc: "Start the interactive TUI" },
        { cmd: "opencode --help", desc: "Show all commands and flags" },
        { cmd: "opencode --model <id>", desc: "Switch LLM provider/model" },
        { cmd: "opencode --share", desc: "Generate a shareable session link" },
        { cmd: "opencode auth github", desc: "Login with GitHub Copilot" },
        { cmd: "opencode session list", desc: "List all saved sessions" },
        { cmd: "opencode --headless", desc: "Run without TUI (scripting mode)" },
        { cmd: "opencode mcp add <url>", desc: "Add an MCP server" },
      ].map((item) => (
        <div style="background: var(--op-bg-surface); border: 2px solid var(--op-border-dim); padding: 1rem;">
          <code style="font-family: var(--op-font-mono); font-size: 0.78rem; color: var(--op-primary-bright); font-weight: 700; display: block; margin-bottom: 0.35rem;">{item.cmd}</code>
          <span style="font-family: var(--op-font-body); font-size: 0.75rem; color: var(--op-text-dim);">{item.desc}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Quick links -->
  <section style="max-width: 1280px; margin: 0 auto 6rem; padding: 0 1.5rem;">
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.25rem;">
      {[
        { label: "Full Changelog", href: "/opencode/changelog/", desc: "Every release in detail", icon: "⌘" },
        { label: "Cheat Sheet", href: "/opencode/cheatsheet/", desc: "Commands & workflows", icon: "≡" },
        { label: "All Releases", href: "/opencode/releases/", desc: "Version grid view", icon: "◎" },
        { label: "RSS Feed", href: "/feed/all.xml", desc: "Subscribe to updates", icon: "⟳" },
      ].map((link) => (
        <a
          href={link.href}
          class="op-quick-link"
          style="display: block; border: 4px solid var(--op-border-dim); background: var(--op-bg-card); padding: 1.5rem; text-decoration: none; box-shadow: var(--op-shadow-sm);"
        >
          <div style="font-family: var(--op-font-mono); font-size: 1.25rem; color: var(--op-primary); margin-bottom: 0.5rem;">{link.icon}</div>
          <div style="font-family: var(--op-font-mono); font-size: 0.85rem; font-weight: 900; text-transform: uppercase; color: var(--op-text); margin-bottom: 0.25rem;">{link.label}</div>
          <div style="font-family: var(--op-font-body); font-size: 0.75rem; color: var(--op-text-muted);">{link.desc}</div>
        </a>
      ))}
    </div>
  </section>
</OpenCodeLayout>
