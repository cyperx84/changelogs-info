---
import HermesLayout from "../../layouts/HermesLayout.astro";
import { getToolReleases, formatDate } from "../../lib/releases";

const data = await getToolReleases("hermes-agent");
const releases = data?.releases || [];
const stableReleases = releases.filter((r) => !r.prerelease);
const latestStable = stableReleases[0] || releases[0];

function getTldr(body: string): string {
  if (!body) return "No summary available.";
  const lines = body.split("\n").filter((l) => l.trim() && !l.includes("<!--"));
  const bullets = lines.filter((l) => /^[-•*]/.test(l.trim()));
  if (bullets.length === 0) return body.slice(0, 120) + "…";
  return bullets.slice(0, 2).map((l) => l.replace(/^[-•*]\s*/, "").replace(/`([^`]+)`/g, "$1")).join(" · ") + ".";
}
---

<HermesLayout
  title="Hermes Agent — changelogs.info"
  description="The agent that grows with you. Self-improving AI with persistent memory, 40+ tools, and 6 platforms."
>
  <!-- Hero -->
  <section class="ha-hero-section" style="max-width: 1280px; margin: 0 auto; padding: 4rem 1.5rem 2rem; display: grid; grid-template-columns: 1fr auto; gap: 3rem; align-items: center;" class="ha-hero-grid">
    <div>
      <div style="display: inline-flex; align-items: center; gap: 0.5rem; font-family: var(--ha-font-mono); font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--ha-text-muted); border: 2px solid var(--ha-border-dim); padding: 0.3rem 0.75rem; margin-bottom: 1.5rem;">
        <span class="ha-pulse-dot" style="width: 7px; height: 7px; background: var(--ha-primary); border-radius: 50%; display: inline-block;"></span>
        TRACKING {releases.length} RELEASES
      </div>

      <h1 class="ha-hero-title" style="font-family: var(--ha-font-headline); font-size: clamp(3rem, 8vw, 6rem); font-weight: 900; text-transform: uppercase; letter-spacing: -0.03em; line-height: 0.92; margin: 0 0 1.5rem; color: var(--ha-text);">
        The agent that<br />
        <span style="color: var(--ha-primary-bright);">grows</span> with you
      </h1>

      <p style="font-family: var(--ha-font-body); font-size: 1.1rem; color: var(--ha-text-dim); line-height: 1.6; max-width: 36rem; margin: 0 0 2rem;">
        Self-improving AI agent with persistent memory and a learning loop. Runs on Telegram, Discord, CLI, WhatsApp, Signal, and Slack. 40+ built-in tools, cron scheduling, and autonomous subagents.
      </p>

      <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
        <a
          href="/hermes-agent/changelog/"
          class="ha-cta-btn"
          style="background: var(--ha-primary); color: white; font-family: var(--ha-font-mono); font-weight: 900; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.08em; padding: 0.85rem 1.75rem; text-decoration: none; box-shadow: var(--ha-shadow); display: inline-block;"
        >
          View Changelog ↗
        </a>
        <a
          href="https://github.com/NousResearch/hermes-agent"
          target="_blank"
          rel="noopener noreferrer"
          class="ha-cta-btn"
          style="background: transparent; color: var(--ha-text); font-family: var(--ha-font-mono); font-weight: 700; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.08em; padding: 0.85rem 1.75rem; text-decoration: none; border: 4px solid var(--ha-border); box-shadow: var(--ha-shadow); display: inline-block;"
        >
          GitHub ↗
        </a>
      </div>
    </div>

    <!-- Terminal card -->
    <div class="ha-terminal-card" style="background: var(--ha-bg-card); border: 4px solid var(--ha-border); box-shadow: var(--ha-shadow); padding: 1.5rem; width: 340px; max-width: 100%;">
      <div style="font-family: var(--ha-font-mono); font-size: 0.65rem; color: var(--ha-text-muted); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem;">
        <span style="color: var(--ha-primary);">⚡</span> TERMINAL
      </div>
      <div style="font-family: var(--ha-font-mono); font-size: 0.82rem; line-height: 1.8; color: var(--ha-text);">
        <div><span style="color: var(--ha-text-muted);">$</span> <span style="color: var(--ha-primary-bright);">hermes</span></div>
        <div style="color: var(--ha-text-dim); padding-left: 1rem;">⚡ Hermes Agent starting...</div>
        <div style="color: var(--ha-text-dim); padding-left: 1rem;">🧠 Loading memory...</div>
        <div style="color: var(--ha-text-dim); padding-left: 1rem;">✓ 40 tools ready</div>
        <div style="margin-top: 0.5rem;"><span style="color: var(--ha-text-muted);">$</span> <span style="color: var(--ha-primary-bright);">hermes setup</span></div>
        <div style="color: var(--ha-text-dim); padding-left: 1rem;">→ API key wizard</div>
        <div style="margin-top: 0.5rem;"><span style="color: var(--ha-text-muted);">$</span> <span style="color: var(--ha-primary-bright);">hermes gateway</span></div>
        <div style="color: var(--ha-text-dim); padding-left: 1rem;">→ multi-platform bridge</div>
        <span class="ha-cursor" style="color: var(--ha-primary);">█</span>
      </div>
    </div>
  </section>

  <!-- Stats bar -->
  <div class="ha-section-reveal" style="background: var(--ha-bg-surface); border-top: 4px solid var(--ha-border-dim); border-bottom: 4px solid var(--ha-border-dim); margin: 0 0 4rem;">
    <div style="max-width: 1280px; margin: 0 auto; padding: 0 1.5rem; display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));">
      {[
        { label: "Total Releases", value: String(releases.length || "—") },
        { label: "Built-in Tools", value: "40+" },
        { label: "Platforms", value: "6" },
        { label: "Memory", value: "∞" },
        { label: "Learning", value: "Loop" },
        { label: "Subagents", value: "Auto" },
      ].map((stat) => (
        <div class="ha-stats-cell" style="padding: 1.25rem 1rem; border-right: 2px solid var(--ha-border-dim); text-align: center;">
          <div style="font-family: var(--ha-font-mono); font-size: 1.4rem; font-weight: 900; color: var(--ha-primary-bright);">{stat.value}</div>
          <div style="font-family: var(--ha-font-mono); font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--ha-text-muted); margin-top: 0.25rem;">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>

  <!-- Latest Release -->
  {latestStable && (
    <section style="max-width: 1280px; margin: 0 auto 4rem; padding: 0 1.5rem;">
      <div style="font-family: var(--ha-font-mono); font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.15em; color: var(--ha-primary); margin-bottom: 1rem;">
        ▸ LATEST RELEASE
      </div>
      <div style="border: 4px solid var(--ha-border); background: var(--ha-bg-card); padding: 2rem; box-shadow: var(--ha-shadow);">
        <div style="display: flex; flex-wrap: wrap; align-items: baseline; gap: 1rem; margin-bottom: 1rem;">
          <span style="font-family: var(--ha-font-mono); font-size: 2.5rem; font-weight: 900; font-style: italic; letter-spacing: -0.02em; color: var(--ha-text);">{latestStable.version}</span>
          <span style="font-family: var(--ha-font-mono); font-size: 0.75rem; font-weight: 700; text-transform: uppercase; color: var(--ha-text-muted); letter-spacing: 0.08em;">{formatDate(latestStable.date)}</span>
        </div>
        <p style="font-family: var(--ha-font-body); font-size: 0.95rem; color: var(--ha-text-dim); line-height: 1.7; margin: 0 0 1rem; max-width: 56rem;">
          {getTldr(latestStable.body)}
        </p>
        <a href="/hermes-agent/changelog/" style="font-family: var(--ha-font-mono); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--ha-primary-bright); text-decoration: none; border-bottom: 2px solid var(--ha-primary); padding-bottom: 1px;">
          Read full changelog →
        </a>
      </div>
    </section>
  )}

  <!-- Cheatsheet quick reference -->
  <section style="max-width: 1280px; margin: 0 auto 4rem; padding: 0 1.5rem;">
    <div style="font-family: var(--ha-font-mono); font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.15em; color: var(--ha-primary); margin-bottom: 1.5rem;">
      ▸ QUICK REFERENCE
    </div>
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.25rem;">
      {[
        { cmd: "curl -fsSL https://hermes.ai/install | sh", desc: "One-line install script" },
        { cmd: "hermes setup", desc: "Interactive setup wizard — API keys, platforms" },
        { cmd: "hermes", desc: "Launch the agent interactively" },
        { cmd: "hermes model", desc: "Switch the underlying LLM" },
        { cmd: "hermes gateway", desc: "Start multi-platform bridge (Telegram, Discord, etc.)" },
        { cmd: "hermes update", desc: "Update Hermes to the latest version" },
        { cmd: "hermes memory show", desc: "Inspect persistent memory entries" },
        { cmd: "hermes skill create", desc: "Create a new learnable skill" },
        { cmd: "hermes cron add", desc: "Schedule a recurring task" },
        { cmd: "hermes agent spawn", desc: "Launch an autonomous subagent" },
      ].map((item) => (
        <div style="background: var(--ha-bg-surface); border: 2px solid var(--ha-border-dim); padding: 1rem;">
          <code style="font-family: var(--ha-font-mono); font-size: 0.72rem; color: var(--ha-primary-bright); font-weight: 700; display: block; margin-bottom: 0.35rem; word-break: break-all;">{item.cmd}</code>
          <span style="font-family: var(--ha-font-body); font-size: 0.75rem; color: var(--ha-text-dim);">{item.desc}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Platforms -->
  <section style="max-width: 1280px; margin: 0 auto 4rem; padding: 0 1.5rem;">
    <div style="font-family: var(--ha-font-mono); font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.15em; color: var(--ha-primary); margin-bottom: 1.5rem;">
      ▸ SUPPORTED PLATFORMS
    </div>
    <div style="display: flex; flex-wrap: wrap; gap: 1rem;">
      {["Telegram", "Discord", "CLI", "WhatsApp", "Signal", "Slack"].map((p) => (
        <span style="font-family: var(--ha-font-mono); font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; padding: 0.5rem 1.25rem; border: 3px solid var(--ha-primary); color: var(--ha-primary-bright);">
          {p}
        </span>
      ))}
    </div>
  </section>

  <!-- Quick links -->
  <section style="max-width: 1280px; margin: 0 auto 6rem; padding: 0 1.5rem;">
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.25rem;">
      {[
        { label: "Full Changelog", href: "/hermes-agent/changelog/", desc: "Every release in detail", icon: "⌘" },
        { label: "Cheat Sheet", href: "/hermes-agent/cheatsheet/", desc: "Commands & workflows", icon: "≡" },
        { label: "All Releases", href: "/hermes-agent/releases/", desc: "Version grid view", icon: "◎" },
        { label: "RSS Feed", href: "/feed/all.xml", desc: "Subscribe to updates", icon: "⟳" },
      ].map((link) => (
        <a
          href={link.href}
          class="ha-quick-link"
          style="display: block; border: 4px solid var(--ha-border-dim); background: var(--ha-bg-card); padding: 1.5rem; text-decoration: none; box-shadow: var(--ha-shadow-sm);"
        >
          <div style="font-family: var(--ha-font-mono); font-size: 1.25rem; color: var(--ha-primary); margin-bottom: 0.5rem;">{link.icon}</div>
          <div style="font-family: var(--ha-font-mono); font-size: 0.85rem; font-weight: 900; text-transform: uppercase; color: var(--ha-text); margin-bottom: 0.25rem;">{link.label}</div>
          <div style="font-family: var(--ha-font-body); font-size: 0.75rem; color: var(--ha-text-muted);">{link.desc}</div>
        </a>
      ))}
    </div>
  </section>
</HermesLayout>
