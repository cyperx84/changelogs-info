---
import HermesLayout from "../../layouts/HermesLayout.astro";
import "../../styles/cheatsheet-shared.css";
---

<HermesLayout
  title="Hermes Agent Quickstart — changelogs.info"
  description="Get up and running with Hermes Agent in 10 minutes. Install, first run, first real task."
  currentPage="quickstart"
>
  <div class="cs-wrapper">
    <section class="cs-hero">
      <div class="cs-hero__emoji">🚀</div>
      <h1 class="ha-headline cs-hero__title">
        Quick<span class="cs-hero__accent">Start</span>
      </h1>
      <p class="cs-hero__sub">Up and running in 10 minutes</p>
      <p class="cs-hero__meta">Autonomous multi-step coding agent with tool plugins and workflow planning</p>
    </section>

    <div class="cs-grid">

      <div class="cs-panel">
        <h2 class="ha-headline cs-panel__title">Prerequisites</h2>
        <div class="cs-item-list">
          <div class="cs-item">
            <div class="cs-item__title">Node.js 18+</div>
            <p class="cs-item__desc">Required runtime. Check with <code>node -v</code>.</p>
          </div>
          <div class="cs-item">
            <div class="cs-item__title">API key for your chosen model</div>
            <p class="cs-item__desc">Hermes supports multiple providers. Export the key for whichever model you pick.</p>
          </div>
        </div>
      </div>

      <div class="cs-panel cs-panel--accent">
        <h2 class="ha-headline cs-panel__title">Install</h2>
        <div class="cs-item-list">
          <div class="cs-item">
            <div class="cs-item__title">Via npm</div>
            <div class="cs-item__cmd"><span class="cs-step-cmd__prompt">$</span> npm install -g hermes-agent</div>
          </div>
        </div>
      </div>

      <div class="cs-panel">
        <h2 class="ha-headline cs-panel__title">First Run</h2>
        <div class="cs-item-list">
          <div class="cs-item">
            <div class="cs-item__title">Initialize config</div>
            <p class="cs-item__desc">Creates hermes.config.json with sensible defaults.</p>
            <div class="cs-item__cmd"><span class="cs-step-cmd__prompt">$</span> hermes init</div>
          </div>
          <div class="cs-item">
            <div class="cs-item__title">Ask a question</div>
            <p class="cs-item__desc">Quick sanity check that everything is wired up.</p>
            <div class="cs-item__cmd"><span class="cs-step-cmd__prompt">$</span> hermes "what does this codebase do"</div>
          </div>
        </div>
      </div>

      <div class="cs-panel cs-panel--accent">
        <h2 class="ha-headline cs-panel__title">⚡ First Real Task</h2>
        <div class="cs-item-list">
          <div class="cs-item">
            <div class="cs-item__title">Dry-run a code change</div>
            <p class="cs-item__desc">Preview what Hermes would do before it touches files.</p>
            <div class="cs-item__cmd"><span class="cs-step-cmd__prompt">$</span> hermes "write unit tests for src/utils/auth.ts" --dry-run</div>
          </div>
          <div class="cs-item">
            <div class="cs-item__title">Configure hermes.config.json</div>
            <p class="cs-item__desc">Set model, temperature, tool permissions, and default behaviors.</p>
          </div>
          <div class="cs-item">
            <div class="cs-item__title">Set up tool integrations</div>
            <p class="cs-item__desc">Add plugins for linting, testing, or custom scripts.</p>
          </div>
          <div class="cs-item">
            <div class="cs-item__title">Try YAML workflow plans</div>
            <p class="cs-item__desc">Define multi-step workflows as YAML and let Hermes execute them sequentially.</p>
          </div>
        </div>
      </div>

      <div class="cs-panel cs-panel--surface">
        <h2 class="ha-headline cs-panel__title">What Next?</h2>
        <div class="cs-flag-grid">
          <div class="cs-flag-item">
            <a href="/hermes-agent/cheatsheet/" class="cs-flag-item__key" style="text-decoration:none;">Cheat Sheet →</a>
            <div class="cs-flag-item__desc">Daily commands and power moves</div>
          </div>
          <div class="cs-flag-item">
            <a href="/hermes-agent/changelog/" class="cs-flag-item__key" style="text-decoration:none;">Changelog →</a>
            <div class="cs-flag-item__desc">Latest updates and release notes</div>
          </div>
          <div class="cs-flag-item">
            <a href="/hermes-agent/configs/" class="cs-flag-item__key" style="text-decoration:none;">Configs →</a>
            <div class="cs-flag-item__desc">Configuration reference and examples</div>
          </div>
        </div>
      </div>

    </div>
  </div>
</HermesLayout>
