---
import HermesLayout from "../../layouts/HermesLayout.astro";
import "../../styles/guide-shared.css";
import "../../styles/cheatsheet-shared.css";
import { readFileSync } from "node:fs";
import { join } from "node:path";
import { getToolReleases, formatDate } from "../../lib/releases";

let cs: any = {};
try {
  const raw = readFileSync(join(process.cwd(), "src/content/cheatsheets-json/hermes-agent.json"), "utf-8");
  cs = JSON.parse(raw);
} catch {}

const cliFlags = cs.cliFlags || [];
const slashCommands = cs.slashCommands || [];
const dailyWorkflows = cs.dailyWorkflows || [];
const powerMoves = cs.powerMoves || [];

const data = await getToolReleases("hermes-agent");
const releases = (data?.releases || []).slice(0, 8);
const latestRelease = data?.releases?.[0] || null;
function isBreaking(body: string = "") { return body.toLowerCase().includes("breaking"); }
---

<HermesLayout
  title="Hermes Agent Guide — Getting Started, Tips, Reference"
  description="Everything you need for Hermes Agent: install guide, power tips, command reference, and latest releases."
  currentPage="guide"
>
  <div class="guide-wrapper">

    <nav class="guide-toc" aria-label="Guide sections">
      <span class="guide-toc__label">Jump to</span>
      <a href="#getting-started" class="guide-toc__link">Getting Started</a>
      <a href="#power-tips" class="guide-toc__link">Power Tips</a>
      <a href="#reference" class="guide-toc__link">Reference</a>
    </nav>

    <!-- ══ 1: GETTING STARTED ══ -->
    <section class="guide-hero" id="getting-started">
      <img class="guide-hero__img" src="/images/guides/hermes-agent-hero.png" alt="Hermes Agent" />
      <div class="guide-hero__content">
        <h2 class="guide-hero__title">Hermes Agent</h2>
        <div class="guide-hero__body">
          <p>
            Hermes is the messenger — a terminal AI agent built around the idea that the hardest part of agentic AI isn't the intelligence, it's the delivery. Getting your AI's output to the right place, at the right time, in the right format. Hermes handles the plumbing so you can focus on the actual task.
          </p>
          <p>
            It's a project-scoped AI agent. You initialize it in your repo with <code>hermes init</code>, configure your stack and constraints in <code>hermes.config.json</code>, and then run tasks against it. The config file is what makes it smart — without it, you're just running a generic AI. With it, Hermes knows your architecture, your conventions, what files to touch, and what to leave alone.
          </p>
          <p>
            The <strong>dry-run habit</strong> is the most important thing to internalize early. Hermes is designed for autonomous execution, which means it will actually make changes to your files. The <code>--dry-run</code> flag gives you a full execution plan preview before anything happens. Review the plan, tweak your task description if needed, then run for real. This loop is fast and it saves you from messy reverts.
          </p>
          <p>
            Model flexibility is a first-class feature. Hermes works with Anthropic Claude, OpenAI, or any OpenAI-compatible provider — including local models via Ollama. You pick the model in config, not in the tool. That means you can swap without relearning the workflow.
          </p>
          <p>
            Who's it for? Engineers who want a reliable, predictable AI agent they can trust with real tasks. Teams who need AI tooling that respects project constraints instead of hallucinating imports and patterns that don't exist. Anyone who's been burned by AI agents going off-script and wants a tool that shows you the plan before executing it.
          </p>
        </div>
      </div>
    </section>

    {latestRelease && (
      <div class="guide-latest">
        <div class="guide-latest__header">
          <span class="guide-latest__version">v{latestRelease.version}</span>
          {latestRelease.name && <span class="guide-latest__name">{latestRelease.name}</span>}
          <span class="guide-latest__date">{formatDate(latestRelease.date)}</span>
        </div>
        <div class="guide-latest__body">{latestRelease.body || "No release notes available."}</div>
        {latestRelease.url && <a href={latestRelease.url} target="_blank" rel="noopener noreferrer" class="guide-latest__link">View on GitHub ↗</a>}
      </div>
    )}

    <!-- ══ 2: POWER TIPS ══ -->
    <section class="guide-section" id="power-tips">
      <div class="guide-section__header">
        <span class="guide-section__num">02</span>
        <span class="guide-section__icon">⚡</span>
        <h2 class="guide-section__title">Power Tips</h2>
        <span class="guide-section__sub">Task descriptions, plans, checkpoints</span>
      </div>

      <div class="tips-section">
        <div class="tips-section__header">
          <span class="tips-section__icon">⚡</span>
          <h3 class="tips-section__title">Quick Wins</h3>
        </div>
        <div class="tips-cards">
          <div class="tips-card tips-card--highlight">
            <span class="tips-card__num">01</span>
            <div class="tips-card__title">hermes init first, always</div>
            <p class="tips-card__desc">Without hermes.config.json, Hermes uses defaults that probably don't match your stack. The init wizard takes 2 minutes and makes every subsequent task dramatically more accurate.</p>
          </div>
          <div class="tips-card">
            <span class="tips-card__num">02</span>
            <div class="tips-card__title">--dry-run before you execute</div>
            <p class="tips-card__desc">Hermes is autonomous. See the full plan before any files are touched. This is especially important for refactors, migrations, and anything involving multiple files.</p>
            <div class="tips-card__cmd">hermes "your task" --dry-run</div>
          </div>
          <div class="tips-card">
            <span class="tips-card__num">03</span>
            <div class="tips-card__title">Specific descriptions = better plans</div>
            <p class="tips-card__desc">Vague: "improve auth." Specific: "Add rate limiting to POST /api/auth/login — max 5 requests per minute per IP, return 429 with Retry-After header." Specificity is everything.</p>
          </div>
          <div class="tips-card">
            <span class="tips-card__num">04</span>
            <div class="tips-card__title">Read the execution log when things go wrong</div>
            <p class="tips-card__desc">Hermes logs every step of its execution. When a task doesn't go as expected, the log tells you exactly what happened and where it diverged from the plan.</p>
            <div class="tips-card__cmd">hermes log</div>
          </div>
          <div class="tips-card">
            <span class="tips-card__num">05</span>
            <div class="tips-card__title">Checkpoint saves mid-task state</div>
            <p class="tips-card__desc">For long-running operations, checkpoint at meaningful milestones. If something goes wrong later, you can resume from the checkpoint instead of starting over.</p>
            <div class="tips-card__cmd">hermes checkpoint</div>
          </div>
          <div class="tips-card">
            <span class="tips-card__num">06</span>
            <div class="tips-card__title">--model swaps the underlying model</div>
            <p class="tips-card__desc">Use a cheaper model for exploration and planning tasks, a smarter one for actual implementation. You're not locked into one model for the whole workflow.</p>
            <div class="tips-card__cmd">hermes --model claude-opus-4-6 "your task"</div>
          </div>
        </div>
      </div>

      <div class="tips-section">
        <div class="tips-section__header">
          <span class="tips-section__icon">🔍</span>
          <h3 class="tips-section__title">Hidden Features</h3>
        </div>
        <div class="tips-features">
          <div class="tips-feature">
            <span class="tips-feature__icon">📋</span>
            <div class="tips-feature__body">
              <div class="tips-feature__title">YAML workflow plans for repeatable tasks</div>
              <p class="tips-feature__desc">Write a .hermes/workflow.yaml that describes a multi-step process. Hermes executes it deterministically every time — great for deployment pipelines, onboarding scripts, and anything you'd otherwise document as a manual runbook.</p>
            </div>
          </div>
          <div class="tips-feature">
            <span class="tips-feature__icon">🔌</span>
            <div class="tips-feature__body">
              <div class="tips-feature__title">Tool plugins extend what Hermes can do</div>
              <p class="tips-feature__desc">Hermes has a plugin system for tools. Add plugins for your database CLI, cloud provider, test framework, or any other tool you use. Hermes can then invoke them directly as part of its execution plans.</p>
            </div>
          </div>
          <div class="tips-feature">
            <span class="tips-feature__icon">🔁</span>
            <div class="tips-feature__body">
              <div class="tips-feature__title">Resume from checkpoint after interruption</div>
              <p class="tips-feature__desc">Long tasks get interrupted — network drops, rate limits, system sleep. Checkpoints let Hermes resume exactly where it left off without re-running everything from the start.</p>
              <code class="tips-feature__cmd">hermes resume --checkpoint latest</code>
            </div>
          </div>
        </div>
      </div>

      <div class="tips-section">
        <div class="tips-section__header">
          <span class="tips-section__icon">💀</span>
          <h3 class="tips-section__title">Common Mistakes</h3>
        </div>
        <div class="tips-gotchas">
          <div class="tips-gotcha">
            <span class="tips-gotcha__skull">☠️</span>
            <div class="tips-gotcha__title">Skipping --dry-run on first tasks</div>
            <p class="tips-gotcha__desc">Hermes is autonomous and will make real changes immediately. Running without --dry-run on a task you haven't validated means you're discovering the plan by watching it execute.</p>
            <span class="tips-gotcha__fix">Always --dry-run on any task that modifies files. No exceptions until you know the tool well.</span>
          </div>
          <div class="tips-gotcha">
            <span class="tips-gotcha__skull">☠️</span>
            <div class="tips-gotcha__title">Vague task descriptions</div>
            <p class="tips-gotcha__desc">Vague input = vague plan = vague output. Hermes is only as good as the task description you give it. Ambiguous tasks produce generic results.</p>
            <span class="tips-gotcha__fix">Include: what to change, where (file/function), the expected behaviour, and any constraints.</span>
          </div>
          <div class="tips-gotcha">
            <span class="tips-gotcha__skull">☠️</span>
            <div class="tips-gotcha__title">No checkpoint on long tasks</div>
            <p class="tips-gotcha__desc">A 15-minute task that gets interrupted at minute 12 has to start over. That's avoidable.</p>
            <span class="tips-gotcha__fix">Run hermes checkpoint at logical milestones during long operations.</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ══ 3: COMMAND REFERENCE ══ -->
    <section class="guide-section" id="reference">
      <div class="guide-section__header">
        <span class="guide-section__num">03</span>
        <span class="guide-section__icon">📋</span>
        <h2 class="guide-section__title">Command Reference</h2>
        <span class="guide-section__sub">Flags and commands</span>
      </div>

      <div class="guide-ref-grid">
        {cliFlags.length > 0 && (
          <div class="guide-ref-panel">
            <div class="guide-ref-panel__title">CLI Flags</div>
            {cliFlags.map((flag: any) => (
              <div class="guide-ref-item">
                <span class="guide-ref-item__key">{flag.flag || flag.command}</span>
                <span class="guide-ref-item__desc">{flag.description}</span>
              </div>
            ))}
          </div>
        )}
        {dailyWorkflows.length > 0 && (
          <div class="guide-ref-panel">
            <div class="guide-ref-panel__title">Daily Workflows</div>
            {dailyWorkflows.map((wf: any) => (
              <div class="guide-ref-item">
                <span class="guide-ref-item__key" style="min-width: 0; font-size: 0.68rem;">{wf.title}</span>
                <span class="guide-ref-item__desc">{wf.command || wf.description}</span>
              </div>
            ))}
          </div>
        )}
        {powerMoves.length > 0 && (
          <div class="guide-ref-panel">
            <div class="guide-ref-panel__title">⚡ Power Moves</div>
            {powerMoves.map((pm: any) => (
              <div class="guide-ref-item">
                <span class="guide-ref-item__key" style="min-width: 0; font-size: 0.68rem;">{pm.title}</span>
                <span class="guide-ref-item__desc">{pm.command || pm.description}</span>
              </div>
            ))}
          </div>
        )}
      </div>
      {cliFlags.length === 0 && dailyWorkflows.length === 0 && (
        <p style="font-family: var(--tool-font-mono); font-size: 0.8rem; color: var(--tool-text-muted);">$ cheatsheet data not available</p>
      )}
    </section>

  </div>

  <script is:inline>
    document.querySelectorAll('.qs-cmd').forEach(function(block) {
      var btn = document.createElement('button');
      btn.className = 'qs-cmd__copy';
      btn.textContent = 'copy';
      btn.addEventListener('click', function() {
        var code = block.querySelector('code');
        if (!code) return;
        var text = code.textContent.replace(/^\$\s*/, '').trim();
        navigator.clipboard.writeText(text).then(function() {
          btn.textContent = 'copied!';
          setTimeout(function() { btn.textContent = 'copy'; }, 1500);
        });
      });
      block.style.paddingRight = '5rem';
      block.appendChild(btn);
    });
    var sections = document.querySelectorAll('.guide-section[id]');
    var tocLinks = document.querySelectorAll('.guide-toc__link');
    function updateToc() {
      var scrollY = window.scrollY + 160;
      var current = '';
      sections.forEach(function(s) { if (s.offsetTop <= scrollY) current = s.id; });
      tocLinks.forEach(function(link) {
        link.classList.toggle('guide-toc__link--active', link.getAttribute('href') === '#' + current);
      });
    }
    window.addEventListener('scroll', updateToc, { passive: true });
    updateToc();
  </script>
</HermesLayout>
