---
import GeminiLayout from "../../layouts/GeminiLayout.astro";
import "../../styles/cheatsheet-shared.css";
import { readFileSync } from "node:fs";
import { join } from "node:path";

let cs: any = {};
try {
  const raw = readFileSync(join(process.cwd(), "src/content/cheatsheets-json/gemini-cli.json"), "utf-8");
  cs = JSON.parse(raw);
} catch {}

const quickStart = cs.quickStart || {};
const dailyWorkflows = cs.dailyWorkflows || [];
const powerMoves = cs.powerMoves || [];
const gotchas = cs.gotchas || [];
const cliFlags = cs.cliFlags || [];
const slashCommands = cs.slashCommands || [];
const proTips = cs.proTips || [];
---

<GeminiLayout
  title="Gemini Cli Cheat Sheet — changelogs.info"
  description="The actually useful Gemini Cli cheat sheet. Daily workflows, power moves, CLI flags, gotchas."
  currentPage="cheatsheet"
>
  <div class="cs-wrapper">

    <section class="cs-hero">
      <div class="cs-hero__emoji">🧠</div>
      <h1 class="gc-headline cs-hero__title">
        Cheat<span class="cs-hero__accent">Sheet</span>
      </h1>
      <p class="cs-hero__sub">The commands that matter. Gemini Cli muscle memory.</p>
      {cs.lastUpdated && <p class="cs-hero__meta">Last updated: {cs.lastUpdated}</p>}
    </section>

    <div class="cs-grid">

      {quickStart.steps && quickStart.steps.length > 0 && (
        <div class="cs-quickstart">
          <h2 class="gc-headline cs-quickstart__title">{quickStart.title || "Quick Start"}</h2>
          <div class="cs-quickstart__steps">
            {quickStart.steps.map((step: string, i: number) => {
              const cmdMatch = step.match(/(\S+\s+[\w\-\-]+(?:\s+[\w\-]+)*)/);
              const cmd = cmdMatch?.[1];
              const hasColon = step.includes(":");
              const label = hasColon ? step.split(":")[0].trim() : step;
              return (
                <div class="cs-quickstart__step">
                  <div class="gc-headline cs-step-num">{String(i + 1).padStart(2, '0')}</div>
                  <div class="cs-step-body">
                    <div class="cs-step-label">{label}</div>
                    {cmd && <div class="cs-step-cmd"><span class="cs-step-cmd__prompt">$</span> {cmd}</div>}
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      )}

      <div class="cs-two-col">
        {dailyWorkflows.length > 0 && (
          <div class="cs-panel">
            <h2 class="gc-headline cs-panel__title cs-panel__title--accent">Daily Workflows</h2>
            <div class="cs-item-list">
              {dailyWorkflows.map((wf: any) => (
                <div class="cs-item">
                  <div class="cs-item__title">{wf.title}</div>
                  {wf.description && <p class="cs-item__desc">{wf.description}</p>}
                  {wf.command && <div class="cs-item__cmd"><span class="cs-step-cmd__prompt">$</span> {wf.command}</div>}
                </div>
              ))}
            </div>
          </div>
        )}

        {powerMoves.length > 0 && (
          <div class="cs-panel cs-panel--accent">
            <h2 class="gc-headline cs-panel__title">⚡ Power Moves</h2>
            <div class="cs-item-list">
              {powerMoves.map((pm: any) => (
                <div class="cs-item cs-item--accent">
                  <div class="cs-item__title cs-item__title--accent">{pm.title}</div>
                  {pm.description && <p class="cs-item__desc">{pm.description}</p>}
                  {pm.command && <div class="cs-item__cmd cs-item__cmd--accent"><span class="cs-step-cmd__prompt">$</span> {pm.command}</div>}
                </div>
              ))}
            </div>
          </div>
        )}
      </div>

      {cliFlags.length > 0 && (
        <div class="cs-panel cs-panel--surface">
          <h2 class="gc-headline cs-panel__title">CLI Flags</h2>
          <div class="cs-flag-grid">
            {cliFlags.map((flag: any) => (
              <div class="cs-flag-item">
                <div class="cs-flag-item__key">{flag.flag || flag.command}</div>
                <div class="cs-flag-item__desc">{flag.description}</div>
              </div>
            ))}
          </div>
        </div>
      )}

      {slashCommands.length > 0 && (
        <div class="cs-panel cs-panel--accent">
          <h2 class="gc-headline cs-panel__title cs-panel__title--accent">/ Slash Commands</h2>
          <div class="cs-cmd-grid">
            {slashCommands.map((cmd: any) => (
              <div class="cs-cmd-item">
                <code class="cs-cmd-item__key">{cmd.command || cmd.cmd}</code>
                <span class="cs-cmd-item__desc">{cmd.description}</span>
              </div>
            ))}
          </div>
        </div>
      )}

      {gotchas.length > 0 && (
        <div class="cs-panel cs-panel--warning">
          <h2 class="gc-headline cs-panel__title">⚠ Gotchas</h2>
          <div class="cs-gotcha-list">
            {gotchas.map((g: any) => (
              <div class="cs-gotcha-item">
                <div class="cs-gotcha-item__title">{g.title}</div>
                <p class="cs-gotcha-item__desc">{g.description}</p>
              </div>
            ))}
          </div>
        </div>
      )}

      {proTips.length > 0 && (
        <div class="cs-panel">
          <h2 class="gc-headline cs-panel__title">💡 Pro Tips</h2>
          <div class="cs-cmd-grid">
            {proTips.map((tip: any) => (
              <div class="cs-tip-item">
                <div class="cs-tip-item__title">{tip.title}</div>
                <p class="cs-tip-item__desc">{tip.description}</p>
                {tip.command && <div class="cs-tip-item__cmd">{tip.command}</div>}
              </div>
            ))}
          </div>
        </div>
      )}

      {dailyWorkflows.length === 0 && powerMoves.length === 0 && cliFlags.length === 0 && (
        <div class="cs-empty">
          <p>$ cheatsheet data not available — run scraper to populate</p>
        </div>
      )}
    </div>
  </div>
</GeminiLayout>
