---
import GeminiLayout from "../../layouts/GeminiLayout.astro";
import "../../styles/cheatsheet-shared.css";
---

<GeminiLayout
  title="Gemini CLI Quickstart — changelogs.info"
  description="Get up and running with Gemini CLI in 10 minutes. Install, first run, first real task."
  currentPage="quickstart"
>
  <div class="cs-wrapper">
    <section class="cs-hero">
      <div class="cs-hero__emoji">🚀</div>
      <h1 class="gc-headline cs-hero__title">
        Quick<span class="cs-hero__accent">Start</span>
      </h1>
      <p class="cs-hero__sub">Up and running in 10 minutes</p>
      <p class="cs-hero__meta">Google's AI CLI with 1M context — feed it an entire codebase at once</p>
    </section>

    <div class="cs-grid">

      <div class="cs-panel">
        <h2 class="gc-headline cs-panel__title">Prerequisites</h2>
        <div class="cs-item-list">
          <div class="cs-item">
            <div class="cs-item__title">Node.js 18+</div>
            <p class="cs-item__desc">Required runtime. Check with <code>node -v</code>.</p>
          </div>
          <div class="cs-item">
            <div class="cs-item__title">Google account or GEMINI_API_KEY</div>
            <p class="cs-item__desc">Browser auth works on first launch, or export an API key from <a href="https://aistudio.google.com/apikey">AI Studio</a>.</p>
          </div>
        </div>
      </div>

      <div class="cs-panel cs-panel--accent">
        <h2 class="gc-headline cs-panel__title">Install</h2>
        <div class="cs-item-list">
          <div class="cs-item">
            <div class="cs-item__title">Via npm</div>
            <div class="cs-item__cmd"><span class="cs-step-cmd__prompt">$</span> npm install -g @google/gemini-cli</div>
          </div>
        </div>
      </div>

      <div class="cs-panel">
        <h2 class="gc-headline cs-panel__title">First Run</h2>
        <div class="cs-item-list">
          <div class="cs-item">
            <div class="cs-item__title">Launch Gemini</div>
            <p class="cs-item__desc">Opens browser auth on first launch. After that, starts instantly.</p>
            <div class="cs-item__cmd"><span class="cs-step-cmd__prompt">$</span> gemini</div>
          </div>
        </div>
      </div>

      <div class="cs-panel cs-panel--accent">
        <h2 class="gc-headline cs-panel__title">⚡ First Real Task</h2>
        <div class="cs-item-list">
          <div class="cs-item">
            <div class="cs-item__title">Pipe a file for review</div>
            <p class="cs-item__desc">One-shot mode with -p flag. Great for code review.</p>
            <div class="cs-item__cmd"><span class="cs-step-cmd__prompt">$</span> gemini -p "review this file for security issues" &lt; src/auth.ts</div>
          </div>
          <div class="cs-item">
            <div class="cs-item__title">Set an API key</div>
            <p class="cs-item__desc">Faster than browser auth, required for CI/scripts.</p>
            <div class="cs-item__cmd"><span class="cs-step-cmd__prompt">$</span> export GEMINI_API_KEY=your-key-here</div>
          </div>
          <div class="cs-item">
            <div class="cs-item__title">Try --yolo mode</div>
            <p class="cs-item__desc">Auto-approve all tool calls. Use on trusted repos only.</p>
            <div class="cs-item__cmd"><span class="cs-step-cmd__prompt">$</span> gemini --yolo "refactor the database layer"</div>
          </div>
          <div class="cs-item">
            <div class="cs-item__title">Explore checkpointing</div>
            <p class="cs-item__desc">Gemini can checkpoint and restore file state, letting you undo changes safely.</p>
          </div>
        </div>
      </div>

      <div class="cs-panel cs-panel--surface">
        <h2 class="gc-headline cs-panel__title">What Next?</h2>
        <div class="cs-flag-grid">
          <div class="cs-flag-item">
            <a href="/gemini-cli/cheatsheet/" class="cs-flag-item__key" style="text-decoration:none;">Cheat Sheet →</a>
            <div class="cs-flag-item__desc">Daily commands and power moves</div>
          </div>
          <div class="cs-flag-item">
            <a href="/gemini-cli/changelog/" class="cs-flag-item__key" style="text-decoration:none;">Changelog →</a>
            <div class="cs-flag-item__desc">Latest updates and release notes</div>
          </div>
          <div class="cs-flag-item">
            <a href="/gemini-cli/releases/" class="cs-flag-item__key" style="text-decoration:none;">Releases →</a>
            <div class="cs-flag-item__desc">Full release history and downloads</div>
          </div>
        </div>
      </div>

    </div>
  </div>
</GeminiLayout>
