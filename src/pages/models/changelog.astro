---
import HubLayout from "../../layouts/HubLayout.astro";
---

<HubLayout title="Model Changelog — changelogs.info" description="Model changelog timeline — coming soon.">

  <section class="mc-wrap">
    <div class="mc-eyebrow">
      <span class="mc-dot"></span>
      Coming Soon
    </div>

    <h1 class="mc-title">MODEL<br/><span class="mc-accent">CHANGELOG</span></h1>

    <p class="mc-desc">
      A per-model version timeline tracking every change — new releases, capability updates,
      breaking API changes, pricing shifts, and deprecation notices across all providers.
    </p>

    <div class="mc-features">
      <div class="mc-feat">
        <span class="mc-feat__icon">▲</span>
        <span>Version-by-version diffs</span>
      </div>
      <div class="mc-feat">
        <span class="mc-feat__icon">◆</span>
        <span>Capability change logs</span>
      </div>
      <div class="mc-feat">
        <span class="mc-feat__icon">$</span>
        <span>Pricing history</span>
      </div>
      <div class="mc-feat">
        <span class="mc-feat__icon">★</span>
        <span>Breaking change alerts</span>
      </div>
    </div>

    <div class="mc-actions">
      <a href="/models/" class="mc-btn">← Back to Models</a>
      <a href="/rss.xml" class="mc-btn mc-btn--outline">RSS Feed</a>
    </div>

    <p class="mc-hint">
      Want early access or want to contribute? Open an issue on GitHub or subscribe to the RSS feed for launch announcements.
    </p>
  </section>

</HubLayout>

<style is:global>
  :root,
  [data-theme="light"] {
    --mc-bg: #f8fbff;
    --mc-bg-card: #ffffff;
    --mc-text: #0a0a0a;
    --mc-text-dim: #3a3a3a;
    --mc-text-muted: #6a6a6a;
    --mc-border: #0a0a0a;
    --mc-border-dim: rgba(10,10,10,0.15);
    --mc-shadow: 6px 6px 0px 0px rgba(10,10,10,0.9);
    --mc-accent: #a855f7;
  }
  [data-theme="dark"] {
    --mc-bg: #0a0a0a;
    --mc-bg-card: #111111;
    --mc-text: #f0f0f0;
    --mc-text-dim: #b0b0b0;
    --mc-text-muted: #707070;
    --mc-border: #f0f0f0;
    --mc-border-dim: rgba(240,240,240,0.15);
    --mc-shadow: 6px 6px 0px 0px rgba(240,240,240,0.12);
    --mc-accent: #a855f7;
  }

  .mc-wrap {
    max-width: 720px;
    margin: 0 auto;
    padding: 5rem 2rem 4rem;
    text-align: center;
  }
  .mc-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--mc-accent);
    margin-bottom: 1.5rem;
  }
  .mc-dot {
    width: 8px; height: 8px;
    background: var(--mc-accent);
    animation: mc-pulse 2s ease-in-out infinite;
  }
  @keyframes mc-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }
  .mc-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(3rem, 10vw, 5.5rem);
    font-weight: 900;
    letter-spacing: -0.05em;
    line-height: 0.9;
    text-transform: uppercase;
    color: var(--mc-text);
    margin-bottom: 1.5rem;
  }
  .mc-accent {
    color: var(--mc-accent);
  }
  .mc-desc {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.88rem;
    color: var(--mc-text-dim);
    line-height: 1.7;
    max-width: 540px;
    margin: 0 auto 2rem;
  }
  .mc-features {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    max-width: 360px;
    margin: 0 auto 2rem;
    text-align: left;
  }
  .mc-feat {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    color: var(--mc-text-dim);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    border: 3px solid var(--mc-border-dim);
    padding: 0.5rem 0.75rem;
    background: var(--mc-bg-card);
  }
  .mc-feat__icon {
    color: var(--mc-accent);
    font-size: 0.9rem;
  }
  .mc-actions {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }
  .mc-btn {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-decoration: none;
    border: 4px solid var(--mc-border);
    padding: 0.6rem 1.2rem;
    background: var(--mc-accent);
    color: #fff;
    box-shadow: var(--mc-shadow);
    transition: transform 100ms, box-shadow 100ms;
  }
  .mc-btn:hover {
    transform: translate(-2px, -2px);
    box-shadow: 8px 8px 0px 0px var(--mc-border);
  }
  .mc-btn--outline {
    background: transparent;
    color: var(--mc-text);
  }
  .mc-hint {
    font-family: 'Work Sans', sans-serif;
    font-size: 0.78rem;
    color: var(--mc-text-muted);
    line-height: 1.5;
  }

  @media (max-width: 640px) {
    .mc-wrap { padding: 3rem 1.25rem 2rem; }
    .mc-title { font-size: clamp(2rem, 12vw, 3rem); }
  }
</style>
