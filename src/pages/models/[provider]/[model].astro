---
import HubLayout from "../../../layouts/HubLayout.astro";
import "../../../styles/models-vars.css";
import {
  formatDate,
  formatPrice,
  formatTokenCount,
  loadModelsData,
  providerSlug,
  modelSlug,
} from "../../../lib/models";
import type { ModelRecord } from "../../../lib/models";

export async function getStaticPaths() {
  const { providers, models } = loadModelsData();
  return models.map((model) => ({
    params: {
      provider: providerSlug(model.provider),
      model: modelSlug(model.id),
    },
    props: { model, allModels: models },
  }));
}

interface Props {
  model: ModelRecord;
  allModels: ModelRecord[];
}

const { model, allModels } = Astro.props;

const brandColors: Record<string, string> = {
  Anthropic: "#ffb800",
  OpenAI: "#10a37f",
  Google: "#4285f4",
  DeepSeek: "#6366f1",
  xAI: "#1d9bf0",
  "Moonshot AI": "#a855f7",
  ZAI: "#ff6b35",
  Minimax: "#06b6d4",
  Meta: "#0668E1",
  Mistral: "#ff7000",
  Qwen: "#7c3aed",
};

const typeColors: Record<string, string> = {
  frontier: "#ef4444",
  balanced: "#f59e0b",
  fast: "#22c55e",
  reasoning: "#a855f7",
  coding: "#3b82f6",
  multimodal: "#ec4899",
  "open-weight": "#06b6d4",
};

const statusColors: Record<string, string> = {
  active: "#22c55e",
  preview: "#f59e0b",
  legacy: "#64748b",
  deprecated: "#ef4444",
};

const providerDocs: Record<string, string> = {
  Anthropic: "https://docs.anthropic.com/en/docs/about-claude/models",
  OpenAI: "https://platform.openai.com/docs/models",
  Google: "https://ai.google.dev/gemini-api/docs/models",
  DeepSeek: "https://platform.deepseek.com/docs",
  xAI: "https://docs.x.ai/docs",
  "Moonshot AI": "https://docs.moonshot.ai/",
  ZAI: "https://zai.ai/docs",
  Minimax: "https://www.minimax.io/docs",
  Meta: "https://ai.meta.com/llama/",
  Mistral: "https://docs.mistral.ai/getting-started/models/models_overview/",
  Qwen: "https://help.aliyun.com/zh/model-studio/developer-reference/what-is-qwen-llm",
};

const accent = brandColors[model.provider] ?? "#a855f7";
const provSlug = providerSlug(model.provider);

// Find predecessor and successor model records
const predecessorModel = model.predecessor
  ? allModels.find((m) => m.id === model.predecessor)
  : null;
const successorModel = model.successor
  ? allModels.find((m) => m.id === model.successor)
  : null;

// Find sibling models (same provider, excluding current)
const siblingModels = allModels
  .filter((m) => m.provider === model.provider && m.id !== model.id)
  .sort((a, b) => b.releaseTs - a.releaseTs)
  .slice(0, 6);

function pricingSummary(): string {
  if (!model.primaryPrice) return "Not listed";
  const source = model.pricingSource === "provider" ? "API" : "OpenRouter";
  return `${formatPrice(model.inputPrice)} in / ${formatPrice(model.outputPrice)} out per 1M tokens (${source})`;
}

function modelLink(m: ModelRecord): string {
  return `/models/${providerSlug(m.provider)}/${modelSlug(m.id)}/`;
}

const capabilities: Array<{ label: string; value: string; icon: string }> = [];
capabilities.push({ label: "Vision", value: model.vision ? "Yes" : "No", icon: model.vision ? "👁️" : "—" });
capabilities.push({ label: "Function calling", value: model.function_calling ? "Yes" : "No", icon: model.function_calling ? "🔧" : "—" });
if (model.knowledge_cutoff) {
  capabilities.push({ label: "Knowledge cutoff", value: model.knowledge_cutoff, icon: "📅" });
}

const pageTitle = `${model.name} — ${model.provider} — changelogs.info`;
const pageDescription = model.description ?? model.notes ?? `${model.name} by ${model.provider}. Context: ${model.context ?? "Unknown"}, Status: ${model.status}.`;
---

<HubLayout title={pageTitle} description={pageDescription} currentSection="models">
  <!-- Breadcrumb -->
  <nav class="mp-breadcrumb">
    <a href="/models/">Models</a>
    <span class="mp-breadcrumb__sep">›</span>
    <a href={`/models/${provSlug}/`}>{model.provider}</a>
    <span class="mp-breadcrumb__sep">›</span>
    <span>{model.name}</span>
  </nav>

  <!-- Hero -->
  <section class="mp-hero" style={`--accent:${accent};--type:${typeColors[model.type] ?? "#888"};--status:${statusColors[model.status] ?? "#888"};`}>
    <div class="mp-hero__bar"></div>
    <div class="mp-hero__inner">
      <div class="mp-hero__copy">
        <div class="mp-label">// model_detail</div>
        <div class="mp-hero__badges">
          <span class="mp-pill mp-pill--status">{model.status}</span>
          <span class="mp-pill mp-pill--type">{model.type}</span>
        </div>
        <h1 class="mp-hero__title">{model.name}</h1>
        <p class="mp-hero__provider">by {model.provider}</p>
        <p class="mp-hero__desc">{model.description ?? model.notes ?? "No description available."}</p>
      </div>

      <div class="mp-hero__specs">
        <div class="mp-spec">
          <span class="mp-spec__label">Context window</span>
          <span class="mp-spec__value">{model.context ?? "Unknown"}</span>
          {model.contextTokens && (
            <span class="mp-spec__sub">{formatTokenCount(model.contextTokens)} tokens</span>
          )}
        </div>
        <div class="mp-spec">
          <span class="mp-spec__label">Max output</span>
          <span class="mp-spec__value">{model.max_output ?? "Unknown"}</span>
          {model.outputTokens && (
            <span class="mp-spec__sub">{formatTokenCount(model.outputTokens)} tokens</span>
          )}
        </div>
        <div class="mp-spec">
          <span class="mp-spec__label">Pricing /1M tok</span>
          <span class="mp-spec__value mp-spec__value--sm">{pricingSummary()}</span>
        </div>
        <div class="mp-spec">
          <span class="mp-spec__label">Released</span>
          <span class="mp-spec__value">{formatDate(model.released)}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Specs detail -->
  <section class="mp-section">
    <div class="mp-section__head">
      <div class="mp-label">// specifications</div>
      <h2 class="mp-section__title">Specs & capabilities</h2>
    </div>

    <div class="mp-specs-grid">
      <div class="mp-detail-card">
        <h3 class="mp-detail-card__title">API details</h3>
        <dl class="mp-dl">
          <div class="mp-dl__row">
            <dt>API model ID</dt>
            <dd><code>{model.api_id}</code></dd>
          </div>
          <div class="mp-dl__row">
            <dt>Internal ID</dt>
            <dd><code>{model.id}</code></dd>
          </div>
          <div class="mp-dl__row">
            <dt>Status</dt>
            <dd><span class="mp-inline-pill" style={`border-color:${statusColors[model.status] ?? "#888"};`}>{model.status}</span></dd>
          </div>
          <div class="mp-dl__row">
            <dt>Type</dt>
            <dd><span class="mp-inline-pill" style={`border-color:${typeColors[model.type] ?? "#888"};`}>{model.type}</span></dd>
          </div>
        </dl>
      </div>

      <div class="mp-detail-card">
        <h3 class="mp-detail-card__title">Capabilities</h3>
        <dl class="mp-dl">
          {capabilities.map((cap) => (
            <div class="mp-dl__row">
              <dt>{cap.label}</dt>
              <dd>{cap.icon !== "—" ? cap.icon : ""} {cap.value}</dd>
            </div>
          ))}
        </dl>
      </div>

      {model.primaryPrice && (
        <div class="mp-detail-card">
          <h3 class="mp-detail-card__title">Pricing</h3>
          <dl class="mp-dl">
            <div class="mp-dl__row">
              <dt>Input</dt>
              <dd>{formatPrice(model.inputPrice)} / 1M tokens</dd>
            </div>
            <div class="mp-dl__row">
              <dt>Output</dt>
              <dd>{formatPrice(model.outputPrice)} / 1M tokens</dd>
            </div>
            <div class="mp-dl__row">
              <dt>Source</dt>
              <dd>{model.pricingSource === "provider" ? "First-party API pricing" : "OpenRouter pricing"}</dd>
            </div>
          </dl>
        </div>
      )}

      {(model.predecessor || model.successor || model.deprecated_date) && (
        <div class="mp-detail-card">
          <h3 class="mp-detail-card__title">Lifecycle</h3>
          <dl class="mp-dl">
            {model.predecessor && (
              <div class="mp-dl__row">
                <dt>Predecessor</dt>
                <dd>
                  {predecessorModel ? (
                    <a href={modelLink(predecessorModel)} class="mp-link">{predecessorModel.name}</a>
                  ) : (
                    <code>{model.predecessor}</code>
                  )}
                </dd>
              </div>
            )}
            {model.successor && (
              <div class="mp-dl__row">
                <dt>Successor</dt>
                <dd>
                  {successorModel ? (
                    <a href={modelLink(successorModel)} class="mp-link">{successorModel.name}</a>
                  ) : (
                    <code>{model.successor}</code>
                  )}
                </dd>
              </div>
            )}
            {model.deprecated_date && (
              <div class="mp-dl__row">
                <dt>Deprecation date</dt>
                <dd>{formatDate(model.deprecated_date)}</dd>
              </div>
            )}
          </dl>
        </div>
      )}
    </div>
  </section>

  <!-- Confidence flags -->
  {model.confidenceFlags.length > 0 && (
    <section class="mp-section">
      <div class="mp-section__head">
        <div class="mp-label">// data_confidence</div>
        <h2 class="mp-section__title">Data notes</h2>
      </div>
      <div class="mp-flags">
        {model.confidenceFlags.map((flag) => (
          <div class="mp-flag">
            <span class="mp-flag__icon">⚠️</span>
            <span>{flag}</span>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- Notes -->
  {model.notes && model.notes !== model.description && (
    <section class="mp-section">
      <div class="mp-section__head">
        <div class="mp-label">// notes</div>
        <h2 class="mp-section__title">Additional notes</h2>
      </div>
      <p class="mp-notes">{model.notes}</p>
    </section>
  )}

  <!-- Sibling models -->
  {siblingModels.length > 0 && (
    <section class="mp-section">
      <div class="mp-section__head">
        <div class="mp-label">// more_from_{provSlug}</div>
        <h2 class="mp-section__title">More {model.provider} models</h2>
      </div>
      <div class="mp-siblings">
        {siblingModels.map((sib) => (
          <a href={modelLink(sib)} class="mp-sibling" style={`--status:${statusColors[sib.status] ?? "#888"};--type:${typeColors[sib.type] ?? "#888"};`}>
            <div class="mp-sibling__head">
              <span class="mp-sibling__name">{sib.name}</span>
              <span class="mp-sibling__badges">
                <span class="mp-mini-pill mp-mini-pill--status">{sib.status}</span>
                <span class="mp-mini-pill mp-mini-pill--type">{sib.type}</span>
              </span>
            </div>
            <p class="mp-sibling__desc">{sib.description ?? sib.notes ?? ""}</p>
            <div class="mp-sibling__meta">
              <span>Context: {sib.context ?? "?"}</span>
              <span>Released: {formatDate(sib.released)}</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- External links -->
  <section class="mp-section">
    <div class="mp-section__head">
      <div class="mp-label">// external_links</div>
      <h2 class="mp-section__title">Links</h2>
    </div>
    <div class="mp-links">
      {providerDocs[model.provider] && (
        <a href={providerDocs[model.provider]} target="_blank" rel="noopener noreferrer" class="mp-ext-link">
          📄 {model.provider} model docs
          <span class="mp-ext-link__arrow">↗</span>
        </a>
      )}
      <a href={`/models/${provSlug}/`} class="mp-ext-link">
        📊 All {model.provider} models
        <span class="mp-ext-link__arrow">→</span>
      </a>
      <a href="/models/changelog/" class="mp-ext-link">
        📰 Model changelog
        <span class="mp-ext-link__arrow">→</span>
      </a>
    </div>
  </section>

  <!-- Footer nav -->
  <div class="mp-footer-nav">
    <a href={`/models/${provSlug}/`} class="mp-btn mp-btn--ghost">← {model.provider} models</a>
    <a href="/models/" class="mp-btn mp-btn--ghost">All providers</a>
  </div>
</HubLayout>

<style>
  /* ── Layout ── */
  .mp-breadcrumb,
  .mp-hero,
  .mp-section,
  .mp-footer-nav {
    max-width: 1280px;
    margin: 0 auto;
    padding-left: 2rem;
    padding-right: 2rem;
  }

  /* ── Breadcrumb ── */
  .mp-breadcrumb {
    padding-top: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--hub-font-mono);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--models-text-muted, #66758a);
    flex-wrap: wrap;
  }
  .mp-breadcrumb a {
    color: var(--models-accent, #0091f7);
    text-decoration: none;
  }
  .mp-breadcrumb a:hover { text-decoration: underline; }
  .mp-breadcrumb__sep { opacity: 0.5; }

  /* ── Hero ── */
  .mp-hero {
    padding-top: 3rem;
    padding-bottom: 2rem;
  }

  .mp-hero__bar {
    height: 8px;
    background: var(--accent);
    margin-bottom: 1.5rem;
    max-width: 1280px;
    border: 3px solid var(--models-border, #0a0a0a);
  }

  .mp-hero__inner {
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) minmax(280px, 0.8fr);
    gap: 1.5rem;
    align-items: start;
  }

  .mp-hero__copy {
    border: 4px solid var(--models-border, #0a0a0a);
    background: var(--models-card, #ffffff);
    box-shadow: var(--models-shadow, 6px 6px 0 0 rgba(10,10,10,0.9));
    padding: 2rem;
  }

  .mp-label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--hub-font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--models-accent, #0091f7);
  }

  .mp-hero__badges {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }

  .mp-pill {
    display: inline-flex;
    align-items: center;
    padding: 0.3rem 0.55rem;
    border: 2px solid var(--models-border, #0a0a0a);
    background: var(--models-surface, #ecf6ff);
    font-family: var(--hub-font-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .mp-pill--status { border-color: var(--status); }
  .mp-pill--type   { border-color: var(--type); }

  .mp-hero__title {
    font-family: var(--hub-font-head);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 0.95;
    letter-spacing: -0.05em;
    margin-top: 0.75rem;
  }

  .mp-hero__provider {
    font-family: var(--hub-font-mono);
    font-size: 0.85rem;
    color: var(--models-text-muted, #66758a);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: 0.5rem;
  }

  .mp-hero__desc {
    color: var(--models-text-dim, #364152);
    font-size: 1.05rem;
    line-height: 1.7;
    margin-top: 0.75rem;
  }

  .mp-hero__specs {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    padding: 1px;
    background: var(--models-border, #0a0a0a);
    border: 4px solid var(--models-border, #0a0a0a);
    box-shadow: var(--models-shadow, 6px 6px 0 0 rgba(10,10,10,0.9));
  }

  .mp-spec {
    padding: 1.25rem;
    background: var(--models-surface, #ecf6ff);
    display: flex;
    flex-direction: column;
  }

  .mp-spec__label {
    font-family: var(--hub-font-mono);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.72rem;
    color: var(--models-text-muted, #66758a);
  }

  .mp-spec__value {
    font-family: var(--hub-font-head);
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    line-height: 1;
    letter-spacing: -0.05em;
    margin-top: 0.25rem;
  }

  .mp-spec__value--sm {
    font-family: var(--hub-font-mono);
    font-size: 0.82rem;
    letter-spacing: 0;
    line-height: 1.5;
  }

  .mp-spec__sub {
    font-family: var(--hub-font-mono);
    font-size: 0.72rem;
    color: var(--models-text-muted, #66758a);
    margin-top: 0.15rem;
  }

  /* ── Sections ── */
  .mp-section {
    padding-top: 2rem;
    padding-bottom: 1rem;
  }

  .mp-section__head {
    margin-bottom: 1.25rem;
  }

  .mp-section__title {
    font-family: var(--hub-font-head);
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    letter-spacing: -0.04em;
    line-height: 1;
    margin-top: 0.45rem;
  }

  /* ── Specs grid ── */
  .mp-specs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1rem;
  }

  .mp-detail-card {
    border: 4px solid var(--models-border, #0a0a0a);
    background: var(--models-card, #ffffff);
    box-shadow: var(--models-shadow, 6px 6px 0 0 rgba(10,10,10,0.9));
    padding: 1.25rem;
  }

  .mp-detail-card__title {
    font-family: var(--hub-font-head);
    font-size: 1.3rem;
    letter-spacing: -0.03em;
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--models-border-dim, rgba(10,10,10,0.15));
  }

  .mp-dl {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .mp-dl__row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--models-border-dim, rgba(10,10,10,0.08));
  }

  .mp-dl__row:last-child {
    border-bottom: none;
  }

  .mp-dl__row dt {
    font-family: var(--hub-font-mono);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--models-text-muted, #66758a);
    flex-shrink: 0;
  }

  .mp-dl__row dd {
    font-size: 0.9rem;
    font-weight: 600;
    text-align: right;
  }

  .mp-dl__row code {
    font-family: var(--hub-font-mono);
    font-size: 0.82rem;
    padding: 0.15rem 0.4rem;
    background: var(--models-surface, #ecf6ff);
    border: 1px solid var(--models-border-dim, rgba(10,10,10,0.15));
  }

  .mp-inline-pill {
    display: inline-flex;
    padding: 0.2rem 0.45rem;
    border: 2px solid;
    font-family: var(--hub-font-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: var(--models-surface, #ecf6ff);
  }

  .mp-link {
    color: var(--models-accent, #0091f7);
    text-decoration: none;
    font-weight: 600;
  }
  .mp-link:hover { text-decoration: underline; }

  /* ── Confidence flags ── */
  .mp-flags {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .mp-flag {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.65rem 0.9rem;
    border: 2px solid var(--models-border-dim, rgba(10,10,10,0.15));
    background: var(--models-surface, #ecf6ff);
    font-size: 0.88rem;
    color: var(--models-text-dim, #364152);
  }

  .mp-flag__icon {
    flex-shrink: 0;
  }

  /* ── Notes ── */
  .mp-notes {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--models-text-dim, #364152);
    padding: 1rem;
    border: 4px solid var(--models-border, #0a0a0a);
    background: var(--models-card, #fff);
    box-shadow: var(--models-shadow, 6px 6px 0 0 rgba(10,10,10,0.9));
  }

  /* ── Siblings ── */
  .mp-siblings {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1rem;
  }

  .mp-sibling {
    display: flex;
    flex-direction: column;
    padding: 1rem;
    border: 3px solid var(--models-border, #0a0a0a);
    background: var(--models-card, #ffffff);
    box-shadow: var(--models-shadow, 6px 6px 0 0 rgba(10,10,10,0.9));
    text-decoration: none;
    color: inherit;
    transition: transform 0.1s ease, box-shadow 0.1s ease;
  }

  .mp-sibling:hover {
    transform: translate(-2px, -2px);
    box-shadow: 8px 8px 0 0 rgba(10,10,10,0.9);
  }

  .mp-sibling__head {
    display: flex;
    justify-content: space-between;
    align-items: start;
    gap: 0.5rem;
  }

  .mp-sibling__name {
    font-family: var(--hub-font-head);
    font-size: 1.2rem;
    letter-spacing: -0.03em;
    line-height: 1.1;
  }

  .mp-sibling__badges {
    display: flex;
    gap: 0.35rem;
    flex-shrink: 0;
  }

  .mp-mini-pill {
    display: inline-flex;
    padding: 0.15rem 0.35rem;
    border: 2px solid;
    font-family: var(--hub-font-mono);
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: var(--models-surface, #ecf6ff);
  }
  .mp-mini-pill--status { border-color: var(--status); }
  .mp-mini-pill--type   { border-color: var(--type); }

  .mp-sibling__desc {
    color: var(--models-text-dim, #364152);
    font-size: 0.85rem;
    line-height: 1.5;
