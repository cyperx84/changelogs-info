---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { MODELS_SECTION } from "../../lib/sections";

const s = MODELS_SECTION;
---

<BaseLayout title="Models — changelogs.info" description="Track AI model releases and updates." section="models">
  <section
    class="relative overflow-hidden border-b"
    style={`border-color: rgba(${s.colorRgb}, 0.2); background: linear-gradient(135deg, rgba(${s.colorRgb}, 0.05) 0%, transparent 60%);`}
  >
    <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6 sm:py-14">
      <div class="max-w-2xl">
        <div class="mb-3 flex items-center gap-3">
          <span class="inline-block h-3 w-3 rounded-sm" style={`background: ${s.color}; box-shadow: 0 0 12px ${s.color};`}></span>
          <span class="font-mono text-xs uppercase tracking-widest text-text-muted">section</span>
        </div>
        <h1 class="font-mono text-3xl font-bold sm:text-4xl" style={`color: ${s.color};`}>Models</h1>
        <p class="mt-3 font-sans text-sm leading-relaxed text-text-secondary sm:text-base">
          Track AI model releases, capabilities, and version changes across providers.
        </p>
      </div>
    </div>
  </section>

  <div class="mx-auto max-w-6xl px-4 py-8 sm:px-6 sm:py-12">
    <div class="rounded-lg border border-dashed border-border bg-bg-card p-8 text-center">
      <p class="font-mono text-base text-text-muted">&gt; Model tracking coming soon.</p>
      <p class="mt-3 font-sans text-sm text-text-secondary">
        We're building a comprehensive model tracker covering Claude, GPT, Gemini, and more.
      </p>
      <p class="mt-4 font-mono text-xs text-text-muted">
        In the meantime, model-related changes are tracked within each tool's changelog.
      </p>
    </div>
  </div>
</BaseLayout>
