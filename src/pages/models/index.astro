---
import HubLayout from "../../layouts/HubLayout.astro";
import "../../styles/models-vars.css";
import { formatDate, formatPrice, formatTokenCount, loadModelsData, providerSlug } from "../../lib/models";

const {
  featured,
  models,
  providers,
  statuses,
  types,
  stats,
} = loadModelsData();

const brandColors: Record<string, string> = {
  Anthropic: "#ffb800",
  OpenAI: "#10a37f",
  Google: "#4285f4",
  DeepSeek: "#6366f1",
  xAI: "#1d9bf0",
  "Moonshot AI": "#a855f7",
  ZAI: "#ff6b35",
  Minimax: "#06b6d4",
  Meta: "#0668E1",
  Mistral: "#ff7000",
  Qwen: "#7c3aed",
};

const typeColors: Record<string, string> = {
  frontier: "#ef4444",
  balanced: "#f59e0b",
  fast: "#22c55e",
  reasoning: "#a855f7",
  coding: "#3b82f6",
  multimodal: "#ec4899",
  "open-weight": "#06b6d4",
};

const statusColors: Record<string, string> = {
  active: "#22c55e",
  preview: "#f59e0b",
  legacy: "#64748b",
  deprecated: "#ef4444",
};

function contextBucket(tokens: number | null): string {
  if (tokens == null) return "unknown";
  if (tokens <= 128_000) return "0-128k";
  if (tokens <= 512_000) return "129k-512k";
  if (tokens <= 1_000_000) return "513k-1m";
  return "gt-1m";
}

function outputBucket(tokens: number | null): string {
  if (tokens == null) return "unknown";
  if (tokens <= 8_000) return "0-8k";
  if (tokens <= 32_000) return "9k-32k";
  if (tokens <= 64_000) return "33k-64k";
  return "gt-64k";
}

function pricingSummary(model: (typeof models)[number]): string {
  if (!model.primaryPrice) {
    return "No listed pricing";
  }
  const source = model.pricingSource === "provider" ? "API" : "OpenRouter";
  return `${formatPrice(model.inputPrice)} / ${formatPrice(model.outputPrice)} per 1M tok • ${source}`;
}
---

<HubLayout
  title="Models — changelogs.info"
  description="Search, sort, and filter AI models across providers with lifecycle signals, pricing transparency, and release intelligence."
  currentSection="models"
>
  <section class="models-hero">
    <div class="models-hero__eyebrow">
      <span class="models-hero__dot"></span>
      AI model directory
    </div>
    <div class="models-hero__grid">
      <div class="models-hero__copy">
        <h1 class="models-hero__title">Global model directory</h1>
        <p class="models-hero__sub">
          Search every tracked model across providers, compare lifecycle state, and make faster decisions without pretending the data is cleaner than it is.
        </p>
        <div class="models-hero__actions">
          <a href="#directory" class="models-btn">Browse directory</a>
          <a href="/models/changelog/" class="models-btn models-btn--ghost">Model timeline</a>
        </div>
      </div>

      <div class="models-hero__stats">
        <div class="models-stat">
          <span class="models-stat__value">{stats.totalModels}</span>
          <span class="models-stat__label">tracked models</span>
        </div>
        <div class="models-stat">
          <span class="models-stat__value">{stats.totalProviders}</span>
          <span class="models-stat__label">providers</span>
        </div>
        <div class="models-stat">
          <span class="models-stat__value">{stats.activeCount}</span>
          <span class="models-stat__label">live or preview</span>
        </div>
        <div class="models-stat">
          <span class="models-stat__value">{stats.upcomingDeprecations}</span>
          <span class="models-stat__label">scheduled retirements</span>
        </div>
      </div>
    </div>
  </section>

  <section class="models-section">
    <div class="models-section__head">
      <div>
        <div class="models-label">// decision_intelligence</div>
        <h2 class="models-section__title">Shortlist picks</h2>
      </div>
      <p class="models-section__note">
        These are heuristic recommendations from structured metadata in <code>src/content/models/*.json</code>, not normalized benchmarks.
      </p>
    </div>

    <div class="featured-grid">
      {featured.map((pick) => {
        const model = pick.model;
        const accent = model ? brandColors[model.provider] || "#a855f7" : "#a855f7";
        return (
          <article class="featured-card" style={`--accent:${accent};`}>
            <div class="featured-card__top">
              <div>
                <p class="featured-card__kicker">{pick.subtitle}</p>
                <h3 class="featured-card__title">{pick.title}</h3>
              </div>
              {model && <span class="featured-card__provider">{model.provider}</span>}
            </div>

            {model ? (
              <>
                <div class="featured-card__model">{model.name}</div>
                <p class="featured-card__why">{pick.rationale}</p>
                <div class="featured-card__facts">
                  <span>{model.type}</span>
                  <span>{model.context ?? "ctx unknown"}</span>
                  <span>{model.max_output ?? "output unknown"}</span>
                  <span>{pricingSummary(model)}</span>
                </div>
                {pick.alternatives.length > 0 && (
                  <p class="featured-card__alts">Also worth a look: {pick.alternatives.join(", ")}</p>
                )}
              </>
            ) : (
              <p class="featured-card__why">No model in the current dataset satisfies this slot yet.</p>
            )}
          </article>
        );
      })}
    </div>
  </section>

  <section class="models-section">
    <div class="models-section__head">
      <div>
        <div class="models-label">// transparency</div>
        <h2 class="models-section__title">Confidence and caveats</h2>
      </div>
    </div>

    <div class="confidence-grid">
      <article class="confidence-card">
        <h3>Pricing is not uniformly first-party</h3>
        <p>
          Some open-weight models only have an <strong>OpenRouter</strong> price in the source data. Those cards are clearly labeled so you do not mistake routed pricing for the provider’s own API price.
        </p>
      </article>
      <article class="confidence-card">
        <h3>Null means unknown, not zero</h3>
        <p>
          Missing context, output, or cutoff values stay marked as unknown. Rankings that depend on those fields will naturally favor models with published numbers.
        </p>
      </article>
      <article class="confidence-card">
        <h3>Preview models are separated</h3>
        <p>
          Preview entries are treated as live for discovery, but the UI calls out that availability and pricing may move faster than stable models.
        </p>
      </article>
    </div>
  </section>

  <section class="models-section" id="directory">
    <div class="models-section__head">
      <div>
        <div class="models-label">// directory</div>
        <h2 class="models-section__title">Searchable model index</h2>
      </div>
      <div class="directory-summary">
        <span id="models-count">{models.length}</span>
        <span>models shown</span>
      </div>
    </div>

    <div class="controls-shell">
      <div class="controls-row controls-row--top">
        <label class="control-search">
          <span class="control-search__label">search</span>
          <input
            id="models-search"
            class="control-search__input"
            type="search"
            placeholder="name, provider, api id, notes, lineage..."
          />
        </label>

        <label class="control-select">
          <span class="control-search__label">sort</span>
          <select id="models-sort" class="control-select__input">
            <option value="recommended">Recommended</option>
            <option value="newest">Newest release</option>
            <option value="oldest">Oldest release</option>
            <option value="context">Longest context</option>
            <option value="output">Largest output</option>
            <option value="cheapest-total">Cheapest total price</option>
            <option value="cheapest-input">Cheapest input price</option>
            <option value="provider">Provider A-Z</option>
            <option value="name">Name A-Z</option>
          </select>
        </label>

        <button id="models-reset" class="models-btn models-btn--ghost models-btn--small" type="button">Reset filters</button>
      </div>

      <div class="filter-group">
        <span class="filter-group__label">Provider</span>
        <div class="chip-row" data-group="provider">
          {providers.map((provider) => (
            <button class="filter-chip" type="button" data-group="provider" data-value={provider}>{provider}</button>
          ))}
        </div>
      </div>

      <div class="filter-group">
        <span class="filter-group__label">Lifecycle</span>
        <div class="chip-row" data-group="status">
          {statuses.map((status) => (
            <button class="filter-chip" type="button" data-group="status" data-value={status}>{status}</button>
          ))}
        </div>
      </div>

      <div class="filter-group">
        <span class="filter-group__label">Type</span>
        <div class="chip-row" data-group="type">
          {types.map((type) => (
            <button class="filter-chip" type="button" data-group="type" data-value={type}>{type}</button>
          ))}
        </div>
      </div>

      <div class="filters-grid">
        <div class="filter-group">
          <span class="filter-group__label">Vision</span>
          <div class="chip-row chip-row--compact">
            <button class="filter-chip is-active" type="button" data-boolean="vision" data-value="any">Any</button>
            <button class="filter-chip" type="button" data-boolean="vision" data-value="yes">Yes</button>
            <button class="filter-chip" type="button" data-boolean="vision" data-value="no">No</button>
          </div>
        </div>

        <div class="filter-group">
          <span class="filter-group__label">Function calling</span>
          <div class="chip-row chip-row--compact">
            <button class="filter-chip is-active" type="button" data-boolean="function" data-value="any">Any</button>
            <button class="filter-chip" type="button" data-boolean="function" data-value="yes">Yes</button>
            <button class="filter-chip" type="button" data-boolean="function" data-value="no">No</button>
          </div>
        </div>

        <div class="filter-group">
          <span class="filter-group__label">Pricing</span>
          <div class="chip-row chip-row--compact">
            <button class="filter-chip is-active" type="button" data-boolean="pricing" data-value="any">Any</button>
            <button class="filter-chip" type="button" data-boolean="pricing" data-value="listed">Listed</button>
            <button class="filter-chip" type="button" data-boolean="pricing" data-value="missing">Missing</button>
          </div>
        </div>

        <div class="filter-group">
          <span class="filter-group__label">Context</span>
          <div class="chip-row chip-row--compact">
            <button class="filter-chip is-active" type="button" data-boolean="context" data-value="any">Any</button>
            <button class="filter-chip" type="button" data-boolean="context" data-value="0-128k">≤128K</button>
            <button class="filter-chip" type="button" data-boolean="context" data-value="129k-512k">129K-512K</button>
            <button class="filter-chip" type="button" data-boolean="context" data-value="513k-1m">513K-1M</button>
            <button class="filter-chip" type="button" data-boolean="context" data-value="gt-1m">{">"}1M</button>
            <button class="filter-chip" type="button" data-boolean="context" data-value="unknown">Unknown</button>
          </div>
        </div>

        <div class="filter-group">
          <span class="filter-group__label">Output</span>
          <div class="chip-row chip-row--compact">
            <button class="filter-chip is-active" type="button" data-boolean="output" data-value="any">Any</button>
            <button class="filter-chip" type="button" data-boolean="output" data-value="0-8k">≤8K</button>
            <button class="filter-chip" type="button" data-boolean="output" data-value="9k-32k">9K-32K</button>
            <button class="filter-chip" type="button" data-boolean="output" data-value="33k-64k">33K-64K</button>
            <button class="filter-chip" type="button" data-boolean="output" data-value="gt-64k">{">"}64K</button>
            <button class="filter-chip" type="button" data-boolean="output" data-value="unknown">Unknown</button>
          </div>
        </div>
      </div>
    </div>

    <div class="cards-grid" id="models-grid">
      {models.map((model, index) => {
        const accent = brandColors[model.provider] || "#a855f7";
        return (
          <article
            class="model-card"
            style={`--accent:${accent};--type:${typeColors[model.type] || "#888"};--status:${statusColors[model.status] || "#888"};`}
            data-rank={index}
            data-name={model.name.toLowerCase()}
            data-provider={model.provider}
            data-status={model.status}
            data-type={model.type}
            data-vision={model.vision ? "yes" : "no"}
            data-function={model.function_calling ? "yes" : "no"}
            data-pricing={model.primaryPrice ? "listed" : "missing"}
            data-context={contextBucket(model.contextTokens)}
            data-output={outputBucket(model.outputTokens)}
            data-released={model.releaseTs}
            data-context-value={model.contextTokens ?? -1}
            data-output-value={model.outputTokens ?? -1}
            data-total-price={model.totalPrice ?? 999999}
            data-input-price={model.inputPrice ?? 999999}
            data-search={model.searchText}
          >
            <div class="model-card__head">
              <div>
                <div class="model-card__provider">{model.provider}</div>
                <h3 class="model-card__name">{model.name}</h3>
              </div>
              <div class="model-card__badges">
                <span class="model-pill model-pill--status">{model.status}</span>
                <span class="model-pill model-pill--type">{model.type}</span>
              </div>
            </div>

            <p class="model-card__desc">{model.description ?? model.notes ?? "No description yet."}</p>

            <div class="model-card__metrics">
              <div class="metric">
                <span class="metric__label">Context</span>
                <span class="metric__value">{model.context ?? "Unknown"}</span>
              </div>
              <div class="metric">
                <span class="metric__label">Max output</span>
                <span class="metric__value">{model.max_output ?? "Unknown"}</span>
              </div>
              <div class="metric">
                <span class="metric__label">Pricing /1M tok</span>
                <span class="metric__value">{pricingSummary(model)}</span>
              </div>
              <div class="metric">
                <span class="metric__label">Released</span>
                <span class="metric__value">{formatDate(model.released)}</span>
              </div>
            </div>

            <div class="model-card__meta">
              <span>API: <code>{model.api_id}</code></span>
              <span>Vision: {model.vision ? "Yes" : "No"}</span>
              <span>Functions: {model.function_calling ? "Yes" : "No"}</span>
              <span>Cutoff: {model.knowledge_cutoff ?? "Unknown"}</span>
            </div>

            {(model.predecessor || model.successor || model.deprecated_date) && (
              <div class="lineage-box">
                <div class="lineage-box__label">Lifecycle</div>
                <div class="lineage-box__items">
                  {model.predecessor && <span>Predecessor: <code>{model.predecessor}</code></span>}
                  {model.successor && <span>Successor: <code>{model.successor}</code></span>}
                  {model.deprecated_date && <span>Retires: {formatDate(model.deprecated_date)}</span>}
                </div>
              </div>
            )}

            {model.confidenceFlags.length > 0 && (
              <div class="confidence-box">
                <div class="confidence-box__label">Data caveats</div>
                <div class="confidence-box__items">
                  {model.confidenceFlags.slice(0, 3).map((flag) => <span>{flag}</span>)}
                </div>
              </div>
            )}

            <div class="model-card__provider-link">
              <a href={`/models/${providerSlug(model.provider)}/`} class="provider-link">
                All {model.provider} models →
              </a>
            </div>
          </article>
        );
      })}
    </div>

    <div id="models-empty" class="empty-state" hidden>
      <h3>No models match the current filters.</h3>
      <p>Loosen one of the capability or lifecycle filters, or clear search and start broader.</p>
    </div>
  </section>

  <section class="models-cta">
    <div>
      <div class="models-label">// next</div>
      <h2 class="models-section__title">Need change history?</h2>
      <p class="models-section__note">
        The model timeline now tracks releases and retirements across providers in reverse chronological order.
      </p>
    </div>
    <a href="/models/changelog/" class="models-btn">Open model changelog</a>
  </section>
</HubLayout>

<script is:inline>
  (function () {
    const grid = document.getElementById("models-grid");
    const count = document.getElementById("models-count");
    const empty = document.getElementById("models-empty");
    const searchInput = document.getElementById("models-search");
    const sortSelect = document.getElementById("models-sort");
    const resetButton = document.getElementById("models-reset");

    if (!grid || !count || !empty || !searchInput || !sortSelect || !resetButton) {
      return;
    }

    const cards = Array.from(grid.querySelectorAll(".model-card"));
    const state = {
      search: "",
      sort: "recommended",
      provider: new Set(),
      status: new Set(),
      type: new Set(),
      vision: "any",
      function: "any",
      pricing: "any",
      context: "any",
      output: "any",
    };

    function sortCards(items) {
      const sorted = [...items];
      sorted.sort((a, b) => {
        const aName = a.dataset.name || "";
        const bName = b.dataset.name || "";
        const aProvider = a.dataset.provider || "";
        const bProvider = b.dataset.provider || "";
        const numeric = (node, key) => Number(node.dataset[key] || 0);

        switch (state.sort) {
          case "newest":
            return numeric(b, "released") - numeric(a, "released") || aName.localeCompare(bName);
          case "oldest":
            return numeric(a, "released") - numeric(b, "released") || aName.localeCompare(bName);
          case "context":
            return numeric(b, "contextValue") - numeric(a, "contextValue") || aName.localeCompare(bName);
          case "output":
            return numeric(b, "outputValue") - numeric(a, "outputValue") || aName.localeCompare(bName);
          case "cheapest-total":
            return numeric(a, "totalPrice") - numeric(b, "totalPrice") || aName.localeCompare(bName);
          case "cheapest-input":
            return numeric(a, "inputPrice") - numeric(b, "inputPrice") || aName.localeCompare(bName);
          case "provider":
            return aProvider.localeCompare(bProvider) || aName.localeCompare(bName);
          case "name":
            return aName.localeCompare(bName);
          default:
            return numeric(a, "rank") - numeric(b, "rank");
        }
      });

      sorted.forEach((card) => grid.appendChild(card));
    }

    function matchesSetFilter(set, value) {
      return set.size === 0 || set.has(value);
    }

    function applyFilters() {
      const query = state.search.trim().toLowerCase();
      let visible = 0;
      const visibleCards = [];

      cards.forEach((card) => {
        const matches =
          (!query || (card.dataset.search || "").includes(query)) &&
          matchesSetFilter(state.provider, card.dataset.provider) &&
          matchesSetFilter(state.status, card.dataset.status) &&
          matchesSetFilter(state.type, card.dataset.type) &&
          (state.vision === "any" || card.dataset.vision === state.vision) &&
          (state.function === "any" || card.dataset.function === state.function) &&
          (state.pricing === "any" || card.dataset.pricing === state.pricing) &&
          (state.context === "any" || card.dataset.context === state.context) &&
          (state.output === "any" || card.dataset.output === state.output);

        card.hidden = !matches;
        if (matches) {
          visible += 1;
          visibleCards.push(card);
        }
      });

      sortCards(visibleCards);
      count.textContent = String(visible);
      empty.hidden = visible !== 0;
    }

    function toggleSetFilter(group, value) {
      if (state[group].has(value)) {
        state[group].delete(value);
      } else {
        state[group].add(value);
      }
      applyFilters();
    }

    searchInput.addEventListener("input", (event) => {
      const target = event.target;
      if (!(target instanceof HTMLInputElement)) {
        return;
      }
      state.search = target.value;
      applyFilters();
    });

    sortSelect.addEventListener("change", (event) => {
      const target = event.target;
      if (!(target instanceof HTMLSelectElement)) {
        return;
      }
      state.sort = target.value;
      applyFilters();
    });

    document.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof Element)) {
        return;
      }

      const button = target.closest(".filter-chip");
      if (!button) {
        return;
      }

      const group = button.dataset.group;
      const booleanGroup = button.dataset.boolean;
      const value = button.dataset.value;

      if (group && value) {
        button.classList.toggle("is-active");
        toggleSetFilter(group, value);
        return;
      }

      if (booleanGroup && value) {
        document
          .querySelectorAll(`.filter-chip[data-boolean="${booleanGroup}"]`)
          .forEach((node) => node.classList.remove("is-active"));
        button.classList.add("is-active");
        state[booleanGroup] = value;
        applyFilters();
      }
    });

    resetButton.addEventListener("click", () => {
      state.search = "";
      state.sort = "recommended";
      state.provider.clear();
      state.status.clear();
      state.type.clear();
      state.vision = "any";
      state.function = "any";
      state.pricing = "any";
      state.context = "any";
      state.output = "any";

      searchInput.value = "";
      sortSelect.value = "recommended";
      document.querySelectorAll(".filter-chip").forEach((node) => {
        const isBooleanAny = node.dataset.boolean && node.dataset.value === "any";
        node.classList.toggle("is-active", Boolean(isBooleanAny));
      });
      applyFilters();
    });

    applyFilters();
  })();
</script>

<style is:global>
  .models-hero,
  .models-section,
  .models-cta {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .models-hero {
    padding-top: 4.5rem;
    padding-bottom: 2rem;
  }

  .models-hero__eyebrow,
  .models-label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--hub-font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--models-accent);
  }

  .models-hero__dot {
    width: 8px;
    height: 8px;
    background: var(--models-accent);
  }

  .models-hero__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.45fr) minmax(320px, 0.85fr);
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  .models-hero__copy,
  .models-hero__stats,
  .featured-card,
  .confidence-card,
  .controls-shell,
  .model-card,
  .models-cta {
    border: 4px solid var(--models-border);
    background: var(--models-card);
    box-shadow: var(--models-shadow);
  }

  .models-hero__copy {
    padding: 2rem;
    background:
      linear-gradient(135deg, rgba(0, 145, 247, 0.14), transparent 55%),
      linear-gradient(0deg, var(--models-card), var(--models-card));
  }

  .models-hero__title {
    font-family: var(--hub-font-head);
    font-size: clamp(3rem, 7vw, 5.5rem);
    line-height: 0.95;
    letter-spacing: -0.05em;
    margin-top: 1rem;
  }

  .models-hero__sub,
  .models-section__note,
  .model-card__desc,
  .confidence-card p,
  .featured-card__why,
  .empty-state p {
    color: var(--models-text-dim);
    font-size: 1rem;
    line-height: 1.7;
  }

  .models-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 1.5rem;
  }

  .models-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0.8rem 1.2rem;
    border: 3px solid var(--models-border);
    background: var(--models-accent);
    color: #ffffff;
    text-decoration: none;
    font-family: var(--hub-font-mono);
    font-size: 0.78rem;
