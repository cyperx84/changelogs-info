---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { MODELS_SECTION } from "../../lib/sections";

const s = MODELS_SECTION;

const providers = [
  { name: "Anthropic", models: ["Claude Opus 4.6", "Claude Sonnet 4.6", "Claude Haiku 4.5"], color: "#ffb800", status: "tracking" },
  { name: "OpenAI", models: ["GPT-5.4", "GPT-5.3 Codex", "o3-pro"], color: "#10a37f", status: "tracking" },
  { name: "Google", models: ["Gemini 3.1 Pro", "Gemini 3.1 Flash", "Gemini Flash Lite"], color: "#4285f4", status: "tracking" },
  { name: "ZAI (Moonshot)", models: ["Kimi K2.5", "Kimi Coding"], color: "#ff6b35", status: "planned" },
  { name: "DeepSeek", models: ["DeepSeek V3", "DeepSeek R1"], color: "#6366f1", status: "planned" },
  { name: "Meta", models: ["Llama 4 Scout", "Llama 4 Maverick"], color: "#0084ff", status: "planned" },
  { name: "Mistral", models: ["Codestral", "Mistral Large"], color: "#ff7000", status: "planned" },
  { name: "xAI", models: ["Grok 3"], color: "#1d9bf0", status: "planned" },
];
---

<BaseLayout title="Models — changelogs.info" description="Track AI model releases and updates across providers." section="models">
  <section
    class="relative overflow-hidden border-b"
    style={`border-color: rgba(${s.colorRgb}, 0.2); background: linear-gradient(135deg, rgba(${s.colorRgb}, 0.05) 0%, transparent 60%);`}
  >
    <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6 sm:py-14">
      <div class="max-w-2xl">
        <div class="mb-3 flex items-center gap-3">
          <span class="inline-block h-3 w-3 rounded-sm" style={`background: ${s.color}; box-shadow: 0 0 12px ${s.color};`}></span>
          <span class="font-mono text-xs uppercase tracking-widest text-text-muted">section</span>
        </div>
        <h1 class="font-mono text-3xl font-bold sm:text-4xl" style={`color: ${s.color};`}>Models</h1>
        <p class="mt-3 font-sans text-sm leading-relaxed text-text-secondary sm:text-base">
          Track AI model releases, capabilities, and version changes across providers. Model tracking coming soon — here's what we'll cover.
        </p>
      </div>
    </div>
  </section>

  <div class="mx-auto max-w-6xl px-4 py-8 sm:px-6 sm:py-12">
    <div class="mb-6 flex items-center justify-between">
      <h2 class="font-mono text-base font-semibold text-text-primary">
        <span style={`color: ${s.color};`}>/</span>providers
      </h2>
      <span class="font-mono text-xs text-text-muted">{providers.length} providers</span>
    </div>

    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
      {providers.map((provider) => (
        <div class="rounded-lg border border-border bg-bg-card p-4 transition-all hover:border-opacity-60" style={`border-left: 3px solid ${provider.color};`}>
          <div class="flex items-center justify-between mb-3">
            <h3 class="font-mono text-sm font-bold text-text-primary">{provider.name}</h3>
            {provider.status === "tracking" ? (
              <span class="flex items-center gap-1.5 rounded-full border border-green/30 bg-green/10 px-2 py-0.5 font-mono text-[9px] text-green">
                <span class="pulse-dot inline-block h-1 w-1 rounded-full bg-green"></span>
                live
              </span>
            ) : (
              <span class="rounded-full border border-border px-2 py-0.5 font-mono text-[9px] text-text-muted">planned</span>
            )}
          </div>
          <div class="space-y-1">
            {provider.models.map((model) => (
              <p class="font-mono text-xs text-text-muted">
                <span style={`color: ${provider.color}; opacity: 0.6;`}>&rsaquo;</span> {model}
              </p>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- What we'll track -->
    <div class="mt-10 rounded-lg border border-border bg-bg-card p-5 sm:p-6">
      <h2 class="mb-4 font-mono text-sm font-semibold" style={`color: ${s.color};`}>
        <span class="opacity-60">//</span> what_we_track
      </h2>
      <div class="grid gap-4 sm:grid-cols-3">
        <div>
          <p class="mb-1 font-mono text-xs font-semibold text-text-primary">Version Changes</p>
          <p class="font-sans text-xs text-text-muted">New model releases, version bumps, deprecations</p>
        </div>
        <div>
          <p class="mb-1 font-mono text-xs font-semibold text-text-primary">Capability Updates</p>
          <p class="font-sans text-xs text-text-muted">Context windows, tool use, multimodal support</p>
        </div>
        <div>
          <p class="mb-1 font-mono text-xs font-semibold text-text-primary">Breaking Changes</p>
          <p class="font-sans text-xs text-text-muted">API changes, model ID swaps, sunset dates</p>
        </div>
      </div>
    </div>

    <div class="mt-6 rounded-lg border border-dashed border-border bg-bg-card p-6 text-center">
      <p class="font-mono text-xs text-text-muted">
        In the meantime, model-related changes are tracked within each tool's changelog.
      </p>
      <div class="mt-3 flex flex-wrap items-center justify-center gap-3 font-mono text-xs">
        <a href="/openclaw/" class="text-[#ff3333] transition-colors hover:opacity-80">OpenClaw</a>
        <span class="text-text-muted/30">|</span>
        <a href="/claude-code/" class="text-[#ffb800] transition-colors hover:opacity-80">Claude Code</a>
        <span class="text-text-muted/30">|</span>
        <a href="/codex-cli/" class="text-[#33ff33] transition-colors hover:opacity-80">Codex CLI</a>
      </div>
    </div>
  </div>
</BaseLayout>
