---
import HubLayout from "../../layouts/HubLayout.astro";
import "../../styles/models-vars.css";
import { formatDate, formatPrice, loadModelsData, providerSlug } from "../../lib/models";

const { models, providers, types, statuses, stats } = loadModelsData();

const brandColors: Record<string, string> = {
  Anthropic: "#ffb800",
  OpenAI: "#10a37f",
  Google: "#4285f4",
  DeepSeek: "#6366f1",
  xAI: "#1d9bf0",
  "Moonshot AI": "#a855f7",
  ZAI: "#ff6b35",
  Minimax: "#06b6d4",
  Meta: "#0668E1",
  Mistral: "#ff7000",
  Qwen: "#7c3aed",
};

const typeColors: Record<string, string> = {
  frontier: "#ef4444",
  balanced: "#f59e0b",
  fast: "#22c55e",
  reasoning: "#a855f7",
  coding: "#3b82f6",
  multimodal: "#ec4899",
  "open-weight": "#06b6d4",
};

const statusColors: Record<string, string> = {
  active: "#22c55e",
  preview: "#f59e0b",
  legacy: "#64748b",
  deprecated: "#ef4444",
};

const modelsByProvider = providers.map((provider) => ({
  provider,
  color: brandColors[provider] || "#a855f7",
  models: models.filter((m) => m.provider === provider),
}));

function pricingSummary(model: (typeof models)[number]): string {
  if (!model.primaryPrice) return "—";
  return `$${formatPrice(model.inputPrice)} / $${formatPrice(model.outputPrice)}`;
}
---

<HubLayout
  title="Models - changelogs.info"
  description="AI model directory — search and filter models across providers with pricing, context windows, and lifecycle state."
  currentSection="models"
>
  <!-- Header -->
  <div class="md-header">
    <div class="md-header__inner">
      <div class="md-header__copy">
        <h1 class="md-header__title">AI Model Directory</h1>
        <p class="md-header__sub">
          {stats.totalModels} models across {stats.totalProviders} providers
          · {stats.activeCount} live or preview · <a href="/models/changelog/" class="md-header__link">timeline →</a>
        </p>
      </div>
      <div class="md-header__stats">
        <div class="md-stat"><span class="md-stat__n">{stats.totalModels}</span><span class="md-stat__l">models</span></div>
        <div class="md-stat"><span class="md-stat__n">{stats.totalProviders}</span><span class="md-stat__l">providers</span></div>
        <div class="md-stat"><span class="md-stat__n">{stats.activeCount}</span><span class="md-stat__l">live</span></div>
      </div>
    </div>
  </div>

  <!-- Controls -->
  <div class="md-controls">
    <div class="md-controls__inner">
      <div class="md-search-row">
        <input
          id="md-search"
          class="md-search"
          type="search"
          placeholder="Search models, IDs, providers..."
          autocomplete="off"
        />
        <select id="md-sort" class="md-select">
          <option value="recommended">Recommended</option>
          <option value="newest">Newest first</option>
          <option value="oldest">Oldest first</option>
          <option value="context">Longest context</option>
          <option value="cheapest">Cheapest input</option>
          <option value="name">Name A–Z</option>
        </select>
        <button id="md-reset" class="md-reset-btn" type="button">Reset</button>
        <span class="md-count"><span id="md-visible-count">{models.length}</span> shown</span>
      </div>

      <div class="md-filter-row">
        <div class="md-filter-group">
          <span class="md-filter-label">Provider</span>
          <div class="md-chips" data-group="provider">
            {providers.map((p) => (
              <button class="md-chip" data-group="provider" data-value={p} type="button"
                style={`--chip-color:${brandColors[p] || "#a855f7"}`}>{p}</button>
            ))}
          </div>
        </div>

        <div class="md-filter-group">
          <span class="md-filter-label">Type</span>
          <div class="md-chips" data-group="type">
            {types.map((t) => (
              <button class="md-chip" data-group="type" data-value={t} type="button"
                style={`--chip-color:${typeColors[t] || "#888"}`}>{t}</button>
            ))}
          </div>
        </div>

        <div class="md-filter-group">
          <span class="md-filter-label">Status</span>
          <div class="md-chips" data-group="status">
            {statuses.map((s) => (
              <button class="md-chip" data-group="status" data-value={s} type="button"
                style={`--chip-color:${statusColors[s] || "#888"}`}>{s}</button>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Directory: grouped by provider -->
  <div class="md-directory" id="md-directory">
    {modelsByProvider.map(({ provider, color, models: providerModels }) => (
      <section class="md-provider-group" data-provider={provider} id={`provider-${providerSlug(provider)}`}>
        <header class="md-provider-head" style={`--pcolor:${color}`}>
          <span class="md-provider-dot"></span>
          <h2 class="md-provider-name">{provider}</h2>
          <a href={`/models/${providerSlug(provider)}/`} class="md-provider-link">
            All {provider} models →
          </a>
        </header>

        <div class="md-model-grid">
          {providerModels.map((model, idx) => (
            <article
              class="md-card"
              style={`--accent:${color};--type-color:${typeColors[model.type] || "#888"};--status-color:${statusColors[model.status] || "#888"};`}
              data-provider={model.provider}
              data-type={model.type}
              data-status={model.status}
              data-search={model.searchText}
              data-released={model.releaseTs}
              data-context-value={model.contextTokens ?? -1}
              data-input-price={model.inputPrice ?? 999999}
              data-rank={idx}
            >
              <div class="md-card__top">
                <div class="md-card__badges">
                  <span class="md-badge md-badge--type">{model.type}</span>
                  <span class="md-badge md-badge--status">{model.status}</span>
                </div>
              </div>

              <h3 class="md-card__name">{model.name}</h3>
              <code class="md-card__id">{model.api_id}</code>

              <div class="md-card__row">
                <span class="md-card__fact">
                  <span class="md-fact-label">Context</span>
                  <span class="md-fact-val">{model.context ?? "—"}</span>
                </span>
                <span class="md-card__fact">
                  <span class="md-fact-label">Output</span>
                  <span class="md-fact-val">{model.max_output ?? "—"}</span>
                </span>
                <span class="md-card__fact">
                  <span class="md-fact-label">Pricing /1M</span>
                  <span class="md-fact-val">{pricingSummary(model)}</span>
                </span>
              </div>

              {model.description && (
                <p class="md-card__desc">{model.description}</p>
              )}

              <div class="md-card__foot">
                <span class="md-card__date">Released {formatDate(model.released)}</span>
                {model.vision && <span class="md-card__cap">Vision</span>}
                {model.function_calling && <span class="md-card__cap">Functions</span>}
              </div>
            </article>
          ))}
        </div>
      </section>
    ))}

    <div id="md-empty" class="md-empty" hidden>
      <p>No models match — try broadening your filters or clearing search.</p>
      <button class="md-reset-btn" onclick="document.getElementById('md-reset').click()">Clear filters</button>
    </div>
  </div>
</HubLayout>

<script is:inline>
(function () {
  const searchInput = document.getElementById("md-search");
  const sortSelect = document.getElementById("md-sort");
  const resetBtn = document.getElementById("md-reset");
  const countEl = document.getElementById("md-visible-count");
  const emptyEl = document.getElementById("md-empty");

  if (!searchInput || !sortSelect || !resetBtn) return;

  const state = {
    search: "",
    sort: "recommended",
    provider: new Set(),
    type: new Set(),
    status: new Set(),
  };

  const allCards = Array.from(document.querySelectorAll(".md-card"));

  function applyFilters() {
    const q = state.search.trim().toLowerCase();
    let visible = 0;

    allCards.forEach((card) => {
      const show =
        (!q || (card.dataset.search || "").includes(q)) &&
        (state.provider.size === 0 || state.provider.has(card.dataset.provider)) &&
        (state.type.size === 0 || state.type.has(card.dataset.type)) &&
        (state.status.size === 0 || state.status.has(card.dataset.status));

      card.hidden = !show;
      if (show) visible++;
    });

    // Show/hide provider group headers
    document.querySelectorAll(".md-provider-group").forEach((group) => {
      const anyVisible = group.querySelector(".md-card:not([hidden])");
      group.hidden = !anyVisible;
    });

    if (countEl) countEl.textContent = String(visible);
    if (emptyEl) emptyEl.hidden = visible > 0;
  }

  function sortCards() {
    document.querySelectorAll(".md-model-grid").forEach((grid) => {
      const cards = Array.from(grid.querySelectorAll(".md-card"));
      cards.sort((a, b) => {
        const num = (el, key) => Number(el.dataset[key] || 0);
        switch (state.sort) {
          case "newest": return num(b, "released") - num(a, "released");
          case "oldest": return num(a, "released") - num(b, "released");
          case "context": return num(b, "contextValue") - num(a, "contextValue");
          case "cheapest": return num(a, "inputPrice") - num(b, "inputPrice");
          case "name": return (a.querySelector(".md-card__name")?.textContent || "").localeCompare(b.querySelector(".md-card__name")?.textContent || "");
          default: return num(a, "rank") - num(b, "rank");
        }
      });
      cards.forEach((c) => grid.appendChild(c));
    });
  }

  function update() {
    sortCards();
    applyFilters();
  }

  searchInput.addEventListener("input", (e) => {
    state.search = e.target.value;
    update();
  });

  sortSelect.addEventListener("change", (e) => {
    state.sort = e.target.value;
    update();
  });

  document.addEventListener("click", (e) => {
    const chip = e.target.closest(".md-chip");
    if (!chip) return;
    const group = chip.dataset.group;
    const val = chip.dataset.value;
    if (!group || !val) return;

    chip.classList.toggle("md-chip--active");
    if (state[group].has(val)) state[group].delete(val);
    else state[group].add(val);
    update();
  });

  resetBtn.addEventListener("click", () => {
    state.search = "";
    state.sort = "recommended";
    state.provider.clear();
    state.type.clear();
    state.status.clear();
    searchInput.value = "";
    sortSelect.value = "recommended";
    document.querySelectorAll(".md-chip--active").forEach((c) => c.classList.remove("md-chip--active"));
    update();
  });

  update();
})();
</script>

<style is:global>
  /* ── Layout shell ── */
  .md-header,
  .md-controls,
  .md-directory {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ── Header ── */
  .md-header {
    padding-top: 3.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 2px solid var(--models-border);
    margin-bottom: 0;
  }
  .md-header__inner {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .md-header__title {
    font-family: var(--hub-font-headline);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 900;
    color: var(--hub-text);
    margin: 0 0 0.25rem;
    letter-spacing: -0.02em;
  }
  .md-header__sub {
    font-family: var(--hub-font-mono);
    font-size: 0.8rem;
    color: var(--hub-text-dim);
    margin: 0;
  }
  .md-header__link {
    color: var(--models-accent);
    text-decoration: none;
  }
  .md-header__link:hover { text-decoration: underline; }
  .md-header__stats {
    display: flex;
    gap: 1.5rem;
    flex-shrink: 0;
  }
  .md-stat {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.1rem;
  }
  .md-stat__n {
    font-family: var(--hub-font-headline);
    font-size: 1.6rem;
    font-weight: 900;
    color: var(--models-accent);
    line-height: 1;
  }
  .md-stat__l {
    font-family: var(--hub-font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--hub-text-muted);
  }

  /* ── Controls ── */
  .md-controls {
    position: sticky;
    top: 56px;
    z-index: 40;
    background: var(--hub-bg);
    border-bottom: 2px solid var(--models-border);
    padding-top: 0.875rem;
    padding-bottom: 0.875rem;
  }
  .md-controls__inner {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .md-search-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .md-search {
    flex: 1 1 240px;
    min-width: 160px;
    padding: 0.45rem 0.75rem;
    background: var(--models-card);
    border: 2px solid var(--models-border);
    color: var(--hub-text);
    font-family: var(--hub-font-mono);
    font-size: 0.8rem;
    outline: none;
  }
  .md-search:focus { border-color: var(--models-accent); }
  .md-select {
    padding: 0.45rem 0.6rem;
    background: var(--models-card);
    border: 2px solid var(--models-border);
    color: var(--hub-text);
    font-family: var(--hub-font-mono);
    font-size: 0.75rem;
    cursor: pointer;
  }
  .md-reset-btn {
    padding: 0.4rem 0.9rem;
    background: transparent;
    border: 2px solid var(--models-border);
    color: var(--hub-text-dim);
    font-family: var(--hub-font-mono);
    font-size: 0.75rem;
    cursor: pointer;
    white-space: nowrap;
  }
  .md-reset-btn:hover { border-color: var(--models-accent); color: var(--models-accent); }
  .md-count {
    font-family: var(--hub-font-mono);
    font-size: 0.75rem;
    color: var(--hub-text-muted);
    white-space: nowrap;
    margin-left: auto;
  }
  .md-filter-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.5rem;
    align-items: flex-start;
  }
  .md-filter-group {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .md-filter-label {
    font-family: var(--hub-font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--hub-text-muted);
    white-space: nowrap;
  }
  .md-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }
  .md-chip {
    padding: 0.2rem 0.65rem;
    border: 1.5px solid var(--models-border);
    background: transparent;
    color: var(--hub-text-dim);
    font-family: var(--hub-font-mono);
    font-size: 0.7rem;
    cursor: pointer;
    transition: border-color 100ms, color 100ms, background 100ms;
    white-space: nowrap;
  }
  .md-chip:hover {
    border-color: var(--chip-color, var(--models-accent));
    color: var(--chip-color, var(--models-accent));
  }
  .md-chip--active {
    background: var(--chip-color, var(--models-accent));
    border-color: var(--chip-color, var(--models-accent));
    color: var(--models-bg);
  }

  /* ── Directory ── */
  .md-directory {
    padding-top: 2rem;
    padding-bottom: 4rem;
  }

  /* ── Provider group ── */
  .md-provider-group {
    margin-bottom: 2.5rem;
  }
  .md-provider-head {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 0;
    border-bottom: 3px solid var(--pcolor);
    margin-bottom: 1rem;
  }
  .md-provider-dot {
    width: 10px;
    height: 10px;
    background: var(--pcolor);
    border-radius: 50%;
    flex-shrink: 0;
  }
  .md-provider-name {
    font-family: var(--hub-font-headline);
    font-size: 1rem;
    font-weight: 900;
    color: var(--hub-text);
    margin: 0;
    letter-spacing: -0.01em;
  }
  .md-provider-link {
    margin-left: auto;
    font-family: var(--hub-font-mono);
    font-size: 0.7rem;
    color: var(--pcolor);
    text-decoration: none;
    opacity: 0.7;
  }
  .md-provider-link:hover { opacity: 1; }

  /* ── Model card grid ── */
  .md-model-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1px;
    border: 2px solid var(--models-border);
  }

  /* ── Model card ── */
  .md-card {
    padding: 1rem;
    background: var(--models-card);
    border-right: 1px solid var(--models-border);
    border-bottom: 1px solid var(--models-border);
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    position: relative;
    transition: background 120ms;
  }
  .md-card:hover {
    background: color-mix(in srgb, var(--accent) 6%, var(--models-card));
  }
  .md-card::before {
    content: "";
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--accent);
    opacity: 0;
    transition: opacity 120ms;
  }
  .md-card:hover::before { opacity: 1; }

  .md-card__top {
    display: flex;
    align-items: flex-start;
    justify-content: flex-end;
  }
  .md-card__badges {
    display: flex;
    gap: 0.3rem;
    flex-wrap: wrap;
  }
  .md-badge {
    font-family: var(--hub-font-mono);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.15rem 0.45rem;
    border-radius: 2px;
  }
  .md-badge--type {
    background: color-mix(in srgb, var(--type-color) 18%, transparent);
    color: var(--type-color);
    border: 1px solid color-mix(in srgb, var(--type-color) 40%, transparent);
  }
  .md-badge--status {
    background: color-mix(in srgb, var(--status-color) 15%, transparent);
    color: var(--status-color);
    border: 1px solid color-mix(in srgb, var(--status-color) 35%, transparent);
  }

  .md-card__name {
    font-family: var(--hub-font-headline);
    font-size: 0.95rem;
    font-weight: 800;
    color: var(--hub-text);
    margin: 0;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }
  .md-card__id {
    font-family: var(--hub-font-mono);
    font-size: 0.65rem;
    color: var(--hub-text-muted);
    background: none;
    padding: 0;
  }
  .md-card__row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1rem;
    margin-top: 0.25rem;
  }
  .md-card__fact {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .md-fact-label {
    font-family: var(--hub-font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--hub-text-muted);
  }
  .md-fact-val {
    font-family: var(--hub-font-mono);
    font-size: 0.75rem;
    color: var(--hub-text);
    font-weight: 600;
  }
  .md-card__desc {
    font-size: 0.75rem;
    color: var(--hub-text-dim);
    margin: 0.25rem 0 0;
    line-height: 1.45;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .md-card__foot {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: auto;
    padding-top: 0.5rem;
    border-top: 1px solid var(--models-border);
  }
  .md-card__date {
    font-family: var(--hub-font-mono);
    font-size: 0.65rem;
    color: var(--hub-text-muted);
    flex: 1;
  }
  .md-card__cap {
    font-family: var(--hub-font-mono);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--models-accent);
    padding: 0.1rem 0.4rem;
    border: 1px solid var(--models-border);
  }

  /* ── Empty state ── */
  .md-empty {
    padding: 4rem 2rem;
    text-align: center;
    border: 2px dashed var(--models-border);
    color: var(--hub-text-dim);
    font-family: var(--hub-font-mono);
    font-size: 0.85rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .md-header__stats { display: none; }
    .md-model-grid { grid-template-columns: 1fr; }
    .md-filter-row { gap: 0.5rem 1rem; }
  }
</style>
