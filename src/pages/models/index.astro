---
import HubLayout from "../../layouts/HubLayout.astro";
import fs from "node:fs";
import path from "node:path";

const modelsDir = path.join(process.cwd(), "src/content/models");
const files = fs.readdirSync(modelsDir).filter(f => f.endsWith(".json"));
const providers = files.map(f => JSON.parse(fs.readFileSync(path.join(modelsDir, f), "utf-8")));

const totalModels = providers.reduce((sum, p) => sum + p.models.length, 0);
const totalProviders = providers.length;

const brandColors: Record<string, string> = {
  "Anthropic": "#ffb800",
  "OpenAI": "#10a37f",
  "Google": "#4285f4",
  "DeepSeek": "#6366f1",
  "xAI": "#1d9bf0",
  "Moonshot": "#a855f7",
  "ZAI": "#ff6b35",
  "Minimax": "#06b6d4",
  "Meta": "#0668E1",
  "Mistral": "#ff7000",
  "Qwen": "#7c3aed",
};

const typeColors: Record<string, string> = {
  frontier: "#ef4444",
  balanced: "#f59e0b",
  fast: "#22c55e",
  reasoning: "#a855f7",
  coding: "#3b82f6",
  "open-weight": "#06b6d4",
};
---

<HubLayout title="Models — changelogs.info" description="Every AI model. Every update. Every provider.">

  <!-- Hero -->
  <section class="m-hero">
    <div class="m-hero__eyebrow">
      <span class="m-hero__dot"></span>
      AI Model Tracker
    </div>
    <h1 class="m-hero__title">
      <span class="m-hero__glitch" data-text="MODELS">MODELS</span>
    </h1>
    <p class="m-hero__sub">Every model. Every update. Every provider.</p>
    <div class="m-hero__stats">
      <div class="m-hero__stat">
        <span class="m-hero__stat-num">{totalModels}</span>
        <span class="m-hero__stat-label">models</span>
      </div>
      <div class="m-hero__stat-divider"></div>
      <div class="m-hero__stat">
        <span class="m-hero__stat-num">{totalProviders}</span>
        <span class="m-hero__stat-label">providers</span>
      </div>
      <div class="m-hero__stat-divider"></div>
      <div class="m-hero__stat">
        <span class="m-hero__stat-dot"></span>
        <span class="m-hero__stat-label">Updated daily</span>
      </div>
    </div>
  </section>

  <!-- Providers -->
  <section class="m-section">
    <div class="m-label">// providers</div>
    <div class="m-grid">
      {providers.map((p) => {
        const color = brandColors[p.provider] || "#a855f7";
        return (
          <div class="m-card" style={`--accent: ${color};`}>
            <div class="m-card__stripe"></div>
            <div class="m-card__head">
              <div class="m-card__icon" style={`background: ${color};`}>{p.provider[0]}</div>
              <div class="m-card__info">
                <h3 class="m-card__name">{p.provider.toUpperCase()}</h3>
                <span class="m-card__badge">{p.models.length} models</span>
              </div>
            </div>
            <div class="m-card__list">
              {p.models.map((m: any) => (
                <div class="m-model">
                  <div class="m-model__row">
                    <span class="m-model__name">{m.name}</span>
                    <span class="m-model__type" style={`--tc: ${typeColors[m.type] || '#888'};`}>{m.type}</span>
                  </div>
                  <div class="m-model__meta">
                    <span>{m.context} ctx</span>
                    <span class="m-model__sep">·</span>
                    <span>{m.released}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </section>

  <!-- What Changes -->
  <section class="m-section">
    <div class="m-label">// what_changes</div>
    <div class="m-stats">
      <div class="m-stat-box">
        <div class="m-stat-box__icon">▲</div>
        <div class="m-stat-box__title">NEW MODELS</div>
        <div class="m-stat-box__desc">Fresh releases and launches</div>
      </div>
      <div class="m-stat-box">
        <div class="m-stat-box__icon">◆</div>
        <div class="m-stat-box__title">CAPABILITY UPDATES</div>
        <div class="m-stat-box__desc">Context, tools, multimodal</div>
      </div>
      <div class="m-stat-box">
        <div class="m-stat-box__icon">★</div>
        <div class="m-stat-box__title">BREAKING CHANGES</div>
        <div class="m-stat-box__desc">API shifts, deprecations</div>
      </div>
      <div class="m-stat-box">
        <div class="m-stat-box__icon">$</div>
        <div class="m-stat-box__title">PRICING SHIFTS</div>
        <div class="m-stat-box__desc">Cost changes, new tiers</div>
      </div>
    </div>
  </section>

  <!-- Roadmap -->
  <section class="m-section">
    <div class="m-label">// roadmap</div>
    <div class="m-terminal">
      <div class="m-terminal__bar">
        <span class="m-terminal__dot" style="background:#ef4444;"></span>
        <span class="m-terminal__dot" style="background:#f59e0b;"></span>
        <span class="m-terminal__dot" style="background:#22c55e;"></span>
        <span class="m-terminal__title">coming_soon.sh</span>
      </div>
      <div class="m-terminal__body">
        <p class="m-terminal__line"><span class="m-terminal__prompt">$</span> Model changelog timeline — per-model version history with diffs</p>
        <p class="m-terminal__line"><span class="m-terminal__prompt">$</span> Comparison tools — side-by-side model benchmarks</p>
        <p class="m-terminal__line"><span class="m-terminal__prompt">$</span> Pricing tracker — real-time cost monitoring across providers</p>
        <p class="m-terminal__line"><span class="m-terminal__prompt">$</span> <span class="m-terminal__blink">_</span></p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="m-cta">
    <p class="m-cta__text">Model changes are also tracked within each tool's changelog.</p>
    <div class="m-cta__links">
      <a href="/openclaw/" class="m-cta__link" style="color: #eb0000;">OpenClaw</a>
      <span class="m-cta__sep">|</span>
      <a href="/claude-code/" class="m-cta__link" style="color: #f59e0b;">Claude Code</a>
      <span class="m-cta__sep">|</span>
      <a href="/codex-cli/" class="m-cta__link" style="color: #00c851;">Codex</a>
      <span class="m-cta__sep">|</span>
      <a href="/gemini-cli/" class="m-cta__link" style="color: #4285f4;">Gemini CLI</a>
    </div>
    <div class="m-cta__bottom">
      <a href="/models/changelog/" class="m-cta__rss">Model Changelog →</a>
      <a href="/rss.xml" class="m-cta__rss">RSS Feed</a>
    </div>
  </section>

</HubLayout>

<style is:global>
  :root,
  [data-theme="light"] {
    --m-bg: #f8fbff;
    --m-bg-card: #ffffff;
    --m-bg-surface: #f0f0f0;
    --m-text: #0a0a0a;
    --m-text-dim: #3a3a3a;
    --m-text-muted: #6a6a6a;
    --m-border: #0a0a0a;
    --m-border-dim: rgba(10,10,10,0.15);
    --m-shadow: 6px 6px 0px 0px rgba(10,10,10,0.9);
    --m-shadow-hover: 9px 9px 0px 0px rgba(10,10,10,1);
    --m-accent: #a855f7;
  }
  [data-theme="dark"] {
    --m-bg: #0a0a0a;
    --m-bg-card: #111111;
    --m-bg-surface: #1a1a1a;
    --m-text: #f0f0f0;
    --m-text-dim: #b0b0b0;
    --m-text-muted: #707070;
    --m-border: #f0f0f0;
    --m-border-dim: rgba(240,240,240,0.15);
    --m-shadow: 6px 6px 0px 0px rgba(240,240,240,0.12);
    --m-shadow-hover: 9px 9px 0px 0px rgba(240,240,240,0.15);
    --m-accent: #a855f7;
  }

  /* Hero */
  .m-hero {
    max-width: 1280px;
    margin: 0 auto;
    padding: 5rem 2rem 3rem;
    text-align: center;
  }
  .m-hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--m-accent);
    margin-bottom: 1.5rem;
  }
  .m-hero__dot {
    width: 8px; height: 8px;
    background: var(--m-accent);
  }
  .m-hero__title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(4rem, 12vw, 8rem);
    font-weight: 900;
    letter-spacing: -0.06em;
    line-height: 0.85;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }
  .m-hero__glitch {
    position: relative;
    color: var(--m-text);
    display: inline-block;
  }
  .m-hero__glitch::before,
  .m-hero__glitch::after {
    content: attr(data-text);
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    pointer-events: none;
  }
  .m-hero__glitch::before {
    color: var(--m-accent);
    clip-path: inset(0 0 65% 0);
    transform: translate(-3px, -2px);
    opacity: 0.7;
  }
  .m-hero__glitch::after {
    color: #ef4444;
    clip-path: inset(60% 0 0 0);
    transform: translate(3px, 2px);
    opacity: 0.5;
  }
  .m-hero__sub {
    font-family: 'JetBrains Mono', monospace;
    font-size: 1rem;
    color: var(--m-text-dim);
    margin-bottom: 2rem;
  }
  .m-hero__stats {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    background: var(--m-bg-card);
    border: 4px solid var(--m-border);
    box-shadow: var(--m-shadow);
    padding: 1rem 2rem;
  }
  .m-hero__stat {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .m-hero__stat-num {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.8rem;
    font-weight: 900;
    color: var(--m-accent);
  }
  .m-hero__stat-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--m-text-muted);
  }
  .m-hero__stat-dot {
    width: 8px; height: 8px;
    background: #22c55e;
    animation: m-pulse 2s ease-in-out infinite;
  }
  .m-hero__stat-divider {
    width: 4px; height: 28px;
    background: var(--m-border-dim);
  }
  @keyframes m-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  /* Sections */
  .m-section {
    max-width: 1280px;
    margin: 0 auto;
    padding: 2rem 2rem 3rem;
  }
  .m-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: var(--m-text-muted);
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .m-label::after {
    content: '';
    flex: 1;
    height: 4px;
    background: var(--m-border);
  }

  /* Provider grid */
  .m-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1.5rem;
  }

  /* Card */
  .m-card {
    background: var(--m-bg-card);
    border: 4px solid var(--m-border);
    box-shadow: var(--m-shadow);
    padding: 1.5rem;
    position: relative;
    overflow: hidden;
    transition: transform 100ms, box-shadow 100ms;
    animation: m-reveal both;
    animation-timeline: view();
    animation-range: entry;
  }
  @keyframes m-reveal {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .m-card:hover {
    transform: translate(-3px, -3px);
    box-shadow: var(--m-shadow-hover);
  }
  .m-card__stripe {
    position: absolute;
    top: 0; left: 0;
    width: 6px; height: 100%;
    background: var(--accent);
  }
  .m-card__head {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
    padding-left: 0.75rem;
  }
  .m-card__icon {
    width: 40px; height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.1rem;
    font-weight: 900;
    color: #fff;
    flex-shrink: 0;
  }
  .m-card__name {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.1rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--m-text);
  }
  .m-card__badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--m-text-muted);
    border: 2px solid var(--m-border-dim);
    padding: 0.15rem 0.5rem;
  }
  .m-card__info {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .m-card__list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    border-top: 2px solid var(--m-border-dim);
    padding-top: 0.75rem;
    padding-left: 0.75rem;
  }
  .m-model__row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    justify-content: space-between;
  }
  .m-model__name {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--m-text);
  }
  .m-model__type {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--tc);
    border: 2px solid var(--tc);
    padding: 0.1rem 0.4rem;
    background: transparent;
  }
  .m-model__meta {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    color: var(--m-text-muted);
    display: flex;
    gap: 0.3rem;
    margin-top: 0.1rem;
  }
  .m-model__sep {
    opacity: 0.4;
  }

  /* Stat boxes */
  .m-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }
  .m-stat-box {
    border: 4px solid var(--m-border);
    box-shadow: var(--m-shadow);
    background: var(--m-bg-card);
    padding: 1.5rem;
    transition: transform 100ms, box-shadow 100ms;
    animation: m-reveal both;
    animation-timeline: view();
    animation-range: entry;
  }
  .m-stat-box:hover {
    transform: translate(-3px, -3px);
    box-shadow: var(--m-shadow-hover);
  }
  .m-stat-box__icon {
    font-family: 'JetBrains Mono', monospace;
    font-size: 1.5rem;
    color: var(--m-accent);
    margin-bottom: 0.75rem;
  }
  .m-stat-box__title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.85rem;
    font-weight: 900;
    text-transform: uppercase;
    color: var(--m-text);
    margin-bottom: 0.3rem;
  }
  .m-stat-box__desc {
    font-family: 'Work Sans', sans-serif;
    font-size: 0.78rem;
    color: var(--m-text-muted);
  }

  /* Terminal */
  .m-terminal {
    border: 4px solid var(--m-border);
    box-shadow: var(--m-shadow);
    background: var(--m-bg-card);
    overflow: hidden;
    animation: m-reveal both;
    animation-timeline: view();
    animation-range: entry;
  }
  .m-terminal__bar {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 1rem;
    background: var(--m-bg-surface);
    border-bottom: 3px solid var(--m-border);
  }
  .m-terminal__dot {
    width: 10px; height: 10px;
  }
  .m-terminal__title {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--m-text-muted);
    margin-left: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .m-terminal__body {
    padding: 1.25rem 1.5rem;
  }
  .m-terminal__line {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    color: var(--m-text-dim);
    margin-bottom: 0.5rem;
    display: flex;
    gap: 0.5rem;
  }
  .m-terminal__prompt {
    color: var(--m-accent);
    font-weight: 700;
  }
  .m-terminal__blink {
    animation: m-blink 1s step-end infinite;
  }
  @keyframes m-blink {
    50% { opacity: 0; }
  }

  /* CTA */
  .m-cta {
    max-width: 1280px;
    margin: 0 auto 4rem;
    padding: 0 2rem;
  }
  .m-cta {
    background: var(--m-bg-card);
    border: 4px solid var(--m-border);
    box-shadow: var(--m-shadow);
    padding: 2rem;
    text-align: center;
  }
  .m-cta__text {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    color: var(--m-text-muted);
    margin-bottom: 1rem;
  }
  .m-cta__links {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }
  .m-cta__link {
    text-decoration: none;
    transition: opacity 100ms;
  }
  .m-cta__link:hover { opacity: 0.7; }
  .m-cta__sep { color: var(--m-border-dim); }
  .m-cta__bottom {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
  }
  .m-cta__rss {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--m-accent);
    text-decoration: none;
    border: 2px solid var(--m-accent);
    padding: 0.35rem 0.85rem;
    transition: background 100ms, color 100ms;
  }
  .m-cta__rss:hover {
    background: var(--m-accent);
    color: #fff;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .m-grid { grid-template-columns: 1fr; }
    .m-stats { grid-template-columns: repeat(2, 1fr); }
    .m-hero { padding: 3rem 1.25rem 2rem; }
    .m-hero__title { font-size: clamp(2.5rem, 14vw, 4rem); }
    .m-section { padding: 1.5rem 1.25rem 2rem; }
    .m-cta { padding: 0 1.25rem; margin-bottom: 2rem; }
  }
  @media (max-width: 480px) {
    .m-stats { grid-template-columns: 1fr; }
    .m-hero__stats { flex-direction: column; gap: 0.5rem; }
    .m-hero__stat-divider { width: 100%; height: 2px; }
  }
</style>
