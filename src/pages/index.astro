---
import HubLayout from "../layouts/HubLayout.astro";
import { getAllToolReleases } from "../lib/releases";

let releaseMap: Record<string, any> = {};
let toolData: Record<string, any> = {};

try {
  const allReleases = await getAllToolReleases();
  for (const tr of allReleases) {
    if (tr.releases.length === 0) continue;
    const stable = tr.releases.find((r: any) => !r.prerelease);
    const latest = stable || tr.releases[0];
    releaseMap[tr.tool.id] = {
      version: latest.version,
      date: latest.date,
      body: latest.body || "",
      count: tr.releases.length,
    };
    toolData[tr.tool.id] = tr.tool;
  }
} catch (e) {
  // fallback: empty
}

const tools = [
  {
    id: "openclaw",
    name: "OpenClaw",
    icon: "⬡",
    desc: "Agent orchestration framework. Gateway, plugins, fleet management.",
    tag: "Agent Framework",
    class: "hub-card--openclaw",
    href: "/openclaw/",
    latest: releaseMap["openclaw"],
  },
  {
    id: "claude-code",
    name: "Claude Code",
    icon: "C",
    desc: "Anthropic's official CLI. Pair programming, agents, skills, hooks.",
    tag: "AI Coding",
    class: "hub-card--claude",
    href: "/claude-code/",
    latest: releaseMap["claude-code"],
  },
  {
    id: "codex-cli",
    name: "Codex CLI",
    icon: "$",
    desc: "OpenAI's terminal-native coding agent. Fast, stateless, extensible.",
    tag: "AI Coding",
    class: "hub-card--codex",
    href: "/codex-cli/",
    latest: releaseMap["codex-cli"],
  },
  {
    id: "models",
    name: "AI Models",
    icon: "◈",
    desc: "Every model, every provider. Track releases across 12 AI companies.",
    tag: "Coming Soon",
    class: "hub-card--models",
    href: "/models/",
    latest: null,
  },
];

function formatDate(dateStr: string): string {
  if (!dateStr) return "";
  const d = new Date(dateStr);
  return d.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
}

function getTldr(body: string): string {
  if (!body) return "No summary available yet.";
  const lines = body.split("\n").filter(l => l.trim() && !l.includes("<!--") && !l.includes("* *" ));
  const bullets = lines.filter(l => /^[-\u2022*]/.test(l.trim()));
  if (bullets.length === 0) return body.slice(0, 120) + "…";
  return bullets.slice(0, 2).map(l => l.replace(/^[-\u2022*]\s*/, "").replace(/`([^`]+)`/g, "$1")).join(" · ") + ".";
}
---

<HubLayout title="changelogs.info — Every AI Tool. Every Release.">

  <!-- Hero -->
  <section class="hub-hero">
    <div class="hub-hero__eyebrow">
      <span class="hub-hero__eyebrow-dot"></span>
      Live changelog tracker
    </div>
    <h1 class="hub-hero__title">
      Every tool.<br/>
      <span class="hub-hero__title-accent">Every release.</span>
    </h1>
    <p class="hub-hero__sub">
      The definitive record of AI coding tools. OpenClaw, Claude Code, Codex CLI — and every major model release — tracked and updated automatically.
    </p>
    <div class="hub-hero__badges">
      <span class="hub-hero__badge">
        <span class="hub-hero__badge-dot"></span>
        {Object.keys(releaseMap).length} tools tracked
      </span>
      <span class="hub-hero__badge">
        <span class="hub-hero__badge-dot"></span>
        Official GitHub releases
      </span>
      <span class="hub-hero__badge">
        <span class="hub-hero__badge-dot"></span>
        Auto-updated hourly
      </span>
    </div>
  </section>

  <!-- 4-card grid -->
  <section class="hub-grid-section">
    <div class="hub-section-label">Choose your tool</div>
    <div class="hub-grid">
      {tools.map(tool => (
        <a href={tool.href} class={`hub-card ${tool.class}`}>
          <div class="hub-card__glow"></div>
          <div class="hub-card__top">
            <div class="hub-card__icon">{tool.icon}</div>
            <span class="hub-card__arrow">↗</span>
          </div>
          <div class="hub-card__name">{tool.name}</div>
          <div class="hub-card__desc">{tool.desc}</div>
          {tool.latest ? (
            <>
              <div class="hub-card__tldr">"{getTldr(tool.latest.body)}"</div>
              <div class="hub-card__meta">
                <span class="hub-card__tag">{tool.tag}</span>
                <span class="hub-card__version">v{tool.latest.version} · {formatDate(tool.latest.date)}</span>
              </div>
            </>
          ) : (
            <div class="hub-card__meta">
              <span class="hub-card__tag">{tool.tag}</span>
              <span class="hub-card__version">Launching soon</span>
            </div>
          )}
        </a>
      ))}
    </div>
  </section>

  <!-- Blog placeholder -->
  <section class="hub-blog-section">
    <div class="hub-section-label">Changelog Dispatches</div>
    <div class="hub-blog-card">
      <div class="hub-blog-card__bg"></div>
      <div class="hub-blog-card__left">
        <span class="hub-blog-card__left-icon">✍</span>
      </div>
      <div class="hub-blog-card__right">
        <div class="hub-blog-card__eyebrow">Coming soon</div>
        <h2 class="hub-blog-card__title">The changelog dispatches</h2>
        <p class="hub-blog-card__desc">
          Human-readable summaries of major releases, migration guides, and deep dives — written automatically when significant versions drop.
        </p>
      </div>
      <div class="hub-blog-card__cta">
        <a href="#" class="hub-blog-card__btn" onclick="return false;">
          Notify me ↗
        </a>
      </div>
    </div>
  </section>

</HubLayout>
