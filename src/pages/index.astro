---
import BaseLayout from "../layouts/BaseLayout.astro";
import ToolCard from "../components/ToolCard.astro";
import MatrixHero from "../components/MatrixHero.astro";
import { getTools, getAllToolReleases, FEATURED_TOOLS, isFeatured, relativeTime } from "../lib/releases";
import type { Release } from "../lib/releases";

const tools = getTools();
const otherTools = tools.filter((t) => !isFeatured(t.id));

let releaseMap: Record<string, Release> = {};
try {
  const allReleases = await getAllToolReleases();
  for (const tr of allReleases) {
    const stable = tr.releases.find((r) => !r.prerelease);
    if (stable) {
      releaseMap[tr.tool.id] = stable;
    } else if (tr.releases.length > 0) {
      releaseMap[tr.tool.id] = tr.releases[0];
    }
  }
} catch {}
---

<BaseLayout title="changelogs.info — OpenClaw & Claude Code Hub + AI Coding Tool Tracker">
  <!-- Terminal Hero -->
  <section class="relative overflow-hidden border-b border-border bg-bg-secondary/30">
    <MatrixHero />
    <div class="hero-content mx-auto max-w-6xl px-4 py-12 sm:px-6 sm:py-16 md:py-20">
      <div class="max-w-3xl">
        <h1 class="font-mono text-2xl font-bold text-green sm:text-3xl md:text-4xl">
          <span class="text-green">&gt;</span> changelogs.info
        </h1>
        <p class="mt-3 font-mono text-xs leading-relaxed text-text-secondary sm:text-sm md:text-base">
          <span class="text-green">#</span> your hub for <span class="text-cyan">OpenClaw</span> and <span class="text-cyan">Claude Code</span> — plus {otherTools.length} more AI coding tools
        </p>
        <p class="mt-4 font-sans text-sm leading-relaxed text-text-secondary sm:text-base">
          Cheatsheets, configs, model compatibility, migration guides, and daily changelog tracking. Everything you need to get the most out of your AI coding workflow.
        </p>
        <div class="mt-6 flex flex-wrap gap-3 font-mono text-xs sm:text-sm">
          <a href="/openclaw" class="rounded border border-green/40 bg-green/10 px-4 py-2 text-green transition-all hover:bg-green/20">OpenClaw</a>
          <a href="/claude-code" class="rounded border border-green/40 bg-green/10 px-4 py-2 text-green transition-all hover:bg-green/20">Claude Code</a>
          <a href="#all-tools" class="rounded border border-border bg-bg-tertiary px-4 py-2 text-text-muted transition-all hover:border-green hover:text-green">all {tools.length} tools</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Latest releases ticker -->
  {Object.keys(releaseMap).length > 0 && (
    <div class="border-b border-border bg-bg-card/50">
      <div class="mx-auto flex max-w-6xl items-center gap-3 overflow-x-auto px-4 py-2 font-mono text-xs sm:px-6">
        <span class="shrink-0 text-green">latest:</span>
        {Object.entries(releaseMap)
          .sort(([, a], [, b]) => new Date(b.date).getTime() - new Date(a.date).getTime())
          .slice(0, 6)
          .map(([toolId, release]) => {
            const tool = tools.find((t) => t.id === toolId);
            return tool ? (
              <a href={`/tools/${toolId}`} class="shrink-0 rounded bg-bg-tertiary px-2 py-1 text-text-muted transition-all hover:text-green">
                <span class="text-cyan">{tool.name}</span> <span class="text-green">{release.version}</span>
              </a>
            ) : null;
          })}
      </div>
    </div>
  )}

  <div class="green-divider"></div>

  <!-- OpenClaw Deep Section -->
  <section id="openclaw" class="border-b border-border bg-green/[0.02]">
    <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6 sm:py-14">
      <div class="mb-8 flex flex-wrap items-start justify-between gap-4">
        <div>
          <h2 class="reveal font-mono text-xl font-bold text-green sm:text-2xl">
            <span class="text-green">/</span>openclaw
          </h2>
          <p class="mt-2 font-mono text-xs text-text-secondary sm:text-sm">
            Personal AI assistant platform \u2014 run your own AI on any device, any channel
          </p>
        </div>
        {releaseMap["openclaw"] && (
          <div class="reveal rounded border border-green/30 bg-bg-card px-3 py-2 font-mono text-xs">
            <span class="text-green">{releaseMap["openclaw"].version}</span>
            <span class="ml-2 text-text-muted">{relativeTime(releaseMap["openclaw"].date)}</span>
          </div>
        )}
      </div>

      <div class="reveal-stagger grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
        <a href="/tools/openclaw" class="reveal rounded-lg border border-border bg-bg-card p-4 transition-all hover:border-green hover:shadow-[0_0_12px_rgba(51,255,51,0.12)]">
          <span class="text-lg">\ud83d\udcdd</span>
          <h3 class="mt-2 font-mono text-sm font-semibold text-text-primary">Changelog</h3>
          <p class="mt-1 font-mono text-xs text-text-muted">Every release tracked with full notes</p>
        </a>
        <a href="/tools/openclaw/cheatsheet" class="reveal rounded-lg border border-border bg-bg-card p-4 transition-all hover:border-cyan hover:shadow-[0_0_12px_rgba(0,212,255,0.12)]">
          <span class="text-lg">\ud83d\udccb</span>
          <h3 class="mt-2 font-mono text-sm font-semibold text-text-primary">Cheat Sheet</h3>
          <p class="mt-1 font-mono text-xs text-text-muted">Skills, cron, memory, plugins, config</p>
        </a>
        <a href="/configs" class="reveal rounded-lg border border-border bg-bg-card p-4 transition-all hover:border-green hover:shadow-[0_0_12px_rgba(51,255,51,0.12)]">
          <span class="text-lg">\u2699\ufe0f</span>
          <h3 class="mt-2 font-mono text-sm font-semibold text-text-primary">Config Templates</h3>
          <p class="mt-1 font-mono text-xs text-text-muted">Gateway, agents, channels, cron</p>
        </a>
        <a href="/migrations" class="reveal rounded-lg border border-border bg-bg-card p-4 transition-all hover:border-amber hover:shadow-[0_0_12px_rgba(255,184,0,0.12)]">
          <span class="text-lg">\ud83d\udd04</span>
          <h3 class="mt-2 font-mono text-sm font-semibold text-text-primary">Migration Guide</h3>
          <p class="mt-1 font-mono text-xs text-text-muted">Upgrade safely between versions</p>
        </a>
      </div>

      <div class="reveal mt-6 grid gap-3 sm:grid-cols-3">
        <a href="/compatibility" class="rounded border border-border bg-bg-card px-4 py-3 font-mono text-xs text-text-muted transition-all hover:border-green hover:text-green">
          \ud83e\udde9 model compatibility
        </a>
        <a href="/recommendations" class="rounded border border-border bg-bg-card px-4 py-3 font-mono text-xs text-text-muted transition-all hover:border-green hover:text-green">
          \u2b50 recommendations
        </a>
        <a href="/deprecations" class="rounded border border-border bg-bg-card px-4 py-3 font-mono text-xs text-text-muted transition-all hover:border-red hover:text-red">
          \u26a0\ufe0f deprecation radar
        </a>
      </div>
    </div>
  </section>

  <div class="green-divider"></div>

  <!-- Claude Code Deep Section -->
  <section id="claude-code" class="border-b border-border bg-green/[0.02]">
    <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6 sm:py-14">
      <div class="mb-8 flex flex-wrap items-start justify-between gap-4">
        <div>
          <h2 class="reveal font-mono text-xl font-bold text-green sm:text-2xl">
            <span class="text-green">/</span>claude-code
          </h2>
          <p class="mt-2 font-mono text-xs text-text-secondary sm:text-sm">
            Anthropic\u2019s agentic coding CLI \u2014 understands your codebase, writes code through natural language
          </p>
        </div>
        {releaseMap["claude-code"] && (
          <div class="reveal rounded border border-green/30 bg-bg-card px-3 py-2 font-mono text-xs">
            <span class="text-green">{releaseMap["claude-code"].version}</span>
            <span class="ml-2 text-text-muted">{relativeTime(releaseMap["claude-code"].date)}</span>
          </div>
        )}
      </div>

      <div class="reveal-stagger grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
        <a href="/tools/claude-code" class="reveal rounded-lg border border-border bg-bg-card p-4 transition-all hover:border-green hover:shadow-[0_0_12px_rgba(51,255,51,0.12)]">
          <span class="text-lg">\ud83d\udcdd</span>
          <h3 class="mt-2 font-mono text-sm font-semibold text-text-primary">Changelog</h3>
          <p class="mt-1 font-mono text-xs text-text-muted">Every release tracked with full notes</p>
        </a>
        <a href="/tools/claude-code/cheatsheet" class="reveal rounded-lg border border-border bg-bg-card p-4 transition-all hover:border-cyan hover:shadow-[0_0_12px_rgba(0,212,255,0.12)]">
          <span class="text-lg">\ud83d\udccb</span>
          <h3 class="mt-2 font-mono text-sm font-semibold text-text-primary">Cheat Sheet</h3>
          <p class="mt-1 font-mono text-xs text-text-muted">CLI flags, agent teams, hooks, MCP, skills</p>
        </a>
        <a href="/configs" class="reveal rounded-lg border border-border bg-bg-card p-4 transition-all hover:border-green hover:shadow-[0_0_12px_rgba(51,255,51,0.12)]">
          <span class="text-lg">\u2699\ufe0f</span>
          <h3 class="mt-2 font-mono text-sm font-semibold text-text-primary">Config Templates</h3>
          <p class="mt-1 font-mono text-xs text-text-muted">CLAUDE.md, settings.json, permissions</p>
        </a>
        <a href="/migrations" class="reveal rounded-lg border border-border bg-bg-card p-4 transition-all hover:border-amber hover:shadow-[0_0_12px_rgba(255,184,0,0.12)]">
          <span class="text-lg">\ud83d\udd04</span>
          <h3 class="mt-2 font-mono text-sm font-semibold text-text-primary">Migration Guide</h3>
          <p class="mt-1 font-mono text-xs text-text-muted">Version upgrades, breaking changes</p>
        </a>
      </div>

      <div class="reveal mt-6 grid gap-3 sm:grid-cols-3">
        <a href="/compatibility" class="rounded border border-border bg-bg-card px-4 py-3 font-mono text-xs text-text-muted transition-all hover:border-green hover:text-green">
          \ud83e\udde9 model compatibility
        </a>
        <a href="/recommendations" class="rounded border border-border bg-bg-card px-4 py-3 font-mono text-xs text-text-muted transition-all hover:border-green hover:text-green">
          \u2b50 recommendations
        </a>
        <a href="/deprecations" class="rounded border border-border bg-bg-card px-4 py-3 font-mono text-xs text-text-muted transition-all hover:border-red hover:text-red">
          \u26a0\ufe0f deprecation radar
        </a>
      </div>
    </div>
  </section>

  <div class="green-divider"></div>

  <!-- Also Tracking -->
  <section id="all-tools" class="mx-auto max-w-6xl px-4 py-8 sm:px-6 sm:py-12">
    <div class="mb-6 flex items-center justify-between sm:mb-8">
      <h2 class="font-mono text-base font-semibold text-green sm:text-lg">
        <span class="text-green">/</span>also_tracking
      </h2>
      <span class="font-mono text-xs text-text-muted sm:text-sm">
        <span class="text-green">[</span>{otherTools.length} more<span class="text-green">]</span>
      </span>
    </div>

    <div class="grid gap-3 sm:grid-cols-2 sm:gap-4 lg:grid-cols-3 reveal-stagger">
      {otherTools.map((tool) => (
        <div class="reveal"><ToolCard tool={tool} latestRelease={releaseMap[tool.id]} /></div>
      ))}
    </div>
  </section>

  <div class="green-divider"></div>

  <!-- Recent releases -->
  <section class="mx-auto max-w-6xl px-4 pb-12 sm:px-6 sm:pb-16">
    <h2 class="reveal mb-4 font-mono text-base font-semibold text-green sm:mb-6 sm:text-lg">
      <span class="text-green">/</span>recent_releases
    </h2>

    {Object.keys(releaseMap).length > 0 ? (
      <div class="rounded-lg border border-border bg-bg-card">
        <div class="border-b border-border px-3 py-2 font-mono text-xs text-text-muted sm:px-4">
          <span class="text-green">\u25cf\u25cf\u25cf</span> <span class="ml-2">release.log</span>
        </div>
        <div class="space-y-0 p-2 sm:p-3">
          {Object.entries(releaseMap)
            .sort(([, a], [, b]) => new Date(b.date).getTime() - new Date(a.date).getTime())
            .slice(0, 10)
            .map(([toolId, release]) => {
              const tool = tools.find((t) => t.id === toolId);
              const date = new Date(release.date);
              const timestamp = date.toLocaleDateString("en-US", { month: "short", day: "2-digit" });
              return tool ? (
                <a
                  href={`/tools/${toolId}`}
                  class="release-card block rounded border border-transparent px-2 py-2 font-mono text-xs transition-all hover:border-green hover:bg-bg-tertiary/50 sm:px-3 sm:text-sm"
                >
                  <span class="text-text-muted">[{timestamp}]</span>
                  <span class="ml-2 text-green">{release.version}</span>
                  <span class="ml-2 text-cyan">{tool.name}</span>
                  {release.name !== release.version && (
                    <span class="ml-2 hidden text-text-secondary sm:inline">\u2501\u2501 \"{release.name}\"</span>
                  )}
                </a>
              ) : null;
            })}
        </div>
      </div>
    ) : (
      <div class="rounded-lg border border-dashed border-border bg-bg-card p-6 sm:p-8">
        <p class="font-mono text-xs text-text-muted sm:text-sm">
          <span class="text-red">ERROR:</span> no release data loaded
        </p>
      </div>
    )}
  </section>

  <!-- Newsletter -->
  <section class="mx-auto max-w-4xl px-4 pb-12 sm:px-6 sm:pb-16">
    <div class="rounded-lg border border-border bg-bg-card">
      <div class="border-b border-border px-3 py-2 font-mono text-xs text-text-muted sm:px-4">
        <span class="text-green">\u25cf\u25cf\u25cf</span> <span class="ml-2">newsletter.sh</span>
      </div>
      <div class="p-4 sm:p-6">
        <h3 class="font-mono text-base font-semibold text-green sm:text-lg">
          <span class="text-green">#</span> weekly changelog digests
        </h3>
        <p class="mt-2 font-mono text-xs text-text-secondary sm:text-sm">
          <span class="text-text-muted">//</span> one email with the most important updates
        </p>
        <form action="#" method="post" class="mt-4 flex flex-col gap-3 sm:flex-row">
          <input
            type="email"
            required
            placeholder="you@company.com"
            class="w-full rounded border border-border bg-bg-tertiary px-4 py-3 font-mono text-sm text-text-primary outline-none transition-all focus:border-green focus:shadow-[0_0_8px_rgba(51,255,51,0.2)]"
          />
          <button
            type="submit"
            class="email-submit-btn rounded border border-accent bg-accent/10 px-5 py-3 font-mono text-sm font-medium text-accent transition-all hover:border-accent-hover hover:bg-accent/20"
          >
            subscribe
          </button>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>
