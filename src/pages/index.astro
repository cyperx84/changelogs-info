---
import HubLayout from "../layouts/HubLayout.astro";
import { getTools, getAllToolReleases } from "../lib/releases";
import { loadModelsData } from "../lib/models";
import { getCollection } from "astro:content";

const blogPosts = (await getCollection("blog"))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

function formatDate(dateStr: string): string {
  if (!dateStr) return "";
  const d = new Date(dateStr);
  return d.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
}

let releaseMap: Record<string, any> = {};

try {
  const allReleases = await getAllToolReleases();
  for (const tr of allReleases) {
    if (tr.releases.length === 0) continue;
    const stable = tr.releases.find((r: any) => !r.prerelease);
    const latest = stable || tr.releases[0];
    releaseMap[tr.tool.id] = {
      version: latest.version,
      date: latest.date,
      body: latest.body || "",
      count: tr.releases.length,
    };
  }
} catch (e) {
  // fallback: empty
}

const FEATURED_IDS = ["openclaw", "claude-code", "codex-cli", "gemini-cli", "cursor", "cline", "windsurf", "roo-code", "kilocode", "opencode", "hermes-agent"];
const allTools = getTools();
const { stats: modelStats } = loadModelsData();
const featuredTools = FEATURED_IDS.map(id => allTools.find(t => t.id === id)).filter(Boolean);
const otherTools = allTools.filter(t => !FEATURED_IDS.includes(t.id));

const toolColors: Record<string, { bg: string; text: string; glow: string }> = {
  "openclaw":    { bg: "#eb0000", text: "#ffffff", glow: "#eb0000" },
  "claude-code": { bg: "#f59e0b", text: "#ffffff", glow: "#f59e0b" },
  "codex-cli":   { bg: "#00c851", text: "#ffffff", glow: "#00c851" },
  "gemini-cli":  { bg: "#4285f4", text: "#ffffff", glow: "#4285f4" },
  "cursor":      { bg: "#146EF5", text: "#ffffff", glow: "#146EF5" },
  "windsurf":    { bg: "#06b6d4", text: "#ffffff", glow: "#06b6d4" },
  "cline":       { bg: "#a855f7", text: "#ffffff", glow: "#a855f7" },
  "opencode":    { bg: "#0ea5e9", text: "#ffffff", glow: "#0ea5e9" },
  "roo-code":    { bg: "#fb923c", text: "#ffffff", glow: "#fb923c" },
  "kilocode":    { bg: "#CCFF33", text: "#000000", glow: "#CCFF33" },
  "hermes-agent": { bg: "#D97706", text: "#ffffff", glow: "#D97706" },
};

const categoryLabels: Record<string, string> = {
  "cli": "AI CLI",
  "ide": "AI IDE",
  "ide-extension": "IDE Extension",
  "harness": "Agent Framework",
};

const toolIcons: Record<string, string> = {
  "openclaw":    "⬡",
  "claude-code": "C",
  "codex-cli":   "$",
  "gemini-cli":  "G",
  "cursor":      "↗",
  "windsurf":    "~",
  "cline":       "»",
  "opencode":    "○",
  "roo-code":    "R",
  "kilocode":    "↗",
  "hermes-agent": "⚡",
};

const featuredLinks: Record<string, string> = {
  "openclaw":    "/openclaw/",
  "claude-code": "/claude-code/",
  "codex-cli":   "/codex-cli/",
  "gemini-cli":  "/gemini-cli/",
  "cursor":      "/cursor/",
  "cline":       "/cline/",
  "windsurf":    "/windsurf/",
  "roo-code":    "/roo-code/",
  "kilocode":    "/kilocode/",
  "opencode":    "/opencode/",
  "hermes-agent": "/hermes-agent/",
};

function formatDate(dateStr: string): string {
  if (!dateStr) return "";
  const d = new Date(dateStr);
  return d.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
}

function getTldr(body: string): string {
  if (!body) return "No summary available yet.";
  const lines = body.split("\n").filter(l => l.trim() && !l.includes("<!--") && !l.includes("* *"));
  const bullets = lines.filter(l => /^[-\u2022*]/.test(l.trim()));
  if (bullets.length === 0) return body.slice(0, 120) + "…";
  return bullets.slice(0, 2).map(l => l.replace(/^[-\u2022*]\s*/, "").replace(/`([^`]+)`/g, "$1")).join(" · ") + ".";
}

const totalReleases = Object.values(releaseMap).reduce((sum: number, r: any) => sum + (r.count || 0), 0);

// Harness-specific bullet prefixes
const harnessPrefix: Record<string, string> = {
  "openclaw": "▸",
  "claude-code": "▸",
  "codex-cli": ">",
  "gemini-cli": "›",
};
---

<HubLayout title="changelogs.info — Every AI Tool. Every Release.">

  <!-- SVG Grain Filter -->
  <svg class="brutal-grain-svg" aria-hidden="true">
    <filter id="brutal-grain">
      <feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch" />
      <feColorMatrix type="saturate" values="0" />
      <feBlend in="SourceGraphic" mode="multiply" />
    </filter>
  </svg>
  <div class="brutal-grain-overlay" aria-hidden="true"></div>

  <!-- ═══════════════════ HERO ═══════════════════ -->
  <section class="brutal-hero">
    <div class="brutal-hero__inner">
      <div class="brutal-hero__eyebrow">
        <span class="brutal-hero__pulse"></span>
        LIVE CHANGELOG TRACKER
      </div>

      <h1 class="brutal-hero__title" aria-label="Too many tools. Too many changes.">
        <span class="brutal-word" data-word="TOO">TOO</span>
        <span class="brutal-word brutal-word--amber" data-word="MANY">MANY</span>
        <span class="brutal-word brutal-word--green" data-word="TOOLS.">TOOLS.</span>
        <br />
        <span class="brutal-word brutal-word--blue" data-word="TOO">TOO</span>
        <span class="brutal-word brutal-word--violet" data-word="MANY">MANY</span>
        <span class="brutal-word" data-word="CHANGES.">CHANGES.</span>
      </h1>

      <p class="brutal-hero__sub">
        AI coding tools shipping faster than documentation gets updated.
      </p>

      <div class="brutal-hero__stats">
        <span class="brutal-stat brutal-stat--red">
          <span class="brutal-stat__num">{allTools.length}</span>
          <span class="brutal-stat__label">tools tracked</span>
        </span>
        <span class="brutal-stat brutal-stat--amber">
          <span class="brutal-stat__num">{totalReleases}+</span>
          <span class="brutal-stat__label">releases indexed</span>
        </span>
        <span class="brutal-stat brutal-stat--green">
          <span class="brutal-stat__num">⚡</span>
          <span class="brutal-stat__label">auto-updated hourly</span>
        </span>
        <span class="brutal-stat brutal-stat--blue">
          <span class="brutal-stat__num">♾</span>
          <span class="brutal-stat__label">official sources</span>
        </span>
      </div>
    </div>
  </section>

  <!-- Skewed divider -->
  <div class="brutal-divider brutal-divider--1" aria-hidden="true"></div>

  <!-- ═══════════════════ FEATURED TOOLS ═══════════════════ -->
  <section class="brutal-section brutal-section--featured">
    <div class="brutal-section__label">
      <span class="brutal-section__label-line"></span>
      FEATURED TOOLS
      <span class="brutal-section__label-line"></span>
    </div>

    <div class="brutal-grid brutal-grid--featured">
      {featuredTools.map((tool, i) => {
        const color = toolColors[tool!.id] || { bg: "#0091f7", text: "#ffffff", glow: "#0091f7" };
        const icon = toolIcons[tool!.id] || tool!.name.charAt(0);
        const tag = categoryLabels[tool!.category] || tool!.category;
        const latest = releaseMap[tool!.id];
        const href = featuredLinks[tool!.id] || `/tools/${tool!.id}/`;
        const prefix = harnessPrefix[tool!.id] || "·";
        const harnessClass = `brutal-card--${tool!.id}`;

        return (
          <a
            href={href}
            class={`brutal-card brutal-card--featured ${harnessClass} brutal-scroll-reveal`}
            style={`--card-accent: ${color.bg}; --card-glow: ${color.glow}; --reveal-delay: ${i * 0.12}s;`}
            transition:name={tool!.id + '-card'}
          >
            {tool!.id === "claude-code" && <div class="brutal-card__scanlines" aria-hidden="true"></div>}
            <div class="brutal-card__border-glow" aria-hidden="true"></div>
            <div class="brutal-card__header">
              <div class="brutal-card__icon" style={`background: ${color.bg}; color: ${color.text};`}>
                {icon}
              </div>
              <span class="brutal-card__tag" style={`border-color: ${color.bg}; color: ${color.bg};`}>{tag}</span>
              <span class="brutal-card__arrow">↗</span>
            </div>
            <h3 class="brutal-card__name">{tool!.name}</h3>
            <p class="brutal-card__desc">{tool!.description}</p>
            {latest ? (
              <>
                <div class="brutal-card__tldr">
                  <span class="brutal-card__prefix">{prefix}</span> {getTldr(latest.body)}
                </div>
                <div class="brutal-card__footer">
                  <span class="brutal-card__version">v{latest.version}</span>
                  <span class="brutal-card__date">{formatDate(latest.date)}</span>
                  <span class="brutal-card__count">{latest.count} releases</span>
                </div>
              </>
            ) : (
              <div class="brutal-card__footer">
                <span class="brutal-card__version">—</span>
              </div>
            )}
          </a>
        );
      })}

      <!-- Models card -->
      <a
        href="/models/"
        class="brutal-card brutal-card--featured brutal-card--models brutal-scroll-reveal"
        style="--card-accent: #8b5cf6; --card-glow: #8b5cf6; --reveal-delay: 0.48s;"
      >
        <div class="brutal-card__border-glow" aria-hidden="true"></div>
        <div class="brutal-card__header">
          <div class="brutal-card__icon" style="background: linear-gradient(135deg, #8b5cf6, #a78bfa); color: #fff;">
            ◆
          </div>
          <span class="brutal-card__tag" style="border-color: #8b5cf6; color: #8b5cf6;">AI Models</span>
          <span class="brutal-card__arrow">↗</span>
        </div>
        <h3 class="brutal-card__name">Models</h3>
        <p class="brutal-card__desc">Track AI model releases across Anthropic, OpenAI, Google, and more.</p>
        <div class="brutal-card__tldr">
          <span class="brutal-card__prefix">◆</span> 11 providers · Claude, GPT, Gemini, Grok, Mistral, Llama, Qwen, GLM, DeepSeek, Kimi, Minimax
        </div>
        <div class="brutal-card__footer">
          <span class="brutal-card__version">{modelStats.totalModels} models tracked</span>
        </div>
      </a>
    </div>
  </section>

  <!-- Skewed divider -->
  <div class="brutal-divider brutal-divider--2" aria-hidden="true"></div>

  <!-- ═══════════════════ ALSO TRACKED ═══════════════════ -->
  {otherTools.length > 0 && (
    <section class="brutal-section brutal-section--other">
      <div class="brutal-section__label">
        <span class="brutal-section__label-line"></span>
        ALSO TRACKED
        <span class="brutal-section__label-line"></span>
      </div>

      <div class="brutal-grid brutal-grid--other">
        {otherTools.map((tool, i) => {
          const color = toolColors[tool.id] || { bg: "#0091f7", text: "#ffffff", glow: "#0091f7" };
          const icon = toolIcons[tool.id] || tool.name.charAt(0);
          const tag = categoryLabels[tool.category] || tool.category;
          const latest = releaseMap[tool.id];
          return (
            <a
              href={`/tools/${tool.id}/`}
              class="brutal-card brutal-card--compact brutal-scroll-reveal"
              style={`--card-accent: ${color.bg}; --card-glow: ${color.glow}; --reveal-delay: ${i * 0.08}s;`}
            >
              <div class="brutal-card__icon brutal-card__icon--sm" style={`background: ${color.bg}; color: ${color.text};`}>
                {icon}
              </div>
              <div class="brutal-card--compact__body">
                <span class="brutal-card__name brutal-card__name--sm">{tool.name}</span>
                <span class="brutal-card__tag brutal-card__tag--inline" style={`border-color: ${color.bg}; color: ${color.bg};`}>{tag}</span>
                {latest && <span class="brutal-card__version brutal-card__version--sm">v{latest.version}</span>}
              </div>
              <span class="brutal-card__arrow">↗</span>
            </a>
          );
        })}
      </div>
    </section>
  )}

  <!-- Skewed divider -->
  <div class="brutal-divider brutal-divider--3" aria-hidden="true"></div>

  <!-- ═══════════════════ CHANGELOG DISPATCHES ═══════════════════ -->
  <section class="brutal-section brutal-section--dispatches">
    <div class="brutal-section__label">
      <span class="brutal-section__label-line"></span>
      CHANGELOG DISPATCHES
      <span class="brutal-section__label-line"></span>
    </div>

    <div class="brutal-grid brutal-grid--dispatches">
      {blogPosts.map((post, i) => (
        <a href={`/blog/${post.slug}/`} class="brutal-card brutal-card--dispatch brutal-scroll-reveal" style={`--card-accent: #eb0000; --card-glow: #eb0000; --reveal-delay: ${i * 0.12}s;`}>
          <div class="brutal-card__border-glow" aria-hidden="true"></div>
          <div class="brutal-card__header">
            <div class="brutal-card__icon" style="background: #eb0000; color: #fff;">✍</div>
            <span class="brutal-card__tag" style="border-color: #eb0000; color: #eb0000;">{post.data.category}</span>
            <span class="brutal-card__arrow">↗</span>
          </div>
          <h3 class="brutal-card__name">{post.data.title}</h3>
          <p class="brutal-card__desc">{post.data.excerpt}</p>
          <div class="brutal-card__footer">
            <span class="brutal-card__version">{formatDate(post.data.date)}</span>
            <span class="brutal-card__date">{post.data.readTime}</span>
          </div>
        </a>
      ))}
    </div>
    <div style="text-align: center; margin-top: 1.5rem;">
      <a href="/blog/" class="brutal-dispatch__btn" style="display: inline-block; text-decoration: none;">All dispatches ↗</a>
    </div>
  </section>

</HubLayout>

<script is:inline>
(function () {
  var CHARS = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789!@#$%&*?";
  var DURATION = 500;
  var FRAME_MS = 40;
  var STAGGER_MS = 120;

  function scramble(el, word, delay) {
    setTimeout(function () {
      var start = null;
      var len = word.length;
      function frame(ts) {
        if (!start) start = ts;
        var elapsed = ts - start;
        var progress = Math.min(elapsed / DURATION, 1);
        var revealed = Math.floor(progress * len);
        var text = "";
        for (var i = 0; i < len; i++) {
          if (i < revealed) {
            text += word[i];
          } else {
            text += CHARS[Math.floor(Math.random() * CHARS.length)];
          }
        }
        el.textContent = text;
        if (progress < 1) {
          requestAnimationFrame(frame);
        } else {
          el.textContent = word;
        }
      }
      requestAnimationFrame(frame);
    }, delay);
  }

  function init() {
    var words = document.querySelectorAll(".brutal-word[data-word]");
    words.forEach(function (el, i) {
      scramble(el, el.getAttribute("data-word"), i * STAGGER_MS);
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }

  // Re-run on Astro view transitions
  document.addEventListener("astro:page-load", init);
})();
</script>

<style is:global>
  /* ══════════════════════════════════════════════════════════
     @property — animatable custom properties for gradient shifts
     ══════════════════════════════════════════════════════════ */
  @property --brutal-hue {
    syntax: '<angle>';
    initial-value: 0deg;
    inherits: false;
  }
  @property --brutal-bg-hue {
    syntax: '<angle>';
    initial-value: 0deg;
    inherits: false;
  }

  /* ══════════════════════════════════════════════════════════
     SVG Grain Overlay
     ══════════════════════════════════════════════════════════ */
  .brutal-grain-svg {
    position: absolute;
    width: 0;
    height: 0;
    pointer-events: none;
  }
  .brutal-grain-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    pointer-events: none;
    opacity: 0.035;
    filter: url(#brutal-grain);
    animation: brutal-grain-shift 0.5s steps(4) infinite;
    mix-blend-mode: overlay;
  }
  [data-theme="light"] .brutal-grain-overlay {
    opacity: 0.025;
  }
  @keyframes brutal-grain-shift {
    0%, 100% { transform: translate(0, 0); }
    25% { transform: translate(-2px, 2px); }
    50% { transform: translate(2px, -2px); }
    75% { transform: translate(-1px, -1px); }
  }

  /* ══════════════════════════════════════════════════════════
     Color-shifting page background
     ══════════════════════════════════════════════════════════ */
  [data-theme="dark"] .brutal-hero {
    background:
      linear-gradient(
        calc(135deg + var(--brutal-bg-hue)),
        hsl(calc(0 + var(--brutal-bg-hue) / 1) 80% 8%) 0%,
        hsl(calc(30 + var(--brutal-bg-hue) / 1) 60% 6%) 25%,
        hsl(calc(120 + var(--brutal-bg-hue) / 1) 50% 5%) 50%,
        hsl(calc(220 + var(--brutal-bg-hue) / 1) 60% 7%) 75%,
        hsl(calc(270 + var(--brutal-bg-hue) / 1) 50% 6%) 100%
      );
    animation: brutal-bg-cycle 20s linear infinite;
  }
  [data-theme="light"] .brutal-hero {
    background:
      linear-gradient(
        calc(135deg + var(--brutal-bg-hue)),
        hsl(calc(0 + var(--brutal-bg-hue) / 1) 90% 97%) 0%,
        hsl(calc(40 + var(--brutal-bg-hue) / 1) 85% 95%) 25%,
        hsl(calc(140 + var(--brutal-bg-hue) / 1) 70% 96%) 50%,
        hsl(calc(220 + var(--brutal-bg-hue) / 1) 80% 96%) 75%,
        hsl(calc(280 + var(--brutal-bg-hue) / 1) 70% 96%) 100%
      );
    animation: brutal-bg-cycle 20s linear infinite;
  }
  @keyframes brutal-bg-cycle {
    from { --brutal-bg-hue: 0deg; }
    to { --brutal-bg-hue: 360deg; }
  }

  /* ══════════════════════════════════════════════════════════
     HERO SECTION
     ══════════════════════════════════════════════════════════ */
  .brutal-hero {
    position: relative;
    padding: clamp(3rem, 8vw, 7rem) 1.5rem clamp(4rem, 10vw, 8rem);
    text-align: center;
    overflow: hidden;
  }
  .brutal-hero__inner {
    max-width: 1000px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  .brutal-hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 0.4rem 1rem;
    border: 2px solid var(--hub-border, #333);
    border-radius: 0;
    margin-bottom: 2rem;
    color: var(--hub-text-secondary, #aaa);
  }
  .brutal-hero__pulse {
    width: 8px;
    height: 8px;
    background: #00c851;
    border-radius: 50%;
    animation: brutal-pulse 2s ease-in-out infinite;
  }
  @keyframes brutal-pulse {
    0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(0, 200, 81, 0.4); }
    50% { opacity: 0.6; box-shadow: 0 0 0 6px rgba(0, 200, 81, 0); }
  }

  /* ══════════════════════════════════════════════════════════
     HEROIC TYPOGRAPHY + GLITCH
     ══════════════════════════════════════════════════════════ */
  .brutal-hero__title {
    font-family: 'Space Grotesk', system-ui, sans-serif;
    font-size: clamp(2.8rem, 9vw, 7.5rem);
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: -0.03em;
    margin: 0 0 1.5rem;
    color: var(--hub-text-primary, #fff);
  }

  .brutal-word {
    display: inline-block;
    color: #eb0000;
  }
  .brutal-word--amber  { color: #f59e0b; }
  .brutal-word--green  { color: #00c851; }
  .brutal-word--blue   { color: #4285f4; }
  .brutal-word--violet { color: #8b5cf6; }

  .brutal-hero__sub {
    font-family: 'Work Sans', sans-serif;
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: var(--hub-text-secondary, #999);
    max-width: 600px;
    margin: 0 auto 2.5rem;
    line-height: 1.6;
  }

  /* ══════════════════════════════════════════════════════════
     STAT BADGES
     ══════════════════════════════════════════════════════════ */
  .brutal-hero__stats {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
  }
  .brutal-stat {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    padding: 0.5rem 1rem;
    border: 3px solid;
    box-shadow: 4px 4px 0 currentColor;
    font-weight: 600;
    transition: transform 0.15s, box-shadow 0.15s;
  }
  .brutal-stat:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 currentColor;
  }
  .brutal-stat--red   { color: #eb0000; border-color: #eb0000; }
  .brutal-stat--amber { color: #f59e0b; border-color: #f59e0b; }
  .brutal-stat--green { color: #00c851; border-color: #00c851; }
  .brutal-stat--blue  { color: #4285f4; border-color: #4285f4; }
  .brutal-stat__num { font-weight: 800; font-size: 1rem; }
  .brutal-stat__label { opacity: 0.85; }

  [data-theme="light"] .brutal-stat {
    background: #fff;
  }
  [data-theme="dark"] .brutal-stat {
    background: rgba(0,0,0,0.4);
  }

  /* ══════════════════════════════════════════════════════════
     DIAGONAL SECTION DIVIDERS
     ══════════════════════════════════════════════════════════ */
  .brutal-divider {
    height: 60px;
    position: relative;
    z-index: 2;
    overflow: hidden;
  }
  .brutal-divider--1 {
    background: var(--hub-bg, #111);
    clip-path: polygon(0 0, 100% 0, 100% 100%, 0 40%);
