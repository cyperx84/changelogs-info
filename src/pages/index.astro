---
import BaseLayout from "../layouts/BaseLayout.astro";
import ToolCard from "../components/ToolCard.astro";
import { getTools, getAllToolReleases } from "../lib/releases";
import type { Release } from "../lib/releases";

const tools = getTools();

let releaseMap: Record<string, Release> = {};
try {
  const allReleases = await getAllToolReleases();
  for (const tr of allReleases) {
    const stable = tr.releases.find((r) => !r.prerelease);
    if (stable) {
      releaseMap[tr.tool.id] = stable;
    } else if (tr.releases.length > 0) {
      releaseMap[tr.tool.id] = tr.releases[0];
    }
  }
} catch {
  // No release data yet — scraper hasn't run
}
---

<BaseLayout title="changelogs.info — AI Coding Tool Release Tracker">
  <!-- Hero -->
  <section class="border-b border-border">
    <div class="mx-auto max-w-6xl px-6 py-16 md:py-24">
      <div class="max-w-2xl">
        <p class="mb-3 font-mono text-sm text-accent">&gt; tracking ai coding tools</p>
        <h1 class="text-4xl font-bold tracking-tight md:text-5xl">
          Every release.<br />
          <span class="text-text-secondary">One place.</span>
        </h1>
        <p class="mt-4 text-lg leading-relaxed text-text-secondary">
          Stay up to date with changelogs from the most popular AI coding assistants.
          Never miss a feature, fix, or breaking change.
        </p>
      </div>
    </div>
  </section>

  <!-- Tools grid -->
  <section class="mx-auto max-w-6xl px-6 py-12">
    <div class="mb-8 flex items-center justify-between">
      <h2 class="text-xl font-semibold">Tracked Tools</h2>
      <span class="text-sm text-text-muted">{tools.length} tools</span>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {tools.map((tool) => (
        <ToolCard tool={tool} latestRelease={releaseMap[tool.id]} />
      ))}
    </div>
  </section>

  <!-- Recent releases -->
  <section class="mx-auto max-w-6xl px-6 pb-16">
    <h2 class="mb-6 text-xl font-semibold">Recent Releases</h2>

    {Object.keys(releaseMap).length > 0 ? (
      <div class="space-y-3">
        {Object.entries(releaseMap)
          .sort(([, a], [, b]) => new Date(b.date).getTime() - new Date(a.date).getTime())
          .slice(0, 10)
          .map(([toolId, release]) => {
            const tool = tools.find((t) => t.id === toolId);
            return tool ? (
              <a
                href={`/tools/${toolId}`}
                class="flex items-center gap-4 rounded-lg border border-border bg-bg-card p-4 transition-all hover:border-border-hover hover:bg-bg-card-hover"
              >
                <span class="font-mono text-sm font-medium text-green">{release.version}</span>
                <span class="text-sm font-medium text-text-primary">{tool.name}</span>
                <span class="text-xs text-text-muted">{release.name !== release.version ? release.name : ""}</span>
                <span class="ml-auto text-xs text-text-muted">
                  {new Date(release.date).toLocaleDateString("en-US", { month: "short", day: "numeric" })}
                </span>
              </a>
            ) : null;
          })}
      </div>
    ) : (
      <div class="rounded-xl border border-dashed border-border p-12 text-center">
        <p class="mb-2 font-mono text-sm text-text-muted">&gt; no release data yet</p>
        <p class="text-sm text-text-secondary">
          Run the scraper to fetch release data:
        </p>
        <code class="mt-3 inline-block rounded-lg bg-bg-tertiary px-4 py-2 font-mono text-sm text-accent">
          npx tsx scrapers/github-releases.ts
        </code>
      </div>
    )}
  </section>
</BaseLayout>
