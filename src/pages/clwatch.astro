---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="clwatch — the changelog watcher for AI coding agents | changelogs.info" description="clwatch monitors changelogs for AI coding tools and patches your agent configs and reference files automatically.">
  <div class="mx-auto max-w-4xl px-6 py-12">

    <!-- Hero -->
    <a href="/" class="mb-8 inline-flex items-center gap-1 font-mono text-sm text-text-muted transition-colors hover:text-green">
      <span class="text-green">&lt;</span> cd ..
    </a>

    <header class="mb-12">
      <h1 class="font-mono text-2xl font-bold text-green sm:text-3xl">clwatch</h1>
      <p class="mt-3 font-sans text-sm leading-relaxed text-text-secondary sm:text-base">
        The changelog watcher for AI coding agents.
      </p>
      <div class="mt-4 flex gap-2">
        <span class="rounded border border-border px-3 py-1 font-mono text-xs text-text-secondary">Open Source</span>
        <span class="rounded border border-border px-3 py-1 font-mono text-xs text-text-secondary">Go Binary</span>
      </div>
    </header>

    <!-- What is clwatch -->
    <section class="mb-12">
      <h2 class="mb-4 font-mono text-lg font-semibold text-green"><span class="text-green">/</span>what_is_clwatch</h2>
      <div class="space-y-4 font-sans text-sm leading-relaxed text-text-secondary sm:text-base">
        <p>
          clwatch monitors changelogs for Claude Code, Codex CLI, Gemini CLI, OpenCode, and OpenClaw. When a tool ships a release, clwatch detects it and tells you exactly what changed.
        </p>
        <p>
          Run it in your terminal or drop it into any AI coding agent workspace. The included skill auto-runs on session start, patches outdated flags and configs (Tier 1), and refreshes your agent reference files when bigger changes ship (Tier 2).
        </p>
      </div>
    </section>

    <!-- Two-tier explainer -->
    <section class="mb-12">
      <div class="grid gap-4 sm:grid-cols-2">
        <div class="rounded-lg border border-green/30 bg-bg-card p-5 sm:p-6">
          <div class="mb-3 flex items-center gap-3">
            <span class="inline-block h-2 w-2 rounded-full bg-green"></span>
            <span class="font-mono text-xs text-green opacity-60">01</span>
          </div>
          <h3 class="font-mono text-base font-semibold text-green sm:text-lg">Tier 1: Config Patch</h3>
          <p class="mt-2 font-sans text-xs leading-relaxed text-text-secondary sm:text-sm">
            A flag changed. A permission mode renamed. clwatch detects the delta and patches your skill files and aliases automatically.
          </p>
        </div>
        <div class="rounded-lg border border-cyan/30 bg-bg-card p-5 sm:p-6">
          <div class="mb-3 flex items-center gap-3">
            <span class="inline-block h-2 w-2 rounded-full bg-cyan"></span>
            <span class="font-mono text-xs text-cyan opacity-60">02</span>
          </div>
          <h3 class="font-mono text-base font-semibold text-cyan sm:text-lg">Tier 2: Knowledge Refresh</h3>
          <p class="mt-2 font-sans text-xs leading-relaxed text-text-secondary sm:text-sm">
            A new feature shipped. New commands, new capabilities. clwatch pulls structured knowledge and your agent rewrites its reference files to match.
          </p>
        </div>
      </div>
    </section>

    <!-- Install -->
    <section class="mb-12">
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
        <!-- Left column — For Humans -->
        <div class="flex flex-col">
          <span class="mb-3 inline-flex w-fit items-center rounded-full border border-border bg-bg-card px-3 py-1 font-mono text-xs text-text-secondary">For Humans</span>

          <div class="flex flex-1 flex-col rounded-lg border border-border bg-bg-card">
            <div class="border-b border-border px-4 py-2 font-mono text-xs text-text-muted">
              <span class="text-green/40">●●●</span> <span class="ml-2">install.sh</span>
            </div>
            <div class="flex flex-1 flex-col gap-0 p-4">
              <div class="clwatch-cmd-row group flex items-center justify-between rounded px-3 py-2 hover:bg-bg-tertiary/50">
                <div class="font-mono text-sm">
                  <span class="text-text-muted"># macOS / Linux</span><br/>
                  <span class="text-green">$</span> <span class="text-text-primary">brew install clwatch</span>
                </div>
                <button class="copy-btn shrink-0 rounded px-2 py-1 font-mono text-xs text-text-muted opacity-0 transition-all hover:text-green group-hover:opacity-100" data-copy="brew install clwatch">copy</button>
              </div>
              <div class="clwatch-cmd-row group flex items-center justify-between rounded px-3 py-2 hover:bg-bg-tertiary/50">
                <div class="font-mono text-sm">
                  <span class="text-text-muted"># Everywhere</span><br/>
                  <span class="text-green">$</span> <span class="text-text-primary">npm install -g clwatch</span>
                </div>
                <button class="copy-btn shrink-0 rounded px-2 py-1 font-mono text-xs text-text-muted opacity-0 transition-all hover:text-green group-hover:opacity-100" data-copy="npm install -g clwatch">copy</button>
              </div>
              <div class="clwatch-cmd-row group flex items-center justify-between rounded px-3 py-2 hover:bg-bg-tertiary/50">
                <div class="font-mono text-sm">
                  <span class="text-text-muted"># No install needed</span><br/>
                  <span class="text-green">$</span> <span class="text-text-primary">npx clwatch diff</span>
                </div>
                <button class="copy-btn shrink-0 rounded px-2 py-1 font-mono text-xs text-text-muted opacity-0 transition-all hover:text-green group-hover:opacity-100" data-copy="npx clwatch diff">copy</button>
              </div>
            </div>
          </div>

          <p class="mt-3 font-sans text-xs text-text-muted">Run <code class="font-mono text-text-secondary">clwatch diff</code> to see what changed in your tools.</p>
        </div>

        <!-- Right column — For Agents -->
        <div class="flex flex-col">
          <span class="mb-3 inline-flex w-fit items-center rounded-full border border-cyan/30 bg-cyan/10 px-3 py-1 font-mono text-xs text-cyan">For Agents</span>

          <div class="flex flex-1 flex-col rounded-lg border border-border bg-bg-card">
            <div class="border-b border-border px-4 py-2 font-mono text-xs text-text-muted">
              <span class="text-green/40">●●●</span> <span class="ml-2">agent-setup.sh</span>
            </div>
            <div class="flex flex-1 flex-col gap-0 p-4">
              <div class="clwatch-cmd-row group flex items-center justify-between rounded px-3 py-2 hover:bg-bg-tertiary/50">
                <div class="font-mono text-sm">
                  <span class="text-text-muted"># Zero-install, run in any agent</span><br/>
                  <span class="text-cyan">$</span> <span class="text-text-primary">npx clwatch diff</span>
                </div>
                <button class="copy-btn shrink-0 rounded px-2 py-1 font-mono text-xs text-text-muted opacity-0 transition-all hover:text-cyan group-hover:opacity-100" data-copy="npx clwatch diff">copy</button>
              </div>
              <div class="clwatch-cmd-row group flex items-center justify-between rounded px-3 py-2 hover:bg-bg-tertiary/50">
                <div class="font-mono text-sm">
                  <span class="text-text-muted"># Zero-install via uv</span><br/>
                  <span class="text-cyan">$</span> <span class="text-text-primary">uvx clwatch diff</span>
                </div>
                <button class="copy-btn shrink-0 rounded px-2 py-1 font-mono text-xs text-text-muted opacity-0 transition-all hover:text-cyan group-hover:opacity-100" data-copy="uvx clwatch diff">copy</button>
              </div>
              <div class="clwatch-cmd-row group flex items-center justify-between rounded px-3 py-2 hover:bg-bg-tertiary/50">
                <div class="font-mono text-sm">
                  <span class="text-text-muted"># Install skill into workspace</span><br/>
                  <span class="text-cyan">$</span> <span class="text-text-primary">clwatch init</span>
                </div>
                <button class="copy-btn shrink-0 rounded px-2 py-1 font-mono text-xs text-text-muted opacity-0 transition-all hover:text-cyan group-hover:opacity-100" data-copy="clwatch init">copy</button>
              </div>
              <div class="clwatch-cmd-row group flex items-center justify-between rounded px-3 py-2 hover:bg-bg-tertiary/50">
                <div class="font-mono text-sm">
                  <span class="text-text-muted"># Machine-readable output for agents</span><br/>
                  <span class="text-cyan">$</span> <span class="text-text-primary">clwatch diff --json</span>
                </div>
                <button class="copy-btn shrink-0 rounded px-2 py-1 font-mono text-xs text-text-muted opacity-0 transition-all hover:text-cyan group-hover:opacity-100" data-copy="clwatch diff --json">copy</button>
              </div>
            </div>
          </div>

          <p class="mt-3 font-sans text-xs text-text-muted">Drop into any Claude Code, Codex CLI, Gemini CLI, or OpenClaw workspace. The skill auto-runs on session start.</p>
        </div>
      </div>
    </section>

    <!-- Commands reference -->
    <section class="mb-12">
      <div class="rounded-lg border border-border bg-bg-card">
        <div class="border-b border-border px-3 py-2 font-mono text-xs text-text-muted sm:px-4">
          <span class="text-green">●●●</span> <span class="ml-2">commands.sh</span>
        </div>
        <div class="p-4 sm:p-6">
          <div class="space-y-0">
            <div class="flex flex-col gap-1 border-b border-border/40 py-2.5 sm:flex-row sm:items-center sm:gap-4">
              <code class="shrink-0 font-mono text-xs text-green sm:w-64">clwatch diff</code>
              <span class="font-mono text-xs text-text-muted">Show what changed since last check</span>
            </div>
            <div class="flex flex-col gap-1 border-b border-border/40 py-2.5 sm:flex-row sm:items-center sm:gap-4">
              <code class="shrink-0 font-mono text-xs text-green sm:w-64">clwatch diff [tool]</code>
              <span class="font-mono text-xs text-text-muted">Diff a specific tool</span>
            </div>
            <div class="flex flex-col gap-1 border-b border-border/40 py-2.5 sm:flex-row sm:items-center sm:gap-4">
              <code class="shrink-0 font-mono text-xs text-green sm:w-64">clwatch diff --since 7d</code>
              <span class="font-mono text-xs text-text-muted">Diff changes in last 7 days</span>
            </div>
            <div class="flex flex-col gap-1 border-b border-border/40 py-2.5 sm:flex-row sm:items-center sm:gap-4">
              <code class="shrink-0 font-mono text-xs text-green sm:w-64">clwatch diff --json</code>
              <span class="font-mono text-xs text-text-muted">Machine-readable output</span>
            </div>
            <div class="flex flex-col gap-1 border-b border-border/40 py-2.5 sm:flex-row sm:items-center sm:gap-4">
              <code class="shrink-0 font-mono text-xs text-green sm:w-64">clwatch refresh [tool]</code>
              <span class="font-mono text-xs text-text-muted">Refresh agent reference files</span>
            </div>
            <div class="flex flex-col gap-1 border-b border-border/40 py-2.5 sm:flex-row sm:items-center sm:gap-4">
              <code class="shrink-0 font-mono text-xs text-green sm:w-64">clwatch refresh --all</code>
              <span class="font-mono text-xs text-text-muted">Refresh all tracked tools</span>
            </div>
            <div class="flex flex-col gap-1 border-b border-border/40 py-2.5 sm:flex-row sm:items-center sm:gap-4">
              <code class="shrink-0 font-mono text-xs text-green sm:w-64">clwatch refresh --diff-only</code>
              <span class="font-mono text-xs text-text-muted">Preview changes without writing</span>
            </div>
            <div class="flex flex-col gap-1 border-b border-border/40 py-2.5 sm:flex-row sm:items-center sm:gap-4">
              <code class="shrink-0 font-mono text-xs text-green sm:w-64">clwatch init</code>
              <span class="font-mono text-xs text-text-muted">Install skill into workspace</span>
            </div>
            <div class="flex flex-col gap-1 py-2.5 sm:flex-row sm:items-center sm:gap-4">
              <code class="shrink-0 font-mono text-xs text-green sm:w-64">clwatch list</code>
              <span class="font-mono text-xs text-text-muted">Show tracked tools + current versions</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Tracked tools -->
    <section class="mb-12">
      <h2 class="mb-4 font-mono text-lg font-semibold text-green"><span class="text-green">/</span>tracked_tools</h2>
      <div class="flex flex-wrap gap-2">
        <span class="rounded border border-border bg-bg-card px-3 py-1 font-mono text-xs text-text-secondary">Claude Code</span>
        <span class="rounded border border-border bg-bg-card px-3 py-1 font-mono text-xs text-text-secondary">Codex CLI</span>
        <span class="rounded border border-border bg-bg-card px-3 py-1 font-mono text-xs text-text-secondary">Gemini CLI</span>
        <span class="rounded border border-border bg-bg-card px-3 py-1 font-mono text-xs text-text-secondary">OpenCode</span>
        <span class="rounded border border-border bg-bg-card px-3 py-1 font-mono text-xs text-text-secondary">OpenClaw</span>
      </div>
    </section>

    <!-- Footer CTA -->
    <div class="text-center">
      <a href="/" class="font-mono text-sm text-text-muted transition-colors hover:text-green">
        View tracked tools &rarr;
      </a>
    </div>
  </div>

  <script>
    document.querySelectorAll('.copy-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const text = btn.getAttribute('data-copy');
        if (!text) return;
        navigator.clipboard.writeText(text).then(() => {
          const original = btn.textContent;
          btn.textContent = '✓';
          setTimeout(() => { btn.textContent = original; }, 1500);
        });
      });
    });
  </script>
</BaseLayout>
