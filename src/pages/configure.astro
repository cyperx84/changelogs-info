---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getTools } from "../lib/releases";

const tools = getTools().filter(t => t.id !== 'amp' && t.id !== 'avante-nvim');
---

<BaseLayout
  title="Config Generator — changelogs.info"
  description="Generate ready-to-paste configuration files for your AI coding tools. CLAUDE.md, settings.json, and more."
>
  <div class="mx-auto max-w-4xl px-6 py-12">

    <a href="/" class="mb-8 inline-flex items-center gap-1 font-mono text-sm text-text-muted transition-colors hover:text-green">
      <span class="text-green">&lt;</span> cd ..
    </a>

    <header class="mb-10">
      <h1 class="text-glow-green font-mono text-2xl font-bold text-green sm:text-3xl">config generator</h1>
      <p class="mt-3 font-sans text-sm leading-relaxed text-text-secondary sm:text-base max-w-2xl">
        Pick a tool, answer a few questions, get a ready-to-paste config file.
      </p>
    </header>

    <!-- Transparency note about referral -->
    <div class="mb-8 rounded-lg border border-green/20 bg-green/[0.03] p-4">
      <p class="font-sans text-xs text-text-muted">
        💡 <strong class="text-text-secondary">Save on inference:</strong> Several of these tools work with the 
        <a href="https://z.ai/subscribe?ic=O24DWAOAER" target="_blank" rel="noopener" class="text-green underline decoration-green/30 hover:decoration-green">GLM Coding Plan</a> 
        — $10/mo for Claude Code, Cline, Roo Code, and 20+ other tools. 
        <span class="text-text-muted">That's significantly cheaper than paying per-model API usage.</span>
        This is a referral link — we get credit if you subscribe.
      </p>
    </div>

    <!-- Tool selector -->
    <section class="mb-8">
      <h2 class="mb-4 font-mono text-sm font-semibold text-green"><span class="text-green">//</span> pick_your_tool</h2>
      <div class="grid gap-2 sm:grid-cols-3" id="tool-selector">
        {tools.map((t) => (
          <button
            class="tool-btn rounded-lg border border-border bg-bg-card px-4 py-3 text-left font-mono text-sm text-text-secondary transition-all hover:border-green hover:text-green"
            data-tool={t.id}
            data-name={t.name}
          >
            {t.name}
          </button>
        ))}
      </div>
    </section>

    <!-- Config form (hidden until tool selected) -->
    <section id="config-form" class="hidden">
      <h2 class="mb-4 font-mono text-sm font-semibold text-green"><span class="text-green">//</span> <span id="tool-name-display">tool</span>_config</h2>

      <!-- Stack selection -->
      <div class="mb-6">
        <label class="mb-2 block font-mono text-xs text-text-muted">What's your primary stack?</label>
        <div class="flex flex-wrap gap-2" id="stack-selector">
          <button class="stack-btn rounded border border-border bg-bg-tertiary px-3 py-1.5 font-mono text-xs text-text-muted transition-all hover:border-green hover:text-green" data-stack="web">Web (React/Next.js)</button>
          <button class="stack-btn rounded border border-border bg-bg-tertiary px-3 py-1.5 font-mono text-xs text-text-muted transition-all hover:border-green hover:text-green" data-stack="python">Python</button>
          <button class="stack-btn rounded border border-border bg-bg-tertiary px-3 py-1.5 font-mono text-xs text-text-muted transition-all hover:border-green hover:text-green" data-stack="rust">Rust</button>
          <button class="stack-btn rounded border border-border bg-bg-tertiary px-3 py-1.5 font-mono text-xs text-text-muted transition-all hover:border-green hover:text-green" data-stack="go">Go</button>
          <button class="stack-btn rounded border border-border bg-bg-tertiary px-3 py-1.5 font-mono text-xs text-text-muted transition-all hover:border-green hover:text-green" data-stack="other">Other</button>
        </div>
      </div>

      <!-- Use case -->
      <div class="mb-6">
        <label class="mb-2 block font-mono text-xs text-text-muted">What do you mostly do?</label>
        <div class="flex flex-wrap gap-2" id="usecase-selector">
          <button class="usecase-btn rounded border border-border bg-bg-tertiary px-3 py-1.5 font-mono text-xs text-text-muted transition-all hover:border-green hover:text-green" data-use="features">Build features</button>
          <button class="usecase-btn rounded border border-border bg-bg-tertiary px-3 py-1.5 font-mono text-xs text-text-muted transition-all hover:border-green hover:text-green" data-use="bugs">Fix bugs</button>
          <button class="usecase-btn rounded border border-border bg-bg-tertiary px-3 py-1.5 font-mono text-xs text-text-muted transition-all hover:border-green hover:text-green" data-use="review">Code review</button>
          <button class="usecase-btn rounded border border-border bg-bg-tertiary px-3 py-1.5 font-mono text-xs text-text-muted transition-all hover:border-green hover:text-green" data-use="refactor">Refactor</button>
          <button class="usecase-btn rounded border border-border bg-bg-tertiary px-3 py-1.5 font-mono text-xs text-text-muted transition-all hover:border-green hover:text-green" data-use="docs">Write docs</button>
        </div>
      </div>

      <!-- Model preference -->
      <div class="mb-6">
        <label class="mb-2 block font-mono text-xs text-text-muted">Model preference?</label>
        <div class="flex flex-wrap gap-2" id="model-selector">
          <button class="model-btn rounded border border-border bg-bg-tertiary px-3 py-1.5 font-mono text-xs text-text-muted transition-all hover:border-green hover:text-green" data-model="claude">Claude</button>
          <button class="model-btn rounded border border-border bg-bg-tertiary px-3 py-1.5 font-mono text-xs text-text-muted transition-all hover:border-green hover:text-green" data-model="gpt">GPT</button>
          <button class="model-btn rounded border border-border bg-bg-tertiary px-3 py-1.5 font-mono text-xs text-text-muted transition-all hover:border-green hover:text-green" data-model="gemini">Gemini</button>
          <button class="model-btn rounded border border-border bg-bg-tertiary px-3 py-1.5 font-mono text-xs text-text-muted transition-all hover:border-green hover:text-green" data-model="any">Whatever works</button>
        </div>
      </div>

      <!-- Generate button -->
      <button id="generate-btn" class="rounded border border-green bg-green/10 px-6 py-3 font-mono text-sm font-medium text-green transition-all hover:bg-green/20 hover:shadow-[0_0_12px_rgba(51,255,51,0.15)]">
        generate config →
      </button>
    </section>

    <!-- Output (hidden until generated) -->
    <section id="config-output" class="mt-8 hidden">
      <div class="rounded-lg border border-green/30 bg-bg-card">
        <div class="flex items-center justify-between border-b border-border px-4 py-2">
          <span class="font-mono text-xs text-text-muted"><span class="text-green">●●●</span> <span id="config-filename" class="ml-2">config.txt</span></span>
          <button id="copy-config-btn" class="rounded border border-border bg-bg-tertiary px-3 py-1 font-mono text-xs text-text-muted transition-all hover:border-green hover:text-green">
            copy
          </button>
        </div>
        <pre id="config-content" class="overflow-x-auto p-5 font-mono text-xs leading-relaxed text-text-secondary"></pre>
      </div>
    </section>
  </div>

  <script>
    // Tool selection
    let selectedTool = '';
    let selectedStack = '';
    let selectedUsecase = '';
    let selectedModel = '';

    document.querySelectorAll('.tool-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.tool-btn').forEach(b => {
          b.classList.remove('border-green', 'text-green');
          b.classList.add('border-border', 'text-text-secondary');
        });
        btn.classList.remove('border-border', 'text-text-secondary');
        btn.classList.add('border-green', 'text-green');
        selectedTool = btn.getAttribute('data-tool') || '';
        const name = btn.getAttribute('data-name') || '';
        document.getElementById('tool-name-display')!.textContent = name;
        document.getElementById('config-form')!.classList.remove('hidden');
      });
    });

    // Multi-select buttons
    function setupMultiSelect(selector: string, attr: string, callback: (val: string) => void) {
      document.querySelectorAll(selector).forEach((btn) => {
        btn.addEventListener('click', () => {
          document.querySelectorAll(selector).forEach(b => {
            b.classList.remove('border-green', 'text-green', 'bg-green/10');
            b.classList.add('border-border', 'text-text-muted');
          });
          btn.classList.remove('border-border', 'text-text-muted');
          btn.classList.add('border-green', 'text-green', 'bg-green/10');
          callback(btn.getAttribute(attr) || '');
        });
      });
    }

    setupMultiSelect('.stack-btn', 'data-stack', (v) => selectedStack = v);
    setupMultiSelect('.usecase-btn', 'data-use', (v) => selectedUsecase = v);
    setupMultiSelect('.model-btn', 'data-model', (v) => selectedModel = v);

    // Config templates
    const configs: Record<string, (stack: string, use: string, model: string) => { filename: string; content: string }> = {
      'claude-code': (stack, use, model) => {
        const modelMap: Record<string, string> = {
          'claude': 'anthropic/claude-sonnet-4-6',
          'gpt': 'openai/gpt-5.4',
          'gemini': 'google/gemini-2.5-flash',
          'any': 'anthropic/claude-sonnet-4-6',
        };
        const useInstructions: Record<string, string> = {
          'features': '- Always write tests for new features\n- Use TypeScript strict mode\n- Create small, focused commits',
          'bugs': '- Always reproduce the bug before fixing\n- Write a regression test\n- Explain the root cause',
          'review': '- Focus on edge cases and error handling\n- Check for security implications\n- Suggest test cases',
          'refactor': '- Preserve existing behavior exactly\n- Run tests after each step\n- Keep public API changes minimal',
          'docs': '- Use clear, concise language\n- Include code examples\n- Document gotchas and edge cases',
        };
        return {
          filename: 'CLAUDE.md',
          content: `# ${stack || 'Project'} Project

## Stack
${stack || 'General'} project using modern tooling.

## Model
Default: ${modelMap[model] || modelMap['claude']}

## Rules
${useInstructions[use] || useInstructions['features']}

## Conventions
- Follow existing code style
- Write tests for new code
- Run \`pnpm test\` before committing

## Commands
- Build: \`pnpm build\`
- Test: \`pnpm test\`
- Lint: \`pnpm lint\`
`,
        };
      },
      'codex-cli': (stack, use, model) => ({
        filename: 'AGENTS.md',
        content: `# Codex AGENTS.md

## Project
${stack || 'General'} project.

## What to do
${use === 'features' ? 'Build new features with tests.' : use === 'bugs' ? 'Fix bugs with regression tests.' : use === 'review' ? 'Review code for edge cases and security.' : use === 'refactor' ? 'Refactor preserving behavior.' : 'Write clean, tested code.'}

## Commands
- Build: \`pnpm build\`
- Test: \`pnpm test\`

## Style
- Follow existing conventions
- Prefer small, focused changes
`,
      }),
      'openclaw': (stack, use, model) => ({
        filename: 'AGENTS.md',
        content: `# OpenClaw Agent Config

## Stack
${stack || 'General'} project.

## Preferences
${use === 'features' ? 'Focus on feature development with thorough testing.' : use === 'bugs' ? 'Prioritize debugging and regression prevention.' : 'Follow best practices for code quality.'}

## Tools
- Use \`pnpm\` for package management
- Run tests before committing
- Keep commits atomic

## Memory
Track important decisions in memory/YYYY-MM-DD.md files.
`,
      }),
    };

    // Generic config for tools without specific templates
    function genericConfig(toolId: string, toolName: string, stack: string, use: string) {
      return {
        filename: `${toolId}-config.md`,
        content: `# ${toolName} Config

## Stack
${stack || 'General'} project.

## Workflow
${use === 'features' ? 'Building new features' : use === 'bugs' ? 'Fixing bugs' : use === 'review' ? 'Code review' : use === 'refactor' ? 'Refactoring' : 'General development'}.

## Commands
- Build: \`pnpm build\`
- Test: \`pnpm test\`
`,
      };
    }

    // Generate
    document.getElementById('generate-btn')?.addEventListener('click', () => {
      if (!selectedTool) return;
      const generator = configs[selectedTool];
      const config = generator
        ? generator(selectedStack, selectedUsecase, selectedModel)
        : genericConfig(selectedTool, selectedTool, selectedStack, selectedUsecase);

      document.getElementById('config-filename')!.textContent = config.filename;
      document.getElementById('config-content')!.textContent = config.content;
      document.getElementById('config-output')!.classList.remove('hidden');
      document.getElementById('config-output')!.scrollIntoView({ behavior: 'smooth' });
    });

    // Copy
    document.getElementById('copy-config-btn')?.addEventListener('click', () => {
      const content = document.getElementById('config-content')?.textContent || '';
      navigator.clipboard.writeText(content).then(() => {
        const btn = document.getElementById('copy-config-btn')!;
        btn.textContent = '✓ copied';
        setTimeout(() => { btn.textContent = 'copy'; }, 1500);
      });
    });
  </script>
</BaseLayout>
