---
import ClaudeCodeLayout from "../../layouts/ClaudeCodeLayout.astro";
import { getToolReleases, formatDate } from "../../lib/releases";

const data = await getToolReleases("claude-code");
const releases = data?.releases || [];
const stableReleases = releases.filter((r) => !r.prerelease);
const latestStable = stableReleases[0];

function isBreaking(body: string = ""): boolean {
  return body.toLowerCase().includes("breaking");
}

const INITIAL_LOAD = 12;
---

<ClaudeCodeLayout
  title="Claude Code Releases — changelogs.info"
  description="All Claude Code releases. Version history and iteration log."
  currentPage="releases"
>
  <div style="max-width: 1280px; margin: 0 auto; padding: 2rem 1.5rem 0;">

    <!-- Header -->
    <header style="margin-bottom: 4rem; display: flex; flex-wrap: wrap; align-items: flex-end; justify-content: space-between; gap: 1.5rem; border-left: 8px solid var(--cc-primary); padding-left: 2rem; padding-top: 1rem; padding-bottom: 1rem;">
      <div>
        <h1 class="cc-headline" style="font-size: clamp(3rem, 8vw, 6rem); font-weight: 900; text-transform: uppercase; letter-spacing: -0.03em; line-height: 0.9; margin: 0 0 0.5rem; color: var(--cc-text);">
          Releases
        </h1>
        <p class="cc-headline" style="font-size: 1.1rem; font-weight: 700; color: var(--cc-primary-bright); margin: 0; text-transform: uppercase; letter-spacing: 0.1em; opacity: 0.8;">
          Version History &amp; Iteration Log
        </p>
      </div>
      <div style="display: flex; align-items: center; gap: 1rem; flex-wrap: wrap;">
        {latestStable && (
          <div style="border: 4px solid var(--cc-border); padding: 0.75rem 1.5rem; background: var(--cc-bg-card);">
            <span style="font-family: var(--cc-font-mono); font-size: 0.65rem; color: var(--cc-text-muted); display: block; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.25rem;">Latest Stable</span>
            <span class="cc-headline" style="font-size: 1.5rem; font-weight: 900; color: var(--cc-primary-bright);">{latestStable.version}</span>
          </div>
        )}
        <div style="border: 4px solid var(--cc-border); padding: 0.75rem 1.5rem; background: var(--cc-bg-card);">
          <span style="font-family: var(--cc-font-mono); font-size: 0.65rem; color: var(--cc-text-muted); display: block; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.25rem;">Total</span>
          <span class="cc-headline" style="font-size: 1.5rem; font-weight: 900; color: var(--cc-text);">{releases.length}</span>
        </div>
      </div>
    </header>

    <!-- Filter bar -->
    {releases.length > 6 && (
      <div style="display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 2rem; align-items: center;">
        <span style="font-family: var(--cc-font-mono); font-size: 0.65rem; color: var(--cc-text-muted); text-transform: uppercase; letter-spacing: 0.1em;">Filter:</span>
        {["all", "stable", "breaking", "prerelease"].map((f) => (
          <button
            class="cc-headline releases-filter-btn"
            data-filter={f}
            style={`border: 2px solid var(--cc-border-dim); padding: 0.35rem 0.9rem; font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; cursor: pointer; transition: all 100ms; background: ${f === 'all' ? 'var(--cc-primary)' : 'transparent'}; color: ${f === 'all' ? 'white' : 'var(--cc-text-muted)'}; border-color: ${f === 'all' ? 'var(--cc-primary)' : 'var(--cc-border-dim)'};`}
          >
            {f === "prerelease" ? "Pre" : f.charAt(0).toUpperCase() + f.slice(1)}
          </button>
        ))}
        <input
          id="releases-search"
          type="text"
          placeholder="Search..."
          style="background: var(--cc-bg); border: 2px solid var(--cc-border-dim); padding: 0.35rem 0.75rem; font-family: var(--cc-font-mono); font-size: 0.72rem; color: var(--cc-text); outline: none; transition: border-color 150ms; margin-left: auto;"
          onfocus="this.style.borderColor='var(--cc-primary-bright)'"
          onblur="this.style.borderColor='var(--cc-border-dim)'"
        />
      </div>
    )}

    <!-- Release grid -->
    {releases.length > 0 ? (
      <div id="releases-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.25rem; margin-bottom: 3rem;">
        {releases.map((release, idx) => {
          const breaking = isBreaking(release.body);
          return (
            <div
              class="release-card"
              data-version={release.version.toLowerCase()}
              data-name={(release.name || "").toLowerCase()}
              data-prerelease={String(release.prerelease)}
              data-breaking={String(breaking)}
              data-hidden-init={idx >= INITIAL_LOAD ? "true" : "false"}
              style={`padding: 1.5rem; border: 4px solid ${breaking ? 'var(--cc-primary)' : 'var(--cc-border)'}; background: ${breaking ? 'rgba(245,158,11,0.06)' : 'var(--cc-bg-card)'}; ${breaking ? 'border-left: 8px solid var(--cc-primary);' : ''} transition: border-color 150ms;`}
            >
              <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 0.5rem; margin-bottom: 0.75rem;">
                <div>
                  <span class="cc-headline" style="font-size: 1.3rem; font-weight: 900; color: var(--cc-text); display: block;">{release.version}</span>
                  <span style="font-family: var(--cc-font-mono); font-size: 0.65rem; color: var(--cc-text-muted);">{formatDate(release.date)}</span>
                </div>
                <div style="display: flex; flex-direction: column; gap: 0.3rem; align-items: flex-end;">
                  {breaking && <span style="background: var(--cc-primary); color: white; font-family: var(--cc-font-mono); padding: 0.15rem 0.5rem; font-size: 0.55rem; font-weight: 700; text-transform: uppercase;">BREAKING</span>}
                  {release.prerelease && <span style="background: rgba(245,158,11,0.15); color: #f59e0b; font-family: var(--cc-font-mono); padding: 0.15rem 0.5rem; font-size: 0.55rem; font-weight: 700; text-transform: uppercase; border: 1px solid #f59e0b;">PRE</span>}
                </div>
              </div>

              {release.name && (
                <p class="cc-headline" style="font-size: 0.78rem; font-weight: 700; color: var(--cc-text-dim); text-transform: uppercase; margin: 0 0 0.75rem; letter-spacing: 0.03em;">
                  {(release.name).replace(/^claude[\s-]code\s+/i, "")}
                </p>
              )}

              <a
                href={release.url}
                target="_blank"
                rel="noopener noreferrer"
                style="display: inline-flex; align-items: center; gap: 0.35rem; font-family: var(--cc-font-mono); font-size: 0.65rem; color: var(--cc-text-muted); text-decoration: none; text-transform: uppercase; letter-spacing: 0.08em; transition: color 150ms; border-top: 1px solid var(--cc-border-dim); padding-top: 0.75rem; width: 100%;"
                onmouseover="this.style.color='var(--cc-primary-bright)'"
                onmouseout="this.style.color='var(--cc-text-muted)'"
              >
                ↗ View on GitHub
              </a>
            </div>
          );
        })}
      </div>
    ) : (
      <div style="padding: 4rem 2rem; border: 4px dashed var(--cc-border-dim); text-align: center; margin-bottom: 3rem;">
        <p style="font-family: var(--cc-font-mono); color: var(--cc-text-muted);">$ no releases tracked yet</p>
      </div>
    )}

    {releases.length > INITIAL_LOAD && (
      <div style="margin-bottom: 4rem; text-align: center;">
        <button
          id="load-more-releases"
          class="cc-headline"
          style="background: transparent; border: 4px solid var(--cc-border); color: var(--cc-text); padding: 1rem 2.5rem; font-size: 0.85rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.1em; cursor: pointer; font-style: italic; transition: background 100ms, color 100ms;"
          onmouseover="this.style.background='var(--cc-primary)';this.style.color='white'"
          onmouseout="this.style.background='transparent';this.style.color='var(--cc-text)'"
        >
          Load More ▼
        </button>
      </div>
    )}
  </div>

  <script>
    const cards = Array.from(document.querySelectorAll('.release-card')) as HTMLElement[];

    // Apply initial hidden state
    cards.forEach(card => {
      if (card.dataset.hiddenInit === 'true') card.style.display = 'none';
    });

    const filterBtns = Array.from(document.querySelectorAll('.releases-filter-btn')) as HTMLElement[];
    const searchInput = document.getElementById('releases-search') as HTMLInputElement;
    const loadMoreBtn = document.getElementById('load-more-releases');
    let activeFilter = 'all';
    let searchQuery = '';
    let allLoaded = false;

    function applyFilters() {
      let visibleCount = 0;
      cards.forEach((card, idx) => {
        const version = card.dataset.version || '';
        const name = card.dataset.name || '';
        const prerelease = card.dataset.prerelease === 'true';
        const breaking = card.dataset.breaking === 'true';

        const matchesSearch = !searchQuery || version.includes(searchQuery) || name.includes(searchQuery);
        const matchesFilter =
          activeFilter === 'all' ||
          (activeFilter === 'stable' && !prerelease) ||
          (activeFilter === 'breaking' && breaking) ||
          (activeFilter === 'prerelease' && prerelease);

        const withinLimit = allLoaded || card.dataset.hiddenInit !== 'true';

        const show = matchesSearch && matchesFilter && withinLimit;
        card.style.display = show ? '' : 'none';
        if (show) visibleCount++;
      });
    }

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        activeFilter = btn.dataset.filter || 'all';
        filterBtns.forEach(b => {
          b.style.background = 'transparent';
          b.style.color = 'var(--cc-text-muted)';
          b.style.borderColor = 'var(--cc-border-dim)';
        });
        btn.style.background = 'var(--cc-primary)';
        btn.style.color = 'white';
        btn.style.borderColor = 'var(--cc-primary)';
        applyFilters();
      });
    });

    searchInput?.addEventListener('input', () => {
      searchQuery = searchInput.value.toLowerCase().trim();
      if (searchQuery) allLoaded = true;
      applyFilters();
    });

    loadMoreBtn?.addEventListener('click', () => {
      allLoaded = true;
      loadMoreBtn.style.display = 'none';
      cards.forEach(card => {
        if (card.dataset.hiddenInit === 'true') card.style.display = '';
      });
      applyFilters();
    });
  </script>
</ClaudeCodeLayout>
