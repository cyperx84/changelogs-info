---
import ClaudeCodeLayout from "../../layouts/ClaudeCodeLayout.astro";
import "../../styles/guide-shared.css";
import "../../styles/cheatsheet-shared.css";
import { readFileSync } from "node:fs";
import { join } from "node:path";
import { getToolReleases, formatDate } from "../../lib/releases";

let cs: any = {};
try {
  const raw = readFileSync(join(process.cwd(), "src/content/cheatsheets-json/claude-code.json"), "utf-8");
  cs = JSON.parse(raw);
} catch {}

const cliFlags = cs.cliFlags || [];
const slashCommands = cs.slashCommands || [];
const dailyWorkflows = cs.dailyWorkflows || [];
const powerMoves = cs.powerMoves || [];
const gotchas = cs.gotchas || [];

const data = await getToolReleases("claude-code");
const releases = (data?.releases || []).slice(0, 8);
const latestRelease = data?.releases?.[0] || null;

function isBreaking(body: string = "") { return body.toLowerCase().includes("breaking"); }
---

<ClaudeCodeLayout
  title="Claude Code Guide — Getting Started, Tips, Reference"
  description="Everything you need for Claude Code: install guide, power tips, command reference, and latest releases."
  currentPage="guide"
>
  <div class="guide-wrapper">

    <!-- TOC -->
    <nav class="guide-toc" aria-label="Guide sections">
      <span class="guide-toc__label">Jump to</span>
      <a href="#getting-started" class="guide-toc__link">Getting Started</a>
      <a href="#power-tips" class="guide-toc__link">Power Tips</a>
      <a href="#reference" class="guide-toc__link">Reference</a>
    </nav>

    <!-- ══ 1: GETTING STARTED ══ -->
    <section class="guide-hero" id="getting-started">
      <img class="guide-hero__img" src="/images/guides/claude-code-hero.png" alt="Claude Code" />
      <div class="guide-hero__content">
        <h2 class="guide-hero__title">Claude Code</h2>
        <div class="guide-hero__body">
          <p>
            Honestly, Claude Code is the one that changed how I actually work. Not "improved" — changed. It's a terminal-based AI coding agent from Anthropic that drops directly into your workflow. No browser tab, no copy-paste loops, no context window juggling. You open your project, type <code>claude</code>, and it starts reading your codebase. It just… knows where it is.
          </p>
          <p>
            What makes it different from other AI coding tools is the agentic loop. Claude Code doesn't just answer questions — it takes actions. It reads files, edits code, runs commands, checks the output, and iterates. You give it a task like "refactor the auth module to use JWTs and make sure the tests still pass" and it actually does that, end to end. You're supervising, not transcribing.
          </p>
          <p>
            The <strong>CLAUDE.md</strong> feature is legitimately sick. Drop a markdown file in your repo root, and it gets read automatically at the start of every session. Put your conventions, your architecture notes, your "don't touch this" warnings — all of it. Suddenly every session starts with full context. No re-explaining. No "as I mentioned before." It's like having a senior dev who actually remembers things.
          </p>
          <p>
            Getting started is fast. You need Node 18+, an Anthropic API key, and one install command. From there you can run it interactively or pipe it into scripts with <code>--print</code> mode. The non-interactive output is clean JSON or plain text — works perfectly in CI, git hooks, or any automation where you need AI reasoning without a human in the loop.
          </p>
          <p>
            Who's it for? Builders who live in the terminal. Backend engineers doing big refactors. Anyone tired of bouncing between an editor and a chat window. If you're spending more than a few minutes a day on copy-paste AI workflows, this is the upgrade.
          </p>
        </div>
      </div>
    </section>

    {latestRelease && (
      <div class="guide-latest">
        <div class="guide-latest__header">
          <span class="guide-latest__version">v{latestRelease.version}</span>
          {latestRelease.name && <span class="guide-latest__name">{latestRelease.name.replace(/^claude[\s-]code\s+/i, "")}</span>}
          <span class="guide-latest__date">{formatDate(latestRelease.date)}</span>
        </div>
        <div class="guide-latest__body">{latestRelease.body || "No release notes available."}</div>
        {latestRelease.url && <a href={latestRelease.url} target="_blank" rel="noopener noreferrer" class="guide-latest__link">View on GitHub ↗</a>}
      </div>
    )}

    <!-- ══ 2: POWER TIPS ══ -->
    <section class="guide-section" id="power-tips">
      <div class="guide-section__header">
        <span class="guide-section__num">02</span>
        <span class="guide-section__icon">⚡</span>
        <h2 class="guide-section__title">Power Tips</h2>
        <span class="guide-section__sub">Non-obvious leverage</span>
      </div>

      <div class="tips-section">
        <div class="tips-section__header">
          <span class="tips-section__icon">⚡</span>
          <h3 class="tips-section__title">Quick Wins</h3>
        </div>
        <div class="tips-cards">
          <div class="tips-card tips-card--highlight">
            <span class="tips-card__num">01</span>
            <div class="tips-card__title">CLAUDE.md is your superpower</div>
            <p class="tips-card__desc">A CLAUDE.md in your repo root is automatically read at the start of every session. Put your conventions, architecture notes, and preferences here. Never re-explain your codebase again.</p>
          </div>
          <div class="tips-card">
            <span class="tips-card__num">02</span>
            <div class="tips-card__title">--print for scripting</div>
            <p class="tips-card__desc">Non-interactive output mode. Pipes cleanly into other tools, perfect for CI and shell automation.</p>
            <div class="tips-card__cmd">claude --print "summarise changes" &lt; git diff HEAD~1</div>
          </div>
          <div class="tips-card">
            <span class="tips-card__num">03</span>
            <div class="tips-card__title">Pipe stdin natively</div>
            <p class="tips-card__desc">Claude Code reads stdin. Feed it files, logs, diffs — anything. No temp files needed.</p>
            <div class="tips-card__cmd">cat error.log | claude "why is this failing"</div>
          </div>
          <div class="tips-card">
            <span class="tips-card__num">04</span>
            <div class="tips-card__title">--continue resumes last session</div>
            <p class="tips-card__desc">Come back to exactly where you were without re-explaining context. Massive time saver for multi-session tasks.</p>
            <div class="tips-card__cmd">claude --continue</div>
          </div>
          <div class="tips-card">
            <span class="tips-card__num">05</span>
            <div class="tips-card__title">JSON output for CI pipelines</div>
            <p class="tips-card__desc">Parse Claude Code output programmatically in CI scripts and automation workflows.</p>
            <div class="tips-card__cmd">claude --print --output-format json "list all TODO comments"</div>
          </div>
          <div class="tips-card">
            <span class="tips-card__num">06</span>
            <div class="tips-card__title">bypassPermissions for trusted repos</div>
            <p class="tips-card__desc">Eliminates all approval friction in repos you own and trust. Don't use on unfamiliar code.</p>
            <div class="tips-card__cmd">claude --permission-mode bypassPermissions</div>
          </div>
        </div>
      </div>

      <div class="tips-section">
        <div class="tips-section__header">
          <span class="tips-section__icon">🔍</span>
          <h3 class="tips-section__title">Hidden Features</h3>
        </div>
        <div class="tips-features">
          <div class="tips-feature">
            <span class="tips-feature__icon">🤖</span>
            <div class="tips-feature__body">
              <div class="tips-feature__title">Spawn parallel sub-agents with the Task tool</div>
              <p class="tips-feature__desc">Claude Code has a built-in Task tool that lets it run parallel sub-agents. For large refactors or multi-file operations, mention it in your prompt: "use multiple agents to process these files in parallel." CC handles the orchestration.</p>
            </div>
          </div>
          <div class="tips-feature">
            <span class="tips-feature__icon">🙈</span>
            <div class="tips-feature__body">
              <div class="tips-feature__title">Respects .gitignore automatically</div>
              <p class="tips-feature__desc">Claude Code reads your .gitignore and won't explore files matching those patterns. No need to tell it to ignore node_modules, dist, or .env — it already knows.</p>
            </div>
          </div>
          <div class="tips-feature">
            <span class="tips-feature__icon">📂</span>
            <div class="tips-feature__body">
              <div class="tips-feature__title">Monorepo aware — point it at a subdir</div>
              <p class="tips-feature__desc">Working in a monorepo? Launch CC from the specific package directory you want it to focus on. It understands the context without needing the whole repo.</p>
              <code class="tips-feature__cmd">cd packages/auth-service && claude</code>
            </div>
          </div>
          <div class="tips-feature">
            <span class="tips-feature__icon">🔄</span>
            <div class="tips-feature__body">
              <div class="tips-feature__title">--permission-mode auto — middle ground</div>
              <p class="tips-feature__desc">Between "ask me about everything" and bypassPermissions, there's <code>auto</code> — Claude decides when to ask based on risk level. Good for semi-trusted repos.</p>
              <code class="tips-feature__cmd">claude --permission-mode auto</code>
            </div>
          </div>
        </div>
      </div>

      <div class="tips-section">
        <div class="tips-section__header">
          <span class="tips-section__icon">💀</span>
          <h3 class="tips-section__title">Common Mistakes</h3>
        </div>
        <div class="tips-gotchas">
          <div class="tips-gotcha">
            <span class="tips-gotcha__skull">☠️</span>
            <div class="tips-gotcha__title">No CLAUDE.md in your repo</div>
            <p class="tips-gotcha__desc">Every session starts from scratch re-learning your codebase. You're leaving the biggest lever on the floor.</p>
            <span class="tips-gotcha__fix">Generate one: claude --print "create a CLAUDE.md for this codebase" > CLAUDE.md</span>
          </div>
          <div class="tips-gotcha">
            <span class="tips-gotcha__skull">☠️</span>
            <div class="tips-gotcha__title">Vague task descriptions</div>
            <p class="tips-gotcha__desc">"Fix the bug" produces mediocre results. "Fix the null check in src/auth.ts line 47 that crashes when user is unauthenticated" produces a surgical fix.</p>
            <span class="tips-gotcha__fix">Be specific: file, line, symptom, expected behaviour.</span>
          </div>
          <div class="tips-gotcha">
            <span class="tips-gotcha__skull">☠️</span>
            <div class="tips-gotcha__title">Wrong working directory</div>
            <p class="tips-gotcha__desc">Claude Code reads files relative to where you launched it. Run it from the wrong dir and it's working in the dark.</p>
            <span class="tips-gotcha__fix">Always confirm you're in the right project root before launching.</span>
          </div>
          <div class="tips-gotcha">
            <span class="tips-gotcha__skull">☠️</span>
            <div class="tips-gotcha__title">Not using --print for automation</div>
            <p class="tips-gotcha__desc">If you're scripting CC into CI or shell pipelines and not using --print, you're getting interactive output that's hard to parse and may block.</p>
            <span class="tips-gotcha__fix">Always add --print for any non-interactive or automated use.</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ══ 3: COMMAND REFERENCE ══ -->
    <section class="guide-section" id="reference">
      <div class="guide-section__header">
        <span class="guide-section__num">03</span>
        <span class="guide-section__icon">📋</span>
        <h2 class="guide-section__title">Command Reference</h2>
        <span class="guide-section__sub">Flags, commands, workflows</span>
      </div>

      <div class="guide-ref-grid">
        {cliFlags.length > 0 && (
          <div class="guide-ref-panel">
            <div class="guide-ref-panel__title">CLI Flags</div>
            {cliFlags.map((flag: any) => (
              <div class="guide-ref-item">
                <span class="guide-ref-item__key">{flag.flag || flag.command}</span>
                <span class="guide-ref-item__desc">{flag.description}</span>
              </div>
            ))}
          </div>
        )}
        {slashCommands.length > 0 && (
          <div class="guide-ref-panel">
            <div class="guide-ref-panel__title">Slash Commands</div>
            {slashCommands.map((cmd: any) => (
              <div class="guide-ref-item">
                <span class="guide-ref-item__key">{cmd.command || cmd.cmd}</span>
                <span class="guide-ref-item__desc">{cmd.description}</span>
              </div>
            ))}
          </div>
        )}
        {dailyWorkflows.length > 0 && (
          <div class="guide-ref-panel">
            <div class="guide-ref-panel__title">Daily Workflows</div>
            {dailyWorkflows.map((wf: any) => (
              <div class="guide-ref-item">
                <span class="guide-ref-item__key" style="min-width: 0; font-size: 0.68rem;">{wf.title}</span>
                <span class="guide-ref-item__desc">{wf.command || wf.description}</span>
              </div>
            ))}
          </div>
        )}
        {powerMoves.length > 0 && (
          <div class="guide-ref-panel">
            <div class="guide-ref-panel__title">⚡ Power Moves</div>
            {powerMoves.map((pm: any) => (
              <div class="guide-ref-item">
                <span class="guide-ref-item__key" style="min-width: 0; font-size: 0.68rem;">{pm.title}</span>
                <span class="guide-ref-item__desc">{pm.command || pm.description}</span>
              </div>
            ))}
          </div>
        )}
      </div>

      {cliFlags.length === 0 && slashCommands.length === 0 && (
        <p style="font-family: var(--tool-font-mono); font-size: 0.8rem; color: var(--tool-text-muted);">
          $ cheatsheet data not available — run scraper to populate
        </p>
      )}
    </section>

  </div>

  <script is:inline>
    // Copy buttons for command blocks
    document.querySelectorAll('.qs-cmd').forEach(function(block) {
      var btn = document.createElement('button');
      btn.className = 'qs-cmd__copy';
      btn.textContent = 'copy';
      btn.addEventListener('click', function() {
        var code = block.querySelector('code');
        if (!code) return;
        var text = code.textContent.replace(/^\$\s*/, '').trim();
        navigator.clipboard.writeText(text).then(function() {
          btn.textContent = 'copied!';
          setTimeout(function() { btn.textContent = 'copy'; }, 1500);
        });
      });
      block.style.paddingRight = '5rem';
      block.appendChild(btn);
    });

    // TOC active state on scroll
    var sections = document.querySelectorAll('.guide-section[id]');
    var tocLinks = document.querySelectorAll('.guide-toc__link');
    function updateToc() {
      var scrollY = window.scrollY + 160;
      var current = '';
      sections.forEach(function(s) {
        if (s.offsetTop <= scrollY) current = s.id;
      });
      tocLinks.forEach(function(link) {
        var isActive = link.getAttribute('href') === '#' + current;
        link.classList.toggle('guide-toc__link--active', isActive);
      });
    }
    window.addEventListener('scroll', updateToc, { passive: true });
    updateToc();
  </script>
</ClaudeCodeLayout>
