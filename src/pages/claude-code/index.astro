---
import ClaudeCodeLayout from "../../layouts/ClaudeCodeLayout.astro";
import { getToolById, getToolReleases, formatDate, relativeTime } from "../../lib/releases";
import { marked } from "marked";
import { readFileSync } from "node:fs";
import { join } from "node:path";

const tool = getToolById("claude-code");
const data = await getToolReleases("claude-code");
const releases = data?.releases || [];
const stableReleases = releases.filter((r) => !r.prerelease);
const latestStable = stableReleases[0];
const latestRelease = releases[0];
const latestForTldr = releases[0];
const restReleases = releases.slice(1);

const breakingCount = releases.filter((r) =>
  r.body?.toLowerCase().includes("breaking")
).length;

const displayVersion = latestStable?.version || latestRelease?.version || "—";
const lastUpdatedAgo = data?.lastUpdated ? relativeTime(data.lastUpdated) : null;

function getPayloadTldr(toolId: string): string | null {
  try {
    const path = join(process.cwd(), "public", "api", "refs", `${toolId}.json`);
    const payload = JSON.parse(readFileSync(path, "utf-8"));
    return payload?.payload?.meta?.tldr ?? null;
  } catch {
    return null;
  }
}

const llmTldr = getPayloadTldr("claude-code");

function isBreaking(body: string = ""): boolean {
  return body.toLowerCase().includes("breaking");
}


function normalizeReleaseBody(body: string): string {
  if (!body) return "";

  let normalized = body.replace(/\r\n/g, "\n").trim();

  normalized = normalized
    .replace(/^\s*##\s*what'?s changed\s*$/gim, "## Changes")
    .replace(/^\s*##\s*full changelog\s*$/gim, "")
    .replace(/^\s*\*\*full changelog\*\*: ?\s*$/gim, "")
    .replace(/^\s*full changelog:?\s*$/gim, "")
    .replace(/^\s*important:?\s*$/gim, "## Important")
    .replace(/^\s*summary:?\s*$/gim, "## Summary")
    .replace(/^\s*notes:?\s*$/gim, "## Notes");

  normalized = normalized.replace(/\n{3,}/g, "\n\n");

  const lines = normalized.split("\n");
  const cleaned: string[] = [];
  let skipGithubBoilerplate = false;

  for (let i = 0; i < lines.length; i++) {
    const line = lines[i];
    const trimmed = line.trim();

    if (!trimmed) {
      if (cleaned.length > 0 && cleaned[cleaned.length - 1] !== "") cleaned.push("");
      continue;
    }

    if (/^\[?full changelog\]?[:：]?$/i.test(trimmed)) continue;
    if (/^full changelog:?\s*https?:\/\//i.test(trimmed)) continue;
    if (/^see full changelog/i.test(trimmed)) continue;
    if (/^compare:/i.test(trimmed)) continue;

    if (/^##\s*new contributors\s*$/i.test(trimmed)) {
      skipGithubBoilerplate = true;
      continue;
    }
    if (skipGithubBoilerplate) {
      if (/^##\s+/.test(trimmed)) skipGithubBoilerplate = false;
      else continue;
    }

    let nextLine = line
      .replace(/\*\*full changelog\*\*:\s*https?:\/\/\S+/gi, "")
      .replace(/\[full changelog\]\([^)]*\)/gi, "")
      .replace(/\s+by\s+@\S+\s+in\s+https?:\/\/\S+/gi, "")
      .replace(/\s+by\s+@\S+\s+in\s+#\d+/gi, "")
      .replace(/\s+in\s+https?:\/\/\S+/gi, "")
      .replace(/\s{2,}/g, " ")
      .trimEnd();

    if (/^[*-]\s+[^\s].*/.test(nextLine)) {
      nextLine = nextLine.replace(/^([*-]\s+)(fix|feat|docs|test|chore|refactor|perf|style|ci|build|docker)(\([^)]*\))?:\s*/i, "$1$2: ");
    }

    cleaned.push(nextLine);
  }

  const structured = cleaned.join("\n").replace(/\n{3,}/g, "\n\n").trim();

  const hasSubsections = /^###\s+/m.test(structured);
  const bulletLines = structured.split("\n").filter((line) => /^[*-]\s+/.test(line.trim()));

  if (hasSubsections || bulletLines.length < 4) return structured;

  const categories = [
    { title: "Breaking Changes", test: /^(breaking|break|deprecat|remove|migration|security)[:\s(]/i },
    { title: "Features", test: /^(feat|feature|add|new|support|introduce)[:\s(]/i },
    { title: "Fixes", test: /^(fix|bug|resolve|patch)[:\s(]/i },
    { title: "Performance", test: /^(perf|performance|speed|optimi[sz]e)[:\s(]/i },
    { title: "Docs", test: /^(docs|doc|readme)[:\s(]/i },
    { title: "Tooling & CI", test: /^(ci|build|infra|tooling|deps|dependency|docker|workflow)[:\s(]/i },
    { title: "Tests", test: /^(test|tests)[:\s(]/i },
    { title: "Other", test: /.*/i },
  ];

  const groups = new Map(categories.map((category) => [category.title, [] as string[]]));
  const prelude: string[] = [];

  for (const line of structured.split("\n")) {
    const trimmed = line.trim();
    if (!trimmed) continue;
    if (/^##\s+changes$/i.test(trimmed)) continue;

    if (/^[*-]\s+/.test(trimmed)) {
      const body = trimmed.replace(/^[*-]\s+/, "").trim();
      const category = categories.find((entry) => entry.test.test(body)) || categories[categories.length - 1];
      groups.get(category.title)?.push(`- ${body}`);
    } else {
      prelude.push(trimmed);
    }
  }

  const groupedSections = categories
    .map((category) => {
      const items = groups.get(category.title) || [];
      if (items.length === 0) return null;
      return [`### ${category.title}`, ...items].join("\n");
    })
    .filter(Boolean);

  if (groupedSections.length < 2) return structured;

  return [
    ...prelude,
    prelude.length ? "" : null,
    "## Changes",
    ...groupedSections,
  ].filter(Boolean).join("\n\n").trim();
}


function renderBody(body: string): string {
  if (!body) return "";
  const normalizedBody = normalizeReleaseBody(body);
  marked.setOptions({ gfm: true, breaks: false });
  let html = marked.parse(normalizedBody) as string;
  html = html.replace(/<a href="(https:\/\/github\.com\/[^/]+\/[^/]+\/pull\/(\d+))"[^>]*>[^<]*<\/a>/g,
    '<a href="$1" target="_blank" rel="noopener noreferrer" class="cl-pr-link">#$2</a>');
  html = html.replace(/<a href="(https:\/\/github\.com\/[^/]+\/[^/]+\/issues\/(\d+))"[^>]*>[^<]*<\/a>/g,
    '<a href="$1" target="_blank" rel="noopener noreferrer" class="cl-pr-link">#$2</a>');
  html = html.replace(/ by <a href="https:\/\/github\.com\/[^"]*"[^>]*>@[^<]+<\/a> in /g, ' ');
  html = html.replace(/ by @[\w-]+ in /g, ' ');
  html = html.replace(/<li>(.*?)<\/li>/gs, (match, content) => {
    const text = content.toLowerCase();
    let badge = '';
    if (/^fix[\s(:]/.test(text)) badge = '<span class="cl-badge cl-badge-fix">FIX</span>';
    else if (/^feat[\s(:]/.test(text)) badge = '<span class="cl-badge cl-badge-feat">FEAT</span>';
    else if (/^docs[\s(:]/.test(text)) badge = '<span class="cl-badge cl-badge-docs">DOCS</span>';
    else if (/^test[\s(:]/.test(text)) badge = '<span class="cl-badge cl-badge-test">TEST</span>';
    else if (/^(refactor|chore)[\s(:]/.test(text)) badge = '<span class="cl-badge cl-badge-chore">CHORE</span>';
    else if (/^(ci|build|docker)[\s(:]/.test(text)) badge = '<span class="cl-badge cl-badge-ci">CI</span>';
    else if (/^(perf|style)[\s(:]/.test(text)) badge = '<span class="cl-badge cl-badge-perf">PERF</span>';
    return `<li>${badge}${content}</li>`;
  });
  return html;
}

function getTldr(body: string): string[] {
  if (!body) return [];
  const lines = body.split("\n").filter(Boolean);
  const bullets: string[] = [];
  for (const line of lines) {
    const match = line.match(/^[\*\-]\s+(.+)/);
    if (match) {
      let text = match[1]
        .replace(/\*\*([^*]+)\*\*/g, "$1")
        .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")
        .replace(/`([^`]+)`/g, "$1")
        .replace(/\s+by\s+@\S+\s+in\s+https:\/\/\S+/g, "")
        .trim();
      if (text.length > 10 && !text.startsWith("http") && !text.startsWith("@")) {
        if (text.length > 120) text = text.slice(0, 117) + "…";
        bullets.push(text);
      }
    }
  }
  return bullets.slice(0, 5);
}
---

<ClaudeCodeLayout
  title="Claude Code — changelogs.info"
  description="Track Claude Code releases, breaking changes, and config updates. Anthropic's agentic coding tool in your terminal."
  currentPage="home"
>
  <!-- Dot grid background -->
  <div class="cc-dotgrid" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -1; pointer-events: none; opacity: 0.35;"></div>

  <div style="max-width: 1100px; margin: 0 auto; padding: 2rem 1.5rem 0;">

    <!-- Hero -->
    <section class="cc-hero-section" style="margin-bottom: 3rem; display: grid; grid-template-columns: 1fr; gap: 2rem; align-items: center;">
      <div style="display: grid; grid-template-columns: 1fr auto; gap: 2.5rem; align-items: center;" class="cc-hero-grid">
        <!-- Left -->
        <div style="display: flex; flex-direction: column; gap: 1.25rem;">
          <div style="display: inline-flex; align-items: center; gap: 0.5rem; width: fit-content;">
            <span class="cc-pulse-dot" style="width: 8px; height: 8px; background: #f59e0b; display: inline-block;"></span>
            <span style="font-family: var(--cc-font-mono); font-size: 0.65rem; color: var(--cc-text-muted); text-transform: uppercase; letter-spacing: 0.15em;">Tracking {releases.length} releases</span>
          </div>

          <h1 class="cc-headline cc-hero-title" style="font-size: clamp(3rem, 9vw, 5.5rem); font-weight: 900; color: var(--cc-text); text-transform: uppercase; line-height: 0.88; margin: 0; letter-spacing: -0.03em;">
            Claude<br><span style="color: var(--cc-primary-bright);">Code</span>
          </h1>

          <p style="font-size: 1.05rem; color: var(--cc-text-dim); max-width: 28rem; line-height: 1.6; margin: 0; font-family: var(--cc-font-body);">
            {tool?.description || "Anthropic's agentic coding tool — run AI in your terminal, build and fix code autonomously."}
          </p>

          <div style="display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 0.5rem;">
            <a
              href={`https://github.com/${tool?.repo || "anthropics/claude-code"}`}
              target="_blank"
              rel="noopener noreferrer"
              class="cc-headline cc-cta-btn"
              style="background: var(--cc-primary); color: white; font-weight: 900; padding: 0.75rem 1.75rem; font-size: 0.85rem; border: 4px solid var(--cc-border); box-shadow: var(--cc-shadow-sm); text-decoration: none; text-transform: uppercase; font-style: italic;"
            >
              GitHub ↗
            </a>
            <a
              href="/claude-code/changelog/"
              class="cc-headline cc-cta-btn"
              style="background: transparent; color: var(--cc-text); font-weight: 900; padding: 0.75rem 1.75rem; font-size: 0.85rem; border: 4px solid var(--cc-border); box-shadow: var(--cc-shadow-sm); text-decoration: none; text-transform: uppercase; font-style: italic;"
            >
              Changelog
            </a>
          </div>
        </div>

        <!-- Right: terminal card -->
        <div class="cc-terminal-card" style="width: 320px; border: 4px solid var(--cc-border); box-shadow: var(--cc-shadow); flex-shrink: 0; overflow: hidden;">
          <div style="background: var(--cc-border); padding: 0.5rem 0.75rem; display: flex; align-items: center; gap: 0.5rem;">
            <span style="width: 10px; height: 10px; background: var(--cc-primary); display: inline-block;"></span>
            <span style="width: 10px; height: 10px; background: #ffb800; display: inline-block;"></span>
            <span style="width: 10px; height: 10px; background: #22c55e; display: inline-block;"></span>
            <span style="font-family: var(--cc-font-mono); font-size: 0.6rem; color: var(--cc-bg); margin-left: 0.5rem; text-transform: uppercase; font-weight: 700;">claude --status</span>
          </div>
          <div style="background: var(--cc-bg); padding: 1rem; font-family: var(--cc-font-mono); font-size: 0.7rem; line-height: 1.8; color: var(--cc-text-dim);">
            <div><span style="color: var(--cc-primary-bright);">$</span> claude --version</div>
            <div style="margin-top: 0.5rem;">
              <span style="color: var(--cc-primary-bright);">●</span> Version: <span style="color: var(--cc-text);">{displayVersion}</span>
            </div>
            <div>
              <span style="color: #22c55e;">●</span> Releases: <span style="color: var(--cc-text);">{releases.length}</span> tracked
            </div>
            <div>
              <span style="color: {breakingCount > 0 ? 'var(--cc-primary-bright)' : '#22c55e'};">{breakingCount > 0 ? '⚠' : '●'}</span> Breaking: <span style="color: {breakingCount > 0 ? 'var(--cc-primary-bright)' : 'var(--cc-text)'};">{breakingCount}</span>
            </div>
            <div>
              <span style="color: #22c55e;">●</span> Updated: <span style="color: var(--cc-text);">{lastUpdatedAgo || "now"}</span>
            </div>
            <div style="margin-top: 0.5rem; color: var(--cc-text-muted);">
              <span style="color: var(--cc-primary-bright);">$</span> <span class="cc-cursor">_</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats Bar -->
    <section class="cc-section-reveal" style="display: flex; flex-wrap: wrap; gap: 0; border: 4px solid var(--cc-border); margin-bottom: 3rem;">
      {[
        { label: "Releases", value: String(releases.length) },
        { label: "Breaking", value: String(breakingCount), warn: true },
        { label: "Stable", value: String(stableReleases.length) },
        { label: "Latest", value: displayVersion },
      ].map((stat, i) => (
        <div
          style={`flex: 1; min-width: 120px; padding: 1rem 1.25rem; ${i < 3 ? 'border-right: 4px solid var(--cc-border);' : ''} background: var(--cc-bg-card); cursor: crosshair; transition: background 150ms;`}
          class="cc-stats-cell"
        >
          <span style="display: block; color: var(--cc-text-muted); font-family: var(--cc-font-headline); font-weight: 700; text-transform: uppercase; font-size: 0.55rem; letter-spacing: 0.15em; margin-bottom: 0.25rem;">{stat.label}</span>
          <span class="cc-headline" style={`display: block; font-size: 1.5rem; font-weight: 900; color: ${stat.warn ? 'var(--cc-primary-bright)' : 'var(--cc-text)'};`}>{stat.value}</span>
        </div>
      ))}
    </section>

    <!-- TL;DR Latest Release -->
    {latestForTldr && (() => {
      const breaking = isBreaking(latestForTldr.body);
      const tldr = getTldr(latestForTldr.body || "");
      const fallback = (latestForTldr.body || "").split("\n").filter(l => l.trim() && !l.startsWith("#")).slice(0, 2).map(l => l.replace(/^[\*\-]\s+/, "").trim());
      const items = tldr.length > 0 ? tldr : fallback;
      const summaryText = llmTldr?.trim() || null;
      const latestRendered = renderBody(latestForTldr.body || "");

      return (
        <section style="margin-bottom: 3rem;">
          <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem;">
            <h2 class="cc-headline" style="font-size: 2.5rem; font-weight: 900; color: var(--cc-text); text-transform: uppercase; font-style: italic; letter-spacing: -0.02em; margin: 0;">
              TL;DR
            </h2>
            <div style="flex: 1; height: 4px; background: var(--cc-border);"></div>
            <span style="font-family: var(--cc-font-mono); font-size: 0.7rem; color: var(--cc-text-muted); text-transform: uppercase;">Latest Release</span>
          </div>

          <div style={`padding: 1.5rem 2rem; border: 4px solid ${breaking ? 'var(--cc-primary)' : 'var(--cc-border)'}; background: ${breaking ? 'var(--cc-bg-surface)' : 'var(--cc-bg-card)'}; ${breaking ? 'border-left: 8px solid var(--cc-primary);' : ''} margin-bottom: 2rem;`}>
            <div style="display: flex; justify-content: space-between; align-items: center; gap: 1rem; margin-bottom: 1rem; flex-wrap: wrap;">
              <div style="display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap;">
                <span class="cc-headline" style="font-size: 1.3rem; font-weight: 900; color: var(--cc-text); text-transform: uppercase;">{latestForTldr.version}</span>
                {breaking && (
                  <span style="background: var(--cc-primary); color: white; font-family: var(--cc-font-mono); padding: 0.15rem 0.5rem; font-size: 0.6rem; font-weight: 700; text-transform: uppercase;">BREAKING</span>
                )}
                {latestForTldr.prerelease && (
                  <span style="background: rgba(245,158,11,0.15); color: #f59e0b; font-family: var(--cc-font-mono); padding: 0.15rem 0.5rem; font-size: 0.6rem; font-weight: 700; text-transform: uppercase; border: 1px solid #f59e0b;">PRE</span>
                )}
              </div>
              <span style="font-family: var(--cc-font-mono); font-size: 0.7rem; color: var(--cc-text-muted); white-space: nowrap;">{formatDate(latestForTldr.date)}</span>
            </div>
            {summaryText ? (
              <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                <p style="margin: 0; font-family: var(--cc-font-body); font-size: 1rem; color: var(--cc-text); line-height: 1.7; max-width: 60ch;">{summaryText}</p>
              </div>
            ) : items.length > 0 && (
              <ul style="list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.4rem;">
                {items.map((item) => (
                  <li style="display: flex; gap: 0.5rem; align-items: flex-start; font-family: var(--cc-font-body); font-size: 0.9rem; color: var(--cc-text-dim); line-height: 1.5;">
                    <span style="color: var(--cc-primary-bright); flex-shrink: 0; font-weight: 700;">▸</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            )}
          </div>

          <div style="padding: 2rem; border: 4px solid var(--cc-border); background: var(--cc-bg-surface);">
            <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 0.5rem;">
              <h3 class="cc-headline" style="font-size: 1.5rem; font-weight: 900; text-transform: uppercase; margin: 0; color: var(--cc-text);">
                {(latestForTldr.name || latestForTldr.version).replace(/^claude[\s-]code\s+/i, "")}
              </h3>
              <a href={latestForTldr.url} target="_blank" rel="noopener noreferrer" class="cc-headline" style="font-size: 0.7rem; font-weight: 700; text-transform: uppercase; color: var(--cc-primary-bright); text-decoration: none;">↗ GitHub</a>
            </div>
            <div class="changelog-body" style="color: var(--cc-text-dim); font-size: 0.875rem; line-height: 1.7; font-family: var(--cc-font-body);" set:html={latestRendered} />
          </div>
        </section>
      );
    })()}

    <!-- Previous Releases -->
    <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 2rem;">
      <div style="flex: 1; height: 4px; background: var(--cc-border);"></div>
      <span class="cc-headline" style="font-size: 0.75rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.15em; color: var(--cc-text-muted);">Previous Releases</span>
      <div style="flex: 1; height: 4px; background: var(--cc-border);"></div>
    </div>

    <section style="margin-bottom: 4rem; display: flex; flex-direction: column; gap: 1.25rem;">
      {restReleases.slice(0, 3).map((release) => {
        const breaking = isBreaking(release.body);
        const renderedBody = renderBody(release.body || "");
        const isLong = (release.body || "").length > 600;
        return (
          <div style={`padding: 1.5rem 2rem; border: 4px solid ${breaking ? 'var(--cc-primary)' : 'var(--cc-border)'}; background: ${breaking ? 'var(--cc-bg-surface)' : 'var(--cc-bg-card)'}; ${breaking ? 'border-left: 8px solid var(--cc-primary);' : ''}`}>
            <div style="display: flex; justify-content: space-between; align-items: center; gap: 1rem; margin-bottom: 0.75rem; flex-wrap: wrap;">
              <div style="display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap;">
                <span class="cc-headline" style="font-size: 1.25rem; font-weight: 900; color: var(--cc-text); text-transform: uppercase;">{release.version}</span>
                <span class="cc-headline" style="font-size: 0.75rem; font-weight: 700; color: var(--cc-text-dim);">{(release.name || "").replace(/^claude[\s-]code\s+/i, "")}</span>
                {breaking && (
                  <span style="background: var(--cc-primary); color: white; font-family: var(--cc-font-mono); padding: 0.15rem 0.5rem; font-size: 0.6rem; font-weight: 700; text-transform: uppercase;">BREAKING</span>
                )}
              </div>
              <span style="font-family: var(--cc-font-mono); font-size: 0.7rem; color: var(--cc-text-muted); white-space: nowrap;">{formatDate(release.date)}</span>
            </div>
            <div
              class={`changelog-body ${isLong ? 'cl-collapsed' : ''}`}
              style="color: var(--cc-text-dim); font-size: 0.85rem; line-height: 1.7; font-family: var(--cc-font-body); overflow: hidden; position: relative;"
              set:html={renderedBody}
            />
            {isLong && (
              <button
                class="cl-expand-btn cc-headline"
                style="display: block; margin-top: 0.75rem; background: transparent; border: 2px solid var(--cc-border); color: var(--cc-text); padding: 0.4rem 1rem; font-size: 0.65rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.1em; cursor: pointer; transition: background 100ms; position: relative; overflow: visible;"
                onclick="this.previousElementSibling.classList.toggle('cl-collapsed'); this.textContent = this.textContent.includes('EXPAND') ? '▲ COLLAPSE' : '▼ EXPAND'"
              >
                ▼ EXPAND
              </button>
            )}
          </div>
        );
      })}
      <a
        href="/claude-code/changelog/"
        class="cc-headline"
        style="display: inline-flex; align-items: center; gap: 0.5rem; font-weight: 900; text-transform: uppercase; color: var(--cc-primary-bright); font-style: italic; text-decoration: none; border-bottom: 2px solid var(--cc-primary-bright); padding-bottom: 2px; font-size: 0.85rem; align-self: flex-start;"
      >
        View all {releases.length} releases →
      </a>
    </section>

    <!-- Quick Links -->
    <section style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin-bottom: 4rem;">
      {[
        { href: "/claude-code/changelog/", icon: "📋", label: "Full Changelog", sub: `${releases.length} releases` },
        { href: "/claude-code/cheatsheet/", icon: "⚡", label: "Cheatsheet", sub: "Commands & tips" },
        { href: "/claude-code/releases/", icon: "📦", label: "All Releases", sub: "Browse & filter" },
        { href: "/feed/all.xml", icon: "📡", label: "RSS Feed", sub: "Subscribe to updates" },
      ].map((link) => (
        <a href={link.href} class="cc-quick-link" style="display: flex; align-items: center; gap: 0.75rem; padding: 1.25rem; border: 4px solid var(--cc-border); background: var(--cc-bg-card); text-decoration: none;">
          <span style="font-size: 1.5rem;">{link.icon}</span>
          <div>
            <span class="cc-headline" style="display: block; font-weight: 900; font-size: 0.85rem; color: var(--cc-text); text-transform: uppercase;">{link.label}</span>
            <span style="font-family: var(--cc-font-mono); font-size: 0.65rem; color: var(--cc-text-muted);">{link.sub}</span>
          </div>
        </a>
      ))}
    </section>

    <!-- Subscribe -->
    <section style="margin-bottom: 5rem; text-align: center; padding: 3rem 2rem; border: 4px solid var(--cc-border); background: var(--cc-bg-surface);">
      <h2 class="cc-headline" style="font-size: 2rem; font-weight: 900; text-transform: uppercase; font-style: italic; letter-spacing: -0.02em; margin: 0 0 0.75rem; color: var(--cc-text);">
        Stay in the Loop
      </h2>
      <p style="font-family: var(--cc-font-body); font-size: 0.95rem; color: var(--cc-text-dim); margin: 0 0 2rem; max-width: 480px; margin-left: auto; margin-right: auto; line-height: 1.5;">
        Get notified when Claude Code ships new releases. No spam — just changelogs.
      </p>
      <div style="display: flex; flex-wrap: wrap; gap: 1rem; justify-content: center; align-items: center; max-width: 500px; margin: 0 auto 1.5rem;">
        <input
          type="email"
          placeholder="you@example.com"
          style="flex: 1; min-width: 220px; padding: 0.85rem 1rem; border: 4px solid var(--cc-border); background: var(--cc-bg); color: var(--cc-text); font-family: var(--cc-font-mono); font-size: 0.85rem; outline: none; transition: border-color 150ms;"
          onfocus="this.style.borderColor='var(--cc-primary)'"
          onblur="this.style.borderColor='var(--cc-border)'"
        />
        <button
          class="cc-headline"
          style="background: var(--cc-primary); color: white; font-weight: 900; padding: 0.85rem 1.75rem; font-size: 0.85rem; border: 4px solid var(--cc-border); box-shadow: var(--cc-shadow-sm); cursor: pointer; text-transform: uppercase; font-style: italic; transition: transform 100ms, box-shadow 100ms; position: relative; overflow: visible;"
          onmouseover="this.style.transform='translate(1px,1px)';this.style.boxShadow='none'"
          onmouseout="this.style.transform='';this.style.boxShadow='var(--cc-shadow-sm)'"
        >
          Subscribe
        </button>
      </div>
      <div style="display: flex; gap: 2rem; justify-content: center; flex-wrap: wrap;">
        <a href="/feed/all.xml" style="display: inline-flex; align-items: center; gap: 0.5rem; font-family: var(--cc-font-mono); font-size: 0.75rem; color: var(--cc-text-dim); text-decoration: none; transition: color 150ms;" onmouseover="this.style.color='var(--cc-primary-bright)'" onmouseout="this.style.color='var(--cc-text-dim)'">
          📡 RSS Feed
        </a>
        <a href={`https://github.com/${tool?.repo || "anthropics/claude-code"}`} target="_blank" rel="noopener noreferrer" style="display: inline-flex; align-items: center; gap: 0.5rem; font-family: var(--cc-font-mono); font-size: 0.75rem; color: var(--cc-text-dim); text-decoration: none; transition: color 150ms;" onmouseover="this.style.color='var(--cc-primary-bright)'" onmouseout="this.style.color='var(--cc-text-dim)'">
          ⭐ Star on GitHub
        </a>
      </div>
    </section>
  </div>
</ClaudeCodeLayout>
