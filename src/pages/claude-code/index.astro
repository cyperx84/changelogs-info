---
import ClaudeCodeLayout from "../../layouts/ClaudeCodeLayout.astro";
import { getToolById, getToolReleases, formatDate, relativeTime } from "../../lib/releases";
import { marked } from "marked";
import { readFileSync } from "node:fs";
import { join } from "node:path";

const tool = getToolById("claude-code");
const data = await getToolReleases("claude-code");
const releases = data?.releases || [];
const stableReleases = releases.filter((r) => !r.prerelease);
const latestStable = stableReleases[0];
const latestRelease = releases[0];
const latestForTldr = releases[0];

const breakingCount = releases.filter((r) =>
  r.body?.toLowerCase().includes("breaking")
).length;

const displayVersion = latestStable?.version || latestRelease?.version || "—";
const lastUpdatedAgo = data?.lastUpdated ? relativeTime(data.lastUpdated) : null;

function getPayloadTldr(toolId: string): string | null {
  try {
    const path = join(process.cwd(), "public", "api", "refs", `${toolId}.json`);
    const payload = JSON.parse(readFileSync(path, "utf-8"));
    return payload?.payload?.meta?.tldr ?? null;
  } catch {
    return null;
  }
}

const llmTldr = getPayloadTldr("claude-code");

async function getCanonicalChangelogEntries(): Promise<{ version: string; heading: string; body: string }[]> {
  try {
    const response = await fetch("https://raw.githubusercontent.com/anthropics/claude-code/main/CHANGELOG.md");
    if (!response.ok) return [];

    const changelog = (await response.text()).replace(/\r\n/g, "\n");
    if (/github releases/i.test(changelog) && changelog.split("\n").length < 20) return [];

    const matches = [...changelog.matchAll(/^##\s+v?(\d+(?:\.\d+)+(?:[-+][A-Za-z0-9.-]+)?)\s*$/gm)];
    const entries: { version: string; heading: string; body: string }[] = [];

    for (let i = 0; i < matches.length && entries.length < 3; i++) {
      const match = matches[i];
      const version = match[1];
      const start = match.index ?? 0;
      const end = i + 1 < matches.length ? (matches[i + 1].index ?? changelog.length) : changelog.length;
      const section = changelog.slice(start, end).trim();
      if (section.length > 20) {
        entries.push({ version, heading: `v${version}`, body: section });
      }
    }

    return entries;
  } catch {
    return [];
  }
}

const canonicalEntries = await getCanonicalChangelogEntries();

function isBreaking(body: string = ""): boolean {
  return body.toLowerCase().includes("breaking");
}

const PRIORITY_PREFIXES = ["BREAKING", "SEC", "FEAT", "PERF"];
const MINOR_PREFIXES = ["FIX", "TEST", "CHORE", "CI", "BUILD", "STYLE"];

function escapeHtml(text: string): string {
  return text
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/\"/g, "&quot;")
    .replace(/'/g, "&#39;");
}

function normalizeReleaseBody(body: string): string {
  if (!body) return "";

  let normalized = body.replace(/\r\n/g, "\n").trim();

  normalized = normalized
    .replace(/^\s*##\s*what'?s changed\s*$/gim, "## Changes")
    .replace(/^\s*##\s*full changelog\s*$/gim, "")
    .replace(/^\s*\*\*full changelog\*\*: ?\s*$/gim, "")
    .replace(/^\s*full changelog:?\s*$/gim, "")
    .replace(/^\s*important:?\s*$/gim, "## Important")
    .replace(/^\s*summary:?\s*$/gim, "## Summary")
    .replace(/^\s*notes:?\s*$/gim, "## Notes")
    .replace(/\n{3,}/g, "\n\n");

  const lines = normalized.split("\n");
  const cleaned: string[] = [];
  let skipGithubBoilerplate = false;

  for (const line of lines) {
    const trimmed = line.trim();

    if (!trimmed) {
      if (cleaned.length > 0 && cleaned[cleaned.length - 1] !== "") cleaned.push("");
      continue;
    }

    if (/^\[?full changelog\]?[:：]?$/i.test(trimmed)) continue;
    if (/^full changelog:?\s*https?:\/\//i.test(trimmed)) continue;
    if (/^see full changelog/i.test(trimmed)) continue;
    if (/^compare:/i.test(trimmed)) continue;

    if (/^##\s*new contributors\s*$/i.test(trimmed)) {
      skipGithubBoilerplate = true;
      continue;
    }
    if (skipGithubBoilerplate) {
      if (/^##\s+/.test(trimmed)) skipGithubBoilerplate = false;
      else continue;
    }

    let nextLine = line
      .replace(/\*\*full changelog\*\*:\s*https?:\/\/\S+/gi, "")
      .replace(/\[full changelog\]\([^)]*\)/gi, "")
      .replace(/\s+by\s+@\S+\s+in\s+https?:\/\/\S+/gi, "")
      .replace(/\s+by\s+@\S+\s+in\s+#\d+/gi, "")
      .replace(/\s+in\s+https?:\/\/\S+/gi, "")
      .replace(/\s{2,}/g, " ")
      .trimEnd();

    if (/^[*-]\s+[^\s].*/.test(nextLine)) {
      nextLine = nextLine.replace(/^([*-]\s+)(fix|feat|docs|test|chore|refactor|perf|style|ci|build|docker|sec|security|breaking)(\([^)]*\))?:\s*/i, "$1$2: ");
    }

    cleaned.push(nextLine);
  }

  return cleaned.join("\n").replace(/\n{3,}/g, "\n\n").trim();
}

function stripMarkdown(text: string): string {
  return text
    .replace(/\*\*([^*]+)\*\*/g, "$1")
    .replace(/__([^_]+)__/g, "$1")
    .replace(/`([^`]+)`/g, "$1")
    .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")
    .replace(/\s+by\s+@\S+\s+in\s+https?:\/\/\S+/gi, "")
    .replace(/\s+by\s+@\S+\s+in\s+#\d+/gi, "")
    .replace(/\s+in\s+https?:\/\/\S+/gi, "")
    .replace(/\s{2,}/g, " ")
    .trim();
}

type ParsedItem = { prefix: string | null; content: string; raw: string };
type ParsedSection = { heading: string; items: ParsedItem[] };

function classifyLine(text: string): { prefix: string | null; content: string } {
  const cleaned = stripMarkdown(text).replace(/^[*-]\s+/, "").trim();
  const match = cleaned.match(/^(BREAKING|SECURITY|SEC|FEAT|FIX|DOCS|TEST|CHORE|REFACTOR|PERF|STYLE|CI|BUILD|OTHER)(\([^)]*\))?:\s*(.+)$/i);
  if (!match) return { prefix: null, content: cleaned };
  const prefix = match[1].toUpperCase() === "SECURITY" ? "SEC" : match[1].toUpperCase();
  return { prefix, content: match[3].trim() || cleaned };
}

function parseChangelog(body: string): ParsedSection[] {
  const normalized = normalizeReleaseBody(body);
  if (!normalized) return [];

  const lines = normalized.split("\n");
  const sections: ParsedSection[] = [];
  let current: ParsedSection | null = null;

  const ensureDefaultSection = () => {
    if (!current) {
      current = { heading: "Changes", items: [] };
      sections.push(current);
    }
  };

  for (const line of lines) {
    const trimmed = line.trim();
    if (!trimmed) continue;
    if (/^##\s+/.test(trimmed)) continue;

    const headingMatch = trimmed.match(/^###\s+(.+)$/);
    if (headingMatch) {
      current = { heading: stripMarkdown(headingMatch[1]), items: [] };
      sections.push(current);
      continue;
    }

    if (/^[*-]\s+/.test(trimmed)) {
      ensureDefaultSection();
      const parsed = classifyLine(trimmed);
      if (parsed.content) current!.items.push({ ...parsed, raw: trimmed });
      continue;
    }

    if (/^(BREAKING|SECURITY|SEC|FEAT|FIX|DOCS|TEST|CHORE|REFACTOR|PERF|STYLE|CI|BUILD|OTHER)(\([^)]*\))?:\s+/i.test(trimmed)) {
      ensureDefaultSection();
      const parsed = classifyLine(`- ${trimmed}`);
      if (parsed.content) current!.items.push({ ...parsed, raw: trimmed });
      continue;
    }

    ensureDefaultSection();
    current!.items.push({ prefix: null, content: stripMarkdown(trimmed), raw: trimmed });
  }

  return sections.filter((section) => section.items.length > 0);
}

function renderPrefix(prefix: string | null): string {
  if (!prefix) return "";
  const palette: Record<string, string> = {
    BREAKING: "background: var(--cc-primary); color: #fff; border-color: var(--cc-primary);",
    FEAT: "background: rgba(34,197,94,0.12); color: #22c55e; border-color: #22c55e;",
    FIX: "background: rgba(59,130,246,0.12); color: #60a5fa; border-color: #60a5fa;",
    DOCS: "background: rgba(168,85,247,0.12); color: #c084fc; border-color: #c084fc;",
    PERF: "background: rgba(245,158,11,0.12); color: #f59e0b; border-color: #f59e0b;",
    REFACTOR: "background: rgba(236,72,153,0.12); color: #f472b6; border-color: #f472b6;",
    CI: "background: rgba(6,182,212,0.12); color: #22d3ee; border-color: #22d3ee;",
    BUILD: "background: rgba(6,182,212,0.12); color: #22d3ee; border-color: #22d3ee;",
    CHORE: "background: rgba(148,163,184,0.12); color: #cbd5e1; border-color: #94a3b8;",
    TEST: "background: rgba(20,184,166,0.12); color: #2dd4bf; border-color: #2dd4bf;",
    STYLE: "background: rgba(244,114,182,0.12); color: #f9a8d4; border-color: #f9a8d4;",
    SEC: "background: rgba(239,68,68,0.12); color: #f87171; border-color: #f87171;",
  };
  const style = palette[prefix] || "background: rgba(255,255,255,0.06); color: currentColor; border-color: currentColor;";
  return `<span style="display:inline-flex;align-items:center;justify-content:center;min-width:3.35rem;padding:0.12rem 0.45rem;border:1.5px solid currentColor;font-family:inherit;font-size:0.68em;font-weight:800;letter-spacing:0.08em;text-transform:uppercase;vertical-align:middle;flex-shrink:0;${style}">${escapeHtml(prefix)}</span>`;
}

function renderChangelogItem(item: ParsedItem): string {
  return `<li class="cc-flex">${renderPrefix(item.prefix)}<span class="cc-s1">${escapeHtml(item.content)}</span></li>`;
}

function renderChangelogSection(title: string, items: ParsedItem[], emphasized = false): string {
  if (items.length === 0) return "";
  return `<div style="padding:1rem 1.1rem; border:3px solid var(--cc-border); background:${emphasized ? 'var(--cc-bg-surface)' : 'transparent'};">`
    + `<div class="cc-s2">${escapeHtml(title)}</div>`
    + `<ul class="cc-vstack">${items.map(renderChangelogItem).join("")}</ul>`
    + `</div>`;
}

function buildChangelogCard(body: string): string {
  const sections = parseChangelog(body);
  const allItems = sections.flatMap((section) => section.items.map((item) => ({ ...item, heading: section.heading })));

  const highlights = allItems.filter((item) => item.prefix && PRIORITY_PREFIXES.includes(item.prefix)).slice(0, 4);
  const notable = allItems
    .filter((item) => !highlights.includes(item))
    .filter((item) => !item.prefix || !MINOR_PREFIXES.includes(item.prefix) || item.prefix === "DOCS" || item.prefix === "REFACTOR")
    .slice(0, 6);
  const used = new Set([...highlights, ...notable]);
  const overflow = allItems.filter((item) => !used.has(item));

  const overflowHtml = overflow.length === 0
    ? ""
    : `<details class="cc-s4"><summary class="cc-s5">Show all changes <span class="cc-s6">(${overflow.length} more)</span></summary><div class="cc-vstack-2">${sections.map((section) => {
        const sectionItems = overflow.filter((item) => item.heading === section.heading);
        if (sectionItems.length === 0) return "";
        return `<div><div class="cc-s8">${escapeHtml(section.heading)}</div><ul class="cc-vstack-3">${sectionItems.map(renderChangelogItem).join("")}</ul></div>`;
      }).join("")}</div></details>`;

  const fallback = sections.length > 0 && highlights.length === 0 && notable.length === 0
    ? renderChangelogSection(sections[0].heading, sections[0].items.slice(0, 6), false)
    : "";

  return `<div class="cc-vstack-4">${renderChangelogSection("Highlights", highlights, true)}${renderChangelogSection("Notable changes", notable, false)}${fallback}${overflowHtml}</div>`;
}

function getTldr(body: string): string[] {
  return parseChangelog(body)
    .flatMap((section) => section.items)
    .map((item) => item.content)
    .filter(Boolean)
    .slice(0, 5);
}
---

<ClaudeCodeLayout
  title="Claude Code Changelog — All Releases & Updates | changelogs.info"
  description="Track Claude Code releases, breaking changes, and config updates. Anthropic's agentic coding tool in your terminal."
  currentPage="home"
>
  <!-- Dot grid background -->
  <div class="cc-dotgrid cc-s11"></div>

  <div class="cc-s12">

    <!-- Hero -->
    <section class="cc-hero-section cc-grid">
      <div class="cc-grid-2 cc-hero-grid">
        <!-- Left -->
        <div class="cc-vstack-5">
          <div class="cc-flex-2">
            <span class="cc-pulse-dot cc-s17"></span>
            <span class="cc-label">Tracking {canonicalEntries.length} latest entries</span>
          </div>

          <h1 class="cc-headline cc-hero-title cc-s19">
            Claude<br><span class="cc-s41">Code</span>
          </h1>

          <p class="cc-s21">
            {tool?.description || "Anthropic's agentic coding tool — run AI in your terminal, build and fix code autonomously."}
          </p>

          <div class="cc-flex-3">
            <a
              href={`https://github.com/${tool?.repo || "anthropics/claude-code"}`}
              target="_blank"
              rel="noopener noreferrer"
              class="cc-headline cc-cta-btn cc-s23"
            >
              GitHub ↗
            </a>
            <a
              href="/claude-code/changelog/"
              class="cc-headline cc-cta-btn cc-s24"
            >
              Changelog
            </a>
          </div>
        </div>

        <!-- Right: terminal card -->
        <div class="cc-terminal-card cc-s25">
          <div class="cc-flex-4">
            <span class="cc-s27"></span>
            <span class="cc-s28"></span>
            <span class="cc-s29"></span>
            <span class="cc-s30">claude --status</span>
          </div>
          <div class="cc-s31">
            <div><span class="cc-s41">$</span> claude --version</div>
            <div class="cc-s33">
              <span class="cc-s41">●</span> Version: <span class="cc-s39">{displayVersion}</span>
            </div>
            <div>
              <span class="cc-s38">●</span> Releases: <span class="cc-s39">{releases.length}</span> tracked
            </div>
            <div>
              <span style="color: {breakingCount > 0 ? 'var(--cc-primary-bright)' : '#22c55e'};">{breakingCount > 0 ? '⚠' : '●'}</span> Breaking: <span style="color: {breakingCount > 0 ? 'var(--cc-primary-bright)' : 'var(--cc-text)'};">{breakingCount}</span>
            </div>
            <div>
              <span class="cc-s38">●</span> Updated: <span class="cc-s39">{lastUpdatedAgo || "now"}</span>
            </div>
            <div class="cc-s40">
              <span class="cc-s41">$</span> <span class="cc-cursor">_</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats Bar -->
    <section class="cc-section-reveal cc-flex-5">
      {[
        { label: "Releases", value: String(releases.length) },
        { label: "Breaking", value: String(breakingCount), warn: true },
        { label: "Stable", value: String(stableReleases.length) },
        { label: "Latest", value: displayVersion },
      ].map((stat, i) => (
        <div
          style={`flex: 1; min-width: 120px; padding: 1rem 1.25rem; ${i < 3 ? 'border-right: 4px solid var(--cc-border);' : ''} background: var(--cc-bg-card); cursor: crosshair; transition: background 150ms;`}
          class="cc-stats-cell"
        >
          <span class="cc-s43">{stat.label}</span>
          <span class="cc-headline" style={`display: block; font-size: 1.5rem; font-weight: 900; color: ${stat.warn ? 'var(--cc-primary-bright)' : 'var(--cc-text)'};`}>{stat.value}</span>
        </div>
      ))}
    </section>

    <!-- TL;DR Latest Release -->
    {latestForTldr && (() => {
      const breaking = isBreaking(latestForTldr.body);
      const tldr = getTldr(latestForTldr.body || "");
      const fallback = (latestForTldr.body || "").split("\n").filter(l => l.trim() && !l.startsWith("#")).slice(0, 2).map(l => l.replace(/^[\*\-]\s+/, "").trim());
      const items = tldr.length > 0 ? tldr : fallback;
      const summaryText = llmTldr?.trim() || null;

      return (
        <section class="cc-s44">
          <div class="cc-flex-6">
            <h2 class="cc-headline cc-s46">
              TL;DR
            </h2>
            <div class="cc-s63"></div>
            <span class="cc-s48">Latest Release</span>
          </div>

          <div style={`padding: 1.5rem 2rem; border: 4px solid ${breaking ? 'var(--cc-primary)' : 'var(--cc-border)'}; background: ${breaking ? 'var(--cc-bg-surface)' : 'var(--cc-bg-card)'}; ${breaking ? 'border-left: 8px solid var(--cc-primary);' : ''} margin-bottom: 2rem;`}>
            <div class="cc-flex-11">
              <div class="cc-flex-7">
                <span class="cc-headline cc-s51">{latestForTldr.version}</span>
                {breaking && (
                  <span class="cc-s68">BREAKING</span>
                )}
                {latestForTldr.prerelease && (
                  <span class="cc-s53">PRE</span>
                )}
              </div>
              <span class="cc-s69">{formatDate(latestForTldr.date)}</span>
            </div>            <img src="/images/guides/claude-code-tldr.jpg" alt="claude-code TLDR" style="width:100%;border-radius:12px;margin-bottom:1rem;border:2px solid var(--oc-border);" />

            {summaryText ? (
              <div class="cc-vstack-6">
                <p class="cc-s56">{summaryText}</p>
              </div>
            ) : items.length > 0 && (
              <ul class="cc-vstack-7">
                {items.map((item) => (
                  <li class="cc-flex-9">
                    <span class="cc-s59">▸</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            )}
          </div>
        </section>
      );
    })()}

    <!-- Recent Changelog -->
    <div class="cc-flex-10">
      <div class="cc-s63"></div>
      <span class="cc-headline cc-s62">Recent Changelog</span>
      <div class="cc-s63"></div>
    </div>

    <section class="cc-vstack-8">
      {canonicalEntries.map((entry) => {
        const release = releases.find((r) => r.version === entry.version) || latestForTldr;
        const breaking = isBreaking(entry.body);
        const renderedBody = buildChangelogCard(entry.body || "");
        return (
          <div style={`padding: 1.5rem 2rem; border: 4px solid ${breaking ? 'var(--cc-primary)' : 'var(--cc-border)'}; background: ${breaking ? 'var(--cc-bg-surface)' : 'var(--cc-bg-card)'}; ${breaking ? 'border-left: 8px solid var(--cc-primary);' : ''}`}>
            <div class="cc-flex-11">
              <div class="cc-flex-7">
                <span class="cc-headline cc-s67">{entry.version}</span>
                {breaking && (
                  <span class="cc-s68">BREAKING</span>
                )}
              </div>
              <span class="cc-s69">{formatDate(release.date)}</span>
            </div>
            <div
              class="changelog-body cc-s70"
              set:html={renderedBody}
            />
          </div>
        );
      })}
      <a
        href="/claude-code/changelog/"
        class="cc-headline cc-flex-8"
      >
        View full changelog →
      </a>
    </section>

    <!-- Quick Links -->
    <section class="cc-grid-3">
      {[
        { href: "/claude-code/quickstart/", icon: "🚀", label: "Quickstart", sub: "Up & running in 10 min" },
        { href: "/claude-code/tips/", icon: "💡", label: "Tips & Tricks", sub: "Quick wins & hidden features" },
        { href: "/claude-code/changelog/", icon: "📋", label: "Full Changelog", sub: `${releases.length} releases` },
        { href: "/claude-code/cheatsheet/", icon: "⚡", label: "Cheatsheet", sub: "Commands & tips" },
        { href: "/claude-code/releases/", icon: "📦", label: "All Releases", sub: "Browse & filter" },
        { href: "/feed/all.xml", icon: "📡", label: "RSS Feed", sub: "Subscribe to updates" },
      ].map((link) => (
        <a href={link.href} class="cc-quick-link cc-flex-12">
          <span class="cc-s74">{link.icon}</span>
          <div>
            <span class="cc-headline cc-s75">{link.label}</span>
            <span class="cc-s76">{link.sub}</span>
          </div>
        </a>
      ))}
    </section>

    <!-- Subscribe -->
    <section class="cc-s77">
      <h2 class="cc-headline cc-s78">
        Stay in the Loop
      </h2>
      <p class="cc-s79">
        Get notified when Claude Code ships new releases. No spam — just changelogs.
      </p>
      <div class="cc-flex-13">
        <input
          type="email"
          placeholder="you@example.com"
          class="cc-flex-item"
          onfocus="this.style.borderColor='var(--cc-primary)'"
          onblur="this.style.borderColor='var(--cc-border)'"
        />
        <button
          class="cc-headline cc-s82"
          onmouseover="this.style.transform='translate(1px,1px)';this.style.boxShadow='none'"
          onmouseout="this.style.transform='';this.style.boxShadow='var(--cc-shadow-sm)'"
        >
          Subscribe
        </button>
      </div>
      <div class="cc-flex-14">
        <a href="/feed/all.xml" class="cc-flex-16" onmouseover="this.style.color='var(--cc-primary-bright)'" onmouseout="this.style.color='var(--cc-text-dim)'">
          📡 RSS Feed
        </a>
        <a href={`https://github.com/${tool?.repo || "anthropics/claude-code"}`} target="_blank" rel="noopener noreferrer" class="cc-flex-16" onmouseover="this.style.color='var(--cc-primary-bright)'" onmouseout="this.style.color='var(--cc-text-dim)'">
          ⭐ Star on GitHub
        </a>
      </div>
    </section>
  </div>
</ClaudeCodeLayout>
