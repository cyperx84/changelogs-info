---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

export function getStaticPaths() {
  return getCollection("workflows").then((workflows) =>
    workflows.map((w) => ({
      params: { slug: w.slug },
      props: { workflow: w },
    }))
  );
}

const { workflow } = Astro.props;
const { Content } = await workflow.render();

// Related workflows (same category or shared tools)
const allWorkflows = await getCollection("workflows");
const related = allWorkflows
  .filter(
    (w) =>
      w.slug !== workflow.slug &&
      (w.data.category === workflow.data.category ||
        w.data.tools?.some((t: string) => workflow.data.tools?.includes(t)))
  )
  .slice(0, 3);
---

<BaseLayout
  title={`${workflow.data.title} — changelogs.info`}
  description={workflow.data.description || `Workflow guide: ${workflow.data.title}`}
>
  <div class="mx-auto max-w-4xl px-6 py-12">
    <div class="mb-8">
      <a
        href="/workflows"
        class="inline-flex items-center gap-1 text-sm text-text-muted transition-colors hover:text-accent"
      >
        &larr; All Workflows
      </a>
    </div>

    <article class="workflow-body">
      <header class="mb-8">
        <h1 class="mb-4 text-3xl font-bold text-text-primary">
          {workflow.data.title}
        </h1>
        <div class="flex flex-wrap gap-3 text-sm">
          {workflow.data.tools?.map((tool: string) => (
            <span class="rounded-full bg-bg-tertiary px-3 py-1 font-mono text-text-secondary">
              {tool}
            </span>
          ))}
        </div>
        <div class="mt-4 flex gap-4 text-sm text-text-muted">
          <span>Category: {workflow.data.category}</span>
          <span>•</span>
          <span>Difficulty: {workflow.data.difficulty}</span>
          {workflow.data.source && (
            <>
              <span>•</span>
              <a
                href={workflow.data.source}
                class="text-accent hover:underline"
              >
                Source
              </a>
            </>
          )}
        </div>
      </header>

      <Content />
    </article>

    {related.length > 0 && (
      <section class="mt-12 border-t border-border pt-8">
        <h2 class="mb-4 text-lg font-semibold text-text-primary">
          Related Workflows
        </h2>
        <div class="grid gap-3 md:grid-cols-3">
          {related.map((w) => (
            <a
              href={`/workflows/${w.slug}`}
              class="group block rounded-lg border border-border bg-bg-secondary p-4 transition-all hover:border-accent"
            >
              <h3 class="font-medium text-text-primary group-hover:text-accent">
                {w.data.title}
              </h3>
              <p class="mt-1 text-xs text-text-muted capitalize">
                {w.data.category}
              </p>
            </a>
          ))}
        </div>
      </section>
    )}
  </div>
</BaseLayout>

<style is:global>
  .workflow-body h1 { font-size: 2rem; font-weight: 700; margin-bottom: 1rem; color: var(--color-text-primary); }
  .workflow-body h2 { font-size: 1.25rem; font-weight: 600; margin-top: 2rem; margin-bottom: 0.75rem; color: var(--color-text-primary); }
  .workflow-body h3 { font-size: 1.1rem; font-weight: 600; margin-top: 1.25rem; margin-bottom: 0.5rem; color: var(--color-text-primary); }
  .workflow-body p { margin-bottom: 0.75rem; line-height: 1.7; color: var(--color-text-secondary); }
  .workflow-body table { width: 100%; border-collapse: collapse; margin-bottom: 1rem; }
  .workflow-body th { text-align: left; padding: 0.5rem 0.75rem; border-bottom: 2px solid var(--color-border); color: var(--color-text-primary); font-size: 0.875rem; }
  .workflow-body td { padding: 0.5rem 0.75rem; border-bottom: 1px solid var(--color-border); color: var(--color-text-secondary); font-size: 0.875rem; }
  .workflow-body tr:hover td { background: var(--color-bg-tertiary); }
  .workflow-body code { background: var(--color-bg-tertiary); padding: 0.15em 0.4em; border-radius: 4px; font-family: var(--font-mono); font-size: 0.875em; }
  .workflow-body pre { background: var(--color-bg-tertiary); padding: 1rem; border-radius: 8px; overflow-x: auto; margin-bottom: 1rem; }
  .workflow-body pre code { background: none; padding: 0; }
  .workflow-body ul { list-style: disc; padding-left: 1.5rem; margin-bottom: 0.75rem; }
  .workflow-body ol { list-style: decimal; padding-left: 1.5rem; margin-bottom: 0.75rem; }
  .workflow-body li { margin-bottom: 0.25rem; line-height: 1.6; color: var(--color-text-secondary); }
  .workflow-body blockquote { border-left: 3px solid var(--color-accent); padding-left: 1rem; margin: 1rem 0; color: var(--color-text-muted); }
</style>
