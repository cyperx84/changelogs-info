---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const workflows = await getCollection("workflows");

// Group by category
const categories: Record<string, typeof workflows> = {};
for (const w of workflows) {
  const cat = w.data.category || "general";
  if (!categories[cat]) categories[cat] = [];
  categories[cat].push(w);
}

const categoryOrder = ["development", "review", "orchestration", "maintenance", "general"];
const sortedCategories = Object.keys(categories).sort(
  (a, b) => categoryOrder.indexOf(a) - categoryOrder.indexOf(b)
);
---

<BaseLayout
  title="Workflows — changelogs.info"
  description="Multi-tool workflow guides for AI coding agents"
>
  <div class="mx-auto max-w-4xl px-6 py-12">
    <h1 class="mb-4 text-3xl font-bold text-text-primary">Workflows</h1>
    <p class="mb-8 text-text-secondary">
      Multi-tool workflow guides for getting the most out of AI coding agents.
      Learn patterns for development, review, orchestration, and maintenance.
    </p>

    {sortedCategories.map((category) => (
      <section class="mb-10">
        <h2 class="mb-4 text-xl font-semibold text-text-primary capitalize">
          {category}
        </h2>
        <div class="grid gap-4 md:grid-cols-2">
          {categories[category].map((workflow) => (
            <a
              href={`/workflows/${workflow.slug}`}
              class="group block rounded-lg border border-border bg-bg-secondary p-5 transition-all hover:border-accent"
            >
              <h3 class="mb-2 font-semibold text-text-primary group-hover:text-accent">
                {workflow.data.title}
              </h3>
              <p class="text-sm text-text-secondary">
                Tools: {workflow.data.tools?.join(", ") || "Various"}
              </p>
              <div class="mt-3 flex items-center gap-2">
                <span class="rounded bg-bg-tertiary px-2 py-0.5 text-xs text-text-muted">
                  {workflow.data.difficulty}
                </span>
              </div>
            </a>
          ))}
        </div>
      </section>
    ))}

    <section class="mt-12 rounded-lg border border-border bg-bg-secondary p-6">
      <h2 class="mb-3 text-lg font-semibold text-text-primary">Contributing</h2>
      <p class="text-text-secondary">
        Have a workflow to share? Submit a PR to{" "}
        <a
          href="https://github.com/cyperx84/changelogs-info"
          class="text-accent hover:underline"
        >
          cyperx84/changelogs-info
        </a>
        . Workflows are markdown files in <code class="rounded bg-bg-tertiary px-1">src/content/workflows/</code>.
      </p>
    </section>
  </div>
</BaseLayout>
