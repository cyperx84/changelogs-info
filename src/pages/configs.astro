---
import BaseLayout from "../layouts/BaseLayout.astro";

const configs = [
  {
    id: "claude-code-settings",
    title: "Claude Code Settings",
    description: "Recommended settings.json for Claude Code",
    language: "json",
    filename: ".claude/settings.json",
    code: `{
  "permissions": {
    "mode": "default",
    "alwaysAllowedTools": ["Read", "Grep", "Glob"],
    "alwaysAllowedBashPrefixes": ["git status", "git diff", "ls", "cat"]
  },
  "editor": {
    "preferredExternalEditor": "cursor",
    "autoOpen": false
  },
  "model": {
    "default": "claude-sonnet-4-5"
  },
  "memory": {
    "enabled": true,
    "autoSave": true
  },
  "hooks": {
    "PreToolUse": [],
    "PostToolUse": [],
    "Notification": [],
    "Stop": []
  }
}`
  },
  {
    id: "claude-code-claudemd",
    title: "Claude Code CLAUDE.md",
    description: "Project instructions template for Claude Code",
    language: "markdown",
    filename: "CLAUDE.md",
    code: `# Project: [Project Name]

## Overview
Brief description of what this project does.

## Architecture
- Frontend: [Framework]
- Backend: [Framework]
- Database: [Database]
- Deployment: [Platform]

## Development Guidelines

### Code Style
- Use TypeScript for all new code
- Follow ESLint configuration
- Write tests for new features
- Document complex logic

### Git Workflow
- Create feature branches from main
- Use conventional commits (feat:, fix:, docs:, etc.)
- Squash commits before merging
- Request code review before merging

### Testing
- Run \`pnpm test\` before committing
- Maintain >80% code coverage
- Write integration tests for API endpoints

## Important Notes
- Never commit .env files
- Always run migrations before schema changes
- Check TypeScript types with \`pnpm typecheck\`

## Useful Commands
- \`pnpm dev\` - Start development server
- \`pnpm build\` - Build for production
- \`pnpm test\` - Run test suite
- \`pnpm lint\` - Lint and format code`
  },
  {
    id: "aider-config",
    title: "Aider Configuration",
    description: "Recommended .aider.conf.yml settings",
    language: "yaml",
    filename: ".aider.conf.yml",
    code: `# Model Configuration
model: claude-sonnet-4-5
# Options: gpt-4-turbo, claude-opus-4, claude-sonnet-4-5, deepseek-coder

# Edit Format
edit-format: diff
# Options: diff, whole, udiff

# Git Integration
auto-commits: true
dirty-commits: false
attribute-author: true
attribute-committer: false

# Context Management
map-tokens: 1024
read: []

# Environment
env-file: .env

# Code Quality
lint: true
test: false

# Performance
cache-prompts: true
stream: true`
  },
  {
    id: "continue-config",
    title: "Continue Configuration",
    description: "config.json for Continue extension",
    language: "json",
    filename: ".continue/config.json",
    code: `{
  "models": [
    {
      "title": "Claude Sonnet",
      "provider": "anthropic",
      "model": "claude-sonnet-4-5",
      "apiKey": ""
    },
    {
      "title": "GPT-4 Turbo",
      "provider": "openai",
      "model": "gpt-4-turbo",
      "apiKey": ""
    }
  ],
  "tabAutocompleteModel": {
    "title": "Codestral",
    "provider": "mistral",
    "model": "codestral-latest"
  },
  "embeddingsProvider": {
    "provider": "openai",
    "model": "text-embedding-3-small"
  },
  "contextProviders": [
    {
      "name": "code",
      "params": {}
    },
    {
      "name": "docs",
      "params": {}
    },
    {
      "name": "diff",
      "params": {}
    },
    {
      "name": "terminal",
      "params": {}
    },
    {
      "name": "problems",
      "params": {}
    },
    {
      "name": "codebase",
      "params": {}
    }
  ],
  "slashCommands": [
    {
      "name": "edit",
      "description": "Edit selected code"
    },
    {
      "name": "comment",
      "description": "Write comments for the code"
    },
    {
      "name": "share",
      "description": "Export chat to markdown"
    },
    {
      "name": "cmd",
      "description": "Generate a shell command"
    }
  ]
}`
  },
  {
    id: "cline-settings",
    title: "Cline VS Code Settings",
    description: "VS Code settings.json for Cline",
    language: "json",
    filename: ".vscode/settings.json (Cline section)",
    code: `{
  "cline.apiProvider": "anthropic",
  "cline.anthropicApiKey": "",
  "cline.defaultModel": "claude-sonnet-4-5",
  "cline.temperature": 0.7,
  "cline.maxTokens": 8192,
  "cline.alwaysApproveWrite": false,
  "cline.alwaysApproveExecute": false,
  "cline.browserEnabled": true,
  "cline.autoSummarize": true,
