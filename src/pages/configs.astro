  },
  {
    id: "cursor-settings",
    title: "Cursor Settings",
    description: "Recommended Cursor IDE settings",
    language: "json",
    filename: ".cursor/settings.json",
    code: `{
  "cursor.ai.model": "claude-sonnet-4-5",
  "cursor.ai.temperature": 0.7,
  "cursor.ai.maxTokens": 4096,
  "cursor.chat.enabled": true,
  "cursor.composer.enabled": true,
  "cursor.autoSave": "afterDelay",
  "cursor.autoSaveDelay": 1000,
  "cursor.telemetry.enabled": false,
  "editor.inlineSuggest.enabled": true,
  "editor.quickSuggestions": {
    "other": true,
    "comments": true,
    "strings": true
  }
}`
  }
];
---

<BaseLayout title="Config Templates — changelogs.info">
  <section class="mx-auto max-w-6xl px-6 py-12">
    <div class="mb-8">
      <h1 class="text-3xl font-bold tracking-tight">Config Templates</h1>
      <p class="mt-2 text-text-secondary">
        Copy-paste configuration templates for popular AI coding tools
      </p>
    </div>

    <div class="space-y-6">
      {configs.map((config) => (
        <div class="rounded-xl border border-border bg-bg-card">
          <div class="border-b border-border px-6 py-4">
            <div class="flex items-center justify-between">
              <div>
                <h2 class="text-lg font-semibold">{config.title}</h2>
                <p class="mt-1 text-sm text-text-secondary">{config.description}</p>
              </div>
              <button
                class="copy-btn rounded-lg border border-border bg-bg-secondary px-4 py-2 text-sm font-medium transition-all hover:border-border-hover hover:bg-bg-tertiary"
                data-code={config.code}
              >
                Copy
              </button>
            </div>
            <p class="mt-2 font-mono text-xs text-text-muted">{config.filename}</p>
          </div>
          <div class="p-6">
            <pre class="overflow-x-auto rounded-lg bg-bg-tertiary p-4"><code class={`language-${config.language} text-sm`}>{config.code}</code></pre>
          </div>
        </div>
      ))}
    </div>
  </section>

  <script>
    const copyButtons = document.querySelectorAll('.copy-btn');

    copyButtons.forEach(button => {
      button.addEventListener('click', async () => {
        const code = button.getAttribute('data-code');
        if (!code) return;

        try {
          await navigator.clipboard.writeText(code);
          const originalText = button.textContent;
          button.textContent = 'Copied!';
          button.classList.add('border-green', 'text-green');

          setTimeout(() => {
            button.textContent = originalText;
            button.classList.remove('border-green', 'text-green');
          }, 2000);
        } catch (err) {
          console.error('Failed to copy:', err);
        }
      });
    });
  </script>
</BaseLayout>
