---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Starter Config Templates — changelogs.info" description="Copy-paste starter configs for popular AI coding tools.">
  <section class="mx-auto max-w-5xl px-6 py-12">
    <h1 class="font-mono text-2xl font-bold text-green sm:text-3xl">
      <span class="text-green">/</span>configs
    </h1>
    <p class="mt-2 font-mono text-sm text-text-secondary">
      <span class="text-green">#</span> baseline templates — tune for your project
    </p>

    <div class="mt-8 space-y-8">
      <article class="rounded-lg border border-border bg-bg-card">
        <div class="border-b border-border px-3 py-2 font-mono text-xs text-text-muted sm:px-4">
          <span class="text-green">●●●</span>
          <span class="ml-2">CLAUDE.md</span>
        </div>
        <pre class="overflow-x-auto p-4 font-mono text-sm"><code class="text-text-secondary"># Project Conventions

- Use TypeScript strict mode
- Write tests for all new features
- Keep commits small and atomic
- Prefer functions over classes where possible
- Never commit secrets
</code></pre>
      </article>

      <article class="rounded-lg border border-border bg-bg-card">
        <div class="border-b border-border px-3 py-2 font-mono text-xs text-text-muted sm:px-4">
          <span class="text-green">●●●</span>
          <span class="ml-2">.cursorrules</span>
        </div>
        <pre class="overflow-x-auto p-4 font-mono text-sm"><code class="text-text-secondary">You are working in a TypeScript monorepo.
- Keep changes minimal and focused
- Add/update tests for behavior changes
- Prefer existing project patterns
- Run lint + typecheck before finishing
</code></pre>
      </article>

      <article class="rounded-lg border border-border bg-bg-card">
        <div class="border-b border-border px-3 py-2 font-mono text-xs text-text-muted sm:px-4">
          <span class="text-green">●●●</span>
          <span class="ml-2">.aider.conf.yml</span>
        </div>
        <pre class="overflow-x-auto p-4 font-mono text-sm"><code class="text-text-secondary">model: sonnet
auto-commits: true
pretty: true
gitignore: true
</code></pre>
      </article>

      <article class="rounded-lg border border-border bg-bg-card">
        <div class="border-b border-border px-3 py-2 font-mono text-xs text-text-muted sm:px-4">
          <span class="text-green">●●●</span>
          <span class="ml-2">.continue/config.json</span>
        </div>
        <pre class="overflow-x-auto p-4 font-mono text-sm"><code class="text-text-secondary">&#123;
  "models": [
    &#123; "title": "Claude Sonnet", "provider": "anthropic", "model": "claude-sonnet-4-5" &#125;
  ],
  "tabAutocompleteModel": &#123; "provider": "ollama", "model": "qwen2.5-coder:7b" &#125;
&#125;
</code></pre>
      </article>
    </div>
  </section>
</BaseLayout>
