  },
  {
    id: "gitignore-ai",
    title: ".gitignore for AI Tools",
    description: "Common patterns to exclude from version control",
    language: "text",
    filename: ".gitignore",
    code: `# AI Tool Directories
.claude/
.aider/
.continue/
.cline/

# API Keys and Secrets
.env
.env.local
*.key
*-key.txt

# AI Conversation History
.aider.chat.history.md
.claude-chat-history/
conversation-*.json

# Model Cache
.model-cache/
.embeddings/

# OS Files
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Dependencies
node_modules/
venv/
.venv/

# Build Output
dist/
build/
out/
*.log`
  },
  {
    id: "openclaw-config",
    title: "OpenClaw Configuration",
    description: "openclaw.config.yml template",
    language: "yaml",
    filename: "openclaw.config.yml",
    code: `# Model Configuration
models:
  default: gpt-4-turbo
  providers:
    openai:
      apiKey: \${OPENAI_API_KEY}
    anthropic:
      apiKey: \${ANTHROPIC_API_KEY}

# Agents
agents:
  - name: coder
    model: gpt-4-turbo
    systemPrompt: "You are an expert programmer. Write clean, maintainable code."
