---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Newsletter — changelogs.info" description="Get a weekly digest of the most important AI coding tool changes.">
  <section class="relative overflow-hidden border-b border-green/20" style="background: linear-gradient(135deg, rgba(51, 255, 51, 0.04) 0%, transparent 50%);">
    <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6 sm:py-14">
      <div class="max-w-2xl">
        <div class="mb-3 flex items-center gap-3">
          <span class="inline-block h-3 w-3 rounded-sm bg-green" style="box-shadow: 0 0 12px #33ff33;"></span>
          <span class="font-mono text-xs uppercase tracking-widest text-text-muted">subscribe</span>
        </div>
        <h1 class="font-mono text-3xl font-bold text-green sm:text-4xl">/newsletter</h1>
        <p class="mt-3 font-sans text-sm leading-relaxed text-text-secondary sm:text-base">
          Weekly digest of the most important changes across all tracked AI coding tools. Breaking changes, new features, and what you need to update.
        </p>
      </div>
    </div>
  </section>

  <div class="mx-auto max-w-2xl px-4 py-8 sm:px-6 sm:py-12">
    <!-- What you get -->
    <div class="mb-8 rounded-lg border border-border bg-bg-card p-5">
      <h2 class="mb-4 font-mono text-sm font-semibold text-green">
        <span class="opacity-60">#</span> what_you_get
      </h2>
      <div class="space-y-3">
        <div class="flex gap-3">
          <span class="shrink-0 font-mono text-xs text-red">!</span>
          <div>
            <p class="font-mono text-xs font-semibold text-text-primary">Breaking changes alert</p>
            <p class="font-sans text-xs text-text-muted">Config-breaking updates across OpenClaw, Claude Code, Codex CLI, and more</p>
          </div>
        </div>
        <div class="flex gap-3">
          <span class="shrink-0 font-mono text-xs text-cyan">+</span>
          <div>
            <p class="font-mono text-xs font-semibold text-text-primary">New features roundup</p>
            <p class="font-sans text-xs text-text-muted">Notable additions and improvements worth trying</p>
          </div>
        </div>
        <div class="flex gap-3">
          <span class="shrink-0 font-mono text-xs text-amber">~</span>
          <div>
            <p class="font-mono text-xs font-semibold text-text-primary">Config migration tips</p>
            <p class="font-sans text-xs text-text-muted">What you need to change and how to update safely</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Signup form -->
    <div class="rounded-lg border border-green/20 bg-bg-card p-6 sm:p-8">
      <div class="border-b border-border pb-2 mb-5 font-mono text-xs text-text-muted">
        <span class="text-green">●●●</span> <span class="ml-2">subscribe.sh</span>
      </div>

      <form id="newsletter-form" class="space-y-4">
        <div>
          <label for="email" class="mb-2 block font-mono text-xs text-text-muted">email_address:</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            placeholder="you@example.com"
            class="w-full rounded border border-border bg-bg-tertiary px-4 py-3 font-mono text-sm text-text-primary placeholder:text-text-muted/50 focus:border-green focus:outline-none focus:ring-1 focus:ring-green/30 transition-colors"
          />
        </div>

        <div class="flex flex-wrap gap-3">
          <label class="flex items-center gap-2 font-mono text-xs text-text-muted">
            <input type="checkbox" name="interest" value="breaking" checked class="accent-green" />
            Breaking changes
          </label>
          <label class="flex items-center gap-2 font-mono text-xs text-text-muted">
            <input type="checkbox" name="interest" value="features" checked class="accent-green" />
            New features
          </label>
          <label class="flex items-center gap-2 font-mono text-xs text-text-muted">
            <input type="checkbox" name="interest" value="configs" class="accent-green" />
            Config tips
          </label>
        </div>

        <button
          type="submit"
          class="w-full rounded border border-green bg-green/10 px-6 py-3 font-mono text-sm font-semibold text-green transition-all hover:bg-green/20 hover:shadow-[0_0_16px_rgba(51,255,51,0.15)]"
        >
          subscribe &rarr;
        </button>

        <p class="font-mono text-[10px] text-text-muted text-center">
          Weekly digest. No spam. Unsubscribe anytime.
        </p>
      </form>

      <div id="newsletter-success" class="hidden text-center py-6">
        <p class="font-mono text-base text-green mb-2">subscribed.</p>
        <p class="font-sans text-xs text-text-muted">You'll get your first digest next week.</p>
      </div>
    </div>

    <!-- Frequency -->
    <div class="mt-8 rounded-lg border border-border bg-bg-card p-5">
      <h2 class="mb-3 font-mono text-sm font-semibold text-text-primary">
        <span class="text-green opacity-60">//</span> frequency
      </h2>
      <div class="space-y-2 font-mono text-xs text-text-secondary">
        <p><span class="text-cyan">schedule:</span> Every Monday at 9:00 UTC</p>
        <p><span class="text-cyan">format:</span> Plain text + HTML (your choice)</p>
        <p><span class="text-cyan">tools:</span> OpenClaw, Claude Code, Codex CLI, Cursor, Cline, Windsurf, Gemini CLI, and more</p>
      </div>
    </div>
  </div>

  <script>
    document.addEventListener("astro:page-load", () => {
      const form = document.getElementById("newsletter-form");
      const success = document.getElementById("newsletter-success");

      form?.addEventListener("submit", async (e) => {
        e.preventDefault();
        const formData = new FormData(form);
        const email = formData.get("email");
        const interests = formData.getAll("interest");

        const data = { email, interests, subscribedAt: new Date().toISOString() };

        try {
          // Store locally for now — backend integration comes later
          const existing = JSON.parse(localStorage.getItem("newsletter_subs") || "[]");
          existing.push(data);
          localStorage.setItem("newsletter_subs", JSON.stringify(existing));

          form.classList.add("hidden");
          success?.classList.remove("hidden");
        } catch {
          alert("Something went wrong. Please try again.");
        }
      });
    });
  </script>
</BaseLayout>
