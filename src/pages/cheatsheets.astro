---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getTools } from "../lib/releases";
import { readFileSync } from "node:fs";
import { join } from "node:path";

const tools = getTools();
const cheatsheetsDir = join(process.cwd(), "src/content/cheatsheets-json");

const toolsWithCheatsheets = tools
  .map((t) => {
    try {
      const raw = readFileSync(join(cheatsheetsDir, `${t.id}.json`), "utf-8");
      const cs = JSON.parse(raw);
      return {
        ...t,
        cheatsheet: cs,
        stats: {
          workflows: (cs.dailyWorkflows || []).length,
          powerMoves: (cs.powerMoves || []).length,
          gotchas: (cs.gotchas || []).length,
          flags: (cs.cliFlags || []).length,
          commands: (cs.slashCommands || []).length,
          tips: (cs.proTips || []).length,
        },
      };
    } catch {
      return null;
    }
  })
  .filter(Boolean);
---

<BaseLayout
  title="AI Coding Tool Cheat Sheets — changelogs.info"
  description="Actually useful cheat sheets for Claude Code, Codex CLI, OpenClaw, and more. Daily workflows, power moves, gotchas, and pro tips."
>
  <div class="mx-auto max-w-4xl px-6 py-12">

    <a href="/" class="mb-8 inline-flex items-center gap-1 font-mono text-sm text-text-muted transition-colors hover:text-green">
      <span class="text-green">&lt;</span> cd ..
    </a>

    <header class="mb-10">
      <h1 class="text-glow-green font-mono text-2xl font-bold text-green sm:text-3xl">cheat sheets</h1>
      <p class="mt-3 font-sans text-sm leading-relaxed text-text-secondary sm:text-base max-w-2xl">
        The stuff you actually need. Task-oriented, copy-paste ready, kept current. Not just flag dumps — real workflows, power moves, and gotchas from people who use these tools daily.
      </p>
    </header>

    <div class="grid gap-4 sm:grid-cols-2">
      {toolsWithCheatsheets.map((t: any) => (
        <a href={`/tools/${t.id}/cheatsheet`} class="group rounded-lg border border-border bg-bg-card p-5 transition-all hover:border-green/40 hover:shadow-[0_0_12px_rgba(51,255,51,0.1)]">
          <div class="mb-3 flex items-center justify-between">
            <h2 class="font-mono text-base font-semibold text-text-primary group-hover:text-green transition-colors">{t.name}</h2>
            <span class="font-mono text-[10px] text-text-muted">{t.cheatsheet.lastUpdated}</span>
          </div>
          <p class="mb-4 font-sans text-xs text-text-muted line-clamp-2">{t.description}</p>
          <div class="flex flex-wrap gap-2">
            {t.stats.workflows > 0 && (
              <span class="rounded bg-green/10 px-1.5 py-0.5 font-mono text-[10px] text-green">
                {t.stats.workflows} workflows
              </span>
            )}
            {t.stats.powerMoves > 0 && (
              <span class="rounded bg-amber/10 px-1.5 py-0.5 font-mono text-[10px] text-amber">
                {t.stats.powerMoves} power moves
              </span>
            )}
            {t.stats.gotchas > 0 && (
              <span class="rounded bg-red-400/10 px-1.5 py-0.5 font-mono text-[10px] text-red-400">
                {t.stats.gotchas} gotchas
              </span>
            )}
            {t.stats.flags > 0 && (
              <span class="rounded bg-bg-tertiary px-1.5 py-0.5 font-mono text-[10px] text-text-muted">
                {t.stats.flags} flags
              </span>
            )}
            {t.stats.commands > 0 && (
              <span class="rounded bg-cyan/10 px-1.5 py-0.5 font-mono text-[10px] text-cyan">
                {t.stats.commands} commands
              </span>
            )}
          </div>
        </a>
      ))}
    </div>

    <!-- CTA -->
    <div class="mt-10 rounded-lg border border-border bg-bg-card p-6 text-center">
      <p class="font-sans text-sm text-text-secondary">
        Missing a tool? Want to contribute a cheatsheet?
      </p>
      <a href="https://github.com/cyperx84/changelogs-info/issues" target="_blank" rel="noopener" class="mt-2 inline-block font-mono text-sm text-green transition-colors hover:text-green/80">
        Open an issue on GitHub →
      </a>
    </div>
  </div>
</BaseLayout>
