---
import ClineLayout from "../../layouts/ClineLayout.astro";
import { getToolById, getToolReleases, formatDate, relativeTime } from "../../lib/releases";
import { readFileSync } from "node:fs";
import { join } from "node:path";

const tool = getToolById("cline");
const data = await getToolReleases("cline");
const releases = data?.releases || [];
const stableReleases = releases.filter((r) => !r.prerelease);
const latestStable = stableReleases[0] || releases[0];
const latestRelease = releases[0];
const breakingCount = releases.filter((r) => (r.body || "").toLowerCase().includes("breaking")).length;
const lastUpdatedAgo = data?.lastUpdated ? relativeTime(data.lastUpdated) : null;

let cheatsheet: any = {};
try {
  const raw = readFileSync(join(process.cwd(), "src/content/cheatsheets-json/cline.json"), "utf-8");
  cheatsheet = JSON.parse(raw);
} catch {}

const slashCommands = (cheatsheet.slashCommands || []).slice(0, 4);
const dailyWorkflows = (cheatsheet.dailyWorkflows || []).slice(0, 3);
const quickCommands = [
  { label: "Open Cline", command: "Cmd/Ctrl+Shift+P → Cline: Focus on Cline View" },
  { label: "Open Settings", command: "Cmd/Ctrl+Shift+P → Cline: Open Settings" },
  { label: "Fresh task", command: "/newtask Start a new bugfix or feature with clean context" },
  { label: "Deep planning", command: "/deep-planning Map the architecture before editing" },
];

function extractHighlights(body: string = ""): string[] {
  return body
    .split("\n")
    .map((line) => line.trim())
    .filter((line) => /^[-*]\s+/.test(line))
    .map((line) => line.replace(/^[-*]\s+/, "").trim())
    .slice(0, 4);
}

const latestHighlights = extractHighlights(latestRelease?.body);
---

<ClineLayout
  title="Cline Changelog — All Releases & Updates | changelogs.info"
  description="Track Cline releases, breaking changes, and workflow updates. Autonomous AI coding extension for VS Code, Cursor, and JetBrains."
  currentPage="home"
>
  <div class="cl-home">
    <section class="cl-home__hero">
      <div class="cl-home__hero-copy">
        <div class="cl-home__eyebrow">IDE extension · official releases · permissioned actions</div>
        <h1 class="cl-home__title">AI coding, open source and uncompromised</h1>
        <p class="cl-home__lede">
          {tool?.description || "Autonomous AI coding extension for VS Code, Cursor, and JetBrains. Creates files, runs commands, uses browser with your permission."}
        </p>
        <div class="cl-home__actions">
          <a href="/cline/changelog/" class="cl-home__button cl-home__button--primary">View changelog</a>
          <a href={`https://github.com/${tool?.repo || "cline/cline"}`} target="_blank" rel="noopener noreferrer" class="cl-home__button">
            GitHub ↗
          </a>
        </div>
      </div>

      <aside class="cl-home__terminal" aria-label="Cline snapshot">
        <div class="cl-home__terminal-bar">
          <span></span><span></span><span></span>
          <code>cline status</code>
        </div>
        <div class="cl-home__terminal-body">
          <div><span>$</span> latest stable</div>
          <div class="cl-home__terminal-line">version: <strong>{latestStable?.version || "—"}</strong></div>
          <div class="cl-home__terminal-line">releases tracked: <strong>{releases.length}</strong></div>
          <div class="cl-home__terminal-line">breaking releases: <strong>{breakingCount}</strong></div>
          <div class="cl-home__terminal-line">last updated: <strong>{lastUpdatedAgo || "now"}</strong></div>
          <div class="cl-home__terminal-line">latest published: <strong>{latestRelease ? formatDate(latestRelease.date) : "—"}</strong></div>
        </div>
      </aside>
    </section>

    <section class="cl-home__stats">
      {[
        { label: "Latest stable", value: latestStable?.version || "—" },
        { label: "Total releases", value: String(releases.length) },
        { label: "Breaking", value: String(breakingCount) },
        { label: "Tracked source", value: "GitHub" },
      ].map((item) => (
        <div class="cl-home__stat">
          <span>{item.label}</span>
          <strong>{item.value}</strong>
        </div>
      ))}
    </section>

    <section class="cl-home__grid">
      <article class="cl-home__panel">
        <div class="cl-home__panel-head">
          <h2>VS Code quick commands</h2>
          <span>Cheatsheet</span>
        </div>
        <div class="cl-home__command-list">
          {quickCommands.map((item) => (
            <div class="cl-home__command">
              <strong>{item.label}</strong>
              <code>{item.command}</code>
            </div>
          ))}
        </div>
      </article>

      <article class="cl-home__panel">
        <div class="cl-home__panel-head">
          <h2>Latest release</h2>
          <span>{latestRelease?.version || "—"}</span>
        </div>
        {latestHighlights.length > 0 ? (
          <ul class="cl-home__bullet-list">
            {latestHighlights.map((item) => <li>{item}</li>)}
          </ul>
        ) : (
          <p class="cl-home__muted">Release summary not available yet.</p>
        )}
        <a href="/cline/releases/" class="cl-home__text-link">Browse all releases →</a>
      </article>
    </section>

    <section class="cl-home__grid">
      <article class="cl-home__panel">
        <div class="cl-home__panel-head">
          <h2>Daily workflows</h2>
          <span>From docs</span>
        </div>
        <div class="cl-home__stack">
          {dailyWorkflows.map((workflow: any) => (
            <div class="cl-home__mini-card">
              <strong>{workflow.title}</strong>
              <p>{workflow.description}</p>
              {workflow.command && <code>{workflow.command}</code>}
            </div>
          ))}
        </div>
      </article>

      <article class="cl-home__panel">
        <div class="cl-home__panel-head">
          <h2>Slash commands</h2>
          <span>High leverage</span>
        </div>
        <div class="cl-home__stack">
          {slashCommands.map((command: any) => (
            <div class="cl-home__mini-card">
              <strong>{command.command || command.cmd}</strong>
              <p>{command.description}</p>
            </div>
          ))}
        </div>
      </article>
    </section>

    <section class="cl-home__links">
      <a href="/cline/changelog/" class="cl-home__link-card">
        <strong>Changelog</strong>
        <span>Every release, every fix, every breaking note.</span>
      </a>
      <a href="/cline/cheatsheet/" class="cl-home__link-card">
        <strong>Cheatsheet</strong>
        <span>Plan/Act habits, slash commands, and Cline setup tips.</span>
      </a>
      <a href="/cline/releases/" class="cl-home__link-card">
        <strong>Releases</strong>
        <span>Version history with filtering for stable, breaking, and pre-release builds.</span>
      </a>
    </section>
  </div>

  <style>
    .cl-home {
      max-width: 1280px;
      margin: 0 auto;
      padding: 2rem 1.5rem 0;
    }
    .cl-home__hero {
      display: grid;
      grid-template-columns: minmax(0, 1.4fr) minmax(320px, 0.9fr);
      gap: 2rem;
      align-items: stretch;
      margin-bottom: 2rem;
    }
    .cl-home__hero-copy,
    .cl-home__terminal,
    .cl-home__panel,
    .cl-home__link-card,
    .cl-home__stat {
      border: 4px solid var(--cl-border);
      background: var(--cl-bg-card);
      box-shadow: var(--cl-shadow);
    }
    .cl-home__hero-copy {
      padding: 2.25rem;
      position: relative;
      overflow: hidden;
    }
    .cl-home__hero-copy::after {
      content: "";
      position: absolute;
      inset: auto -3rem -3rem auto;
      width: 14rem;
      height: 14rem;
      background: radial-gradient(circle, rgba(168, 85, 247, 0.22), transparent 68%);
      pointer-events: none;
    }
    .cl-home__eyebrow {
      display: inline-flex;
      padding: 0.45rem 0.8rem;
      border: 2px solid var(--cl-border-dim);
      background: var(--cl-bg-surface);
      color: var(--cl-primary-bright);
      font-family: var(--cl-font-mono);
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }
    .cl-home__title {
      margin: 1rem 0 1rem;
      font-family: var(--cl-font-headline);
      font-size: clamp(3rem, 7vw, 6rem);
      line-height: 0.92;
      letter-spacing: -0.04em;
      text-transform: uppercase;
    }
    .cl-home__lede,
    .cl-home__mini-card p,
    .cl-home__link-card span,
    .cl-home__muted {
      margin: 0;
      color: var(--cl-text-dim);
      font-size: 1rem;
      line-height: 1.6;
    }
    .cl-home__actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.9rem;
      margin-top: 1.5rem;
    }
    .cl-home__button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.9rem 1.35rem;
      border: 3px solid var(--cl-border);
      color: var(--cl-text);
      font-family: var(--cl-font-mono);
      font-size: 0.85rem;
      font-weight: 800;
      text-transform: uppercase;
      text-decoration: none;
      letter-spacing: 0.08em;
      background: transparent;
      transition: transform 120ms, background 120ms, color 120ms;
    }
    .cl-home__button:hover {
      transform: translate(1px, 1px);
      background: var(--cl-primary);
      color: #fff;
    }
    .cl-home__button--primary {
      background: var(--cl-primary);
      color: #fff;
      border-color: var(--cl-primary);
    }
    .cl-home__terminal {
      padding: 0;
      overflow: hidden;
    }
    .cl-home__terminal-bar {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.8rem 1rem;
      border-bottom: 2px solid var(--cl-border-dim);
      background: var(--cl-bg-surface);
      font-family: var(--cl-font-mono);
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }
    .cl-home__terminal-bar span {
      width: 0.75rem;
      height: 0.75rem;
      border-radius: 999px;
      background: var(--cl-primary);
      opacity: 0.8;
    }
    .cl-home__terminal-bar code {
      margin-left: auto;
      color: var(--cl-text-dim);
    }
    .cl-home__terminal-body {
      padding: 1.2rem 1.1rem 1.35rem;
      font-family: var(--cl-font-mono);
      font-size: 0.88rem;
      color: var(--cl-text);
      line-height: 1.8;
    }
    .cl-home__terminal-body span {
      color: var(--cl-primary-bright);
    }
    .cl-home__terminal-line {
      color: var(--cl-text-dim);
    }
    .cl-home__terminal-line strong {
      color: var(--cl-text);
    }
    .cl-home__stats {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 1rem;
      margin-bottom: 1.25rem;
    }
    .cl-home__stat {
      padding: 1rem 1.1rem;
    }
    .cl-home__stat span {
      display: block;
      margin-bottom: 0.5rem;
      color: var(--cl-text-muted);
      font-family: var(--cl-font-mono);
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.09em;
    }
    .cl-home__stat strong {
      font-family: var(--cl-font-headline);
      font-size: 1.5rem;
    }
    .cl-home__grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
      margin-bottom: 1rem;
    }
    .cl-home__panel {
      padding: 1.4rem;
    }
    .cl-home__panel-head {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      align-items: baseline;
      margin-bottom: 1rem;
    }
    .cl-home__panel-head h2 {
      margin: 0;
      font-family: var(--cl-font-headline);
      font-size: 1.4rem;
      text-transform: uppercase;
      letter-spacing: -0.02em;
    }
    .cl-home__panel-head span {
      color: var(--cl-primary-bright);
      font-family: var(--cl-font-mono);
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }
    .cl-home__command-list,
    .cl-home__stack {
      display: grid;
      gap: 0.85rem;
    }
    .cl-home__command,
    .cl-home__mini-card {
      padding: 1rem;
      border: 2px solid var(--cl-border-dim);
      background: var(--cl-bg-surface);
    }
    .cl-home__command strong,
    .cl-home__mini-card strong,
    .cl-home__link-card strong {
      display: block;
      margin-bottom: 0.45rem;
      font-family: var(--cl-font-headline);
      font-size: 0.95rem;
      text-transform: uppercase;
      letter-spacing: -0.01em;
    }
    .cl-home__command code,
    .cl-home__mini-card code {
      display: block;
      overflow-x: auto;
      color: var(--cl-primary-bright);
      font-family: var(--cl-font-mono);
      font-size: 0.78rem;
      line-height: 1.6;
      white-space: pre-wrap;
    }
    .cl-home__bullet-list {
      margin: 0 0 1rem;
      padding-left: 1.2rem;
      color: var(--cl-text-dim);
      line-height: 1.7;
    }
    .cl-home__text-link {
      color: var(--cl-primary-bright);
      font-family: var(--cl-font-mono);
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      text-decoration: none;
    }
    .cl-home__links {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem;
      margin-top: 1.25rem;
    }
    .cl-home__link-card {
      padding: 1.25rem;
      text-decoration: none;
      color: inherit;
      transition: transform 120ms, border-color 120ms;
    }
    .cl-home__link-card:hover {
      transform: translate(1px, 1px);
      border-color: var(--cl-primary);
    }
    @media (max-width: 960px) {
      .cl-home__hero,
      .cl-home__grid,
      .cl-home__links,
      .cl-home__stats {
        grid-template-columns: 1fr;
      }
    }
  </style>
</ClineLayout>
