---
import CodexLayout from "../../layouts/CodexLayout.astro";
import { getToolById, getToolReleases, formatDate, relativeTime } from "../../lib/releases";
import { marked } from "marked";

const tool = getToolById("codex-cli");
const data = await getToolReleases("codex-cli");
const releases = data?.releases || [];
const stableReleases = releases.filter((r) => !r.prerelease);
const latestStable = stableReleases[0];
const latestRelease = releases[0];
const latestForTldr = releases[0];
const restReleases = releases.slice(1);

const breakingCount = releases.filter((r) =>
  r.body?.toLowerCase().includes("breaking")
).length;

const displayVersion = latestStable?.version || latestRelease?.version || "—";
const lastUpdatedAgo = data?.lastUpdated ? relativeTime(data.lastUpdated) : null;

function isBreaking(body: string = ""): boolean {
  return body.toLowerCase().includes("breaking");
}

function renderBody(body: string): string {
  if (!body) return "";
  marked.setOptions({ gfm: true, breaks: false });
  let html = marked.parse(body) as string;
  html = html.replace(/<a href="(https:\/\/github\.com\/[^/]+\/[^/]+\/pull\/(\d+))"[^>]*>[^<]*<\/a>/g,
    '<a href="$1" target="_blank" rel="noopener noreferrer" class="cl-pr-link">#$2</a>');
  html = html.replace(/<a href="(https:\/\/github\.com\/[^/]+\/[^/]+\/issues\/(\d+))"[^>]*>[^<]*<\/a>/g,
    '<a href="$1" target="_blank" rel="noopener noreferrer" class="cl-pr-link">#$2</a>');
  html = html.replace(/ by <a href="https:\/\/github\.com\/[^"]*"[^>]*>@[^<]+<\/a> in /g, ' ');
  html = html.replace(/ by @[\w-]+ in /g, ' ');
  html = html.replace(/<li>(.*?)<\/li>/gs, (match, content) => {
    const text = content.toLowerCase();
    let badge = '';
    if (/^fix[\s(:]/.test(text)) badge = '<span class="cl-badge cl-badge-fix">FIX</span>';
    else if (/^feat[\s(:]/.test(text)) badge = '<span class="cl-badge cl-badge-feat">FEAT</span>';
    else if (/^docs[\s(:]/.test(text)) badge = '<span class="cl-badge cl-badge-docs">DOCS</span>';
    else if (/^test[\s(:]/.test(text)) badge = '<span class="cl-badge cl-badge-test">TEST</span>';
    else if (/^(refactor|chore)[\s(:]/.test(text)) badge = '<span class="cl-badge cl-badge-chore">CHORE</span>';
    else if (/^(ci|build|docker)[\s(:]/.test(text)) badge = '<span class="cl-badge cl-badge-ci">CI</span>';
    else if (/^(perf|style)[\s(:]/.test(text)) badge = '<span class="cl-badge cl-badge-perf">PERF</span>';
    return `<li>${badge}${content}</li>`;
  });
  return html;
}

function getTldr(body: string): string[] {
  if (!body) return [];
  const lines = body.split("\n").filter(Boolean);
  const bullets: string[] = [];
  for (const line of lines) {
    const match = line.match(/^[\*\-]\s+(.+)/);
    if (match) {
      let text = match[1]
        .replace(/\*\*([^*]+)\*\*/g, "$1")
        .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")
        .replace(/`([^`]+)`/g, "$1")
        .replace(/\s+by\s+@\S+\s+in\s+https:\/\/\S+/g, "")
        .trim();
      if (text.length > 10 && !text.startsWith("http") && !text.startsWith("@")) {
        if (text.length > 120) text = text.slice(0, 117) + "…";
        bullets.push(text);
      }
    }
  }
  return bullets.slice(0, 5);
}
---

<CodexLayout
  title="Codex CLI — changelogs.info"
  description="Track Codex CLI releases, breaking changes, and config updates. OpenAI's agentic coding CLI."
  currentPage="home"
>
  <!-- Dot grid -->
  <div class="cx-dotgrid" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -1; pointer-events: none; opacity: 0.3;"></div>

  <div style="max-width: 1100px; margin: 0 auto; padding: 2rem 1.5rem 0;">

    <!-- Hero -->
    <section class="cx-hero-section" style="margin-bottom: 3rem;">
      <div style="display: grid; grid-template-columns: 1fr auto; gap: 2.5rem; align-items: center;" class="cx-hero-grid">
        <!-- Left -->
        <div style="display: flex; flex-direction: column; gap: 1.25rem;">
          <div style="display: inline-flex; align-items: center; gap: 0.5rem; width: fit-content;">
            <span class="cx-pulse-dot" style="width: 8px; height: 8px; background: #33ff33; display: inline-block;"></span>
            <span style="font-family: var(--cx-font-mono); font-size: 0.65rem; color: var(--cx-text-muted); text-transform: uppercase; letter-spacing: 0.15em;">Tracking {releases.length} releases</span>
          </div>

          <h1 class="cx-headline cx-hero-title" style="font-size: clamp(3rem, 9vw, 5.5rem); font-weight: 900; color: var(--cx-text); text-transform: uppercase; line-height: 0.88; margin: 0; letter-spacing: -0.03em;">
            Codex<br><span style="color: var(--cx-primary-bright);">CLI</span>
          </h1>

          <p style="font-size: 1.05rem; color: var(--cx-text-dim); max-width: 28rem; line-height: 1.6; margin: 0; font-family: var(--cx-font-body);">
            {tool?.description || "OpenAI's agentic coding CLI — autonomous code editing, testing, and execution from the terminal."}
          </p>

          <div style="display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 0.5rem;">
            <a
              href={`https://github.com/${tool?.repo || "openai/codex"}`}
              target="_blank"
              rel="noopener noreferrer"
              class="cx-headline cx-cta-btn"
              style="background: var(--cx-primary); color: var(--cx-bg); font-weight: 900; padding: 0.75rem 1.75rem; font-size: 0.85rem; border: 4px solid var(--cx-border); box-shadow: var(--cx-shadow-sm); text-decoration: none; text-transform: uppercase; font-style: italic;"
            >
              GitHub ↗
            </a>
            <a
              href="/codex-cli/changelog/"
              class="cx-headline cx-cta-btn"
              style="background: transparent; color: var(--cx-text); font-weight: 900; padding: 0.75rem 1.75rem; font-size: 0.85rem; border: 4px solid var(--cx-border); box-shadow: var(--cx-shadow-sm); text-decoration: none; text-transform: uppercase; font-style: italic;"
            >
              Changelog
            </a>
          </div>
        </div>

        <!-- Right: terminal card -->
        <div class="cx-terminal-card" style="width: 320px; border: 4px solid var(--cx-border); box-shadow: var(--cx-shadow); flex-shrink: 0; overflow: hidden;">
          <div style="background: var(--cx-primary); padding: 0.5rem 0.75rem; display: flex; align-items: center; gap: 0.5rem;">
            <span style="font-family: var(--cx-font-mono); font-size: 0.6rem; color: var(--cx-bg); text-transform: uppercase; font-weight: 700;">$ codex --version</span>
          </div>
          <div style="background: var(--cx-bg); padding: 1rem; font-family: var(--cx-font-mono); font-size: 0.7rem; line-height: 1.8; color: var(--cx-text-dim);">
            <div><span style="color: var(--cx-primary-bright);">$</span> codex --full-auto "status"</div>
            <div style="margin-top: 0.5rem;">
              <span style="color: var(--cx-primary-bright);">&gt;</span> version: <span style="color: var(--cx-text);">{displayVersion}</span>
            </div>
            <div>
              <span style="color: #22c55e;">&gt;</span> releases: <span style="color: var(--cx-text);">{releases.length}</span> tracked
            </div>
            <div>
              <span style="color: {breakingCount > 0 ? 'var(--cx-primary-bright)' : '#22c55e'};">{breakingCount > 0 ? '!' : '>'}</span> breaking: <span style="color: {breakingCount > 0 ? 'var(--cx-primary-bright)' : 'var(--cx-text)'};">{breakingCount}</span>
            </div>
            <div>
              <span style="color: #22c55e;">&gt;</span> updated: <span style="color: var(--cx-text);">{lastUpdatedAgo || "now"}</span>
            </div>
            <div style="margin-top: 0.5rem; color: var(--cx-text-muted);">
              <span style="color: var(--cx-primary-bright);">$</span> <span class="cx-cursor">_</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats Bar -->
    <section class="cx-section-reveal" style="display: flex; flex-wrap: wrap; gap: 0; border: 4px solid var(--cx-border); margin-bottom: 3rem;">
      {[
        { label: "Releases", value: String(releases.length) },
        { label: "Breaking", value: String(breakingCount), warn: true },
        { label: "Stable", value: String(stableReleases.length) },
        { label: "Latest", value: displayVersion },
      ].map((stat, i) => (
        <div
          style={`flex: 1; min-width: 120px; padding: 1rem 1.25rem; ${i < 3 ? 'border-right: 4px solid var(--cx-border);' : ''} background: var(--cx-bg-card); cursor: crosshair;`}
          class="cx-stats-cell"
        >
          <span style="display: block; color: var(--cx-text-muted); font-family: var(--cx-font-headline); font-weight: 700; text-transform: uppercase; font-size: 0.55rem; letter-spacing: 0.15em; margin-bottom: 0.25rem;">{stat.label}</span>
          <span class="cx-headline" style={`display: block; font-size: 1.5rem; font-weight: 900; color: ${stat.warn ? 'var(--cx-primary-bright)' : 'var(--cx-text)'};`}>{stat.value}</span>
        </div>
      ))}
    </section>

    <!-- TL;DR -->
    {latestForTldr && (() => {
      const breaking = isBreaking(latestForTldr.body);
      const tldr = getTldr(latestForTldr.body || "");
      const fallback = (latestForTldr.body || "").split("\n").filter(l => l.trim() && !l.startsWith("#")).slice(0, 2).map(l => l.replace(/^[\*\-]\s+/, "").trim());
      const items = tldr.length > 0 ? tldr : fallback;
      const latestRendered = renderBody(latestForTldr.body || "");

      return (
        <section style="margin-bottom: 3rem;">
          <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem;">
            <h2 class="cx-headline" style="font-size: 2.5rem; font-weight: 900; color: var(--cx-text); text-transform: uppercase; font-style: italic; letter-spacing: -0.02em; margin: 0;">
              TL;DR
            </h2>
            <div style="flex: 1; height: 4px; background: var(--cx-border);"></div>
            <span style="font-family: var(--cx-font-mono); font-size: 0.7rem; color: var(--cx-text-muted); text-transform: uppercase;">Latest Release</span>
          </div>

          <div style={`padding: 1.5rem 2rem; border: 4px solid ${breaking ? 'var(--cx-primary)' : 'var(--cx-border)'}; background: ${breaking ? 'var(--cx-bg-surface)' : 'var(--cx-bg-card)'}; ${breaking ? 'border-left: 8px solid var(--cx-primary);' : ''} margin-bottom: 2rem;`}>
            <div style="display: flex; justify-content: space-between; align-items: center; gap: 1rem; margin-bottom: 1rem; flex-wrap: wrap;">
              <div style="display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap;">
                <span class="cx-headline" style="font-size: 1.3rem; font-weight: 900; color: var(--cx-text); text-transform: uppercase;">{latestForTldr.version}</span>
                {breaking && <span style="background: var(--cx-primary); color: var(--cx-bg); font-family: var(--cx-font-mono); padding: 0.15rem 0.5rem; font-size: 0.6rem; font-weight: 700; text-transform: uppercase;">BREAKING</span>}
                {latestForTldr.prerelease && <span style="background: rgba(51,255,51,0.12); color: #33ff33; font-family: var(--cx-font-mono); padding: 0.15rem 0.5rem; font-size: 0.6rem; font-weight: 700; text-transform: uppercase; border: 1px solid #33ff33;">PRE</span>}
              </div>
              <span style="font-family: var(--cx-font-mono); font-size: 0.7rem; color: var(--cx-text-muted); white-space: nowrap;">{formatDate(latestForTldr.date)}</span>
            </div>
            {items.length > 0 && (
              <ul style="list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.4rem;">
                {items.map((item) => (
                  <li style="display: flex; gap: 0.5rem; align-items: flex-start; font-family: var(--cx-font-body); font-size: 0.9rem; color: var(--cx-text-dim); line-height: 1.5;">
                    <span style="color: var(--cx-primary-bright); flex-shrink: 0; font-weight: 700;">&gt;</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            )}
          </div>

          <div style="padding: 2rem; border: 4px solid var(--cx-border); background: var(--cx-bg-surface);">
            <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 0.5rem;">
              <h3 class="cx-headline" style="font-size: 1.5rem; font-weight: 900; text-transform: uppercase; margin: 0; color: var(--cx-text);">
                {(latestForTldr.name || latestForTldr.version).replace(/^codex[\s-]cli\s+/i, "")}
              </h3>
              <a href={latestForTldr.url} target="_blank" rel="noopener noreferrer" class="cx-headline" style="font-size: 0.7rem; font-weight: 700; text-transform: uppercase; color: var(--cx-primary-bright); text-decoration: none;">↗ GitHub</a>
            </div>
            <div class="changelog-body" style="color: var(--cx-text-dim); font-size: 0.875rem; line-height: 1.7; font-family: var(--cx-font-body);" set:html={latestRendered} />
          </div>
        </section>
      );
    })()}

    <!-- Previous Releases -->
    <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 2rem;">
      <div style="flex: 1; height: 4px; background: var(--cx-border);"></div>
      <span class="cx-headline" style="font-size: 0.75rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.15em; color: var(--cx-text-muted);">Previous Releases</span>
      <div style="flex: 1; height: 4px; background: var(--cx-border);"></div>
    </div>

    <section style="margin-bottom: 4rem; display: flex; flex-direction: column; gap: 1.25rem;">
      {restReleases.slice(0, 3).map((release) => {
        const breaking = isBreaking(release.body);
        const renderedBody = renderBody(release.body || "");
        const isLong = (release.body || "").length > 600;
        return (
          <div style={`padding: 1.5rem 2rem; border: 4px solid ${breaking ? 'var(--cx-primary)' : 'var(--cx-border)'}; background: ${breaking ? 'var(--cx-bg-surface)' : 'var(--cx-bg-card)'}; ${breaking ? 'border-left: 8px solid var(--cx-primary);' : ''}`}>
            <div style="display: flex; justify-content: space-between; align-items: center; gap: 1rem; margin-bottom: 0.75rem; flex-wrap: wrap;">
              <div style="display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap;">
                <span class="cx-headline" style="font-size: 1.25rem; font-weight: 900; color: var(--cx-text); text-transform: uppercase;">{release.version}</span>
                <span class="cx-headline" style="font-size: 0.75rem; font-weight: 700; color: var(--cx-text-dim);">{(release.name || "").replace(/^codex[\s-]cli\s+/i, "")}</span>
                {breaking && <span style="background: var(--cx-primary); color: var(--cx-bg); font-family: var(--cx-font-mono); padding: 0.15rem 0.5rem; font-size: 0.6rem; font-weight: 700; text-transform: uppercase;">BREAKING</span>}
              </div>
              <span style="font-family: var(--cx-font-mono); font-size: 0.7rem; color: var(--cx-text-muted); white-space: nowrap;">{formatDate(release.date)}</span>
            </div>
            <div
              class={`changelog-body ${isLong ? 'cl-collapsed' : ''}`}
              style="color: var(--cx-text-dim); font-size: 0.85rem; line-height: 1.7; font-family: var(--cx-font-body); overflow: hidden; position: relative;"
              set:html={renderedBody}
            />
            {isLong && (
              <button
                class="cl-expand-btn cx-headline"
                style="display: block; margin-top: 0.75rem; background: transparent; border: 2px solid var(--cx-border); color: var(--cx-text); padding: 0.4rem 1rem; font-size: 0.65rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.1em; cursor: pointer; transition: background 100ms;"
                onclick="this.previousElementSibling.classList.toggle('cl-collapsed'); this.textContent = this.textContent.includes('EXPAND') ? '▲ COLLAPSE' : '▼ EXPAND'"
              >
                ▼ EXPAND
              </button>
            )}
          </div>
        );
      })}
      <a
        href="/codex-cli/changelog/"
        class="cx-headline"
        style="display: inline-flex; align-items: center; gap: 0.5rem; font-weight: 900; text-transform: uppercase; color: var(--cx-primary-bright); font-style: italic; text-decoration: none; border-bottom: 2px solid var(--cx-primary-bright); padding-bottom: 2px; font-size: 0.85rem; align-self: flex-start;"
      >
        View all {releases.length} releases →
      </a>
    </section>

    <!-- Quick Links -->
    <section style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin-bottom: 4rem;">
      {[
        { href: "/codex-cli/changelog/", icon: "📋", label: "Full Changelog", sub: `${releases.length} releases` },
        { href: "/codex-cli/cheatsheet/", icon: "⚡", label: "Cheatsheet", sub: "Commands & flags" },
        { href: "/codex-cli/releases/", icon: "📦", label: "All Releases", sub: "Browse & filter" },
        { href: "/feed/all.xml", icon: "📡", label: "RSS Feed", sub: "Subscribe to updates" },
      ].map((link) => (
        <a href={link.href} class="cx-quick-link" style="display: flex; align-items: center; gap: 0.75rem; padding: 1.25rem; border: 4px solid var(--cx-border); background: var(--cx-bg-card); text-decoration: none;">
          <span style="font-size: 1.5rem;">{link.icon}</span>
          <div>
            <span class="cx-headline" style="display: block; font-weight: 900; font-size: 0.85rem; color: var(--cx-text); text-transform: uppercase;">{link.label}</span>
            <span style="font-family: var(--cx-font-mono); font-size: 0.65rem; color: var(--cx-text-muted);">{link.sub}</span>
          </div>
        </a>
      ))}
    </section>

    <!-- Subscribe -->
    <section style="margin-bottom: 5rem; text-align: center; padding: 3rem 2rem; border: 4px solid var(--cx-border); background: var(--cx-bg-surface);">
      <h2 class="cx-headline" style="font-size: 2rem; font-weight: 900; text-transform: uppercase; font-style: italic; letter-spacing: -0.02em; margin: 0 0 0.75rem; color: var(--cx-text);">
        Stay in the Loop
      </h2>
      <p style="font-family: var(--cx-font-body); font-size: 0.95rem; color: var(--cx-text-dim); margin: 0 0 2rem; max-width: 480px; margin-left: auto; margin-right: auto; line-height: 1.5;">
        Get notified when Codex CLI ships new releases. No spam — just changelogs.
      </p>
      <div style="display: flex; flex-wrap: wrap; gap: 1rem; justify-content: center; align-items: center; max-width: 500px; margin: 0 auto 1.5rem;">
        <input
          type="email"
          placeholder="you@example.com"
          style="flex: 1; min-width: 220px; padding: 0.85rem 1rem; border: 4px solid var(--cx-border); background: var(--cx-bg); color: var(--cx-text); font-family: var(--cx-font-mono); font-size: 0.85rem; outline: none; transition: border-color 150ms;"
          onfocus="this.style.borderColor='var(--cx-primary)'"
          onblur="this.style.borderColor='var(--cx-border)'"
        />
        <button
          class="cx-headline"
          style="background: var(--cx-primary); color: var(--cx-bg); font-weight: 900; padding: 0.85rem 1.75rem; font-size: 0.85rem; border: 4px solid var(--cx-border); box-shadow: var(--cx-shadow-sm); cursor: pointer; text-transform: uppercase; font-style: italic; transition: transform 100ms;"
        >
          Subscribe
        </button>
      </div>
      <div style="display: flex; gap: 2rem; justify-content: center; flex-wrap: wrap;">
        <a href="/feed/all.xml" style="font-family: var(--cx-font-mono); font-size: 0.75rem; color: var(--cx-text-dim); text-decoration: none;">📡 RSS Feed</a>
        <a href={`https://github.com/${tool?.repo || "openai/codex"}`} target="_blank" rel="noopener noreferrer" style="font-family: var(--cx-font-mono); font-size: 0.75rem; color: var(--cx-text-dim); text-decoration: none;">⭐ Star on GitHub</a>
      </div>
    </section>
  </div>
</CodexLayout>
