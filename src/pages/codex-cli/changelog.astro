---
import CodexLayout from "../../layouts/CodexLayout.astro";
import { getToolReleases, formatDate } from "../../lib/releases";
import { marked } from "marked";

const data = await getToolReleases("codex-cli");
const releases = data?.releases || [];

function isBreaking(body: string = ""): boolean {
  return body.toLowerCase().includes("breaking");
}

function renderBody(body: string): string {
  if (!body) return "";
  marked.setOptions({ gfm: true, breaks: false });
  let html = marked.parse(body) as string;
  html = html.replace(/<a href="(https:\/\/github\.com\/[^/]+\/[^/]+\/pull\/(\d+))"[^>]*>[^<]*<\/a>/g,
    '<a href="$1" target="_blank" rel="noopener noreferrer" class="cl-pr-link">#$2</a>');
  html = html.replace(/<a href="(https:\/\/github\.com\/[^/]+\/[^/]+\/issues\/(\d+))"[^>]*>[^<]*<\/a>/g,
    '<a href="$1" target="_blank" rel="noopener noreferrer" class="cl-pr-link">#$2</a>');
  html = html.replace(/ by <a href="https:\/\/github\.com\/[^"]*"[^>]*>@[^<]+<\/a> in /g, ' ');
  html = html.replace(/ by @[\w-]+ in /g, ' ');
  html = html.replace(/<li>(.*?)<\/li>/gs, (match, content) => {
    const text = content.toLowerCase();
    let badge = '';
    if (/^fix[\s(:]/.test(text)) badge = '<span class="cl-badge cl-badge-fix">FIX</span>';
    else if (/^feat[\s(:]/.test(text)) badge = '<span class="cl-badge cl-badge-feat">FEAT</span>';
    else if (/^docs[\s(:]/.test(text)) badge = '<span class="cl-badge cl-badge-docs">DOCS</span>';
    else if (/^test[\s(:]/.test(text)) badge = '<span class="cl-badge cl-badge-test">TEST</span>';
    else if (/^(refactor|chore)[\s(:]/.test(text)) badge = '<span class="cl-badge cl-badge-chore">CHORE</span>';
    else if (/^(ci|build|docker)[\s(:]/.test(text)) badge = '<span class="cl-badge cl-badge-ci">CI</span>';
    else if (/^(perf|style)[\s(:]/.test(text)) badge = '<span class="cl-badge cl-badge-perf">PERF</span>';
    return `<li>${badge}${content}</li>`;
  });
  return html;
}
---

<CodexLayout
  title="Codex CLI Changelog — changelogs.info"
  description="Full changelog for Codex CLI. Every release, every breaking change, every fix."
  currentPage="changelog"
>
  <div style="max-width: 1280px; margin: 0 auto; padding: 2rem 1.5rem 0;">

    <section style="margin-bottom: 4rem;">
      <h1
        class="cx-headline"
        style="font-size: clamp(3.5rem, 10vw, 7rem); font-weight: 900; text-transform: uppercase; font-style: italic; letter-spacing: -0.03em; line-height: 0.9; margin: 0 0 1.5rem; color: var(--cx-text);"
      >
        Changelog
      </h1>
      <div style="display: flex; flex-wrap: wrap; gap: 2rem; align-items: flex-end; justify-content: space-between;">
        <p style="font-family: var(--cx-font-body); font-size: 1.1rem; max-width: 32rem; color: var(--cx-text-dim); line-height: 1.6; margin: 0; text-transform: uppercase; letter-spacing: 0.05em;">
          Every Codex CLI release. Straight to the terminal record.
        </p>
        <div style="width: 100%; max-width: 320px;">
          <label class="cx-headline" style="display: block; font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.15em; color: var(--cx-primary-bright); margin-bottom: 0.5rem;">
            Filter updates
          </label>
          <div style="position: relative;">
            <input
              id="cl-search"
              type="text"
              placeholder="SEARCH RELEASES..."
              style="width: 100%; background: var(--cx-bg); border: 4px solid var(--cx-border); padding: 1rem; font-family: var(--cx-font-mono); font-weight: 700; text-transform: uppercase; color: var(--cx-text); font-size: 0.85rem; outline: none; box-shadow: var(--cx-shadow); transition: border-color 100ms;"
              onfocus="this.style.borderColor='var(--cx-primary-bright)'"
              onblur="this.style.borderColor='var(--cx-border)'"
            />
            <span style="position: absolute; right: 1rem; top: 50%; transform: translateY(-50%); color: var(--cx-text-muted); font-size: 1rem;">⌕</span>
          </div>
          <div style="display: flex; gap: 0.5rem; margin-top: 0.75rem;">
            {["stable", "breaking", "prerelease"].map((f) => (
              <button
                id={`cl-filter-${f}`}
                class="cx-headline"
                data-filter={f}
                style="background: transparent; border: 2px solid var(--cx-border-dim); padding: 0.3rem 0.75rem; font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--cx-text-muted); cursor: pointer; transition: all 100ms;"
              >
                {f === "prerelease" ? "Pre" : f.charAt(0).toUpperCase() + f.slice(1)}
              </button>
            ))}
          </div>
        </div>
      </div>
    </section>

    {releases.length > 0 ? (
      <div id="cl-releases-list" style="position: relative; padding-left: 3rem; border-left: 6px solid var(--cx-border);">
        {releases.map((release, idx) => {
          const breaking = isBreaking(release.body);
          const renderedBody = renderBody(release.body || "");
          const isLong = (release.body || "").length > 600;

          return (
            <article
              class="cl-entry"
              data-version={release.version.toLowerCase()}
              data-name={(release.name || "").toLowerCase()}
              data-body={(release.body || "").toLowerCase().slice(0, 800)}
              data-prerelease={String(release.prerelease)}
              data-breaking={String(breaking)}
              data-index={idx}
              style={`position: relative; margin-bottom: 5rem; ${idx >= 10 ? 'display: none;' : ''}`}
            >
              <div style={`position: absolute; left: -3.9rem; top: 0.5rem; width: 3rem; height: 3rem; border: 4px solid var(--cx-border); display: flex; align-items: center; justify-content: center; background: ${breaking ? 'var(--cx-primary)' : 'var(--cx-bg-card)'};`}>
                <span style={`font-family: var(--cx-font-mono); font-size: 0.75rem; color: ${breaking ? 'var(--cx-bg)' : 'var(--cx-primary-bright)'};`}>
                  {breaking ? "!" : release.prerelease ? "β" : "$"}
                </span>
              </div>

              <div style="display: flex; flex-wrap: wrap; gap: 1rem; align-items: baseline; margin-bottom: 1rem;">
                <span class="cx-headline" style="font-size: 2.25rem; font-weight: 900; font-style: italic; letter-spacing: -0.02em; color: var(--cx-text);">
                  {release.version}
                </span>
                <span style="font-family: var(--cx-font-mono); font-size: 0.85rem; font-weight: 700; text-transform: uppercase; color: var(--cx-text-muted);">
                  {formatDate(release.date)}
                </span>
                {breaking && (
                  <span style="background: var(--cx-primary); color: var(--cx-bg); padding: 0.2rem 0.75rem; font-family: var(--cx-font-mono); font-size: 0.7rem; font-weight: 900; text-transform: uppercase; border: 2px solid var(--cx-border);">
                    BREAKING
                  </span>
                )}
                {release.prerelease && (
                  <span style="background: rgba(51,255,51,0.1); color: #33ff33; padding: 0.2rem 0.75rem; font-family: var(--cx-font-mono); font-size: 0.7rem; font-weight: 900; text-transform: uppercase; border: 2px solid #33ff33;">
                    PRE-RELEASE
                  </span>
                )}
              </div>

              <div style={`padding: 2rem; border: 4px solid var(--cx-border); background: ${breaking ? 'rgba(51,255,51,0.04)' : 'var(--cx-bg-surface)'}; ${breaking ? 'border-left: 8px solid var(--cx-primary);' : ''}`}>
                <h3 class="cx-headline" style="font-size: 1.5rem; font-weight: 900; text-transform: uppercase; margin: 0 0 1.5rem; color: var(--cx-text);">
                  {(release.name || release.version).replace(/^codex[\s-]cli\s+/i, "")}
                </h3>

                <div
                  class={`changelog-body ${isLong && idx > 0 ? 'cl-collapsed' : ''}`}
                  style="color: var(--cx-text-dim); font-size: 0.875rem; line-height: 1.7; font-family: var(--cx-font-body); overflow: hidden; position: relative;"
                  set:html={renderedBody}
                />

                {isLong && (
                  <button
                    class="cl-expand-btn cx-headline"
                    style="display: block; margin-top: 1rem; background: transparent; border: 2px solid var(--cx-border); color: var(--cx-text); padding: 0.5rem 1.25rem; font-size: 0.7rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.1em; cursor: pointer; transition: background 100ms;"
                    onclick="this.previousElementSibling.classList.toggle('cl-collapsed'); this.textContent = this.textContent.includes('EXPAND') ? '▲ COLLAPSE' : '▼ EXPAND FULL CHANGELOG'"
                  >
                    {idx === 0 ? '▲ COLLAPSE' : '▼ EXPAND FULL CHANGELOG'}
                  </button>
                )}

                <div style="display: flex; justify-content: flex-end; margin-top: 1rem; padding-top: 0.75rem; border-top: 1px solid var(--cx-border-dim);">
                  <a
                    href={release.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    style="font-family: var(--cx-font-mono); font-size: 0.65rem; color: var(--cx-text-muted); text-decoration: none; text-transform: uppercase; letter-spacing: 0.1em; transition: color 150ms;"
                    onmouseover="this.style.color='var(--cx-primary-bright)'"
                    onmouseout="this.style.color='var(--cx-text-muted)'"
                  >
                    ↗ GitHub
                  </a>
                </div>
              </div>
            </article>
          );
        })}

        {releases.length > 10 && (
          <div style="margin-bottom: 4rem;">
            <button
              id="cl-load-more"
              class="cx-headline"
              style="background: transparent; border: 4px solid var(--cx-border); color: var(--cx-text); padding: 1rem 2.5rem; font-size: 0.85rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.1em; cursor: pointer; font-style: italic; transition: background 100ms;"
              onmouseover="this.style.background='rgba(51,255,51,0.1)'"
              onmouseout="this.style.background='transparent'"
            >
              Load {releases.length - 10} More Releases ▼
            </button>
          </div>
        )}
      </div>
    ) : (
      <div style="padding: 4rem 2rem; border: 4px dashed var(--cx-border-dim); text-align: center;">
        <p style="font-family: var(--cx-font-mono); color: var(--cx-text-muted);">$ no releases tracked yet</p>
      </div>
    )}

    <button
      id="cl-scroll-top"
      style="position: fixed; bottom: 2rem; right: 2rem; background: var(--cx-primary); color: var(--cx-bg); border: 4px solid var(--cx-border); padding: 0.75rem; cursor: pointer; font-size: 1rem; box-shadow: var(--cx-shadow); opacity: 0; pointer-events: none; transition: opacity 200ms; z-index: 50; font-family: var(--cx-font-mono);"
      onclick="window.scrollTo({top: 0, behavior: 'smooth'})"
    >↑</button>
  </div>

  <script>
    const entries = Array.from(document.querySelectorAll('.cl-entry')) as HTMLElement[];
    const searchInput = document.getElementById('cl-search') as HTMLInputElement;
    const stableBtn = document.getElementById('cl-filter-stable');
    const breakingBtn = document.getElementById('cl-filter-breaking');
    const prereleaseBtn = document.getElementById('cl-filter-prerelease');
    const scrollTopBtn = document.getElementById('cl-scroll-top');

    let activeFilter = '';
    let searchQuery = '';
    let allLoaded = entries.length <= 10;

    function filterEntries() {
      entries.forEach((entry, idx) => {
        const version = entry.dataset.version || '';
        const name = entry.dataset.name || '';
        const body = entry.dataset.body || '';
        const prerelease = entry.dataset.prerelease === 'true';
        const breaking = entry.dataset.breaking === 'true';

        const matchesSearch = !searchQuery || version.includes(searchQuery) || name.includes(searchQuery) || body.includes(searchQuery);
        const matchesFilter = activeFilter === '' ||
          (activeFilter === 'stable' && !prerelease) ||
          (activeFilter === 'breaking' && breaking) ||
          (activeFilter === 'prerelease' && prerelease);
        const withinLoadLimit = allLoaded || idx < 10;

        entry.style.display = (matchesSearch && matchesFilter && withinLoadLimit) ? '' : 'none';
      });
    }

    searchInput?.addEventListener('input', () => {
      searchQuery = searchInput.value.toLowerCase().trim();
      if (searchQuery) allLoaded = true;
      filterEntries();
    });

    function resetBtns() {
      [stableBtn, breakingBtn, prereleaseBtn].forEach(btn => {
        if (btn) {
          (btn as HTMLElement).style.background = 'transparent';
          (btn as HTMLElement).style.borderColor = 'var(--cx-border-dim)';
          (btn as HTMLElement).style.color = 'var(--cx-text-muted)';
        }
      });
    }

    [stableBtn, breakingBtn, prereleaseBtn].forEach(btn => {
      btn?.addEventListener('click', () => {
        const f = (btn as HTMLElement).getAttribute('data-filter') || '';
        if (activeFilter === f) { activeFilter = ''; resetBtns(); }
        else {
          activeFilter = f;
          resetBtns();
          (btn as HTMLElement).style.background = 'var(--cx-primary)';
          (btn as HTMLElement).style.borderColor = 'var(--cx-primary)';
          (btn as HTMLElement).style.color = 'var(--cx-bg)';
        }
        filterEntries();
      });
    });

    document.getElementById('cl-load-more')?.addEventListener('click', function() {
      allLoaded = true;
      this.style.display = 'none';
      filterEntries();
    });

    window.addEventListener('scroll', () => {
      if (scrollTopBtn) {
        scrollTopBtn.style.opacity = window.scrollY > 400 ? '1' : '0';
        scrollTopBtn.style.pointerEvents = window.scrollY > 400 ? 'auto' : 'none';
      }
    }, { passive: true });
  </script>
</CodexLayout>
