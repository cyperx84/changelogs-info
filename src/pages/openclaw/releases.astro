---
import SectionLayout from "../../layouts/SectionLayout.astro";
import ReleaseCard from "../../components/ReleaseCard.astro";
import { getSectionById } from "../../lib/sections";
import { getToolReleases } from "../../lib/releases";

const section = getSectionById("openclaw")!;
const data = await getToolReleases("openclaw");
const releases = data?.releases || [];
---

<SectionLayout
  section={section}
  title="OpenClaw Releases — changelogs.info"
  description="All OpenClaw releases."
  showHero={false}
>
  <div class="mx-auto max-w-4xl px-4 py-8 sm:px-6 sm:py-12">
    <div class="mb-8 flex flex-wrap items-center justify-between gap-3">
      <h1 class="font-mono text-2xl font-bold" style={`color: ${section.color};`}>
        <span style={`color: ${section.color};`}>/</span>releases
      </h1>
      <span class="font-mono text-xs text-text-muted">{releases.length} releases</span>
    </div>

    {releases.length > 0 ? (
      <div class="space-y-4">
        {releases.map((release) => (
          <ReleaseCard
            release={release}
            sectionColor={section.color}
            sectionRgb={section.colorRgb}
            toolId={section.id}
          />
        ))}
      </div>
    ) : (
      <div class="rounded-lg border border-dashed border-border bg-bg-card p-8 text-center">
        <p class="font-mono text-sm text-text-muted">&gt; no releases tracked yet.</p>
      </div>
    )}
  </div>
</SectionLayout>
