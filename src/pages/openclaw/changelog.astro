---
import OpenClawLayout from "../../layouts/OpenClawLayout.astro";
import { getToolReleases, formatDate } from "../../lib/releases";
import { marked } from "marked";

const data = await getToolReleases("openclaw");
const releases = data?.releases || [];

function isBreaking(body: string = ""): boolean {
  return body.toLowerCase().includes("breaking");
}

function renderBody(body: string): string {
  if (!body) return "";
  // Configure marked for release notes
  marked.setOptions({
    gfm: true,
    breaks: false,
  });
  return marked.parse(body) as string;
}
---

<OpenClawLayout
  title="OpenClaw Changelog — changelogs.info"
  description="Full changelog for OpenClaw. Every release, every breaking change, every fix."
  currentPage="changelog"
>
  <div style="max-width: 1280px; margin: 0 auto; padding: 2rem 1.5rem 0;">

    <!-- Hero -->
    <section style="margin-bottom: 4rem;">
      <h1
        class="oc-headline"
        style="font-size: clamp(3.5rem, 10vw, 7rem); font-weight: 900; text-transform: uppercase; font-style: italic; letter-spacing: -0.03em; line-height: 0.9; margin: 0 0 1.5rem; color: var(--oc-text);"
      >
        Changelog
      </h1>
      <div style="display: flex; flex-wrap: wrap; gap: 2rem; align-items: flex-end; justify-content: space-between;">
        <p style="font-family: var(--oc-font-body); font-size: 1.1rem; max-width: 32rem; color: var(--oc-text-dim); line-height: 1.6; margin: 0; text-transform: uppercase; letter-spacing: 0.05em;">
          Every OpenClaw release. Bolted straight to the record.
        </p>
        <!-- Search -->
        <div style="width: 100%; max-width: 320px;">
          <label class="oc-headline" style="display: block; font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.15em; color: var(--oc-primary-bright); margin-bottom: 0.5rem;">
            Filter updates
          </label>
          <div style="position: relative;">
            <input
              id="cl-search"
              type="text"
              placeholder="SEARCH RELEASES..."
              style="width: 100%; background: var(--oc-bg); border: 4px solid var(--oc-border); padding: 1rem; font-family: var(--oc-font-headline); font-weight: 700; text-transform: uppercase; color: var(--oc-text); font-size: 0.85rem; outline: none; box-shadow: var(--oc-shadow); transition: border-color 100ms;"
              onfocus="this.style.borderColor='var(--oc-primary-bright)'"
              onblur="this.style.borderColor='var(--oc-border)'"
            />
            <span style="position: absolute; right: 1rem; top: 50%; transform: translateY(-50%); color: var(--oc-text-muted); font-size: 1rem;">⌕</span>
          </div>
          <!-- Filter pills -->
          <div style="display: flex; gap: 0.5rem; margin-top: 0.75rem;">
            <button
              id="cl-filter-stable"
              class="oc-headline"
              data-filter="stable"
              style="background: transparent; border: 2px solid var(--oc-border-dim); padding: 0.3rem 0.75rem; font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--oc-text-muted); cursor: pointer; transition: all 100ms;"
            >
              Stable
            </button>
            <button
              id="cl-filter-breaking"
              class="oc-headline"
              data-filter="breaking"
              style="background: transparent; border: 2px solid var(--oc-border-dim); padding: 0.3rem 0.75rem; font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--oc-text-muted); cursor: pointer; transition: all 100ms;"
            >
              Breaking
            </button>
            <button
              id="cl-filter-prerelease"
              class="oc-headline"
              data-filter="prerelease"
              style="background: transparent; border: 2px solid var(--oc-border-dim); padding: 0.3rem 0.75rem; font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--oc-text-muted); cursor: pointer; transition: all 100ms;"
            >
              Pre-release
            </button>
          </div>
        </div>
      </div>
    </section>

    <!-- Timeline -->
    {releases.length > 0 ? (
      <div
        id="cl-releases-list"
        style="position: relative; padding-left: 3rem; border-left: 6px solid var(--oc-border);"
      >
        {releases.map((release, idx) => {
          const breaking = isBreaking(release.body);
          const renderedBody = renderBody(release.body || "");
          const isLong = (release.body || "").length > 600;

          return (
            <article
              class="cl-entry"
              data-version={release.version.toLowerCase()}
              data-name={(release.name || "").toLowerCase()}
              data-body={(release.body || "").toLowerCase().slice(0, 800)}
              data-prerelease={String(release.prerelease)}
              data-breaking={String(breaking)}
              style="position: relative; margin-bottom: 5rem;"
            >
              <!-- Timeline dot -->
              <div
                style={`position: absolute; left: -3.9rem; top: 0.5rem; width: 3rem; height: 3rem; border: 4px solid var(--oc-border); display: flex; align-items: center; justify-content: center; background: ${breaking ? 'var(--oc-primary)' : 'white'};`}
              >
                <span style={`font-size: 0.8rem; ${breaking ? 'color:white;' : 'color:black;'}`}>
                  {breaking ? "⚡" : release.prerelease ? "β" : "●"}
                </span>
              </div>

              <!-- Entry header -->
              <div style="display: flex; flex-wrap: wrap; gap: 1rem; align-items: baseline; margin-bottom: 1rem;">
                <span
                  class="oc-headline"
                  style="font-size: 2.25rem; font-weight: 900; font-style: italic; letter-spacing: -0.02em; color: var(--oc-text);"
                >
                  {release.version}
                </span>
                <span
                  class="oc-headline"
                  style="font-size: 1rem; font-weight: 700; text-transform: uppercase; color: var(--oc-text-muted); letter-spacing: 0.05em;"
                >
                  {formatDate(release.date)}
                </span>
                {breaking && (
                  <span style="background: var(--oc-primary); color: var(--oc-text); padding: 0.2rem 0.75rem; font-family: var(--oc-font-headline); font-size: 0.7rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.1em; border: 2px solid var(--oc-border);">
                    BREAKING
                  </span>
                )}
                {release.prerelease && (
                  <span style="background: rgba(255,184,0,0.15); color: #ffb800; padding: 0.2rem 0.75rem; font-family: var(--oc-font-headline); font-size: 0.7rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.1em; border: 2px solid #ffb800;">
                    PRE-RELEASE
                  </span>
                )}
              </div>

              <!-- Entry card -->
              <div
                style={`padding: 2rem; border: 4px solid var(--oc-border); background: ${breaking ? 'var(--oc-border)' : 'var(--oc-bg-surface)'}; ${breaking ? 'border-right: 8px solid var(--oc-primary); border-bottom: 8px solid var(--oc-primary);' : ''}`}
              >
                <!-- Release name -->
                <h3
                  class="oc-headline"
                  style={`font-size: 1.5rem; font-weight: 900; text-transform: uppercase; margin: 0 0 1.5rem; letter-spacing: -0.01em; color: ${breaking ? 'var(--oc-bg)' : 'var(--oc-text)'};`}
                >
                  {(release.name || release.version).replace(/^openclaw\s+/i, "")}
                </h3>

                <!-- Full rendered body -->
                <div
                  class={`changelog-body ${isLong ? 'cl-collapsed' : ''}`}
                  style={`color: ${breaking ? 'var(--oc-bg)' : 'var(--oc-text-dim)'}; font-size: 0.875rem; line-height: 1.7; font-family: var(--oc-font-body); overflow: hidden; position: relative;`}
                  set:html={renderedBody}
                />

                {isLong && (
                  <button
                    class="cl-expand-btn oc-headline"
                    style={`display: block; margin-top: 1rem; background: transparent; border: 2px solid ${breaking ? 'var(--oc-bg)' : 'var(--oc-border)'}; color: ${breaking ? 'var(--oc-bg)' : 'var(--oc-text)'}; padding: 0.5rem 1.25rem; font-size: 0.7rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.1em; cursor: pointer; transition: background 100ms;`}
                    onclick="this.previousElementSibling.classList.toggle('cl-collapsed'); this.textContent = this.textContent.includes('EXPAND') ? '▲ COLLAPSE' : '▼ EXPAND FULL CHANGELOG'"
                  >
                    ▼ EXPAND FULL CHANGELOG
                  </button>
                )}

                <!-- Footer -->
                <div style={`display: flex; justify-content: space-between; align-items: center; margin-top: 1.5rem; padding-top: 1rem; border-top: 2px solid var(--oc-border-dim);`}>
                  <a
                    href={release.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="oc-headline"
                    style={`display: inline-flex; align-items: center; gap: 0.5rem; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; color: ${breaking ? 'var(--oc-primary)' : 'var(--oc-primary-bright)'}; text-decoration: none; transition: opacity 150ms;`}
                    onmouseover="this.style.opacity='0.7'"
                    onmouseout="this.style.opacity='1'"
                  >
                    ↗ View on GitHub
                  </a>
                  <span style={`font-family: var(--oc-font-mono); font-size: 0.65rem; color: var(--oc-text-muted);`}>
                    #{idx + 1}
                  </span>
                </div>
              </div>
            </article>
          );
        })}

        <!-- Empty state -->
        <div id="cl-empty" style="display: none; padding: 3rem; border: 4px dashed var(--oc-border-dim); text-align: center;">
          <p class="oc-headline" style="font-weight: 700; text-transform: uppercase; color: var(--oc-text-muted);">
            No releases match your filter.
          </p>
        </div>
      </div>
    ) : (
      <div style="padding: 3rem; border: 4px dashed var(--oc-border-dim); text-align: center;">
        <p class="oc-headline" style="font-weight: 700; text-transform: uppercase; color: var(--oc-text-muted);">
          No releases tracked yet.
        </p>
      </div>
    )}

    <!-- Scroll to top FAB -->
    <button
      id="cl-scroll-top"
      style="position: fixed; bottom: 2rem; right: 2rem; z-index: 60; background: var(--oc-border); color: var(--oc-bg); padding: 1rem; border: 4px solid var(--oc-border); box-shadow: 6px 6px 0px 0px rgba(235,0,0,1); cursor: pointer; transition: transform 100ms, box-shadow 100ms; font-size: 1.25rem; opacity: 0; pointer-events: none; transition: opacity 200ms, transform 100ms, box-shadow 100ms;"
      aria-label="Scroll to top"
      onmouseover="this.style.transform='translate(2px,2px)';this.style.boxShadow='none'"
      onmouseout="this.style.transform='';this.style.boxShadow='6px 6px 0px 0px rgba(235,0,0,1)'"
      onclick="window.scrollTo({top:0,behavior:'smooth'})"
    >
      ↑
    </button>
  </div>

  <script>
    const search = document.getElementById("cl-search") as HTMLInputElement;
    const entries = document.querySelectorAll<HTMLElement>(".cl-entry");
    const emptyState = document.getElementById("cl-empty");
    const stableBtn = document.getElementById("cl-filter-stable");
    const breakingBtn = document.getElementById("cl-filter-breaking");
    const prereleaseBtn = document.getElementById("cl-filter-prerelease");
    const scrollTopBtn = document.getElementById("cl-scroll-top");
    let activeFilter = "";

    function filterEntries() {
      const query = (search?.value || "").toLowerCase().trim();
      let visible = 0;

      entries.forEach((el) => {
        const version = el.dataset.version || "";
        const name = el.dataset.name || "";
        const body = el.dataset.body || "";
        const prerelease = el.dataset.prerelease === "true";
        const breaking = el.dataset.breaking === "true";

        const textMatch =
          !query ||
          version.includes(query) ||
          name.includes(query) ||
          body.includes(query);

        let filterMatch = true;
        if (activeFilter === "stable") filterMatch = !prerelease;
        if (activeFilter === "breaking") filterMatch = breaking;
        if (activeFilter === "prerelease") filterMatch = prerelease;

        const show = textMatch && filterMatch;
        el.style.display = show ? "" : "none";
        if (show) visible++;
      });

      if (emptyState) emptyState.style.display = visible === 0 ? "block" : "none";
    }

    search?.addEventListener("input", filterEntries);

    function resetFilterBtns() {
      [stableBtn, breakingBtn, prereleaseBtn].forEach((btn) => {
        if (btn) {
          (btn as HTMLElement).style.background = "transparent";
          (btn as HTMLElement).style.borderColor = "var(--oc-border-dim)";
          (btn as HTMLElement).style.color = "var(--oc-text-muted)";
        }
      });
    }

    function activateBtn(btn: HTMLElement | null) {
      if (btn) {
        btn.style.background = "var(--oc-primary)";
        btn.style.borderColor = "var(--oc-primary)";
        btn.style.color = "white";
      }
    }

    [stableBtn, breakingBtn, prereleaseBtn].forEach((btn) => {
      btn?.addEventListener("click", () => {
        const f = btn.getAttribute("data-filter") || "";
        if (activeFilter === f) {
          activeFilter = "";
          resetFilterBtns();
        } else {
          activeFilter = f;
          resetFilterBtns();
          activateBtn(btn as HTMLElement);
        }
        filterEntries();
      });
    });

    // Scroll to top button
    window.addEventListener("scroll", () => {
      if (scrollTopBtn) {
        if (window.scrollY > 400) {
          scrollTopBtn.style.opacity = "1";
          scrollTopBtn.style.pointerEvents = "auto";
        } else {
          scrollTopBtn.style.opacity = "0";
          scrollTopBtn.style.pointerEvents = "none";
        }
      }
    }, { passive: true });
  </script>
</OpenClawLayout>
