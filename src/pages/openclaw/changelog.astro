---
import OpenClawLayout from "../../layouts/OpenClawLayout.astro";
import { getToolReleases, formatDate } from "../../lib/releases";
import { marked } from "marked";

const data = await getToolReleases("openclaw");
const releases = data?.releases || [];

function isBreaking(body: string = ""): boolean {
  return body.toLowerCase().includes("breaking");
}

function renderBody(body: string): string {
  if (!body) return "";
  marked.setOptions({ gfm: true, breaks: false });
  let html = marked.parse(body) as string;
  // Shorten GitHub PR/issue links: full URL → #1234
  html = html.replace(/<a href="(https:\/\/github\.com\/[^/]+\/[^/]+\/pull\/(\d+))"[^>]*>[^<]*<\/a>/g,
    '<a href="$1" target="_blank" rel="noopener noreferrer" class="cl-pr-link">#$2</a>');
  html = html.replace(/<a href="(https:\/\/github\.com\/[^/]+\/[^/]+\/issues\/(\d+))"[^>]*>[^<]*<\/a>/g,
    '<a href="$1" target="_blank" rel="noopener noreferrer" class="cl-pr-link">#$2</a>');
  // Strip "by @username in" before PR links
  html = html.replace(/ by <a href="https:\/\/github\.com\/[^"]*"[^>]*>@[^<]+<\/a> in /g, ' ');
  // Strip remaining "by @username in" plain text before links
  html = html.replace(/ by @[\w-]+ in /g, ' ');
  // Inject type badges into list items based on conventional commit prefixes
  html = html.replace(/<li>(.*?)<\/li>/gs, (match, content) => {
    const text = content.toLowerCase();
    let badge = '';
    if (/^fix[\s(:]/.test(text)) badge = '<span class="cl-badge cl-badge-fix">FIX</span>';
    else if (/^feat[\s(:]/.test(text)) badge = '<span class="cl-badge cl-badge-feat">FEAT</span>';
    else if (/^docs[\s(:]/.test(text)) badge = '<span class="cl-badge cl-badge-docs">DOCs</span>';
    else if (/^test[\s(:]/.test(text)) badge = '<span class="cl-badge cl-badge-test">TEST</span>';
    else if (/^(refactor|chore)[\s(:]/.test(text)) badge = '<span class="cl-badge cl-badge-chore">CHORE</span>';
    else if (/^(ci|build|docker)[\s(:]/.test(text)) badge = '<span class="cl-badge cl-badge-ci">CI</span>';
    else if (/^(perf|style)[\s(:]/.test(text)) badge = '<span class="cl-badge cl-badge-perf">PERF</span>';
    else if (/^(android|ios|cli|docker):/.test(text)) badge = '<span class="cl-badge cl-badge-feat">PLAT</span>';
    return `<li>${badge}${content}</li>`;
  });
  return html;
}
---

<style>
  /* === Changelog Page === */

  /* Search */
  .cl-search-wrap {
    width: 100%;
    max-width: 320px;
  }
  .cl-search-inner {
    position: relative;
  }
  .cl-search-input {
    width: 100%;
    background: var(--oc-bg);
    border: 4px solid var(--oc-border);
    padding: 1rem;
    font-family: var(--oc-font-headline);
    font-weight: 700;
    text-transform: uppercase;
    color: var(--oc-text);
    font-size: 0.85rem;
    outline: none;
    box-shadow: var(--oc-shadow);
    transition: border-color 100ms, box-shadow 100ms;
  }
  .cl-search-input::placeholder {
    color: var(--oc-text-muted);
    font-size: 0.85rem;
  }
  .cl-search-input:focus {
    border-color: var(--oc-primary);
    box-shadow: 6px 6px 0 0 var(--oc-primary);
  }
  .cl-search-icon {
    position: absolute;
    right: 1rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--oc-text-muted);
    font-size: 1rem;
    pointer-events: none;
  }

  /* Filter pills */
  .cl-filter-btn {
    background: transparent;
    border: 2px solid var(--oc-border-dim);
    padding: 0.3rem 0.75rem;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--oc-text-muted);
    cursor: pointer;
    transition: all 100ms;
  }
  .cl-filter-btn:hover {
    border-color: var(--oc-border);
    color: var(--oc-text);
    background: var(--oc-bg-surface);
  }
  .cl-filter-btn.is-active {
    border-color: var(--oc-primary);
    color: var(--oc-text);
    background: var(--oc-bg-surface);
  }
  .cl-filter-btn:focus-visible {
    outline: 3px solid var(--oc-primary);
    outline-offset: 2px;
  }

  /* Timeline */
  .cl-timeline {
    position: relative;
    padding-left: 3rem;
    border-left: 6px solid var(--oc-border);
  }

  /* Timeline dot */
  .cl-dot {
    position: absolute;
    left: -3.9rem;
    top: 0.5rem;
    width: 3rem;
    height: 3rem;
    border: 4px solid var(--oc-border);
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--oc-bg-card);
    transition: border-color 150ms;
  }
  .cl-dot--breaking {
    background: var(--oc-primary);
    border-color: var(--oc-primary);
  }
  .cl-dot__icon {
    font-size: 0.8rem;
    color: var(--oc-primary-bright);
  }
  .cl-dot--breaking .cl-dot__icon {
    color: #fff;
  }

  /* Header */
  .cl-header {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: baseline;
    margin-bottom: 1rem;
  }
  .cl-header__version {
    font-size: 2.25rem;
    font-weight: 900;
    font-style: italic;
    letter-spacing: -0.02em;
    color: var(--oc-text);
  }
  .cl-header__date {
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--oc-text-muted);
    letter-spacing: 0.05em;
  }

  /* Badges */
  .cl-label {
    display: inline-block;
    padding: 0.2rem 0.75rem;
    font-family: var(--oc-font-headline);
    font-size: 0.7rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .cl-label--breaking {
    background: var(--oc-primary);
    color: var(--oc-text-on-accent);
  }
  .cl-label--prerelease {
    background: transparent;
    color: var(--oc-primary);
    border: 2px solid var(--oc-primary);
  }

  /* Entry card */
  .cl-card {
    padding: 2rem;
    background: var(--oc-bg-card);
    border: 4px solid var(--oc-border-dim);
    transition: border-color 150ms, box-shadow 150ms;
  }
  .cl-card:hover {
    border-color: var(--oc-border);
  }
  .cl-card--breaking {
    border-left: 8px solid var(--oc-primary);
  }
  .cl-card--breaking:hover {
    box-shadow: 4px 4px 0 0 var(--oc-primary);
  }

  /* Entry title */
  .cl-card__title {
    font-size: 1.5rem;
    font-weight: 900;
    text-transform: uppercase;
    margin: 0 0 1.5rem;
    letter-spacing: -0.01em;
    color: var(--oc-text);
  }

  /* Entry body */
  .cl-card__body {
    color: var(--oc-text-dim);
    font-size: 0.875rem;
    line-height: 1.7;
    font-family: var(--oc-font-body);
    overflow: hidden;
    position: relative;
  }

  /* Expand button */
  .cl-expand-btn {
    display: block;
    margin-top: 1rem;
    background: transparent;
    border: 2px solid var(--oc-border);
    color: var(--oc-text);
    padding: 0.5rem 1.25rem;
    font-size: 0.7rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    cursor: pointer;
    transition: background 100ms, transform 100ms;
  }
  .cl-expand-btn:hover {
    background: var(--oc-bg-surface);
    transform: translate(-1px, -1px);
  }
  .cl-expand-btn:focus-visible {
    outline: 3px solid var(--oc-primary);
    outline-offset: 2px;
  }

  /* Footer */
  .cl-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 1.5rem;
    padding-top: 1rem;
    border-top: 2px solid var(--oc-border-dim);
  }
  .cl-footer__link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--oc-primary-bright);
    text-decoration: none;
    transition: opacity 150ms, gap 150ms;
  }
  .cl-footer__link:hover {
    opacity: 0.7;
    gap: 0.75rem;
  }
  .cl-footer__link:focus-visible {
    outline: 2px solid var(--oc-primary);
    outline-offset: 2px;
  }
  .cl-footer__num {
    font-family: var(--oc-font-mono);
    font-size: 0.65rem;
    color: var(--oc-text-muted);
  }

  /* Scroll to top */
  #cl-scroll-top {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    z-index: 60;
    background: var(--oc-border);
    color: var(--oc-bg);
    padding: 1rem;
    border: 4px solid var(--oc-border);
    box-shadow: 6px 6px 0px 0px rgba(235,0,0,1);
    cursor: pointer;
    font-size: 1.25rem;
    opacity: 0;
    pointer-events: none;
    transition: opacity 200ms, transform 100ms, box-shadow 100ms;
  }
  #cl-scroll-top.is-visible {
    opacity: 1;
    pointer-events: auto;
  }
  #cl-scroll-top:hover {
    transform: translate(-2px, -2px);
    box-shadow: 8px 8px 0px 0px rgba(235,0,0,1);
  }
  #cl-scroll-top:focus-visible {
    outline: 3px solid var(--oc-primary);
    outline-offset: 2px;
  }

  /* Hero */
  .cl-hero__title {
    font-size: clamp(3.5rem, 10vw, 7rem);
    font-weight: 900;
    text-transform: uppercase;
    font-style: italic;
    letter-spacing: -0.03em;
    line-height: 0.9;
    margin: 0 0 1.5rem;
    color: var(--oc-text);
  }
  .cl-hero__sub {
    font-family: var(--oc-font-body);
    font-size: 1.1rem;
    max-width: 32rem;
    color: var(--oc-text-dim);
    line-height: 1.6;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .cl-hero__actions {
    margin-top: 2rem;
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
</style>

<OpenClawLayout
  title="OpenClaw Changelog — changelogs.info"
  description="Full changelog for OpenClaw. Every release, every breaking change, every fix."
  currentPage="changelog"
>
  <div style="max-width: 1280px; margin: 0 auto; padding: 2rem 1.5rem 0;">
    <section style="margin-bottom: 4rem;">
      <h1 class="cl-hero__title">Changelog</h1>
      <p class="cl-hero__sub">Every release, every breaking change, every fix.</p>
      <div class="cl-hero__actions">
        <div class="cl-search-wrap">
          <div class="cl-search-inner">
            <input
              type="text"
              id="cl-search"
              class="cl-search-input"
              placeholder="Search releases..."
              autocomplete="off"
              spellcheck="false"
            />
            <span class="cl-search-icon">⌕</span>
          </div>
        </div>
        <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
          <button id="cl-filter-all" class="cl-filter-btn">All</button>
          <button id="cl-filter-breaking" class="cl-filter-btn">Breaking</button>
          <button id="cl-filter-prerelease" class="cl-filter-btn">Pre-release</button>
        </div>
      </div>
    </section>

    <section
      class="cl-timeline"
      id="cl-timeline"
      aria-label="Release timeline"
    >
      {releases.map((release, idx) => {
        const breaking = isBreaking(release.body);
        const renderedBody = renderBody(release.body || "");
        const isLong = (release.body || "").length > 600;

        return (
          <article
            class="cl-entry"
            data-version={release.version.toLowerCase()}
            data-name={(release.name || "").toLowerCase()}
            data-body={(release.body || "").toLowerCase().slice(0, 800)}
            data-prerelease={String(release.prerelease)}
            data-breaking={String(breaking)}
            data-index={idx}
            style={`position: relative; margin-bottom: 3rem; ${idx >= 10 ? 'display: none;' : ''}`}
          >
            <div class={`cl-dot ${breaking ? 'cl-dot--breaking' : ''}`}>
              <span class="cl-dot__icon">
                {breaking ? "⚡" : release.prerelease ? "β" : "●"}
              </span>
            </div>

            <div class="cl-header">
              <span class="oc-headline cl-header__version">
                {release.version}
              </span>
              <span class="oc-headline cl-header__date">
                {formatDate(release.date)}
              </span>
              {breaking && (
                <span class="cl-label cl-label--breaking">Breaking</span>
              )}
              {release.prerelease && (
                <span class="cl-label cl-label--prerelease">Pre-release</span>
              )}
            </div>

            <div class={`cl-card ${breaking ? 'cl-card--breaking' : ''}`}>
              <h3 class="oc-headline cl-card__title">
                {(release.name || release.version).replace(/^openclaw\s+/i, "")}
              </h3>

              <div
                class={`changelog-body ${isLong && idx > 0 ? 'cl-collapsed' : ''} cl-card__body`}
                set:html={renderedBody}
              />

              {isLong && (
                <button
                  class="cl-expand-btn oc-headline"
                  data-expand-target={idx}
                >
                  {idx === 0 ? '▲ Collapse' : '▼ Expand Full Changelog'}
                </button>
              )}

              <div class="cl-footer">
                <a
                  href={release.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="cl-footer__link oc-headline"
                >
                  ↗ View on GitHub
                </a>
                <span class="cl-footer__num">#{idx + 1}</span>
              </div>
            </div>
          </article>
        );
      })}

      <p class="oc-headline" style="font-weight: 700; text-transform: uppercase; color: var(--oc-text-muted);">
        — {releases.length} releases tracked —
      </p>
    </section>

    <div style="padding: 3rem; border: 4px dashed var(--oc-border-dim); text-align: center;">
      <p class="oc-headline" style="font-weight: 700; text-transform: uppercase; color: var(--oc-text-muted);">
        Looking for older releases?
      </p>
      <p style="color: var(--oc-text-dim); font-size: 0.875rem; margin-top: 0.5rem;">
        <a href="https://github.com/openclaw/openclaw/releases" target="_blank" rel="noopener noreferrer" style="color: var(--oc-primary-bright);">View all releases on GitHub →</a>
      </p>
    </div>
  </div>

  <button id="cl-scroll-top" aria-label="Scroll to top">↑</button>

  <script>
    // Search
    const searchInput = document.getElementById("cl-search");
    const allEntries = document.querySelectorAll<HTMLElement>(".cl-entry");

    searchInput?.addEventListener("input", (e) => {
      const q = (e.target as HTMLInputElement).value.toLowerCase();
      allEntries.forEach((entry) => {
        const version = entry.dataset.version || "";
        const name = entry.dataset.name || "";
        const body = entry.dataset.body || "";
        const match = version.includes(q) || name.includes(q) || body.includes(q);
        (entry as HTMLElement).style.display = match || q === "" ? "" : "none";
      });
    });

    // Filters
    let activeFilter = "all";
    const breakingBtn = document.getElementById("cl-filter-breaking");
    const prereleaseBtn = document.getElementById("cl-filter-prerelease");
    const allFilterBtn = document.getElementById("cl-filter-all");

    // Set initial active state
    allFilterBtn?.classList.add("is-active");

    function applyFilter(filter: string) {
      activeFilter = filter;
      allEntries.forEach((entry) => {
        const isBreaking = entry.dataset.breaking === "true";
        const isPrerelease = entry.dataset.prerelease === "true";
        let show = true;
        if (filter === "breaking") show = isBreaking;
        else if (filter === "prerelease") show = isPrerelease;
        (entry as HTMLElement).style.display = show ? "" : "none";
      });
      // Update active button state
      breakingBtn?.classList.toggle("is-active", filter === "breaking");
      prereleaseBtn?.classList.toggle("is-active", filter === "prerelease");
      allFilterBtn?.classList.toggle("is-active", filter === "all");
    }

    breakingBtn?.addEventListener("click", () => applyFilter("breaking"));
    prereleaseBtn?.addEventListener("click", () => applyFilter("prerelease"));
    allFilterBtn?.addEventListener("click", () => applyFilter("all"));

    // Expand/collapse (event delegation)
    document.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLElement>(".cl-expand-btn");
      if (!btn) return;
      const body = btn.previousElementSibling as HTMLElement;
      body?.classList.toggle("cl-collapsed");
      btn.textContent = body?.classList.contains("cl-collapsed")
        ? "▼ Expand Full Changelog"
        : "▲ Collapse";
    });

    // Scroll to top
    const scrollTopBtn = document.getElementById("cl-scroll-top");
    scrollTopBtn?.addEventListener("click", () => {
      window.scrollTo({ top: 0, behavior: "smooth" });
    });

    // Show/hide scroll button
    window.addEventListener("scroll", () => {
      if (!scrollTopBtn) return;
      if (window.scrollY > 600) {
        scrollTopBtn.style.opacity = "1";
        scrollTopBtn.classList.add("is-visible");
      } else {
        scrollTopBtn.style.opacity = "0";
        scrollTopBtn.classList.remove("is-visible");
      }
    }, { passive: true });
  </script>
</OpenClawLayout>
