---
import SectionLayout from "../../layouts/SectionLayout.astro";
import { getSectionById } from "../../lib/sections";

const section = getSectionById("openclaw")!;
---

<SectionLayout
  section={section}
  title="OpenClaw Configs — changelogs.info"
  description="Configuration examples for OpenClaw."
  showHero={false}
>
  <div class="mx-auto max-w-4xl px-4 py-8 sm:px-6 sm:py-12">
    <h1 class="mb-2 font-mono text-2xl font-bold" style={`color: ${section.color};`}>
      <span style={`color: ${section.color};`}>/</span>configs
    </h1>
    <p class="mb-8 font-sans text-sm text-text-muted">Configuration examples and templates for OpenClaw.</p>

    <div class="rounded-lg border border-dashed border-border bg-bg-card p-8 text-center">
      <p class="font-mono text-base text-text-muted">&gt; Config examples coming soon.</p>
      <p class="mt-3 font-sans text-xs text-text-muted">
        In the meantime, check the <a href="https://github.com/AugmentCode/openclaw" target="_blank" rel="noopener noreferrer" class="text-cyan transition-colors hover:text-cyan/80">OpenClaw repo</a> for configuration docs.
      </p>
    </div>
  </div>
</SectionLayout>
