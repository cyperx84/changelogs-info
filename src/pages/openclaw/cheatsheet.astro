---
import SectionLayout from "../../layouts/SectionLayout.astro";
import { getSectionById } from "../../lib/sections";
import { readFileSync } from "node:fs";
import { join } from "node:path";

const section = getSectionById("openclaw")!;

let cs: any = {};
try {
  const raw = readFileSync(join(process.cwd(), "src/content/cheatsheets-json/openclaw.json"), "utf-8");
  cs = JSON.parse(raw);
} catch {}

const dailyWorkflows = cs.dailyWorkflows || [];
const powerMoves = cs.powerMoves || [];
const gotchas = cs.gotchas || [];
const cliFlags = cs.cliFlags || [];
const slashCommands = cs.slashCommands || [];
const proTips = cs.proTips || [];
---

<SectionLayout
  section={section}
  title="OpenClaw Cheat Sheet — changelogs.info"
  description="The actually useful OpenClaw cheat sheet."
  showHero={false}
>

    <div class="mx-auto max-w-4xl px-4 py-8 sm:px-6 sm:py-12">
      <h1 class="mb-2 font-mono text-2xl font-bold" style={`color: ${section.color};`}>OpenClaw cheat sheet</h1>
      <p class="mb-8 font-sans text-sm text-text-muted">The stuff you actually need.{cs.lastUpdated ? ` Updated ${cs.lastUpdated}.` : ""}</p>

      {dailyWorkflows.length > 0 && (
        <section class="mb-10">
          <h2 class="mb-4 font-mono text-base font-semibold" style={`color: ${section.color};`}><span style={`color: ${section.color};`}>//</span> daily_workflows</h2>
          <div class="space-y-3">
            {dailyWorkflows.map((wf: any) => (
              <div class="group rounded-lg border border-border bg-bg-card p-4 transition-all" style={`--hover-border: rgba(${section.colorRgb}, 0.4);`}>
                <h3 class="mb-1 font-mono text-sm font-semibold text-text-primary">{wf.title}</h3>
                <p class="mb-2 font-sans text-xs text-text-muted">{wf.description}</p>
                {wf.command && (
                  <div class="flex items-center justify-between gap-2 rounded bg-bg-tertiary px-3 py-2 overflow-x-auto">
                    <code class="font-mono text-xs" style={`color: ${section.color};`}>{wf.command}</code>
                  </div>
                )}
              </div>
            ))}
          </div>
        </section>
      )}

      {powerMoves.length > 0 && (
        <section class="mb-10">
          <h2 class="mb-4 font-mono text-base font-semibold text-amber">power_moves</h2>
          <div class="grid gap-3 sm:grid-cols-2">
            {powerMoves.map((pm: any) => (
              <div class="rounded-lg border border-border bg-bg-card p-4">
                <h3 class="mb-1 font-mono text-sm font-semibold text-text-primary">{pm.title}</h3>
                <p class="mb-2 font-sans text-xs text-text-muted">{pm.description}</p>
                {pm.command && <code class="block rounded bg-bg-tertiary px-3 py-2 font-mono text-[11px] text-amber overflow-x-auto">{pm.command}</code>}
              </div>
            ))}
          </div>
        </section>
      )}

      {gotchas.length > 0 && (
        <section class="mb-10">
          <h2 class="mb-4 font-mono text-base font-semibold text-red">common_gotchas</h2>
          <div class="space-y-3">
            {gotchas.map((g: any) => (
              <div class="rounded-lg border border-red/20 bg-red/[0.03] p-4">
                <h3 class="mb-1 font-mono text-sm font-semibold text-text-primary">{g.problem}</h3>
                <p class="font-sans text-xs text-text-secondary">{g.solution}</p>
              </div>
            ))}
          </div>
        </section>
      )}

      {cliFlags.length > 0 && (
        <section class="mb-10">
          <h2 class="mb-4 font-mono text-base font-semibold" style={`color: ${section.color};`}>cli_flags</h2>
          <div class="rounded-lg border border-border bg-bg-card divide-y divide-border/30 overflow-hidden">
            {cliFlags.map((f: any) => (
              <div class="flex flex-col gap-1 px-4 py-2.5 sm:flex-row sm:items-start sm:gap-4">
                <code class="shrink-0 font-mono text-xs font-semibold sm:w-48" style={`color: ${section.color};`}>--{f.flag}{f.shorthand ? `, -${f.shorthand}` : ""}</code>
                <p class="font-sans text-xs text-text-secondary">{f.description}</p>
              </div>
            ))}
          </div>
        </section>
      )}

      {slashCommands.length > 0 && (
        <section class="mb-10">
          <h2 class="mb-4 font-mono text-base font-semibold text-cyan">/ commands</h2>
          <div class="grid gap-2 sm:grid-cols-2">
            {slashCommands.map((cmd: any) => (
              <div class="rounded border border-border bg-bg-card px-4 py-3">
                <code class="font-mono text-sm font-semibold text-cyan">{cmd.command}</code>
                <p class="mt-1 font-sans text-xs text-text-muted">{cmd.description}</p>
              </div>
            ))}
          </div>
        </section>
      )}

      {proTips.length > 0 && (
        <section class="mb-10">
          <h2 class="mb-4 font-mono text-base font-semibold text-amber">pro_tips</h2>
          <div class="rounded-lg border border-amber/20 bg-amber/[0.03] p-5">
            <ul class="grid gap-2 sm:grid-cols-2">
              {proTips.map((tip: string) => (
                <li class="flex gap-2 font-sans text-xs text-text-secondary">
                  <span class="shrink-0 text-amber">&rsaquo;</span>
                  <span>{tip}</span>
                </li>
              ))}
            </ul>
          </div>
        </section>
      )}
    </div>
</SectionLayout>
