---
import OpenClawLayout from "../../layouts/OpenClawLayout.astro";
import { getToolById, getToolReleases, formatDate, relativeTime } from "../../lib/releases";
import { marked } from "marked";
import { readFileSync } from "node:fs";
import { join } from "node:path";

const tool = getToolById("openclaw");
const data = await getToolReleases("openclaw");
const releases = data?.releases || [];
const stableReleases = releases.filter((r) => !r.prerelease);
const latestStable = stableReleases[0];
const latestRelease = releases[0];
const latestForTldr = releases[0];
const restReleases = releases.slice(1);

const breakingCount = releases.filter((r) =>
  r.body?.toLowerCase().includes("breaking")
).length;

const displayVersion = latestStable?.version || latestRelease?.version || "—";
const lastUpdatedAgo = data?.lastUpdated ? relativeTime(data.lastUpdated) : null;

function getPayloadTldr(toolId: string): string | null {
  try {
    const path = join(process.cwd(), "public", "api", "refs", `${toolId}.json`);
    const payload = JSON.parse(readFileSync(path, "utf-8"));
    return payload?.payload?.meta?.tldr ?? null;
  } catch {
    return null;
  }
}

const llmTldr = getPayloadTldr("openclaw");

function isBreaking(body: string = ""): boolean {
  return body.toLowerCase().includes("breaking");
}


function normalizeReleaseBody(body: string): string {
  if (!body) return "";

  let normalized = body.replace(/\r\n/g, "\n").trim();

  normalized = normalized
    .replace(/^\s*##\s*what'?s changed\s*$/gim, "## Changes")
    .replace(/^\s*##\s*full changelog\s*$/gim, "")
    .replace(/^\s*\*\*full changelog\*\*: ?\s*$/gim, "")
    .replace(/^\s*full changelog:?\s*$/gim, "")
    .replace(/^\s*important:?\s*$/gim, "## Important")
    .replace(/^\s*summary:?\s*$/gim, "## Summary")
    .replace(/^\s*notes:?\s*$/gim, "## Notes");

  normalized = normalized.replace(/\n{3,}/g, "\n\n");

  const lines = normalized.split("\n");
  const cleaned: string[] = [];
  let skipGithubBoilerplate = false;

  for (let i = 0; i < lines.length; i++) {
    const line = lines[i];
    const trimmed = line.trim();

    if (!trimmed) {
      if (cleaned.length > 0 && cleaned[cleaned.length - 1] !== "") cleaned.push("");
      continue;
    }

    if (/^\[?full changelog\]?[:：]?$/i.test(trimmed)) continue;
    if (/^full changelog:?\s*https?:\/\//i.test(trimmed)) continue;
    if (/^see full changelog/i.test(trimmed)) continue;
    if (/^compare:/i.test(trimmed)) continue;

    if (/^##\s*new contributors\s*$/i.test(trimmed)) {
      skipGithubBoilerplate = true;
      continue;
    }
    if (skipGithubBoilerplate) {
      if (/^##\s+/.test(trimmed)) skipGithubBoilerplate = false;
      else continue;
    }

    let nextLine = line
      .replace(/\*\*full changelog\*\*:\s*https?:\/\/\S+/gi, "")
      .replace(/\[full changelog\]\([^)]*\)/gi, "")
      .replace(/\s+by\s+@\S+\s+in\s+https?:\/\/\S+/gi, "")
      .replace(/\s+by\s+@\S+\s+in\s+#\d+/gi, "")
      .replace(/\s+in\s+https?:\/\/\S+/gi, "")
      .replace(/\s{2,}/g, " ")
      .trimEnd();

    if (/^[*-]\s+[^\s].*/.test(nextLine)) {
      nextLine = nextLine.replace(/^([*-]\s+)(fix|feat|docs|test|chore|refactor|perf|style|ci|build|docker)(\([^)]*\))?:\s*/i, "$1$2: ");
    }

    cleaned.push(nextLine);
  }

  return cleaned.join("\n").replace(/\n{3,}/g, "\n\n").trim();
}


function renderBody(body: string): string {
  if (!body) return "";
  const normalizedBody = normalizeReleaseBody(body);
  marked.setOptions({ gfm: true, breaks: false });
  let html = marked.parse(normalizedBody) as string;
  // Shorten GitHub PR/issue links: full URL → #1234
  html = html.replace(/<a href="(https:\/\/github\.com\/[^/]+\/[^/]+\/pull\/(\d+))"[^>]*>[^<]*<\/a>/g,
    '<a href="$1" target="_blank" rel="noopener noreferrer" class="cl-pr-link">#$2</a>');
  html = html.replace(/<a href="(https:\/\/github\.com\/[^/]+\/[^/]+\/issues\/(\d+))"[^>]*>[^<]*<\/a>/g,
    '<a href="$1" target="_blank" rel="noopener noreferrer" class="cl-pr-link">#$2</a>');
  // Strip "by @username in" before PR links
  html = html.replace(/ by <a href="https:\/\/github\.com\/[^"]*"[^>]*>@[^<]+<\/a> in /g, ' ');
  html = html.replace(/ by @[\w-]+ in /g, ' ');
  html = html.replace(/<li>(.*?)<\/li>/gs, (match, content) => {
    const text = content.toLowerCase();
    let badge = '';
    if (/^fix[\s(:]/.test(text)) badge = '<span class="cl-badge cl-badge-fix">FIX</span>';
    else if (/^feat[\s(:]/.test(text)) badge = '<span class="cl-badge cl-badge-feat">FEAT</span>';
    else if (/^docs[\s(:]/.test(text)) badge = '<span class="cl-badge cl-badge-docs">DOCS</span>';
    else if (/^test[\s(:]/.test(text)) badge = '<span class="cl-badge cl-badge-test">TEST</span>';
    else if (/^(refactor|chore)[\s(:]/.test(text)) badge = '<span class="cl-badge cl-badge-chore">CHORE</span>';
    else if (/^(ci|build|docker)[\s(:]/.test(text)) badge = '<span class="cl-badge cl-badge-ci">CI</span>';
    else if (/^(perf|style)[\s(:]/.test(text)) badge = '<span class="cl-badge cl-badge-perf">PERF</span>';
    else if (/^(android|ios|cli|docker):/.test(text)) badge = '<span class="cl-badge cl-badge-feat">PLAT</span>';
    return `<li>${badge}${content}</li>`;
  });
  return html;
}

// Generate a short TLDR from the body
function getTldr(body: string): string[] {
  if (!body) return [];
  const lines = body.split("\n").filter(Boolean);
  const bullets: string[] = [];
  for (const line of lines) {
    // Match markdown list items and extract the key part
    const match = line.match(/^[\*\-]\s+(.+)/);
    if (match) {
      let text = match[1]
        .replace(/\*\*([^*]+)\*\*/g, "$1")  // strip bold
        .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")  // strip links
        .replace(/`([^`]+)`/g, "$1")  // strip code
        .replace(/\s+by\s+@\S+\s+in\s+https:\/\/\S+/g, "")  // strip PR refs
        .trim();
      if (text.length > 10 && !text.startsWith("http") && !text.startsWith("@")) {
        // Truncate long items
        if (text.length > 120) text = text.slice(0, 117) + "…";
        bullets.push(text);
      }
    }
  }
  return bullets.slice(0, 5); // top 5 changes per release
}
---

<OpenClawLayout
  title="OpenClaw — changelogs.info"
  description="Track OpenClaw releases, breaking changes, and config updates. Personal AI assistant platform — run your own AI on any device, any channel."
  currentPage="home"
>
  <!-- Dot grid background -->
  <div class="oc-dotgrid" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -1; pointer-events: none; opacity: 0.4;"></div>

  <div style="max-width: 1100px; margin: 0 auto; padding: 2rem 1.5rem 0;">

    <!-- Hero -->
    <section class="oc-hero-section" style="margin-bottom: 3rem; display: grid; grid-template-columns: 1fr; gap: 2rem; align-items: center;">
      <div style="display: grid; grid-template-columns: 1fr auto; gap: 2.5rem; align-items: center;" class="oc-hero-grid">
        <!-- Left: text + CTA -->
        <div style="display: flex; flex-direction: column; gap: 1.25rem;">
          <!-- Live badge -->
          <div style="display: inline-flex; align-items: center; gap: 0.5rem; width: fit-content;">
            <span class="oc-pulse-dot" style="width: 8px; height: 8px; background: #22c55e; display: inline-block;"></span>
            <span style="font-family: var(--oc-font-mono); font-size: 0.65rem; color: var(--oc-text-muted); text-transform: uppercase; letter-spacing: 0.15em;">Tracking {releases.length} releases</span>
          </div>

          <h1 class="oc-headline oc-hero-title" style="font-size: clamp(3.5rem, 9vw, 6rem); font-weight: 900; color: var(--oc-text); text-transform: uppercase; line-height: 0.85; margin: 0; letter-spacing: -0.03em;">
            Open<span style="color: var(--oc-primary-bright);">Claw</span>
          </h1>

          <p style="font-size: 1.05rem; color: var(--oc-text-dim); max-width: 28rem; line-height: 1.6; margin: 0; font-family: var(--oc-font-body);">
            {tool?.description || "Personal AI assistant platform — run your own AI on any device, any channel."}
          </p>

          <!-- CTA row -->
          <div style="display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 0.5rem;">
            <a
              href={`https://github.com/${tool?.repo || "openclaw/openclaw"}`}
              target="_blank"
              rel="noopener noreferrer"
              class="oc-headline oc-cta-btn"
              style="background: var(--oc-primary); color: white; font-weight: 900; padding: 0.75rem 1.75rem; font-size: 0.85rem; border: 4px solid var(--oc-border); box-shadow: var(--oc-shadow-sm); text-decoration: none; text-transform: uppercase; font-style: italic;"
            >
              GitHub ↗
            </a>
            <a
              href="/openclaw/changelog/"
              class="oc-headline oc-cta-btn"
              style="background: transparent; color: var(--oc-text); font-weight: 900; padding: 0.75rem 1.75rem; font-size: 0.85rem; border: 4px solid var(--oc-border); box-shadow: var(--oc-shadow-sm); text-decoration: none; text-transform: uppercase; font-style: italic;"
            >
              Changelog
            </a>
          </div>
        </div>

        <!-- Right: terminal card -->
        <div class="oc-terminal-card" style="width: 320px; border: 4px solid var(--oc-border); box-shadow: var(--oc-shadow); flex-shrink: 0; overflow: hidden;">
          <!-- Title bar -->
          <div style="background: var(--oc-border); padding: 0.5rem 0.75rem; display: flex; align-items: center; gap: 0.5rem;">
            <span style="width: 10px; height: 10px; background: var(--oc-primary); display: inline-block;"></span>
            <span style="width: 10px; height: 10px; background: #ffb800; display: inline-block;"></span>
            <span style="width: 10px; height: 10px; background: #22c55e; display: inline-block;"></span>
            <span style="font-family: var(--oc-font-mono); font-size: 0.6rem; color: var(--oc-bg); margin-left: 0.5rem; text-transform: uppercase; font-weight: 700;">openclaw status</span>
          </div>
          <!-- Terminal body -->
          <div style="background: var(--oc-bg); padding: 1rem; font-family: var(--oc-font-mono); font-size: 0.7rem; line-height: 1.8; color: var(--oc-text-dim);">
            <div><span style="color: var(--oc-primary-bright);">❯</span> openclaw status</div>
            <div style="margin-top: 0.5rem;">
              <span style="color: #22c55e;">●</span> Gateway: <span style="color: #22c55e;">running</span>
            </div>
            <div>
              <span style="color: #22c55e;">●</span> Version: <span style="color: var(--oc-text);">{displayVersion}</span>
            </div>
            <div>
              <span style="color: #22c55e;">●</span> Releases: <span style="color: var(--oc-text);">{releases.length}</span> tracked
            </div>
            <div>
              <span style="color: {breakingCount > 0 ? 'var(--oc-primary-bright)' : '#22c55e'};">{breakingCount > 0 ? '⚠' : '●'}</span> Breaking: <span style="color: {breakingCount > 0 ? 'var(--oc-primary-bright)' : 'var(--oc-text)'};">{breakingCount}</span>
            </div>
            <div>
              <span style="color: #22c55e;">●</span> Updated: <span style="color: var(--oc-text);">{lastUpdatedAgo || "now"}</span>
            </div>
            <div style="margin-top: 0.5rem; color: var(--oc-text-muted);">
              <span style="color: var(--oc-primary-bright);">❯</span> <span class="oc-cursor">_</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats Bar -->
    <section class="oc-section-reveal" style="display: flex; flex-wrap: wrap; gap: 0; border: 4px solid var(--oc-border); margin-bottom: 3rem;">
      {[
        { label: "Releases", value: String(releases.length) },
        { label: "Breaking", value: String(breakingCount), red: true },
        { label: "Stable", value: String(stableReleases.length) },
        { label: "Latest", value: displayVersion },
      ].map((stat, i) => (
        <div
          style={`flex: 1; min-width: 120px; padding: 1rem 1.25rem; ${i < 3 ? 'border-right: 4px solid var(--oc-border);' : ''} background: var(--oc-bg-card); cursor: crosshair; transition: background 150ms;`}
          class="stats-cell"
        >
          <span style="display: block; color: var(--oc-text-muted); font-family: var(--oc-font-headline); font-weight: 700; text-transform: uppercase; font-size: 0.55rem; letter-spacing: 0.15em; margin-bottom: 0.25rem;">{stat.label}</span>
          <span class="oc-headline" style={`display: block; font-size: 1.5rem; font-weight: 900; color: ${stat.red ? 'var(--oc-primary-bright)' : 'var(--oc-text)'};`}>{stat.value}</span>
        </div>
      ))}
    </section>

    <!-- TLDR: Latest Release -->
    {latestForTldr && (() => {
      const breaking = isBreaking(latestForTldr.body);
      const tldr = getTldr(latestForTldr.body || "");
      const fallback = (latestForTldr.body || "").split("\n").filter(l => l.trim() && !l.startsWith("#")).slice(0, 2).map(l => l.replace(/^[\*\-]\s+/, "").trim());
      const items = tldr.length > 0 ? tldr : fallback;
      const summaryText = llmTldr?.trim() || null;
      const latestRendered = renderBody(latestForTldr.body || "");

      return (
        <section style="margin-bottom: 3rem;">
          <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem;">
            <h2 class="oc-headline" style="font-size: 2.5rem; font-weight: 900; color: var(--oc-text); text-transform: uppercase; font-style: italic; letter-spacing: -0.02em; margin: 0;">
              TL;DR
            </h2>
            <div style="flex: 1; height: 4px; background: var(--oc-border);"></div>
            <span style="font-family: var(--oc-font-mono); font-size: 0.7rem; color: var(--oc-text-muted); text-transform: uppercase;">Latest Release</span>
          </div>

          <!-- TLDR card -->
          <div style={`padding: 1.5rem 2rem; border: 4px solid ${breaking ? 'var(--oc-primary)' : 'var(--oc-border)'}; background: ${breaking ? 'var(--oc-bg-surface)' : 'var(--oc-bg-card)'}; ${breaking ? 'border-left: 8px solid var(--oc-primary);' : ''} margin-bottom: 2rem;`}>
            <div style="display: flex; justify-content: space-between; align-items: center; gap: 1rem; margin-bottom: 1rem; flex-wrap: wrap;">
              <div style="display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap;">
                <span class="oc-headline" style="font-size: 1.3rem; font-weight: 900; color: var(--oc-text); text-transform: uppercase;">{latestForTldr.version}</span>
                {breaking && (
                  <span style="background: var(--oc-primary); color: white; font-family: var(--oc-font-mono); padding: 0.15rem 0.5rem; font-size: 0.6rem; font-weight: 700; text-transform: uppercase;">BREAKING</span>
                )}
                {latestForTldr.prerelease && (
                  <span style="background: rgba(255,184,0,0.15); color: #ffb800; font-family: var(--oc-font-mono); padding: 0.15rem 0.5rem; font-size: 0.6rem; font-weight: 700; text-transform: uppercase; border: 1px solid #ffb800;">PRE</span>
                )}
              </div>
              <span style="font-family: var(--oc-font-mono); font-size: 0.7rem; color: var(--oc-text-muted); white-space: nowrap;">{formatDate(latestForTldr.date)}</span>
            </div>
            {summaryText ? (
              <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                <p style="margin: 0; font-family: var(--oc-font-body); font-size: 1rem; color: var(--oc-text); line-height: 1.7; max-width: 60ch;">{summaryText}</p>
              </div>
            ) : items.length > 0 && (
              <ul style="list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.4rem;">
                {items.map((item) => (
                  <li style="display: flex; gap: 0.5rem; align-items: flex-start; font-family: var(--oc-font-body); font-size: 0.9rem; color: var(--oc-text-dim); line-height: 1.5;">
                    <span style="color: var(--oc-primary-bright); flex-shrink: 0; font-weight: 700;">▸</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            )}
          </div>

          <!-- Full changelog of latest release -->
          <div style={`padding: 2rem; border: 4px solid var(--oc-border); background: var(--oc-bg-surface);`}>
            <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 0.5rem;">
              <h3 class="oc-headline" style="font-size: 1.5rem; font-weight: 900; text-transform: uppercase; margin: 0; color: var(--oc-text);">
                {(latestForTldr.name || latestForTldr.version).replace(/^openclaw\s+/i, "")}
              </h3>
              <a href={latestForTldr.url} target="_blank" rel="noopener noreferrer" class="oc-headline" style="font-size: 0.7rem; font-weight: 700; text-transform: uppercase; color: var(--oc-primary-bright); text-decoration: none;">↗ GitHub</a>
            </div>
            <div
              class="changelog-body"
              style="color: var(--oc-text-dim); font-size: 0.875rem; line-height: 1.7; font-family: var(--oc-font-body);"
              set:html={latestRendered}
            />
          </div>
        </section>
      );
    })()}

    <!-- Previous 3 Releases -->
    <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 2rem;">
      <div style="flex: 1; height: 4px; background: var(--oc-border);"></div>
      <span class="oc-headline" style="font-size: 0.75rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.15em; color: var(--oc-text-muted);">Previous Releases</span>
      <div style="flex: 1; height: 4px; background: var(--oc-border);"></div>
    </div>

    <section style="margin-bottom: 4rem; display: flex; flex-direction: column; gap: 1.25rem;">
      {restReleases.slice(0, 3).map((release) => {
        const breaking = isBreaking(release.body);
        const renderedBody = renderBody(release.body || "");
        const isLong = (release.body || "").length > 600;
        return (
          <div style={`padding: 1.5rem 2rem; border: 4px solid ${breaking ? 'var(--oc-primary)' : 'var(--oc-border)'}; background: ${breaking ? 'var(--oc-bg-surface)' : 'var(--oc-bg-card)'}; ${breaking ? 'border-left: 8px solid var(--oc-primary);' : ''}`}>
            <div style="display: flex; justify-content: space-between; align-items: center; gap: 1rem; margin-bottom: 0.75rem; flex-wrap: wrap;">
              <div style="display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap;">
                <span class="oc-headline" style="font-size: 1.25rem; font-weight: 900; color: var(--oc-text); text-transform: uppercase;">{release.version}</span>
                <span class="oc-headline" style="font-size: 0.75rem; font-weight: 700; color: var(--oc-text-dim);">{(release.name || "").replace(/^openclaw\s+/i, "")}</span>
                {breaking && (
                  <span style="background: var(--oc-primary); color: white; font-family: var(--oc-font-mono); padding: 0.15rem 0.5rem; font-size: 0.6rem; font-weight: 700; text-transform: uppercase;">BREAKING</span>
                )}
              </div>
              <span style="font-family: var(--oc-font-mono); font-size: 0.7rem; color: var(--oc-text-muted); white-space: nowrap;">{formatDate(release.date)}</span>
            </div>
            <div
              class={`changelog-body ${isLong ? 'cl-collapsed' : ''}`}
              style="color: var(--oc-text-dim); font-size: 0.85rem; line-height: 1.7; font-family: var(--oc-font-body); overflow: hidden; position: relative;"
              set:html={renderedBody}
            />
            {isLong && (
              <button
                class="cl-expand-btn oc-headline"
                style="display: block; margin-top: 0.75rem; background: transparent; border: 2px solid var(--oc-border); color: var(--oc-text); padding: 0.4rem 1rem; font-size: 0.65rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.1em; cursor: pointer; transition: background 100ms; position: relative; overflow: visible;"
                onclick="this.previousElementSibling.classList.toggle('cl-collapsed'); this.textContent = this.textContent.includes('EXPAND') ? '▲ COLLAPSE' : '▼ EXPAND'"
              >
                ▼ EXPAND
              </button>
            )}
          </div>
        );
      })}
      <a
        href="/openclaw/changelog/"
        class="oc-headline"
        style="display: inline-flex; align-items: center; gap: 0.5rem; font-weight: 900; text-transform: uppercase; color: var(--oc-primary-bright); font-style: italic; text-decoration: none; border-bottom: 2px solid var(--oc-primary-bright); padding-bottom: 2px; font-size: 0.85rem; align-self: flex-start;"
      >
        View all {releases.length} releases →
      </a>
    </section>

    <!-- Quick Links -->
    <section style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin-bottom: 4rem;">
      <a href="/openclaw/changelog/" class="oc-quick-link" style="display: flex; align-items: center; gap: 0.75rem; padding: 1.25rem; border: 4px solid var(--oc-border); background: var(--oc-bg-card); text-decoration: none;">
        <span style="font-size: 1.5rem;">📋</span>
        <div>
          <span class="oc-headline" style="display: block; font-weight: 900; font-size: 0.85rem; color: var(--oc-text); text-transform: uppercase;">Full Changelog</span>
          <span style="font-family: var(--oc-font-mono); font-size: 0.65rem; color: var(--oc-text-muted);">{releases.length} releases</span>
        </div>
      </a>
      <a href="/openclaw/cheatsheet/" class="oc-quick-link" style="display: flex; align-items: center; gap: 0.75rem; padding: 1.25rem; border: 4px solid var(--oc-border); background: var(--oc-bg-card); text-decoration: none;">
        <span style="font-size: 1.5rem;">⚡</span>
        <div>
          <span class="oc-headline" style="display: block; font-weight: 900; font-size: 0.85rem; color: var(--oc-text); text-transform: uppercase;">Cheatsheet</span>
          <span style="font-family: var(--oc-font-mono); font-size: 0.65rem; color: var(--oc-text-muted);">Commands & tips</span>
        </div>
      </a>
      <a href="/openclaw/releases/" class="oc-quick-link" style="display: flex; align-items: center; gap: 0.75rem; padding: 1.25rem; border: 4px solid var(--oc-border); background: var(--oc-bg-card); text-decoration: none;">
        <span style="font-size: 1.5rem;">📦</span>
        <div>
          <span class="oc-headline" style="display: block; font-weight: 900; font-size: 0.85rem; color: var(--oc-text); text-transform: uppercase;">All Releases</span>
          <span style="font-family: var(--oc-font-mono); font-size: 0.65rem; color: var(--oc-text-muted);">Browse & filter</span>
        </div>
      </a>
      <a href="/feed/all.xml" class="oc-quick-link" style="display: flex; align-items: center; gap: 0.75rem; padding: 1.25rem; border: 4px solid var(--oc-border); background: var(--oc-bg-card); text-decoration: none;">
        <span style="font-size: 1.5rem;">📡</span>
        <div>
          <span class="oc-headline" style="display: block; font-weight: 900; font-size: 0.85rem; color: var(--oc-text); text-transform: uppercase;">RSS Feed</span>
          <span style="font-family: var(--oc-font-mono); font-size: 0.65rem; color: var(--oc-text-muted);">Subscribe to updates</span>
        </div>
      </a>
    </section>

    <!-- Clwatch Section -->
    <section style="margin-bottom: 4rem; border: 4px solid var(--oc-border); overflow: hidden;">
      <div style="background: var(--oc-primary); padding: 2rem 2.5rem; display: flex; flex-wrap: wrap; gap: 2rem; align-items: center; justify-content: space-between;">
        <div style="max-width: 560px;">
          <h2 class="oc-headline" style="font-size: 2.5rem; font-weight: 900; text-transform: uppercase; font-style: italic; letter-spacing: -0.02em; margin: 0 0 0.75rem; color: white; line-height: 1;">
            Clwatch
          </h2>
          <p style="font-family: var(--oc-font-body); font-size: 1rem; color: rgba(255,255,255,0.85); margin: 0; line-height: 1.6;">
            Monitor coding CLI releases in real-time. Track Claude Code, Codex CLI, Gemini CLI, and OpenClaw all in one dashboard. Get notified when new versions drop.
          </p>
        </div>
        <a
          href="/clwatch"
          class="oc-headline"
          style="background: white; color: var(--oc-primary); font-weight: 900; padding: 1rem 2rem; font-size: 1rem; border: 4px solid white; box-shadow: 6px 6px 0 rgba(0,0,0,0.3); text-decoration: none; text-transform: uppercase; font-style: italic; transition: transform 100ms, box-shadow 100ms; white-space: nowrap;"
          onmouseover="this.style.transform='translate(2px,2px)';this.style.boxShadow='2px 2px 0 rgba(0,0,0,0.3)'"
          onmouseout="this.style.transform='';this.style.boxShadow='6px 6px 0 rgba(0,0,0,0.3)'"
        >
          Launch Dashboard →
        </a>
      </div>
      <div style="background: var(--oc-bg-card); padding: 1.5rem 2.5rem; display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1.5rem;">
        <div>
          <span style="color: var(--oc-primary-bright); font-size: 1.25rem; display: block; margin-bottom: 0.25rem;">🔔</span>
          <span class="oc-headline" style="font-weight: 800; font-size: 0.75rem; text-transform: uppercase; color: var(--oc-text); display: block; margin-bottom: 0.25rem;">Real-time Monitoring</span>
          <span style="font-family: var(--oc-font-body); font-size: 0.75rem; color: var(--oc-text-dim); line-height: 1.4;">Polls GitHub releases and surfaces new versions the moment they drop.</span>
        </div>
        <div>
          <span style="color: var(--oc-primary-bright); font-size: 1.25rem; display: block; margin-bottom: 0.25rem;">⚡</span>
          <span class="oc-headline" style="font-weight: 800; font-size: 0.75rem; text-transform: uppercase; color: var(--oc-text); display: block; margin-bottom: 0.25rem;">Breaking Change Alerts</span>
          <span style="font-family: var(--oc-font-body); font-size: 0.75rem; color: var(--oc-text-dim); line-height: 1.4;">Flags breaking changes so you know before upgrading.</span>
        </div>
        <div>
          <span style="color: var(--oc-primary-bright); font-size: 1.25rem; display: block; margin-bottom: 0.25rem;">📊</span>
          <span class="oc-headline" style="font-weight: 800; font-size: 0.75rem; text-transform: uppercase; color: var(--oc-text); display: block; margin-bottom: 0.25rem;">Multi-Tool Dashboard</span>
          <span style="font-family: var(--oc-font-body); font-size: 0.75rem; color: var(--oc-text-dim); line-height: 1.4;">Claude Code, Codex, Gemini CLI, OpenCode — all tools in one view.</span>
        </div>
      </div>
    </section>

    <!-- Newsletter / Subscribe -->
    <section style="margin-bottom: 5rem; text-align: center; padding: 3rem 2rem; border: 4px solid var(--oc-border); background: var(--oc-bg-surface);">
      <h2 class="oc-headline" style="font-size: 2rem; font-weight: 900; text-transform: uppercase; font-style: italic; letter-spacing: -0.02em; margin: 0 0 0.75rem; color: var(--oc-text);">
        Stay in the Loop
      </h2>
      <p style="font-family: var(--oc-font-body); font-size: 0.95rem; color: var(--oc-text-dim); margin: 0 0 2rem; max-width: 480px; margin-left: auto; margin-right: auto; line-height: 1.5;">
        Get notified when OpenClaw ships new releases. No spam — just changelogs.
      </p>
      <div style="display: flex; flex-wrap: wrap; gap: 1rem; justify-content: center; align-items: center; max-width: 500px; margin: 0 auto 1.5rem;">
        <input
          type="email"
          placeholder="you@example.com"
          style="flex: 1; min-width: 220px; padding: 0.85rem 1rem; border: 4px solid var(--oc-border); background: var(--oc-bg); color: var(--oc-text); font-family: var(--oc-font-mono); font-size: 0.85rem; outline: none; transition: border-color 150ms;"
          onfocus="this.style.borderColor='var(--oc-primary)'"
          onblur="this.style.borderColor='var(--oc-border)'"
        />
        <button
          class="oc-headline"
          style="background: var(--oc-primary); color: white; font-weight: 900; padding: 0.85rem 1.75rem; font-size: 0.85rem; border: 4px solid var(--oc-border); box-shadow: var(--oc-shadow-sm); cursor: pointer; text-transform: uppercase; font-style: italic; transition: transform 100ms, box-shadow 100ms; position: relative; overflow: visible;"
          onmouseover="this.style.transform='translate(1px,1px)';this.style.boxShadow='none'"
          onmouseout="this.style.transform='';this.style.boxShadow='var(--oc-shadow-sm)'"
        >
          Subscribe
        </button>
      </div>
      <div style="display: flex; gap: 2rem; justify-content: center; flex-wrap: wrap;">
        <a href="/feed/all.xml" style="display: inline-flex; align-items: center; gap: 0.5rem; font-family: var(--oc-font-mono); font-size: 0.75rem; color: var(--oc-text-dim); text-decoration: none; transition: color 150ms;" onmouseover="this.style.color='var(--oc-primary-bright)'" onmouseout="this.style.color='var(--oc-text-dim)'">
          📡 RSS Feed
        </a>
        <a href={`https://github.com/${tool?.repo || "openclaw/openclaw"}`} target="_blank" rel="noopener noreferrer" style="display: inline-flex; align-items: center; gap: 0.5rem; font-family: var(--oc-font-mono); font-size: 0.75rem; color: var(--oc-text-dim); text-decoration: none; transition: color 150ms;" onmouseover="this.style.color='var(--oc-primary-bright)'" onmouseout="this.style.color='var(--oc-text-dim)'">
          ⭐ Star on GitHub
        </a>
        <a href={`https://github.com/${tool?.repo || "openclaw/openclaw"}/releases.atom`} target="_blank" rel="noopener noreferrer" style="display: inline-flex; align-items: center; gap: 0.5rem; font-family: var(--oc-font-mono); font-size: 0.75rem; color: var(--oc-text-dim); text-decoration: none; transition: color 150ms;" onmouseover="this.style.color='var(--oc-primary-bright)'" onmouseout="this.style.color='var(--oc-text-dim)'">
          🔖 GitHub Releases Atom
        </a>
      </div>
    </section>
  </div>

  <style>
    /* Dot grid background */
    .oc-dotgrid {
      background-image: radial-gradient(circle, var(--oc-border-dim) 1px, transparent 1px);
      background-size: 24px 24px;
    }

    /* Hero animations */
    .oc-hero-title {
      animation: oc-slide-in 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
    }
    .oc-hero-section p {
      animation: oc-slide-in 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both;
    }
    .oc-terminal-card {
      animation: oc-slide-in 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.2s both;
    }
    @keyframes oc-slide-in {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* Terminal cursor blink */
    .oc-cursor {
      animation: oc-blink 1s step-end infinite;
    }
    @keyframes oc-blink {
      0%, 100% { opacity: 1; }
      50% { opacity: 0; }
    }

    /* Live pulse dot */
    .oc-pulse-dot {
      animation: oc-pulse 2s ease-in-out infinite;
    }
    @keyframes oc-pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.4; }
    }

    /* CTA button hover */
    .oc-cta-btn {
      transition: transform 100ms, box-shadow 100ms;
    }
    .oc-cta-btn:hover {
      transform: translate(1px, 1px);
      box-shadow: none !important;
    }

    /* Section reveal on scroll */
    .oc-section-reveal {
      opacity: 0;
      transform: translateY(16px);
      animation: oc-slide-in 0.5s cubic-bezier(0.16, 1, 0.3, 1) 0.3s both;
    }

    /* Stats */
    .stats-cell {
      transition: background 150ms;
    }
    .stats-cell:hover {
      background: var(--oc-primary) !important;
    }
    .stats-cell:hover span:last-child {
      color: var(--oc-text) !important;
    }

    /* Quick links */
    .oc-quick-link {
      transition: border-color 150ms, box-shadow 150ms;
    }
    .oc-quick-link:hover {
      border-color: var(--oc-primary) !important;
      box-shadow: var(--oc-shadow-sm) !important;
    }

    /* Responsive hero */
    @media (max-width: 768px) {
      .oc-hero-grid {
        grid-template-columns: 1fr !important;
      }
      .oc-terminal-card {
        width: 100% !important;
      }
    }

    @media (max-width: 640px) {
      section[style*="display: flex; flex-wrap: wrap; gap: 0;"] {
        flex-direction: column !important;
      }
      section[style*="display: flex; flex-wrap: wrap; gap: 0;"] > div {
        border-right: none !important;
        border-bottom: 4px solid var(--oc-border) !important;
      }
      section[style*="display: flex; flex-wrap: wrap; gap: 0;"] > div:last-child {
        border-bottom: none !important;
      }
    }

    /* Respect reduced motion */
    @media (prefers-reduced-motion: reduce) {
      .oc-hero-title,
      .oc-hero-section p,
      .oc-terminal-card,
      .oc-section-reveal {
        animation: none !important;
        opacity: 1;
        transform: none;
      }
      .oc-cursor, .oc-pulse-dot {
        animation: none !important;
      }
    }
  </style>
</OpenClawLayout>
