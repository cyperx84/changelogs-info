---
import OpenClawLayout from "../../layouts/OpenClawLayout.astro";
import { getToolById, getToolReleases, formatDate, relativeTime } from "../../lib/releases";
import { marked } from "marked";
import { readFileSync } from "node:fs";
import { join } from "node:path";

const tool = getToolById("openclaw");
const data = await getToolReleases("openclaw");
const releases = data?.releases || [];
const stableReleases = releases.filter((r) => !r.prerelease);
const latestStable = stableReleases[0];
const latestRelease = releases[0];
const tldrReleases = releases.slice(0, 6);

const breakingCount = releases.filter((r) =>
  r.body?.toLowerCase().includes("breaking")
).length;

const displayVersion = latestStable?.version || latestRelease?.version || "—";
const lastUpdatedAgo = data?.lastUpdated ? relativeTime(data.lastUpdated) : null;

function isBreaking(body: string = ""): boolean {
  return body.toLowerCase().includes("breaking");
}

function renderBody(body: string): string {
  if (!body) return "";
  marked.setOptions({ gfm: true, breaks: false });
  return marked.parse(body) as string;
}

// Generate a short TLDR from the body
function getTldr(body: string): string[] {
  if (!body) return [];
  const lines = body.split("\n").filter(Boolean);
  const bullets: string[] = [];
  for (const line of lines) {
    // Match markdown list items and extract the key part
    const match = line.match(/^[\*\-]\s+(.+)/);
    if (match) {
      let text = match[1]
        .replace(/\*\*([^*]+)\*\*/g, "$1")  // strip bold
        .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")  // strip links
        .replace(/`([^`]+)`/g, "$1")  // strip code
        .replace(/\s+by\s+@\S+\s+in\s+https:\/\/\S+/g, "")  // strip PR refs
        .trim();
      if (text.length > 10 && !text.startsWith("http") && !text.startsWith("@")) {
        // Truncate long items
        if (text.length > 120) text = text.slice(0, 117) + "…";
        bullets.push(text);
      }
    }
  }
  return bullets.slice(0, 5); // top 5 changes per release
}
---

<OpenClawLayout
  title="OpenClaw — changelogs.info"
  description="Track OpenClaw releases, breaking changes, and config updates. Personal AI assistant platform — run your own AI on any device, any channel."
  currentPage="home"
>
  <div style="max-width: 1100px; margin: 0 auto; padding: 2rem 1.5rem 0;">

    <!-- Compact Hero -->
    <section style="margin-bottom: 3rem; display: flex; flex-wrap: wrap; gap: 2rem; align-items: center; justify-content: space-between;">
      <div style="display: flex; flex-direction: column; gap: 0.75rem;">
        <h1 class="oc-headline" style="font-size: clamp(3rem, 8vw, 5rem); font-weight: 900; color: var(--oc-text); text-transform: uppercase; line-height: 0.9; margin: 0;">
          Open<span style="color: var(--oc-primary-bright);">Claw</span>
        </h1>
        <p style="font-size: 1rem; color: var(--oc-text-dim); max-width: 32rem; line-height: 1.5; margin: 0; font-family: var(--oc-font-body);">
          {tool?.description || "Personal AI assistant platform — run your own AI on any device, any channel."}
        </p>
      </div>
      <div style="display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap;">
        <div style="display: flex; flex-direction: column; gap: 0.25rem; text-align: right;">
          <span style="font-family: var(--oc-font-mono); font-size: 1.75rem; color: var(--oc-text); font-weight: 700;">{displayVersion}</span>
          {lastUpdatedAgo && (
            <span style="font-family: var(--oc-font-mono); font-size: 0.7rem; color: var(--oc-text-muted); text-transform: uppercase;">Updated {lastUpdatedAgo}</span>
          )}
        </div>
        <a
          href={`https://github.com/${tool?.repo || "openclaw/openclaw"}`}
          target="_blank"
          rel="noopener noreferrer"
          class="oc-headline"
          style="background: var(--oc-primary); color: white; font-weight: 900; padding: 0.75rem 1.5rem; font-size: 0.9rem; border: 4px solid var(--oc-border); box-shadow: var(--oc-shadow-sm); text-decoration: none; text-transform: uppercase; font-style: italic; transition: transform 100ms, box-shadow 100ms;"
          onmouseover="this.style.transform='translate(1px,1px)';this.style.boxShadow='none'"
          onmouseout="this.style.transform='';this.style.boxShadow='var(--oc-shadow-sm)'"
        >
          GitHub ↗
        </a>
      </div>
    </section>

    <!-- Stats Bar -->
    <section style="display: flex; flex-wrap: wrap; gap: 0; border: 4px solid var(--oc-border); margin-bottom: 3rem;">
      {[
        { label: "Releases", value: String(releases.length) },
        { label: "Breaking", value: String(breakingCount), red: true },
        { label: "Stable", value: String(stableReleases.length) },
        { label: "Latest", value: displayVersion },
      ].map((stat, i) => (
        <div
          style={`flex: 1; min-width: 120px; padding: 1rem 1.25rem; ${i < 3 ? 'border-right: 4px solid var(--oc-border);' : ''} background: var(--oc-bg-card); cursor: crosshair; transition: background 150ms;`}
          onmouseover="this.style.background='var(--oc-primary)'"
          onmouseout="this.style.background='var(--oc-bg-card)'"
          class="stats-cell"
        >
          <span style="display: block; color: var(--oc-text-muted); font-family: var(--oc-font-headline); font-weight: 700; text-transform: uppercase; font-size: 0.55rem; letter-spacing: 0.15em; margin-bottom: 0.25rem;">{stat.label}</span>
          <span class="oc-headline" style={`display: block; font-size: 1.5rem; font-weight: 900; color: ${stat.red ? 'var(--oc-primary-bright)' : 'var(--oc-text)'};`}>{stat.value}</span>
        </div>
      ))}
    </section>

    <!-- TLDR Section -->
    <section style="margin-bottom: 4rem;">
      <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 2rem;">
        <h2 class="oc-headline" style="font-size: 2.5rem; font-weight: 900; color: var(--oc-text); text-transform: uppercase; font-style: italic; letter-spacing: -0.02em; margin: 0;">
          TL;DR
        </h2>
        <div style="flex: 1; height: 4px; background: var(--oc-border);"></div>
        <span style="font-family: var(--oc-font-mono); font-size: 0.7rem; color: var(--oc-text-muted); text-transform: uppercase;">Last {tldrReleases.length} releases</span>
      </div>

      <div style="display: flex; flex-direction: column; gap: 1.5rem;">
        {tldrReleases.map((release) => {
          const breaking = isBreaking(release.body);
          const tldr = getTldr(release.body || "");
          // Fallback: first non-empty, non-heading line
          const fallback = (release.body || "").split("\n").filter(l => l.trim() && !l.startsWith("#")).slice(0, 2).map(l => l.replace(/^[\*\-]\s+/, "").trim());
          const items = tldr.length > 0 ? tldr : fallback;

          return (
            <div style={`padding: 1.25rem 1.5rem; border: 4px solid ${breaking ? 'var(--oc-primary)' : 'var(--oc-border)'}; background: ${breaking ? 'var(--oc-bg-surface)' : 'var(--oc-bg-card)'}; ${breaking ? 'border-left: 8px solid var(--oc-primary);' : ''}`}>
              <div style="display: flex; justify-content: space-between; align-items: center; gap: 1rem; margin-bottom: 0.75rem; flex-wrap: wrap;">
                <div style="display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap;">
                  <span class="oc-headline" style="font-size: 1.1rem; font-weight: 900; color: var(--oc-text); text-transform: uppercase;">{release.version}</span>
                  {breaking && (
                    <span style="background: var(--oc-primary); color: white; font-family: var(--oc-font-mono); padding: 0.15rem 0.5rem; font-size: 0.6rem; font-weight: 700; text-transform: uppercase;">BREAKING</span>
                  )}
                  {release.prerelease && (
                    <span style="background: rgba(255,184,0,0.15); color: #ffb800; font-family: var(--oc-font-mono); padding: 0.15rem 0.5rem; font-size: 0.6rem; font-weight: 700; text-transform: uppercase; border: 1px solid #ffb800;">PRE</span>
                  )}
                </div>
                <span style="font-family: var(--oc-font-mono); font-size: 0.7rem; color: var(--oc-text-muted); white-space: nowrap;">{formatDate(release.date)}</span>
              </div>
              {items.length > 0 && (
                <ul style="list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.3rem;">
                  {items.map((item) => (
                    <li style="display: flex; gap: 0.5rem; align-items: flex-start; font-family: var(--oc-font-body); font-size: 0.85rem; color: var(--oc-text-dim); line-height: 1.5;">
                      <span style="color: var(--oc-primary-bright); flex-shrink: 0; font-weight: 700;">▸</span>
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
              )}
            </div>
          );
        })}
      </div>
    </section>

    <!-- Divider -->
    <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 3rem;">
      <div style="flex: 1; height: 4px; background: var(--oc-border);"></div>
      <span class="oc-headline" style="font-size: 0.75rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.15em; color: var(--oc-text-muted);">Full Changelog</span>
      <div style="flex: 1; height: 4px; background: var(--oc-border);"></div>
    </div>

    <!-- Full Changelog (expandable) -->
    <section style="position: relative; padding-left: 3rem; border-left: 6px solid var(--oc-border); margin-bottom: 5rem;">
      {releases.length > 0 ? (
        <div style="display: flex; flex-direction: column; gap: 4rem;">
          {releases.map((release, idx) => {
            const breaking = isBreaking(release.body);
            const renderedBody = renderBody(release.body || "");
            const isLong = (release.body || "").length > 600;

            return (
              <article
                class="cl-entry"
                data-version={release.version.toLowerCase()}
                data-name={(release.name || "").toLowerCase()}
                data-body={(release.body || "").toLowerCase().slice(0, 800)}
                data-prerelease={String(release.prerelease)}
                data-breaking={String(breaking)}
                style="position: relative;"
              >
                <!-- Timeline dot -->
                <div
                  style={`position: absolute; left: -3.9rem; top: 0.5rem; width: 3rem; height: 3rem; border: 4px solid var(--oc-border); display: flex; align-items: center; justify-content: center; background: ${breaking ? 'var(--oc-primary)' : 'var(--oc-border)'};`}
                >
                  <span style={`font-size: 0.8rem; ${breaking ? 'color:white;' : 'color: var(--oc-bg);'}`}>
                    {breaking ? "⚡" : release.prerelease ? "β" : "●"}
                  </span>
                </div>

                <!-- Entry header -->
                <div style="display: flex; flex-wrap: wrap; gap: 1rem; align-items: baseline; margin-bottom: 1rem;">
                  <span
                    class="oc-headline"
                    style="font-size: 2rem; font-weight: 900; font-style: italic; letter-spacing: -0.02em; color: var(--oc-text);"
                  >
                    {release.version}
                  </span>
                  <span
                    class="oc-headline"
                    style="font-size: 0.85rem; font-weight: 700; text-transform: uppercase; color: var(--oc-text-muted); letter-spacing: 0.05em;"
                  >
                    {formatDate(release.date)}
                  </span>
                  {breaking && (
                    <span style="background: var(--oc-primary); color: white; padding: 0.2rem 0.75rem; font-family: var(--oc-font-headline); font-size: 0.7rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.1em; border: 2px solid var(--oc-border);">
                      BREAKING
                    </span>
                  )}
                  {release.prerelease && (
                    <span style="background: rgba(255,184,0,0.15); color: #ffb800; padding: 0.2rem 0.75rem; font-family: var(--oc-font-headline); font-size: 0.7rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.1em; border: 2px solid #ffb800;">
                      PRE-RELEASE
                    </span>
                  )}
                </div>

                <!-- Entry card -->
                <div
                  style={`padding: 2rem; border: 4px solid var(--oc-border); background: ${breaking ? 'var(--oc-border)' : 'var(--oc-bg-surface)'}; ${breaking ? 'border-right: 8px solid var(--oc-primary); border-bottom: 8px solid var(--oc-primary);' : ''}`}
                >
                  <h3
                    class="oc-headline"
                    style={`font-size: 1.5rem; font-weight: 900; text-transform: uppercase; margin: 0 0 1.5rem; letter-spacing: -0.01em; color: ${breaking ? 'var(--oc-bg)' : 'var(--oc-text)'};`}
                  >
                    {(release.name || release.version).replace(/^openclaw\s+/i, "")}
                  </h3>

                  <div
                    class={`changelog-body ${isLong && idx > 0 ? 'cl-collapsed' : ''}`}
                    style={`color: ${breaking ? 'var(--oc-bg)' : 'var(--oc-text-dim)'}; font-size: 0.875rem; line-height: 1.7; font-family: var(--oc-font-body); overflow: hidden; position: relative;`}
                    set:html={renderedBody}
                  />

                  {isLong && (
                    <button
                      class="cl-expand-btn oc-headline"
                      style={`display: block; margin-top: 1rem; background: transparent; border: 2px solid ${breaking ? 'var(--oc-bg)' : 'var(--oc-border)'}; color: ${breaking ? 'var(--oc-bg)' : 'var(--oc-text)'}; padding: 0.5rem 1.25rem; font-size: 0.7rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.1em; cursor: pointer; transition: background 100ms; position: relative; overflow: visible;`}
                      onclick="this.previousElementSibling.classList.toggle('cl-collapsed'); this.textContent = this.textContent.includes('EXPAND') ? '▲ COLLAPSE' : '▼ EXPAND FULL CHANGELOG'"
                    >
                      {idx === 0 ? '▲ COLLAPSE' : '▼ EXPAND FULL CHANGELOG'}
                    </button>
                  )}

                  <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 1.5rem; padding-top: 1rem; border-top: 2px solid var(--oc-border-dim);">
                    <a
                      href={release.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="oc-headline"
                      style={`display: inline-flex; align-items: center; gap: 0.5rem; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; color: ${breaking ? 'var(--oc-primary)' : 'var(--oc-primary-bright)'}; text-decoration: none; transition: opacity 150ms;`}
                      onmouseover="this.style.opacity='0.7'"
                      onmouseout="this.style.opacity='1'"
                    >
                      ↗ View on GitHub
                    </a>
                    <span style="font-family: var(--oc-font-mono); font-size: 0.65rem; color: var(--oc-text-muted);">
                      #{idx + 1}
                    </span>
                  </div>
                </div>
              </article>
            );
          })}
        </div>
      ) : (
        <div style="padding: 3rem; border: 4px dashed var(--oc-border-dim); text-align: center;">
          <p class="oc-headline" style="font-weight: 700; text-transform: uppercase; color: var(--oc-text-muted);">No releases tracked yet.</p>
        </div>
      )}
    </section>
  </div>

  <style>
    .stats-cell:hover span:last-child {
      color: var(--oc-text) !important;
    }
    @media (max-width: 640px) {
      section[style*="display: flex; flex-wrap: wrap; gap: 0;"] {
        flex-direction: column !important;
      }
      section[style*="display: flex; flex-wrap: wrap; gap: 0;"] > div {
        border-right: none !important;
        border-bottom: 4px solid var(--oc-border) !important;
      }
      section[style*="display: flex; flex-wrap: wrap; gap: 0;"] > div:last-child {
        border-bottom: none !important;
      }
    }
  </style>
</OpenClawLayout>
