---
import OpenClawLayout from "../../layouts/OpenClawLayout.astro";
import { getToolById, getToolReleases, formatDate, relativeTime } from "../../lib/releases";
import { marked } from "marked";
import { readFileSync } from "node:fs";
import { join } from "node:path";

const tool = getToolById("openclaw");
const data = await getToolReleases("openclaw");
const releases = data?.releases || [];
const stableReleases = releases.filter((r) => !r.prerelease);
const latestStable = stableReleases[0];
const latestRelease = releases[0];
const latestForTldr = releases[0];

const breakingCount = releases.filter((r) =>
  r.body?.toLowerCase().includes("breaking")
).length;

const displayVersion = latestStable?.version || latestRelease?.version || "—";
const lastUpdatedAgo = data?.lastUpdated ? relativeTime(data.lastUpdated) : null;

function getPayloadTldr(toolId: string): string | null {
  try {
    const path = join(process.cwd(), "public", "api", "refs", `${toolId}.json`);
    const payload = JSON.parse(readFileSync(path, "utf-8"));
    return payload?.payload?.meta?.tldr ?? null;
  } catch {
    return null;
  }
}

const llmTldr = getPayloadTldr("openclaw");

async function getCanonicalChangelogEntries(): Promise<{ version: string; heading: string; body: string }[]> {
  try {
    const response = await fetch("https://raw.githubusercontent.com/openclaw/openclaw/main/CHANGELOG.md");
    if (!response.ok) return [];

    const changelog = (await response.text()).replace(/\r\n/g, "\n");
    if (/github releases/i.test(changelog) && changelog.split("\n").length < 20) return [];

    const matches = [...changelog.matchAll(/^##\s+v?(\d+(?:\.\d+)+(?:[-+][A-Za-z0-9.-]+)?)\s*$/gm)];
    const entries: { version: string; heading: string; body: string }[] = [];

    for (let i = 0; i < matches.length && entries.length < 3; i++) {
      const match = matches[i];
      const version = match[1];
      const start = match.index ?? 0;
      const end = i + 1 < matches.length ? (matches[i + 1].index ?? changelog.length) : changelog.length;
      const section = changelog.slice(start, end).trim();
      if (section.length > 20) {
        entries.push({ version, heading: `v${version}`, body: section });
      }
    }

    return entries;
  } catch {
    return [];
  }
}

const canonicalEntries = await getCanonicalChangelogEntries();

function isBreaking(body: string = ""): boolean {
  return body.toLowerCase().includes("breaking");
}

const PRIORITY_PREFIXES = ["BREAKING", "SEC", "FEAT", "PERF"];
const MINOR_PREFIXES = ["FIX", "TEST", "CHORE", "CI", "BUILD", "STYLE"];

function escapeHtml(text: string): string {
  return text
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/\"/g, "&quot;")
    .replace(/'/g, "&#39;");
}

function normalizeReleaseBody(body: string): string {
  if (!body) return "";

  let normalized = body.replace(/\r\n/g, "\n").trim();

  normalized = normalized
    .replace(/^\s*##\s*what'?s changed\s*$/gim, "## Changes")
    .replace(/^\s*##\s*full changelog\s*$/gim, "")
    .replace(/^\s*\*\*full changelog\*\*: ?\s*$/gim, "")
    .replace(/^\s*full changelog:?\s*$/gim, "")
    .replace(/^\s*important:?\s*$/gim, "## Important")
    .replace(/^\s*summary:?\s*$/gim, "## Summary")
    .replace(/^\s*notes:?\s*$/gim, "## Notes")
    .replace(/\n{3,}/g, "\n\n");

  const lines = normalized.split("\n");
  const cleaned: string[] = [];
  let skipGithubBoilerplate = false;

  for (const line of lines) {
    const trimmed = line.trim();

    if (!trimmed) {
      if (cleaned.length > 0 && cleaned[cleaned.length - 1] !== "") cleaned.push("");
      continue;
    }

    if (/^\[?full changelog\]?[:：]?$/i.test(trimmed)) continue;
    if (/^full changelog:?\s*https?:\/\//i.test(trimmed)) continue;
    if (/^see full changelog/i.test(trimmed)) continue;
    if (/^compare:/i.test(trimmed)) continue;

    if (/^##\s*new contributors\s*$/i.test(trimmed)) {
      skipGithubBoilerplate = true;
      continue;
    }
    if (skipGithubBoilerplate) {
      if (/^##\s+/.test(trimmed)) skipGithubBoilerplate = false;
      else continue;
    }

    let nextLine = line
      .replace(/\*\*full changelog\*\*:\s*https?:\/\/\S+/gi, "")
      .replace(/\[full changelog\]\([^)]*\)/gi, "")
      .replace(/\s+by\s+@\S+\s+in\s+https?:\/\/\S+/gi, "")
      .replace(/\s+by\s+@\S+\s+in\s+#\d+/gi, "")
      .replace(/\s+in\s+https?:\/\/\S+/gi, "")
      .replace(/\s{2,}/g, " ")
      .trimEnd();

    if (/^[*-]\s+[^\s].*/.test(nextLine)) {
      nextLine = nextLine.replace(/^([*-]\s+)(fix|feat|docs|test|chore|refactor|perf|style|ci|build|docker|sec|security|breaking)(\([^)]*\))?:\s*/i, "$1$2: ");
    }

    cleaned.push(nextLine);
  }

  return cleaned.join("\n").replace(/\n{3,}/g, "\n\n").trim();
}

function stripMarkdown(text: string): string {
  return text
    .replace(/\*\*([^*]+)\*\*/g, "$1")
    .replace(/__([^_]+)__/g, "$1")
    .replace(/`([^`]+)`/g, "$1")
    .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")
    .replace(/\s+by\s+@\S+\s+in\s+https?:\/\/\S+/gi, "")
    .replace(/\s+by\s+@\S+\s+in\s+#\d+/gi, "")
    .replace(/\s+in\s+https?:\/\/\S+/gi, "")
    .replace(/\s{2,}/g, " ")
    .trim();
}

type ParsedItem = { prefix: string | null; content: string; raw: string };
type ParsedSection = { heading: string; items: ParsedItem[] };

function classifyLine(text: string): { prefix: string | null; content: string } {
  const cleaned = stripMarkdown(text).replace(/^[*-]\s+/, "").trim();
  const match = cleaned.match(/^(BREAKING|SECURITY|SEC|FEAT|FIX|DOCS|TEST|CHORE|REFACTOR|PERF|STYLE|CI|BUILD|OTHER)(\([^)]*\))?:\s*(.+)$/i);
  if (!match) return { prefix: null, content: cleaned };
  const prefix = match[1].toUpperCase() === "SECURITY" ? "SEC" : match[1].toUpperCase();
  return { prefix, content: match[3].trim() || cleaned };
}

function parseChangelog(body: string): ParsedSection[] {
  const normalized = normalizeReleaseBody(body);
  if (!normalized) return [];

  const lines = normalized.split("\n");
  const sections: ParsedSection[] = [];
  let current: ParsedSection | null = null;

  const ensureDefaultSection = () => {
    if (!current) {
      current = { heading: "Changes", items: [] };
      sections.push(current);
    }
  };

  for (const line of lines) {
    const trimmed = line.trim();
    if (!trimmed) continue;
    if (/^##\s+/.test(trimmed)) continue;

    const headingMatch = trimmed.match(/^###\s+(.+)$/);
    if (headingMatch) {
      current = { heading: stripMarkdown(headingMatch[1]), items: [] };
      sections.push(current);
      continue;
    }

    if (/^[*-]\s+/.test(trimmed)) {
      ensureDefaultSection();
      const parsed = classifyLine(trimmed);
      if (parsed.content) current!.items.push({ ...parsed, raw: trimmed });
      continue;
    }

    if (/^(BREAKING|SECURITY|SEC|FEAT|FIX|DOCS|TEST|CHORE|REFACTOR|PERF|STYLE|CI|BUILD|OTHER)(\([^)]*\))?:\s+/i.test(trimmed)) {
      ensureDefaultSection();
      const parsed = classifyLine(`- ${trimmed}`);
      if (parsed.content) current!.items.push({ ...parsed, raw: trimmed });
      continue;
    }

    ensureDefaultSection();
    current!.items.push({ prefix: null, content: stripMarkdown(trimmed), raw: trimmed });
  }

  return sections.filter((section) => section.items.length > 0);
}

function renderPrefix(prefix: string | null): string {
  if (!prefix) return "";
  const palette: Record<string, string> = {
    BREAKING: "background: var(--oc-primary); color: #fff; border-color: var(--oc-primary);",
    FEAT: "background: rgba(34,197,94,0.12); color: #22c55e; border-color: #22c55e;",
    FIX: "background: rgba(59,130,246,0.12); color: #60a5fa; border-color: #60a5fa;",
    DOCS: "background: rgba(168,85,247,0.12); color: #c084fc; border-color: #c084fc;",
    PERF: "background: rgba(245,158,11,0.12); color: #f59e0b; border-color: #f59e0b;",
    REFACTOR: "background: rgba(236,72,153,0.12); color: #f472b6; border-color: #f472b6;",
    CI: "background: rgba(6,182,212,0.12); color: #22d3ee; border-color: #22d3ee;",
    BUILD: "background: rgba(6,182,212,0.12); color: #22d3ee; border-color: #22d3ee;",
    CHORE: "background: rgba(148,163,184,0.12); color: #cbd5e1; border-color: #94a3b8;",
    TEST: "background: rgba(20,184,166,0.12); color: #2dd4bf; border-color: #2dd4bf;",
    STYLE: "background: rgba(244,114,182,0.12); color: #f9a8d4; border-color: #f9a8d4;",
    SEC: "background: rgba(239,68,68,0.12); color: #f87171; border-color: #f87171;",
  };
  const style = palette[prefix] || "background: rgba(255,255,255,0.06); color: currentColor; border-color: currentColor;";
  return `<span style="display:inline-flex;align-items:center;justify-content:center;min-width:3.35rem;padding:0.12rem 0.45rem;border:1.5px solid currentColor;font-family:inherit;font-size:0.68em;font-weight:800;letter-spacing:0.08em;text-transform:uppercase;vertical-align:middle;flex-shrink:0;${style}">${escapeHtml(prefix)}</span>`;
}

function renderChangelogItem(item: ParsedItem): string {
  return `<li class="oc-flex">${renderPrefix(item.prefix)}<span class="oc-s1">${escapeHtml(item.content)}</span></li>`;
}

function renderChangelogSection(title: string, items: ParsedItem[], emphasized = false): string {
  if (items.length === 0) return "";
  return `<div style="padding:1rem 1.1rem; border:3px solid var(--oc-border); background:${emphasized ? 'var(--oc-bg-surface)' : 'transparent'};">`
    + `<div class="oc-s2">${escapeHtml(title)}</div>`
    + `<ul class="oc-vstack">${items.map(renderChangelogItem).join("")}</ul>`
    + `</div>`;
}

function buildChangelogCard(body: string): string {
  const sections = parseChangelog(body);
  const allItems = sections.flatMap((section) => section.items.map((item) => ({ ...item, heading: section.heading })));

  const highlights = allItems.filter((item) => item.prefix && PRIORITY_PREFIXES.includes(item.prefix)).slice(0, 4);
  const notable = allItems
    .filter((item) => !highlights.includes(item))
    .filter((item) => !item.prefix || !MINOR_PREFIXES.includes(item.prefix) || item.prefix === "DOCS" || item.prefix === "REFACTOR")
    .slice(0, 6);
  const used = new Set([...highlights, ...notable]);
  const overflow = allItems.filter((item) => !used.has(item));

  const overflowHtml = overflow.length === 0
    ? ""
    : `<details class="oc-s4"><summary class="oc-s5">Show all changes <span class="oc-s6">(${overflow.length} more)</span></summary><div class="oc-vstack-2">${sections.map((section) => {
        const sectionItems = overflow.filter((item) => item.heading === section.heading);
        if (sectionItems.length === 0) return "";
        return `<div><div class="oc-s8">${escapeHtml(section.heading)}</div><ul class="oc-vstack-3">${sectionItems.map(renderChangelogItem).join("")}</ul></div>`;
      }).join("")}</div></details>`;

  const fallback = sections.length > 0 && highlights.length === 0 && notable.length === 0
    ? renderChangelogSection(sections[0].heading, sections[0].items.slice(0, 6), false)
    : "";

  return `<div class="oc-vstack-4">${renderChangelogSection("Highlights", highlights, true)}${renderChangelogSection("Notable changes", notable, false)}${fallback}${overflowHtml}</div>`;
}

function getTldr(body: string): string[] {
  return parseChangelog(body)
    .flatMap((section) => section.items)
    .map((item) => item.content)
    .filter(Boolean)
    .slice(0, 5);
}
---

<OpenClawLayout
  title="OpenClaw Changelog — All Releases & Updates | changelogs.info"
  description="Track OpenClaw releases, breaking changes, and config updates. Personal AI assistant platform — run your own AI on any device, any channel."
  currentPage="home"
>
  <!-- Dot grid background -->
  <div class="oc-dotgrid oc-s11"></div>

  <div class="oc-s12">

    <!-- Hero -->
    <section class="oc-hero-section oc-grid">
      <div class="oc-grid-2 oc-hero-grid">
        <!-- Left: text + CTA -->
        <div class="oc-vstack-5">
          <!-- Live badge -->
          <div class="oc-flex-2">
            <span class="oc-pulse-dot oc-s17"></span>
            <span class="oc-label">Tracking {canonicalEntries.length} latest entries</span>
          </div>

          <h1 class="oc-headline oc-hero-title oc-s19">
            Open<span class="oc-s43">Claw</span>
          </h1>

          <p class="oc-s21">
            {tool?.description || "Personal AI assistant platform — run your own AI on any device, any channel."}
          </p>

          <!-- CTA row -->
          <div class="oc-flex-3">
            <a
              href={`https://github.com/${tool?.repo || "openclaw/openclaw"}`}
              target="_blank"
              rel="noopener noreferrer"
              class="oc-headline oc-cta-btn oc-s23"
            >
              GitHub ↗
            </a>
            <a
              href="/openclaw/changelog/"
              class="oc-headline oc-cta-btn oc-s24"
            >
              Changelog
            </a>
          </div>
        </div>

        <!-- Right: terminal card -->
        <div class="oc-terminal-card oc-s25">
          <!-- Title bar -->
          <div class="oc-flex-4">
            <span class="oc-s27"></span>
            <span class="oc-s28"></span>
            <span class="oc-s29"></span>
            <span class="oc-s30">openclaw status</span>
          </div>
          <!-- Terminal body -->
          <div class="oc-s31">
            <div><span class="oc-s43">❯</span> openclaw status</div>
            <div class="oc-s33">
              <span class="oc-s40">●</span> Gateway: <span class="oc-s40">running</span>
            </div>
            <div>
              <span class="oc-s40">●</span> Version: <span class="oc-s41">{displayVersion}</span>
            </div>
            <div>
              <span class="oc-s40">●</span> Releases: <span class="oc-s41">{releases.length}</span> tracked
            </div>
            <div>
              <span style="color: {breakingCount > 0 ? 'var(--oc-primary-bright)' : '#22c55e'};">{breakingCount > 0 ? '⚠' : '●'}</span> Breaking: <span style="color: {breakingCount > 0 ? 'var(--oc-primary-bright)' : 'var(--oc-text)'};">{breakingCount}</span>
            </div>
            <div>
              <span class="oc-s40">●</span> Updated: <span class="oc-s41">{lastUpdatedAgo || "now"}</span>
            </div>
            <div class="oc-s42">
              <span class="oc-s43">❯</span> <span class="oc-cursor">_</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats Bar -->
    <section class="oc-section-reveal oc-flex-5">
      {[
        { label: "Releases", value: String(releases.length) },
        { label: "Breaking", value: String(breakingCount), red: true },
        { label: "Stable", value: String(stableReleases.length) },
        { label: "Latest", value: displayVersion },
      ].map((stat, i) => (
        <div
          style={`flex: 1; min-width: 120px; padding: 1rem 1.25rem; ${i < 3 ? 'border-right: 4px solid var(--oc-border);' : ''} background: var(--oc-bg-card); cursor: crosshair; transition: background 150ms;`}
          class="stats-cell"
        >
          <span class="oc-s45">{stat.label}</span>
          <span class="oc-headline" style={`display: block; font-size: 1.5rem; font-weight: 900; color: ${stat.red ? 'var(--oc-primary-bright)' : 'var(--oc-text)'};`}>{stat.value}</span>
        </div>
      ))}
    </section>

    <!-- TLDR: Latest Release -->
    {latestForTldr && (() => {
      const breaking = isBreaking(latestForTldr.body);
      const tldr = getTldr(latestForTldr.body || "");
      const fallback = (latestForTldr.body || "").split("\n").filter(l => l.trim() && !l.startsWith("#")).slice(0, 2).map(l => l.replace(/^[\*\-]\s+/, "").trim());
      const items = tldr.length > 0 ? tldr : fallback;
      const summaryText = llmTldr?.trim() || null;

      return (
        <section class="oc-s46">
          <div class="oc-flex-6">
            <h2 class="oc-headline oc-s48">
              TL;DR
            </h2>
            <div class="oc-s65"></div>
            <span class="oc-s50">Latest Release</span>
          </div>

          <div style={`padding: 1.5rem 2rem; border: 4px solid ${breaking ? 'var(--oc-primary)' : 'var(--oc-border)'}; background: ${breaking ? 'var(--oc-bg-surface)' : 'var(--oc-bg-card)'}; ${breaking ? 'border-left: 8px solid var(--oc-primary);' : ''}`}>
            <div class="oc-flex-11">
              <div class="oc-flex-7">
                <span class="oc-headline oc-s53">{latestForTldr.version}</span>
                {breaking && (
                  <span class="oc-s70">BREAKING</span>
                )}
                {latestForTldr.prerelease && (
                  <span class="oc-s55">PRE</span>
                )}
              </div>
              <span class="oc-s71">{formatDate(latestForTldr.date)}</span>
            </div>
            <img src="/images/guides/openclaw-tldr.jpg" alt="openclaw TLDR" style="width:100%;border-radius:12px;margin-bottom:1rem;border:2px solid var(--oc-border);" />
            {summaryText ? (
              <div class="oc-vstack-6">
                <p class="oc-s58">{summaryText}</p>
              </div>
            ) : items.length > 0 && (
              <ul class="oc-vstack-7">
                {items.map((item) => (
                  <li class="oc-flex-9">
                    <span class="oc-s61">▸</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            )}
          </div>
        </section>
      );
    })()}

    <!-- Previous 3 Releases -->
    <div class="oc-flex-10">
      <div class="oc-s65"></div>
      <span class="oc-headline oc-s64">Recent Changelog</span>
      <div class="oc-s65"></div>
    </div>

    <section class="oc-vstack-8">
      {canonicalEntries.map((entry) => {
        const release = releases.find((r) => r.version === entry.version) || latestForTldr;
        const breaking = isBreaking(entry.body);
        const renderedBody = buildChangelogCard(entry.body || "");
        return (
          <div style={`padding: 1.5rem 2rem; border: 4px solid ${breaking ? 'var(--oc-primary)' : 'var(--oc-border)'}; background: ${breaking ? 'var(--oc-bg-surface)' : 'var(--oc-bg-card)'}; ${breaking ? 'border-left: 8px solid var(--oc-primary);' : ''}`}>
            <div class="oc-flex-11">
              <div class="oc-flex-7">
                <span class="oc-headline oc-s69">{entry.version}</span>
                {breaking && (
                  <span class="oc-s70">BREAKING</span>
                )}
              </div>
              <span class="oc-s71">{formatDate(release.date)}</span>
            </div>
            <div
              class="changelog-body oc-s72"
              set:html={renderedBody}
            />
          </div>
        );
      })}
      <a
        href="/openclaw/changelog/"
        class="oc-headline oc-flex-8"
      >
        View full changelog →
      </a>
    </section>

    <!-- Quick Links -->
    <section class="oc-grid-3">
      <a href="/openclaw/quickstart/" class="oc-quick-link oc-flex-13">
        <span class="oc-s88">🚀</span>
        <div>
          <span class="oc-headline oc-s89">Quickstart</span>
          <span class="oc-s90">Up & running in 10 min</span>
        </div>
      </a>
      <a href="/openclaw/tips/" class="oc-quick-link oc-flex-13">
        <span class="oc-s88">💡</span>
        <div>
          <span class="oc-headline oc-s89">Tips & Tricks</span>
          <span class="oc-s90">Quick wins & hidden features</span>
        </div>
      </a>
      <a href="/openclaw/changelog/" class="oc-quick-link oc-flex-13">
        <span class="oc-s88">📋</span>
        <div>
          <span class="oc-headline oc-s89">Full Changelog</span>
          <span class="oc-s90">{releases.length} releases</span>
        </div>
      </a>
      <a href="/openclaw/cheatsheet/" class="oc-quick-link oc-flex-13">
        <span class="oc-s88">⚡</span>
        <div>
          <span class="oc-headline oc-s89">Cheatsheet</span>
          <span class="oc-s90">Commands & tips</span>
        </div>
      </a>
      <a href="/openclaw/releases/" class="oc-quick-link oc-flex-13">
        <span class="oc-s88">📦</span>
        <div>
          <span class="oc-headline oc-s89">All Releases</span>
          <span class="oc-s90">Browse & filter</span>
        </div>
      </a>
      <a href="/feed/all.xml" class="oc-quick-link oc-flex-13">
        <span class="oc-s88">📡</span>
        <div>
          <span class="oc-headline oc-s89">RSS Feed</span>
          <span class="oc-s90">Subscribe to updates</span>
        </div>
      </a>
    </section>

    <!-- Clwatch Section -->
    <section class="oc-s91">
      <div class="oc-flex-12">
        <div class="oc-s93">
          <h2 class="oc-headline oc-s94">
            Clwatch
          </h2>
          <p class="oc-s95">
            Monitor coding CLI releases in real-time. Track Claude Code, Codex CLI, Gemini CLI, and OpenClaw all in one dashboard. Get notified when new versions drop.
          </p>
        </div>
        <a
          href="/clwatch"
          class="oc-headline oc-s96"
          onmouseover="this.style.transform='translate(2px,2px)';this.style.boxShadow='2px 2px 0 rgba(0,0,0,0.3)'"
          onmouseout="this.style.transform='';this.style.boxShadow='6px 6px 0 rgba(0,0,0,0.3)'"
        >
          Launch Dashboard →
        </a>
      </div>
      <div class="oc-grid-4">
        <div>
          <span class="oc-s104">🔔</span>
          <span class="oc-headline oc-s105">Real-time Monitoring</span>
          <span class="oc-s106">Polls GitHub releases and surfaces new versions the moment they drop.</span>
        </div>
        <div>
          <span class="oc-s104">⚡</span>
          <span class="oc-headline oc-s105">Breaking Change Alerts</span>
          <span class="oc-s106">Flags breaking changes so you know before upgrading.</span>
        </div>
        <div>
          <span class="oc-s104">📊</span>
          <span class="oc-headline oc-s105">Multi-Tool Dashboard</span>
          <span class="oc-s106">Claude Code, Codex, Gemini CLI, OpenCode — all tools in one view.</span>
        </div>
      </div>
    </section>

    <!-- Newsletter / Subscribe -->
    <section class="oc-s107">
      <h2 class="oc-headline oc-s108">
        Stay in the Loop
      </h2>
      <p class="oc-s109">
        Get notified when OpenClaw ships new releases. No spam — just changelogs.
      </p>
      <div class="oc-flex-14">
        <input
          type="email"
          placeholder="you@example.com"
          class="oc-flex-item"
          onfocus="this.style.borderColor='var(--oc-primary)'"
          onblur="this.style.borderColor='var(--oc-border)'"
        />
        <button
          class="oc-headline oc-s112"
          onmouseover="this.style.transform='translate(1px,1px)';this.style.boxShadow='none'"
          onmouseout="this.style.transform='';this.style.boxShadow='var(--oc-shadow-sm)'"
        >
          Subscribe
        </button>
      </div>
      <div class="oc-flex-15">
        <a href="/feed/all.xml" class="oc-flex-16" onmouseover="this.style.color='var(--oc-primary-bright)'" onmouseout="this.style.color='var(--oc-text-dim)'">
          📡 RSS Feed
        </a>
        <a href={`https://github.com/${tool?.repo || "openclaw/openclaw"}`} target="_blank" rel="noopener noreferrer" class="oc-flex-16" onmouseover="this.style.color='var(--oc-primary-bright)'" onmouseout="this.style.color='var(--oc-text-dim)'">
          ⭐ Star on GitHub
        </a>
        <a href={`https://github.com/${tool?.repo || "openclaw/openclaw"}/releases.atom`} target="_blank" rel="noopener noreferrer" class="oc-flex-16" onmouseover="this.style.color='var(--oc-primary-bright)'" onmouseout="this.style.color='var(--oc-text-dim)'">
          🔖 GitHub Releases Atom
        </a>
      </div>
    </section>
  </div>

  <style>
    /* Dot grid background */
    .oc-dotgrid {
      background-image: radial-gradient(circle, var(--oc-border-dim) 1px, transparent 1px);
      background-size: 24px 24px;
    }

    /* Hero animations */
    .oc-hero-title {
      animation: oc-slide-in 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
    }
    .oc-hero-section p {
      animation: oc-slide-in 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both;
    }
    .oc-terminal-card {
      animation: oc-slide-in 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.2s both;
    }
    @keyframes oc-slide-in {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* Terminal cursor blink */
    .oc-cursor {
      animation: oc-blink 1s step-end infinite;
    }
    @keyframes oc-blink {
      0%, 100% { opacity: 1; }
      50% { opacity: 0; }
    }

    /* Live pulse dot */
    .oc-pulse-dot {
      animation: oc-pulse 2s ease-in-out infinite;
    }
    @keyframes oc-pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.4; }
    }

    /* CTA button hover */
    .oc-cta-btn {
      transition: transform 100ms, box-shadow 100ms;
    }
    .oc-cta-btn:hover {
      transform: translate(1px, 1px);
      box-shadow: none !important;
    }

    /* Section reveal on scroll */
    .oc-section-reveal {
      opacity: 0;
      transform: translateY(16px);
      animation: oc-slide-in 0.5s cubic-bezier(0.16, 1, 0.3, 1) 0.3s both;
    }

    /* Stats */
    .stats-cell {
      transition: background 150ms;
    }
    .stats-cell:hover {
      background: var(--oc-primary) !important;
    }
    .stats-cell:hover span:last-child {
      color: var(--oc-text) !important;
    }

    /* Quick links */
    .oc-quick-link {
      transition: border-color 150ms, box-shadow 150ms;
    }
    .oc-quick-link:hover {
      border-color: var(--oc-primary) !important;
      box-shadow: var(--oc-shadow-sm) !important;
    }

    /* Responsive hero */
    @media (max-width: 768px) {
      .oc-hero-grid {
        grid-template-columns: 1fr !important;
      }
      .oc-terminal-card {
        width: 100% !important;
      }
    }

    @media (max-width: 640px) {
      section[style*="display: flex; flex-wrap: wrap; gap: 0;"] {
        flex-direction: column !important;
      }
      section[style*="display: flex; flex-wrap: wrap; gap: 0;"] > div {
        border-right: none !important;
        border-bottom: 4px solid var(--oc-border) !important;
      }
      section[style*="display: flex; flex-wrap: wrap; gap: 0;"] > div:last-child {
        border-bottom: none !important;
      }
    }

    /* Respect reduced motion */
    @media (prefers-reduced-motion: reduce) {
      .oc-hero-title,
      .oc-hero-section p,
      .oc-terminal-card,
      .oc-section-reveal {
        animation: none !important;
        opacity: 1;
        transform: none;
      }
      .oc-cursor, .oc-pulse-dot {
        animation: none !important;
      }
    }
  </style>
</OpenClawLayout>
