---
import "../styles/global.css";
import Search from "../components/Search.astro";
import Haptics from "../components/Haptics.astro";
import { ViewTransitions } from "astro:transitions";

type SectionId = "openclaw" | "claude-code" | "codex-cli" | "models" | "tools";

interface Props {
  title: string;
  description?: string;
  section?: SectionId;
}

const { title, description = "Track changelogs for every major AI coding tool. clwatch keeps your agent configs and reference files automatically current.", section } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en" {...section ? {"data-section": section} : {}}>
  <head>
    <ViewTransitions />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" /></noscript>
    <title>{title}</title>
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="changelogs.info" />
    <meta property="og:image" content="https://changelogs.info/og-image.svg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://changelogs.info/og-image.svg" />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#0c0c0c" />
    <meta name="author" content="CyperX" />
    <meta name="keywords" content="AI coding tools,changelogs,AI agents,claude code,codex CLI,gemini CLI,developer tools,clwatch" />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [{
        "@type": "WebSite",
        "name": "changelogs.info",
        "url": "https://changelogs.info",
        "description": description,
        "potentialAction": {
          "@type": "SearchAction",
          "target": "https://changelogs.info/?q={search_term_string}",
          "query-input": "required name=search_term_string"
        }
      }, {
        "@type": "Organization",
        "name": "changelogs.info",
        "url": "https://changelogs.info",
        "logo": "https://changelogs.info/favicon.svg",
        "sameAs": ["https://github.com/cyperx84/changelogs-info"]
      }]
    })} />
    <link rel="alternate" type="application/rss+xml" title="changelogs.info — All Releases" href="/feed/all.xml" />
    <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin />
    <link rel="dns-prefetch" href="https://plausible.io" />
    <script defer data-domain="changelogs.info" src="https://plausible.io/js/script.js"></script>
  </head>
  <body class="min-h-screen bg-bg-primary text-text-primary">
    <nav id="main-nav" class="sticky top-0 z-50 border-b border-border bg-bg-primary/95 backdrop-blur-xl transition-all duration-200">
      <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4 sm:px-6">
        <a href="/" class="font-mono text-base font-bold tracking-tight transition-opacity hover:opacity-80">
          <span class="text-text-primary">changelogs</span><span class="text-green">.info</span>
        </a>

        <!-- Desktop Navigation -->
        <div class="hidden items-center gap-2 md:flex">
          <a href="/openclaw/" class:list={["nav-link", { "nav-link-active": section === "openclaw" }]} style={section === "openclaw" ? "color: var(--section-color);" : ""}>OpenClaw</a>
          <a href="/claude-code/" class:list={["nav-link", { "nav-link-active": section === "claude-code" }]} style={section === "claude-code" ? "color: var(--section-color);" : ""}>Claude Code</a>
          <a href="/codex-cli/" class:list={["nav-link", { "nav-link-active": section === "codex-cli" }]} style={section === "codex-cli" ? "color: var(--section-color);" : ""}>Codex</a>
          <a href="/models/" class:list={["nav-link", { "nav-link-active": section === "models" }]} style={section === "models" ? "color: var(--section-color);" : ""}>Models</a>
          <a href="/tools/" class:list={["nav-link", { "nav-link-active": section === "tools" }]} style={section === "tools" ? "color: var(--section-color);" : ""}>Tools</a>
          <a href="/breaking/" class="nav-link">Breaking</a>
          <a href="/compare/" class="nav-link">Compare</a>
          <a href="/clwatch" class="nav-link">clwatch</a>
          <a href="/feed/all.xml" class="nav-link" title="RSS feed" aria-label="RSS feed">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
            </svg>
          </a>
          <div class="ml-2 flex items-center gap-1">
            <Search />
            <button id="theme-toggle-desktop" class="theme-toggle" aria-label="Toggle theme">
              <svg id="sun-icon-desktop" class="hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>
              </svg>
              <svg id="moon-icon-desktop" class="" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
              </svg>
            </button>
          </div>
        </div>

        <!-- Mobile Menu Button -->
        <button id="mobile-menu-btn" class="mobile-menu-btn md:hidden" aria-label="Toggle menu">
          <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path class="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
            <path class="close-icon hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>

      <!-- Mobile Navigation Menu -->
      <div id="mobile-menu" class="mobile-menu hidden border-t border-border bg-bg-primary md:hidden">
        <div class="space-y-1 px-4 py-3">
          <a href="/openclaw/" class="mobile-nav-link" style={section === "openclaw" ? "color: var(--section-color); border-left-color: var(--section-color);" : ""}>OpenClaw</a>
          <a href="/claude-code/" class="mobile-nav-link" style={section === "claude-code" ? "color: var(--section-color); border-left-color: var(--section-color);" : ""}>Claude Code</a>
          <a href="/codex-cli/" class="mobile-nav-link" style={section === "codex-cli" ? "color: var(--section-color); border-left-color: var(--section-color);" : ""}>Codex</a>
          <a href="/models/" class="mobile-nav-link" style={section === "models" ? "color: var(--section-color); border-left-color: var(--section-color);" : ""}>Models</a>
          <a href="/tools/" class="mobile-nav-link" style={section === "tools" ? "color: var(--section-color); border-left-color: var(--section-color);" : ""}>Tools</a>
          <a href="/breaking/" class="mobile-nav-link">Breaking</a>
          <a href="/compare/" class="mobile-nav-link">Compare</a>
          <a href="/clwatch" class="mobile-nav-link">clwatch</a>
          <a href="/feed/all.xml" class="mobile-nav-link flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="currentColor" viewBox="0 0 24 24">
              <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
            </svg>
            RSS
          </a>
          <div class="pt-3 pb-2 flex items-center justify-between">
            <span class="text-sm text-text-secondary">Theme</span>
            <button id="theme-toggle-mobile" class="theme-toggle" aria-label="Toggle theme">
              <svg id="sun-icon-mobile" class="hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>
              </svg>
              <svg id="moon-icon-mobile" class="" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
              </svg>
            </button>
          </div>
          <div class="pt-2">
            <Search />
          </div>
        </div>
      </div>
    </nav>

    <main data-pagefind-body>
      <slot />
    </main>

    <footer class="border-t border-border">
      <div class="mx-auto max-w-6xl px-4 py-8 sm:px-6">
        <div class="mb-4 font-mono text-xs text-text-muted">
          <span class="text-green">───</span> EOF <span class="text-green">───</span>
        </div>
        <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
          <p class="font-mono text-sm text-text-muted">
            <a href="https://github.com/cyperx84/changelogs-info" target="_blank" rel="noopener noreferrer" class="text-accent hover:text-accent-hover transition-colors">src</a>
          </p>
          <div class="flex flex-wrap items-center gap-3 font-mono text-xs sm:gap-4">
            <a href="/openclaw/" class="footer-link">OpenClaw</a>
            <a href="/claude-code/" class="footer-link">Claude Code</a>
            <a href="/codex-cli/" class="footer-link">Codex</a>
            <a href="/breaking/" class="footer-link">Breaking</a>
            <a href="/compare/" class="footer-link">Compare</a>
            <a href="/newsletter/" class="footer-link">Newsletter</a>
            <a href="/clwatch" class="footer-link">clwatch</a>
            <a href="/feed/all.xml" class="footer-link">RSS</a>
          </div>
        </div>
        <p class="mt-3 font-mono text-xs text-text-muted">
          <span class="text-green">#</span> data from official github releases
        </p>
        <p class="mt-4 text-center font-mono text-xs text-text-muted">
          made with ❤️ by CyperX
        </p>
      </div>
    </footer>

    <script is:inline>
      // Theme management - runs before page render to prevent flash
      (function() {
        const THEME_KEY = 'theme';

        function getInitialTheme() {
          const stored = localStorage.getItem(THEME_KEY);
          if (stored) return stored;
          return window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
        }

        function applyTheme(theme) {
          if (theme === 'light') {
            document.documentElement.setAttribute('data-theme', 'light');
          } else {
            document.documentElement.removeAttribute('data-theme');
          }
        }

        applyTheme(getInitialTheme());
      })();
    </script>

    <script>
      // Theme toggle functionality
      const THEME_KEY = 'theme';

      function updateThemeIcons(theme) {
        const sunDesktop = document.getElementById('sun-icon-desktop');
        const moonDesktop = document.getElementById('moon-icon-desktop');
        const sunMobile = document.getElementById('sun-icon-mobile');
        const moonMobile = document.getElementById('moon-icon-mobile');

        if (theme === 'light') {
          sunDesktop?.classList.remove('hidden');
          moonDesktop?.classList.add('hidden');
          sunMobile?.classList.remove('hidden');
          moonMobile?.classList.add('hidden');
        } else {
          sunDesktop?.classList.add('hidden');
          moonDesktop?.classList.remove('hidden');
          sunMobile?.classList.add('hidden');
          moonMobile?.classList.remove('hidden');
        }
      }

      function toggleTheme() {
        const current = localStorage.getItem(THEME_KEY) || 'dark';
        const next = current === 'dark' ? 'light' : 'dark';

        if (next === 'light') {
          document.documentElement.setAttribute('data-theme', 'light');
        } else {
          document.documentElement.removeAttribute('data-theme');
        }

        localStorage.setItem(THEME_KEY, next);
        updateThemeIcons(next);
      }

      // Initialize icons on page load
      document.addEventListener('DOMContentLoaded', () => {
        const current = localStorage.getItem(THEME_KEY) || 'dark';
        updateThemeIcons(current);

        const desktopToggle = document.getElementById('theme-toggle-desktop');
        const mobileToggle = document.getElementById('theme-toggle-mobile');

        desktopToggle?.addEventListener('click', toggleTheme);
        mobileToggle?.addEventListener('click', toggleTheme);
      });

      // Mobile menu toggle
      const menuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      const menuIcon = menuBtn?.querySelector('.menu-icon');
      const closeIcon = menuBtn?.querySelector('.close-icon');

      menuBtn?.addEventListener('click', () => {
        const isOpen = !mobileMenu?.classList.contains('hidden');

        if (isOpen) {
          mobileMenu?.classList.add('hidden');
          menuIcon?.classList.remove('hidden');
          closeIcon?.classList.add('hidden');
        } else {
          mobileMenu?.classList.remove('hidden');
          menuIcon?.classList.add('hidden');
          closeIcon?.classList.remove('hidden');
        }
      });

      // Close mobile menu when clicking a link
      const mobileLinks = document.querySelectorAll('.mobile-nav-link');
      mobileLinks.forEach(link => {
        link.addEventListener('click', () => {
          mobileMenu?.classList.add('hidden');
          menuIcon?.classList.remove('hidden');
          closeIcon?.classList.add('hidden');
        });
      });

      // Close mobile menu on resize to desktop
      window.addEventListener('resize', () => {
        if (window.innerWidth >= 768) {
          mobileMenu?.classList.add('hidden');
          menuIcon?.classList.remove('hidden');
          closeIcon?.classList.add('hidden');
        }
      });

      // Nav scroll effect
      const nav = document.getElementById('main-nav');
      window.addEventListener('scroll', () => {
        if (window.scrollY > 10) {
          nav?.classList.add('scrolled');
        } else {
          nav?.classList.remove('scrolled');
        }
      }, { passive: true });

      // Scroll reveal — adds .visible class for scroll-triggered animation
      // Content is ALWAYS visible by default (opacity:1 in CSS). This just animates on scroll.
      function initReveal() {
        if (!('IntersectionObserver' in window)) return;
        const revealEls = document.querySelectorAll('.reveal:not(.visible), .reveal-left:not(.visible), .reveal-scale:not(.visible)');
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.05 });
        revealEls.forEach(el => observer.observe(el));
      }
      initReveal();
      document.addEventListener('astro:page-load', initReveal);
    </script>

    <style>
      /* Nav scroll state */
      #main-nav.scrolled {
        backdrop-filter: blur(20px) saturate(1.2);
        -webkit-backdrop-filter: blur(20px) saturate(1.2);
      }

      /* Desktop nav links */
      .nav-link {
        font-family: var(--font-mono);
        font-size: 0.875rem;
        color: var(--color-text-muted);
        transition: color 150ms ease;
        padding: 0.5rem 0.625rem;
        border-radius: 0.25rem;
        min-height: 44px;
        display: flex;
        align-items: center;
      }

      .nav-link:hover {
        color: var(--color-text-primary);
      }

      .nav-link-active {
        color: var(--color-text-primary);
        border-bottom: 2px solid currentColor;
        border-radius: 0;
        padding-bottom: calc(0.5rem - 2px);
      }

      /* CTA button */
      .nav-cta {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        color: var(--color-text-muted);
        padding: 0.375rem 0.75rem;
        border-radius: 0.25rem;
        border: 1px solid var(--color-border);
        background: transparent;
        transition: color 150ms ease, border-color 150ms ease;
        margin-left: 0.25rem;
        white-space: nowrap;
      }

      .nav-cta:hover {
        color: var(--color-green);
        border-color: color-mix(in srgb, var(--color-green) 50%, transparent);
      }

      /* Mobile menu button */
      .mobile-menu-btn {
        color: var(--color-text-secondary);
        padding: 0.5rem;
        border-radius: 0.375rem;
        transition: all 150ms ease;
        min-width: 44px;
        min-height: 44px;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .mobile-menu-btn:hover {
        color: var(--color-text-primary);
        background: rgba(255, 255, 255, 0.05);
      }

      .mobile-menu-btn svg {
        transition: transform 150ms ease;
      }

      /* Mobile nav links */
      .mobile-nav-link {
        display: block;
        padding: 0.75rem 1rem;
        font-family: var(--font-mono);
        font-size: 0.875rem;
        color: var(--color-text-muted);
        border-radius: 0.375rem;
        transition: all 150ms ease;
        min-height: 44px;
        border-left: 2px solid transparent;
      }

      .mobile-nav-link:hover {
        color: var(--color-text-primary);
        border-left-color: var(--color-green);
        padding-left: 0.875rem;
      }

      /* Footer links */
      .footer-link {
        color: var(--color-text-muted);
        transition: color 150ms ease;
        padding: 0.25rem 0.5rem;
        min-height: 44px;
        display: inline-flex;
        align-items: center;
      }

      .footer-link:hover {
        color: var(--color-text-secondary);
      }
    </style>
    <Haptics />
  </body>
</html>
