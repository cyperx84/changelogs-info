---
import "../styles/global.css";
import "../styles/view-transitions.css";
import { ViewTransitions } from "astro:transitions";
import SharedNav from "../components/SharedNav.astro";

interface Props {
  title?: string;
  description?: string;
  currentSection?: string;
}

const {
  title = "changelogs.info — AI Tool Changelog Tracker",
  description = "Track every major AI coding tool. OpenClaw, Claude Code, Codex CLI, and AI models — all in one place.",
  currentSection = "hub"
} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700;800&family=Work+Sans:ital,wght@0,400;0,500;0,700;1,400&family=JetBrains+Mono:wght@400;500&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700;800&family=Work+Sans:ital,wght@0,400;0,500;0,700;1,400&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" /></noscript>
    <ViewTransitions />
    <title>{title}</title>
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="theme-color" content="#f8fbff" />
    <meta name="author" content="CyperX" />
      <link rel="alternate" type="application/rss+xml" title="changelogs.info RSS" href="/feed/all.xml" />
  </head>
  <body>
    <SharedNav currentSection={currentSection} />

    <main>
      <slot />
    </main>

    <footer class="hub-footer">
      <div class="hub-footer__inner">
        <div class="hub-footer__brand">
          <span class="hub-footer__brand-text">changelogs</span><span class="hub-footer__brand-dot">.info</span>
          <span class="hub-footer__tagline">AI tools shipping faster than docs get updated. We try anyway.</span>
        </div>
        <div class="hub-footer__links">
          <a href="/openclaw/" class="hub-footer__link">OpenClaw</a>
          <a href="/claude-code/" class="hub-footer__link">Claude Code</a>
          <a href="/codex-cli/" class="hub-footer__link">Codex</a>
          <a href="/gemini-cli/" class="hub-footer__link">Gemini</a>
          <a href="/models/" class="hub-footer__link">Models</a>
          <a href="/feed/all.xml" class="hub-footer__link">RSS</a>
        </div>
        <p class="hub-footer__copy">data from official GitHub releases · made with ❤️ by CyperX</p>
      </div>
    </footer>

    <script is:inline>
      (function () {
        var storedTheme = localStorage.getItem('theme');
        var storedInsane = localStorage.getItem('hub-insane');
        var theme = storedTheme || (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
        if (theme === 'light') {
          document.documentElement.setAttribute('data-theme', 'light');
        } else {
          document.documentElement.removeAttribute('data-theme');
        }
        // Insane Mode: stored separately
        if (storedInsane === 'true') {
          document.documentElement.setAttribute('data-hub-insane', 'true');
        }
      })();
    </script>

    <!-- Insane Mode only (theme handled by SharedNav) -->
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function() {
        var INSANE_KEY = 'hub-insane';
        function isInsane() { return localStorage.getItem(INSANE_KEY) === 'true'; }
        function startInsaneNoise() {
          var canvas = document.getElementById('hub-noise-canvas');
          if (!canvas) return;
          canvas.width = Math.min(window.innerWidth, 800);
          canvas.height = Math.min(window.innerHeight, 450);
          var ctx = canvas.getContext('2d');
          function drawNoise() {
            if (!document.documentElement.hasAttribute('data-hub-insane')) { ctx.clearRect(0,0,canvas.width,canvas.height); return; }
            var imgData = ctx.createImageData(canvas.width, canvas.height);
            var data = imgData.data;
            for (var i = 0; i < data.length; i += 4) {
              var v = Math.random() > 0.97 ? Math.random() * 60 : 0;
              data[i] = v * 0.2; data[i+1] = v * 0.5; data[i+2] = v * 1.2; data[i+3] = v > 0 ? v * 3 : 0;
            }
            ctx.putImageData(imgData, 0, 0);
            requestAnimationFrame(drawNoise);
          }
          drawNoise();
        }
        function applyInsane(insane) {
          if (insane) {
            document.documentElement.setAttribute('data-hub-insane', 'true');
            localStorage.setItem(INSANE_KEY, 'true');
            var banner = document.getElementById('hub-insane-banner');
            if (banner) {
              banner.style.display = 'block';
              requestAnimationFrame(function() { banner.style.transform = 'translate(-50%,-50%) scale(1)'; banner.style.opacity = '1'; });
              setTimeout(function() { banner.style.transform = 'translate(-50%,-50%) scale(0)'; banner.style.opacity = '0'; setTimeout(function(){banner.style.display='none';},400); }, 1800);
            }
            startInsaneNoise();
          } else {
            document.documentElement.removeAttribute('data-hub-insane');
            localStorage.setItem(INSANE_KEY, 'false');
          }
        }
        if (isInsane()) { startInsaneNoise(); }
        document.addEventListener('keydown', function(e) {
          if (e.ctrlKey && e.shiftKey && e.key === 'I') { e.preventDefault(); applyInsane(!isInsane()); }
        });
      });
    </script>

    <!-- Insane Mode canvas + banner -->
    <canvas id="hub-noise-canvas" style="position:fixed;top:0;left:0;width:100%;height:100%;z-index:9990;pointer-events:none;display:none;"></canvas>
    <div id="hub-insane-banner" style="display:none;position:fixed;top:50%;left:50%;transform:translate(-50%,-50%) scale(0);opacity:0;z-index:9991;pointer-events:none;font-family:var(--hub-font-head);font-weight:900;font-size:clamp(2rem,10vw,8rem);color:#fff;text-shadow:0 0 40px rgba(0,200,255,0.9),0 0 80px rgba(255,0,200,0.4),0 0 120px rgba(0,255,200,0.3),6px 6px 0 #000;text-transform:uppercase;letter-spacing:-0.04em;text-align:center;width:90vw;max-width:900px;transition:transform 500ms cubic-bezier(0.34,1.56,0.64,1),opacity 300ms;">🔥 INSANE MODE 🔥</div>


</html>

<style is:global>
  /* Hub color system — neo-brutalist, matches subdomain language */
  /* Default: LIGHT theme */
  :root {
    --hub-bg: #f8fbff;
    --hub-bg-card: #ffffff;
    --hub-bg-surface: #e8f4fd;
    --hub-bg-surface-2: #dceefb;
    --hub-text: #0a0a0a;
    --hub-text-dim: #3a3a3a;
    --hub-text-muted: #6a6a6a;
    --hub-primary: #0091f7;
    --hub-primary-hover: #007bc9;
    --hub-primary-bright: #00b0ff;
    --hub-border: #0a0a0a;
    --hub-border-dim: rgba(10, 10, 10, 0.2);
    --hub-shadow: 0 0 0 2px rgba(10, 10, 10, 0.1);
    --hub-shadow-card: 6px 6px 0px 0px rgba(10, 10, 10, 0.9);
    --hub-shadow-card-hover: 8px 8px 0px 0px rgba(10, 10, 10, 1);
    --hub-font-head: 'Space Grotesk', sans-serif;
    --hub-font-body: 'Work Sans', sans-serif;
    --hub-font-mono: 'JetBrains Mono', monospace;
  }

  /* Explicit LIGHT theme */
  [data-theme="light"] {
    --hub-bg: #f8fbff;
    --hub-bg-card: #ffffff;
    --hub-bg-surface: #e8f4fd;
    --hub-bg-surface-2: #dceefb;
    --hub-text: #0a0a0a;
    --hub-text-dim: #3a3a3a;
    --hub-text-muted: #6a6a6a;
    --hub-primary: #0091f7;
    --hub-primary-hover: #007bc9;
    --hub-primary-bright: #00b0ff;
    --hub-border: #0a0a0a;
    --hub-border-dim: rgba(10, 10, 10, 0.2);
    --hub-shadow: 0 0 0 2px rgba(10, 10, 10, 0.1);
    --hub-shadow-card: 6px 6px 0px 0px rgba(10, 10, 10, 0.9);
    --hub-shadow-card-hover: 8px 8px 0px 0px rgba(10, 10, 10, 1);
  }

  /* DARK theme — default, no data-theme attribute */
  :root:not([data-theme="light"]) {
    --hub-bg: #0a0a0a;
    --hub-bg-card: #111111;
    --hub-bg-surface: #1a1a1a;
    --hub-bg-surface-2: #222222;
    --hub-text: #f0f0f0;
    --hub-text-dim: #b0b0b0;
    --hub-text-muted: #707070;
    --hub-primary: #00b0ff;
    --hub-primary-hover: #38c0ff;
    --hub-primary-bright: #60d0ff;
    --hub-border: #f0f0f0;
    --hub-border-dim: rgba(240, 240, 240, 0.2);
    --hub-shadow: 0 0 0 2px rgba(240, 240, 240, 0.1);
    --hub-shadow-card: 6px 6px 0px 0px rgba(240, 240, 240, 0.15);
    --hub-shadow-card-hover: 8px 8px 0px 0px rgba(240, 240, 240, 0.2);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  html {
    scroll-behavior: smooth;
  }

  html body {
    background-color: var(--hub-bg);
    color: var(--hub-text);
    font-family: var(--hub-font-body);
    line-height: 1.6;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
  }

  ::selection {
    background: var(--hub-primary);
    color: #ffffff;
  }

  :focus-visible {
    outline: 3px solid var(--hub-primary);
    outline-offset: 2px;
  }

  /* Scrollbar */
  ::-webkit-scrollbar { width: 8px; height: 8px; }
  ::-webkit-scrollbar-track { background: var(--hub-bg); }
  ::-webkit-scrollbar-thumb { background: var(--hub-border); border-radius: 0; }
  ::-webkit-scrollbar-thumb:hover { background: var(--hub-primary); }
</style>

<style is:global>
  /* ── FOOTER ── */
  [data-theme] .hub-footer,
  .hub-footer {
    border-top: 4px solid var(--hub-border);
    background-color: var(--hub-bg-card) !important;
    margin-top: 6rem;
    box-shadow: 0 -4px 0 0 var(--hub-border);
  }
  .hub-footer__inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 3rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: center;
    text-align: center;
  }
  .hub-footer__brand {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }
  .hub-footer__brand-text {
    font-family: var(--hub-font-mono);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--hub-text);
    letter-spacing: -0.02em;
  }
  .hub-footer__brand-dot { color: var(--hub-primary); }
  .hub-footer__tagline {
    font-family: var(--hub-font-body);
    font-size: 0.85rem;
    color: var(--hub-text-muted);
    font-style: italic;
  }
  .hub-footer__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
  }
  .hub-footer__link {
    font-family: var(--hub-font-mono);
    font-size: 0.75rem;
    color: var(--hub-text-muted);
    text-decoration: none;
    padding: 0.3rem 0.6rem;
    transition: color 150ms;
  }
  .hub-footer__link:hover { color: var(--hub-primary); }
  .hub-footer__copy {
    font-family: var(--hub-font-mono);
    font-size: 0.7rem;
    color: var(--hub-text-muted);
  }

  /* ── HERO ── */
  .hub-hero {
    max-width: 1280px;
    margin: 0 auto;
    padding: 5rem 2rem 3rem;
    text-align: center;
  }
  .hub-hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--hub-font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--hub-primary);
    margin-bottom: 1.5rem;
    animation: hub-enter 0.5s ease-out both;
  }
  .hub-hero__eyebrow-dot {
    width: 8px;
    height: 8px;
    background: var(--hub-primary);
    animation: hub-pulse 2s ease-in-out infinite;
  }
  @keyframes hub-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
  .hub-hero__title {
    font-family: var(--hub-font-head);
    font-size: clamp(3.5rem, 9vw, 7rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 0.88;
    color: var(--hub-text);
    text-transform: uppercase;
    margin-bottom: 2rem;
    animation: hub-enter 0.5s ease-out 0.1s both;
  }
  .hub-hero__title-accent {
    color: var(--hub-primary);
    display: block;
  }
  .hub-hero__sub {
    font-family: var(--hub-font-mono);
    font-size: 0.95rem;
    color: var(--hub-text-dim);
    max-width: 520px;
    margin: 0 auto 2rem;
    line-height: 1.7;
    animation: hub-enter 0.5s ease-out 0.2s both;
  }
  .hub-hero__badges {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
    animation: hub-enter 0.5s ease-out 0.3s both;
  }
  [data-theme] .hub-hero__badge,
  .hub-hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--hub-font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--hub-text) !important;
    background-color: var(--hub-bg-surface) !important;
    border: 2px solid var(--hub-border);
    padding: 0.35rem 0.85rem;
  }
  .hub-hero__badge-dot {
    width: 6px;
    height: 6px;
    background: var(--hub-primary);
  }
  @keyframes hub-enter {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ── CARD GRID ── */
  .hub-grid-section {
    max-width: 1280px;
    margin: 0 auto;
    padding: 2rem 2rem 3rem;
  }
  .hub-section-label {
    font-family: var(--hub-font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--hub-text-muted);
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .hub-section-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--hub-border);
  }
  .hub-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.25rem;
  }
  .hub-card {
    display: block;
    text-decoration: none;
    background: var(--hub-bg-card);
    border: 4px solid var(--hub-border);
    border-radius: 0;
    padding: 1.75rem;
    box-shadow: var(--hub-shadow-card);
    transition: transform 100ms, box-shadow 100ms;
    position: relative;
    overflow: hidden;
    animation: hub-enter 0.5s ease-out both;
  }
  .hub-card:nth-child(1) { animation-delay: 0.35s; }
  .hub-card:nth-child(2) { animation-delay: 0.4s; }
  .hub-card:nth-child(3) { animation-delay: 0.45s; }
  .hub-card:nth-child(4) { animation-delay: 0.5s; }
  .hub-card:hover {
    transform: translate(-3px, -3px);
    box-shadow: var(--hub-shadow-card-hover);
  }
  .hub-card__glow {
    position: absolute;
    top: -40px;
    right: -40px;
    width: 120px;
    height: 120px;
    opacity: 0.08;
    transition: opacity 150ms;
    pointer-events: none;
  }
  .hub-card:hover .hub-card__glow { opacity: 0.15; }
  .hub-card--openclaw .hub-card__glow { background: #eb0000; }
  .hub-card--claude .hub-card__glow { background: #f59e0b; }
  .hub-card--codex .hub-card__glow { background: #00c851; }
  .hub-card--models .hub-card__glow { background: var(--hub-primary); }
  .hub-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.25rem;
  }
  .hub-card__icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    font-weight: 900;
    font-family: var(--hub-font-head);
    border: 3px solid var(--hub-border);
  }
  .hub-card--openclaw .hub-card__icon { background: #eb0000; color: white; border-color: #eb0000; }
  .hub-card--claude .hub-card__icon { background: #f59e0b; color: white; border-color: #f59e0b; }
  .hub-card--codex .hub-card__icon { background: #00c851; color: white; border-color: #00c851; }
  .hub-card--models .hub-card__icon { background: var(--hub-primary); color: white; border-color: var(--hub-primary); }
  .hub-card__arrow {
    font-size: 1.2rem;
    color: var(--hub-text-muted);
    transition: color 150ms, transform 150ms;
  }
  .hub-card:hover .hub-card__arrow {
    color: var(--hub-primary);
    transform: translate(3px, -3px);
  }
  .hub-card__name {
    font-family: var(--hub-font-head);
    font-size: 1.5rem;
    font-weight: 900;
    text-transform: uppercase;
    color: var(--hub-text);
    letter-spacing: -0.02em;
    margin-bottom: 0.4rem;
  }
  .hub-card__desc {
    font-family: var(--hub-font-body);
    font-size: 0.95rem;
    color: var(--hub-text);
    line-height: 1.5;
    margin-bottom: 1.25rem;
    font-weight: 400;
  }
  .hub-card__tldr {
    font-family: var(--hub-font-mono);
    font-size: 0.72rem;
    color: var(--hub-text-muted);
    background: var(--hub-bg-surface);
    border: 2px solid var(--hub-border-dim);
    padding: 0.5rem 0.75rem;
    line-height: 1.5;
  }
  .hub-card__meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 1rem;
    padding-top: 0.75rem;
    border-top: 2px solid var(--hub-border-dim);
  }
  .hub-card__tag {
    font-family: var(--hub-font-mono);
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.15rem 0.5rem;
    
  }
  .hub-card--openclaw .hub-card__tag { background: rgba(235,0,0,0.1); color: #c50000; }
  .hub-card--claude .hub-card__tag { background: rgba(245,158,11,0.1); color: #b27200; }
  .hub-card--codex .hub-card__tag { background: rgba(0,200,81,0.1); color: #009e3a; }
  .hub-card--models .hub-card__tag { background: rgba(0,145,247,0.1); color: var(--hub-primary); }
  .hub-card__version {
    font-family: var(--hub-font-mono);
    font-size: 0.72rem;
    color: var(--hub-text-muted);
    margin-left: auto;
  }

  /* ── BLOG PLACEHOLDER ── */
  .hub-blog-section {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem 4rem;
  }
  .hub-blog-card {
    background: var(--hub-bg-card);
    border: 1px solid var(--hub-border);
    border-radius: 16px;
    padding: 2.5rem;
    box-shadow: var(--hub-shadow-card);
    display: flex;
    align-items: center;
    gap: 2rem;
    position: relative;
    overflow: hidden;
    animation: hub-enter 0.5s ease-out 0.55s both;
  }
  .hub-blog-card__bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--hub-bg-surface) 0%, transparent 60%);
    pointer-events: none;
  }
  .hub-blog-card__left {
    flex-shrink: 0;
    width: 80px;
    height: 80px;
    border-radius: 16px;
    background: var(--hub-bg-surface-2);
    border: 1px solid var(--hub-border);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 1;
  }
  .hub-blog-card__left-icon {
    font-size: 2rem;
  }
  .hub-blog-card__right {
    flex: 1;
    position: relative;
    z-index: 1;
  }
  .hub-blog-card__eyebrow {
    font-family: var(--hub-font-mono);
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--hub-primary);
    margin-bottom: 0.5rem;
  }
  .hub-blog-card__title {
    font-family: var(--hub-font-head);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--hub-text);
    letter-spacing: -0.02em;
    margin-bottom: 0.5rem;
  }
  .hub-blog-card__desc {
    font-family: var(--hub-font-body);
    font-size: 0.9rem;
    color: var(--hub-text-dim);
    line-height: 1.6;
  }
  .hub-blog-card__cta {
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }
  .hub-blog-card__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--hub-font-mono);
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--hub-primary);
    text-decoration: none;
    border: 2px solid var(--hub-border-strong);
    padding: 0.6rem 1.25rem;
    border-radius: 8px;
    transition: background 150ms, color 150ms, border-color 150ms, transform 150ms;
  }
  .hub-blog-card__btn:hover {
    background: var(--hub-primary);
    color: white;
    border-color: var(--hub-primary);
    transform: translateY(-2px);
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 640px) {
