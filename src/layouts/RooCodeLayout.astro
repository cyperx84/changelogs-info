---
import "../styles/rc-extracted.css";
import "../styles/tool-shared.css";
import "../styles/global.css";
import "../styles/shared-nav.css";
import "../styles/view-transitions.css";
import SharedNav from "../components/SharedNav.astro";

interface Props {
  title: string;
  description?: string;
  currentPage?: string;
}

const {
  title,
  description = "AI coding assistant with multiple agent modes — Code, Architect, Ask, Debug. Open source VS Code extension with deep customization.",
  currentPage = "",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const navLinks = [
  { label: "Changelog", href: "/roo-code/changelog/", key: "changelog" },
  { label: "Cheatsheet", href: "/roo-code/cheatsheet/", key: "cheatsheet" },
  { label: "Releases", href: "/roo-code/releases/", key: "releases" },
];
---

<!doctype html>
<html lang="en" data-layout="roo-code">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <script defer data-domain="changelogs.info" src="https://plausible.io/js/script.js"></script>

    <style is:global>
      @font-face {
        font-family: "Space Grotesk Fallback";
        src: local("Arial Black"), local("Arial");
        size-adjust: 107%;
        ascent-override: 95%;
        descent-override: 22%;
        line-gap-override: 0%;
      }

      @font-face {
        font-family: "Work Sans Fallback";
        src: local("Helvetica Neue"), local("Arial");
        size-adjust: 100%;
        ascent-override: 96%;
        descent-override: 24%;
        line-gap-override: 0%;
      }

      :root {
        --rc-primary: #FB923C;
        --rc-primary-bright: #fdba74;
        --rc-accent: #fed7aa;
        --rc-bg: #120a05;
        --rc-bg-card: #1a110b;
        --rc-bg-surface: #2a1b12;
        --rc-text: #fff7ed;
        --rc-text-dim: rgba(255, 247, 237, 0.72);
        --rc-text-muted: rgba(255, 247, 237, 0.48);
        --rc-border: #FB923C;
        --rc-border-dim: rgba(251, 146, 60, 0.28);
        --rc-shadow: 8px 8px 0 rgba(251, 146, 60, 0.22);
        --rc-shadow-sm: 4px 4px 0 rgba(251, 146, 60, 0.18);
        --rc-font-headline: "Space Grotesk", "Space Grotesk Fallback", sans-serif;
        --rc-font-body: "Work Sans", "Work Sans Fallback", sans-serif;
        --rc-font-mono: "JetBrains Mono", ui-monospace, monospace;

        --tool-primary: var(--rc-primary);
        --tool-primary-bright: var(--rc-primary-bright);
        --tool-font-mono: var(--rc-font-mono);
        --tool-font-headline: var(--rc-font-headline);
        --tool-font-body: var(--rc-font-body);
        --tool-bg: var(--rc-bg);
        --tool-bg-card: var(--rc-bg-card);
        --tool-bg-surface: var(--rc-bg-surface);
        --tool-text: var(--rc-text);
        --tool-border-dim: var(--rc-border-dim);
      }

      [data-theme="light"] {
        --rc-bg: #fff7ed;
        --rc-bg-card: #ffffff;
        --rc-bg-surface: #ffedd5;
        --rc-text: #34180a;
        --rc-text-dim: rgba(52, 24, 10, 0.72);
        --rc-text-muted: rgba(52, 24, 10, 0.5);
        --rc-border: #34180a;
        --rc-border-dim: rgba(52, 24, 10, 0.18);
        --rc-shadow: 8px 8px 0 rgba(52, 24, 10, 0.95);
        --rc-shadow-sm: 4px 4px 0 rgba(52, 24, 10, 0.85);
      }

      html[data-layout="roo-code"] {
        background: radial-gradient(circle at top, rgba(251, 146, 60, 0.13), transparent 40%), var(--rc-bg);
        color: var(--rc-text);
      }

      html[data-layout="roo-code"] body {
        margin: 0;
        min-height: 100vh;
        background: transparent;
        color: var(--rc-text);
        font-family: var(--rc-font-body);
      }

      .rc-headline {
        font-family: var(--rc-font-headline);
        font-weight: 900;
      }

      .rc-page {
        max-width: 1280px;
        margin: 0 auto;
        padding: 2rem 1.5rem 0;
      }

      .rc-subnav {
        position: sticky;
        top: 56px;
        z-index: 49;
        backdrop-filter: blur(16px);
        background: color-mix(in srgb, var(--rc-bg-surface) 88%, transparent);
        border-bottom: 2px solid var(--rc-border-dim);
      }

      .rc-subnav__inner {
        max-width: 1400px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        gap: 1.25rem;
        padding: 0.7rem 1.25rem;
      }

      .rc-subnav__brand {
        font-family: var(--rc-font-mono);
        font-size: 0.95rem;
        font-weight: 900;
        color: var(--rc-primary-bright);
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }

      .rc-subnav__link {
        font-family: var(--rc-font-mono);
        font-size: 0.74rem;
        font-weight: 700;
        color: var(--rc-text-dim);
        text-decoration: none;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        padding-bottom: 2px;
        border-bottom: 3px solid transparent;
      }

      .rc-subnav__link:hover,
      .rc-subnav__link--active {
        color: var(--rc-primary-bright);
        border-bottom-color: var(--rc-primary-bright);
      }

      .rc-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.45rem 0.8rem;
        border: 2px solid var(--rc-border-dim);
        background: var(--rc-bg-card);
        color: var(--rc-text-dim);
        font-family: var(--rc-font-mono);
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }

      .rc-card {
        border: 4px solid var(--rc-border);
        background: var(--rc-bg-card);
        box-shadow: var(--rc-shadow);
      }

      .rc-card-soft {
        border: 2px solid var(--rc-border-dim);
        background: color-mix(in srgb, var(--rc-bg-card) 82%, var(--rc-bg-surface));
      }

      .rc-link {
        color: var(--rc-primary-bright);
        text-decoration: none;
      }

      .rc-link:hover {
        text-decoration: underline;
      }

      footer.rc-footer {
        margin-top: 5rem;
        border-top: 8px solid var(--rc-primary);
        padding: 2.5rem 1.5rem 3rem;
      }

      .rc-footer__inner {
        max-width: 1280px;
        margin: 0 auto;
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        gap: 1.5rem;
      }

      .rc-footer__meta {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
      }

      .rc-footer__links {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem 1.5rem;
      }

      .rc-footer__links a,
      .rc-footer__meta span,
      .rc-footer__status {
        font-family: var(--rc-font-mono);
        font-size: 0.68rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--rc-text-dim);
        text-decoration: none;
      }

      @media (max-width: 720px) {
        .rc-subnav__inner {
          flex-wrap: wrap;
          gap: 0.5rem 1rem;
        }
      }
    </style>

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "Roo Code",
      "description": "AI coding assistant with multiple agent modes for VS Code, open source and deeply customizable",
      "url": "https://github.com/RooVetGit/Roo-Code",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "Cross-platform",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      }
    })} />
    <link rel="alternate" type="application/rss+xml" title="changelogs.info RSS" href="/feed/all.xml" />
  </head>
  <body>
    <SharedNav currentSection="roo-code" />

    <div class="rc-subnav">
      <div class="rc-subnav__inner">
        <span class="rc-subnav__brand">Roo Code</span>
        {navLinks.map((link) => (
          <a
            href={link.href}
            class={`rc-subnav__link ${currentPage === link.key ? "rc-subnav__link--active" : ""}`}
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>

    <main>
      <slot />
    </main>

    <footer class="rc-footer">
      <div class="rc-footer__inner">
        <div class="rc-footer__meta">
          <span>© {new Date().getFullYear()} changelogs.info / Roo Code</span>
          <span>Data from official GitHub releases and site content</span>
        </div>

        <div class="rc-footer__links">
          <a href="/">Hub</a>
          <a href="/roo-code/changelog/">Changelog</a>
          <a href="/roo-code/cheatsheet/">Cheatsheet</a>
          <a href="/roo-code/releases/">Releases</a>
          <a href="https://github.com/RooVetGit/Roo-Code" target="_blank" rel="noopener noreferrer">GitHub ↗</a>
          <a href="/feed/all.xml">RSS</a>
        </div>

        <div class="rc-footer__status">Mode stack: code / architect / ask / debug</div>
      </div>
    </footer>
  </body>
</html>
