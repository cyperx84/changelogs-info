---
import "../styles/gc-extracted.css";
import "../styles/tool-shared.css";
import "../styles/global.css";
import "../styles/shared-nav.css";
import "../styles/view-transitions.css";
import { ViewTransitions } from "astro:transitions";
import SharedNav from "../components/SharedNav.astro";
import SiteAnimations from "../components/SiteAnimations.astro";

interface Props {
  title: string;
  description?: string;
  currentPage?: string;
}

const {
  title,
  description = "Track every Gemini CLI release — versions, patches, features, and fixes.",
  currentPage = "",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const navLinks = [
  { label: "Changelog", href: "/gemini-cli/changelog/", key: "changelog" },
  { label: "Cheatsheet", href: "/gemini-cli/cheatsheet/", key: "cheatsheet" },
  { label: "Quickstart", href: "/gemini-cli/quickstart/", key: "quickstart" },
  { label: "Tips", href: "/gemini-cli/tips/", key: "tips" },
  { label: "Releases", href: "/gemini-cli/releases/", key: "releases" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>    <ViewTransitions />
    <script defer data-domain="changelogs.info" src="https://plausible.io/js/script.js"></script>

    <style is:global>
      @font-face {
        font-family: 'Space Grotesk Fallback';
        src: local('Arial Black'), local('Arial');
        size-adjust: 107%;
        ascent-override: 95%;
        descent-override: 22%;
        line-gap-override: 0%;
      }
      @font-face {
        font-family: 'Work Sans Fallback';
        src: local('Helvetica Neue'), local('Arial');
        size-adjust: 100%;
        ascent-override: 96%;
        descent-override: 24%;
        line-gap-override: 0%;
      }

      /* Gemini CLI Google Blue Neo-Brutalist Theme */
      :root {
        --gc-header-bg: rgba(0, 10, 26, 0.92);
        --gc-primary: #4285f4;
        --gc-primary-bright: #669df6;
        --gc-accent: #8ab4f8;
        --gc-bg: #000a1a;
        --gc-bg-card: #001230;
        --gc-bg-surface: #001a45;
        --gc-text: #e0f0ff;
        --gc-text-dim: rgba(200, 230, 255, 0.65);
        --gc-text-muted: rgba(180, 220, 255, 0.4);
        --gc-border: #4285f4;
        --gc-border-dim: rgba(66, 133, 244, 0.2);
        --gc-shadow: 6px 6px 0px 0px rgba(66, 133, 244, 0.25);
        --gc-shadow-sm: 4px 4px 0px 0px rgba(66, 133, 244, 0.2);
        --gc-shadow-lg: 12px 12px 0px 0px rgba(66, 133, 244, 0.12);
        --gc-font-headline: "Space Grotesk", "Space Grotesk Fallback", sans-serif;
        --gc-font-body: "JetBrains Mono", ui-monospace, monospace;
        --gc-font-mono: "JetBrains Mono", ui-monospace, monospace;

        /* Bridge vars for tool-shared.css */
        --tool-primary: var(--gc-primary);
        --tool-primary-bright: var(--gc-primary-bright);
        --tool-font-mono: var(--gc-font-mono);
        --tool-font-headline: var(--gc-font-headline);
        --tool-font-body: var(--gc-font-body);
        --tool-bg: var(--gc-bg);
        --tool-bg-card: var(--gc-bg-card);
        --tool-bg-surface: var(--gc-bg-surface);
        --tool-text: var(--gc-text);
        --tool-border-dim: var(--gc-border-dim);
      }

      [data-theme="light"] {
        --gc-header-bg: rgba(240, 246, 255, 0.92);
        --gc-primary: #1a73e8;
        --gc-primary-bright: #174ea6;
        --gc-bg: #f0f6ff;
        --gc-bg-card: #ffffff;
        --gc-bg-surface: #dce8ff;
        --gc-text: #001a45;
        --gc-text-dim: rgba(0, 26, 69, 0.65);
        --gc-text-muted: rgba(0, 26, 69, 0.4);
        --gc-border: #001a45;
        --gc-border-dim: rgba(0, 26, 69, 0.2);
        --gc-shadow: 6px 6px 0px 0px rgba(0, 0, 0, 1);
        --gc-shadow-sm: 4px 4px 0px 0px rgba(0, 0, 0, 1);
        --gc-shadow-lg: 12px 12px 0px 0px rgba(0, 0, 0, 0.8);
      }

      /* Base */
      html[data-layout="gemini"] {
        background: var(--gc-bg);
        color: var(--gc-text);
      }
      html[data-layout="gemini"] body {
        margin: 0;
        padding: 0;
        background: var(--gc-bg);
        color: var(--gc-text);
        font-family: var(--gc-font-body);
        min-height: 100vh;
      }

      /* CRT scanlines overlay (always subtle) */
      html[data-layout="gemini"] body::before {
        content: '';
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        background: repeating-linear-gradient(
          0deg,
          rgba(66, 133, 244, 0.015),
          rgba(66, 133, 244, 0.015) 1px,
          transparent 1px,
          transparent 3px
        );
        pointer-events: none;
        z-index: 9998;
        opacity: 0.8;
      }

      /* Typography */
      .gc-headline {
        font-family: var(--gc-font-headline);
        font-weight: 900;
      }

      /* Badge styles, cl-pr-link, changelog-body, cl-collapsed → see tool-shared.css */

      /* Dot grid */
      .gc-dotgrid {
        background-image: radial-gradient(circle, var(--gc-border-dim) 1px, transparent 1px);
        background-size: 24px 24px;
      }

      /* Cursor blink */
      .gc-cursor {
        animation: gc-blink 1s step-end infinite;
      }
      @keyframes gc-blink {
        0%, 100% { opacity: 1; }
        50% { opacity: 0; }
      }

      /* Pulse dot */
      .gc-pulse-dot {
        animation: gc-pulse 2s ease-in-out infinite;
      }
      @keyframes gc-pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.4; }
      }

      /* CTA button */
      .gc-cta-btn {
        transition: transform 100ms, box-shadow 100ms;
      }
      .gc-cta-btn:hover {
        transform: translate(1px, 1px);
        box-shadow: none !important;
      }

      /* Quick link */
      .gc-quick-link {
        transition: border-color 150ms, box-shadow 150ms;
      }
      .gc-quick-link:hover {
        border-color: var(--gc-primary) !important;
        box-shadow: var(--gc-shadow-sm) !important;
      }

      /* Hero animation */
      .gc-hero-title {
        animation: gc-slide-in 0.5s cubic-bezier(0.16, 1, 0.3, 1) both;
      }
      .gc-hero-section p {
        animation: gc-slide-in 0.5s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both;
      }
      .gc-terminal-card {
        animation: gc-slide-in 0.5s cubic-bezier(0.16, 1, 0.3, 1) 0.2s both;
      }
      @keyframes gc-slide-in {
        from { opacity: 0; transform: translateY(18px); }
        to { opacity: 1; transform: translateY(0); }
      }
      .gc-section-reveal {
        opacity: 0;
        transform: translateY(16px);
        animation: gc-slide-in 0.5s cubic-bezier(0.16, 1, 0.3, 1) 0.3s both;
      }

      /* Stats */
      .gc-stats-cell {
        transition: background 150ms;
      }
      .gc-stats-cell:hover {
        background: rgba(66, 133, 244, 0.1) !important;
      }

      /* Responsive */
      @media (max-width: 768px) {
        .gc-hero-grid { grid-template-columns: 1fr !important; }
        .gc-terminal-card { width: 100% !important; }
      }

      /* Sub-nav */
      .gc-subnav {
        background: var(--gc-bg-surface, var(--gc-bg));
        border-bottom: 2px solid var(--gc-border-dim, var(--gc-border));
        position: sticky;
        top: 56px;
        z-index: 49;
      }
      .gc-subnav__inner {
        max-width: 1400px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        gap: 1.5rem;
        padding: 0.5rem 1.25rem;
      }
      .gc-subnav__brand {
        font-family: var(--gc-font-headline);
        font-weight: 900;
        font-size: 1rem;
        color: var(--gc-primary-bright, var(--gc-primary));
        font-style: italic;
        letter-spacing: -0.03em;
      }
      .gc-subnav__link {
        font-family: var(--gc-font-headline);
        font-weight: 700;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        text-decoration: none;
        color: var(--gc-text);
        opacity: 0.6;
        padding-bottom: 2px;
        transition: color 100ms, opacity 100ms;
      }
      .gc-subnav__link:hover {
        opacity: 1;
        color: var(--gc-primary-bright, var(--gc-primary));
      }
      .gc-subnav__link--active {
        color: var(--gc-primary-bright, var(--gc-primary));
        opacity: 1;
        border-bottom: 3px solid var(--gc-primary-bright, var(--gc-primary));
      }

      @media (max-width: 640px) {
        .gc-subnav__inner {
          flex-wrap: wrap;
          gap: 0.5rem;
        }
        .gc-subnav__brand {
          font-size: 0.85rem;
        }
        .gc-subnav__link {
          font-size: 0.7rem;
        }
      }
    </style>
      <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "Gemini CLI",
      "description": "An open-source AI agent for the command line, built on the Gemini model",
      "url": "https://github.com/google-gemini/gemini-cli",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "Cross-platform",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      }
    })} />
      <link rel="alternate" type="application/rss+xml" title="changelogs.info RSS" href="/feed/all.xml" />
  </head>
  <body>
        <!-- Shared top nav -->
    <SharedNav currentSection="gemini-cli" />

    <!-- Gemini sub-nav -->
    <div class="gc-subnav">
      <div class="gc-subnav__inner">
        <span class="gc-subnav__brand">Gemini</span>
        {navLinks.map((link) => (
          <a
            href={link.href}
            class={`gc-subnav__link ${currentPage === link.key ? "gc-subnav__link--active" : ""}`}
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>

    <!-- Main content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer style="border-top: 8px solid var(--gc-primary); background: var(--gc-bg); margin-top: 6rem; padding: 3rem 2rem;">
      <div style="max-width: 1280px; margin: 0 auto; display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; gap: 1.5rem;">
        <div style="display: flex; flex-direction: column; gap: 0.25rem;">
          <span class="gc-headline" style="font-size: 0.65rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.15em; color: var(--gc-text-dim);">
            © {new Date().getFullYear()} changelogs.info / Gemini CLI
          </span>
          <span style="font-family: var(--gc-font-mono); font-size: 0.6rem; color: var(--gc-text-muted);">
            DATA FROM OFFICIAL GITHUB RELEASES
          </span>
        </div>
        <div style="display: flex; gap: 2rem; flex-wrap: wrap;">
          {[
            { label: "Hub", href: "/" },
            { label: "Changelog", href: "/gemini-cli/changelog/" },
            { label: "Cheatsheet", href: "/gemini-cli/cheatsheet/" },
            { label: "Quickstart", href: "/gemini-cli/quickstart/" },
            { label: "Tips", href: "/gemini-cli/tips/" },
            { label: "Releases", href: "/gemini-cli/releases/" },
            { label: "GitHub ↗", href: "https://github.com/google-gemini/gemini-cli", external: true },
            { label: "RSS", href: "/feed/all.xml" },
          ].map((link) => (
            <a
              href={link.href}
              target={link.external ? "_blank" : undefined}
              rel={link.external ? "noopener noreferrer" : undefined}
              class="gc-headline"
              style="font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--gc-text-dim); text-decoration: none; transition: color 150ms;"
              onmouseover={`this.style.color='var(--gc-primary-bright)'`}
              onmouseout={`this.style.color='var(--gc-text-dim)'`}
            >
              {link.label}
            </a>
          ))}
        </div>
        <div style="font-family: var(--gc-font-mono); font-size: 0.65rem; color: var(--gc-text-muted); display: flex; align-items: center; gap: 0.5rem;">
          <span style="color: var(--gc-primary);">›</span>
          GEMINI-CLI: ~
        </div>
      </div>
    </footer>

    
    <SiteAnimations />
  </body>
</html>
