---
import "../styles/global.css";
import "../styles/view-transitions.css";
import { ViewTransitions } from "astro:transitions";
import SharedNav from "../components/SharedNav.astro";

interface Props {
  title: string;
  description?: string;
  currentPage?: string;
}

const {
  title,
  description = "Track Codex CLI releases, breaking changes, and config updates.",
  currentPage = "",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const navLinks = [
  { label: "Changelog", href: "/codex-cli/changelog/", key: "changelog" },
  { label: "Cheatsheet", href: "/codex-cli/cheatsheet/", key: "cheatsheet" },
  { label: "Releases", href: "/codex-cli/releases/", key: "releases" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@700;800;900&family=Work+Sans:wght@400;500;700&family=JetBrains+Mono:wght@400;700&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@700;800;900&family=Work+Sans:wght@400;500;700&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" />
    </noscript>
    <ViewTransitions />
    <script defer data-domain="changelogs.info" src="https://plausible.io/js/script.js"></script>

    <style is:global>
      @font-face {
        font-family: 'Space Grotesk Fallback';
        src: local('Arial Black'), local('Arial');
        size-adjust: 107%;
        ascent-override: 95%;
        descent-override: 22%;
        line-gap-override: 0%;
      }
      @font-face {
        font-family: 'Work Sans Fallback';
        src: local('Helvetica Neue'), local('Arial');
        size-adjust: 100%;
        ascent-override: 96%;
        descent-override: 24%;
        line-gap-override: 0%;
      }

      /* Codex CLI Terminal Green Neo-Brutalist Theme */
      :root {
        --cx-header-bg: rgba(0, 10, 2, 0.92);
        --cx-primary: #00c851;
        --cx-primary-bright: #33ff33;
        --cx-accent: #00ff41;
        --cx-bg: #000a02;
        --cx-bg-card: #001204;
        --cx-bg-surface: #001a06;
        --cx-text: #e0ffe8;
        --cx-text-dim: rgba(200, 255, 220, 0.65);
        --cx-text-muted: rgba(180, 255, 200, 0.4);
        --cx-border: #33ff33;
        --cx-border-dim: rgba(51, 255, 51, 0.2);
        --cx-shadow: 6px 6px 0px 0px rgba(51, 255, 51, 0.25);
        --cx-shadow-sm: 4px 4px 0px 0px rgba(51, 255, 51, 0.2);
        --cx-shadow-lg: 12px 12px 0px 0px rgba(51, 255, 51, 0.12);
        --cx-font-headline: "Space Grotesk", "Space Grotesk Fallback", sans-serif;
        --cx-font-body: "JetBrains Mono", ui-monospace, monospace;
        --cx-font-mono: "JetBrains Mono", ui-monospace, monospace;
      }

      [data-theme="light"] {
        --cx-header-bg: rgba(240, 255, 244, 0.92);
        --cx-primary: #00a83e;
        --cx-primary-bright: #007a2e;
        --cx-bg: #f0fff4;
        --cx-bg-card: #ffffff;
        --cx-bg-surface: #dcffe8;
        --cx-text: #001a06;
        --cx-text-dim: rgba(0, 26, 6, 0.65);
        --cx-text-muted: rgba(0, 26, 6, 0.4);
        --cx-border: #001a06;
        --cx-border-dim: rgba(0, 26, 6, 0.2);
        --cx-shadow: 6px 6px 0px 0px rgba(0, 0, 0, 1);
        --cx-shadow-sm: 4px 4px 0px 0px rgba(0, 0, 0, 1);
        --cx-shadow-lg: 12px 12px 0px 0px rgba(0, 0, 0, 0.8);
      }

      /* Base */
      html[data-layout="codex"] {
        background: var(--cx-bg);
        color: var(--cx-text);
      }
      html[data-layout="codex"] body {
        margin: 0;
        padding: 0;
        background: var(--cx-bg);
        color: var(--cx-text);
        font-family: var(--cx-font-body);
        min-height: 100vh;
      }

      /* CRT scanlines overlay (always subtle) */
      html[data-layout="codex"] body::before {
        content: '';
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        background: repeating-linear-gradient(
          0deg,
          rgba(0, 255, 65, 0.015),
          rgba(0, 255, 65, 0.015) 1px,
          transparent 1px,
          transparent 3px
        );
        pointer-events: none;
        z-index: 9998;
        opacity: 0.8;
      }

      /* Typography */
      .cx-headline {
        font-family: var(--cx-font-headline);
        font-weight: 900;
      }

      /* Badge styles */
      .cl-badge {
        display: inline-block;
        font-family: var(--cx-font-mono);
        font-size: 0.55rem;
        font-weight: 700;
        padding: 0.1rem 0.4rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-right: 0.4rem;
        vertical-align: middle;
      }
      .cl-badge-fix { background: rgba(51, 255, 51, 0.1); color: #33ff33; border: 1px solid rgba(51, 255, 51, 0.3); }
      .cl-badge-feat { background: rgba(0, 200, 81, 0.12); color: #00c851; border: 1px solid rgba(0, 200, 81, 0.3); }
      .cl-badge-docs { background: rgba(0, 255, 65, 0.08); color: #00ff41; border: 1px solid rgba(0, 255, 65, 0.2); }
      .cl-badge-test { background: rgba(0, 168, 62, 0.1); color: #00a83e; border: 1px solid rgba(0, 168, 62, 0.2); }
      .cl-badge-chore { background: rgba(0, 100, 30, 0.1); color: #00641e; border: 1px solid rgba(0, 100, 30, 0.2); }
      .cl-badge-ci { background: rgba(0, 80, 20, 0.08); color: #005014; border: 1px solid rgba(0, 80, 20, 0.15); }
      .cl-badge-perf { background: rgba(51, 255, 51, 0.15); color: #33ff33; border: 1px solid rgba(51, 255, 51, 0.35); }

      .cl-pr-link {
        color: var(--cx-primary-bright) !important;
        text-decoration: none;
        font-family: var(--cx-font-mono);
        font-size: 0.8em;
        opacity: 0.7;
        transition: opacity 150ms;
      }
      .cl-pr-link:hover { opacity: 1; }

      /* Changelog body */
      .changelog-body h1, .changelog-body h2, .changelog-body h3, .changelog-body h4 {
        font-family: var(--cx-font-headline);
        font-weight: 800;
        text-transform: uppercase;
        color: var(--cx-text);
        margin: 1.5rem 0 0.75rem;
        letter-spacing: -0.01em;
      }
      .changelog-body h1 { font-size: 1.3rem; }
      .changelog-body h2 { font-size: 1.1rem; border-bottom: 2px solid var(--cx-border-dim); padding-bottom: 0.25rem; }
      .changelog-body h3 { font-size: 0.95rem; color: var(--cx-primary-bright); }
      .changelog-body p { margin: 0.75rem 0; }
      .changelog-body ul { list-style: none; margin: 0.5rem 0; padding: 0; }
      .changelog-body li { padding: 0.25rem 0; display: flex; align-items: flex-start; gap: 0.5rem; }
      .changelog-body li::before { content: '>'; color: var(--cx-primary-bright); flex-shrink: 0; font-weight: 700; font-family: var(--cx-font-mono); }
      .changelog-body code {
        font-family: var(--cx-font-mono);
        font-size: 0.85em;
        background: rgba(51, 255, 51, 0.08);
        color: var(--cx-primary-bright);
        padding: 0.1rem 0.35rem;
        border: 1px solid rgba(51, 255, 51, 0.2);
      }
      .changelog-body pre {
        background: var(--cx-bg-surface);
        border: 2px solid var(--cx-border-dim);
        padding: 1rem;
        overflow-x: auto;
        font-family: var(--cx-font-mono);
        font-size: 0.8rem;
      }
      .changelog-body a {
        color: var(--cx-primary-bright);
        text-decoration: none;
        border-bottom: 1px solid rgba(51, 255, 51, 0.3);
        transition: border-color 150ms;
      }
      .changelog-body a:hover { border-color: var(--cx-primary-bright); }
      .changelog-body strong { color: var(--cx-text); font-weight: 700; }

      /* Collapsed changelog */
      .cl-collapsed {
        max-height: 180px;
      }
      .cl-collapsed::after {
        content: '';
        position: absolute;
        bottom: 0; left: 0; right: 0;
        height: 80px;
        background: linear-gradient(to bottom, transparent, var(--cx-bg-card));
        pointer-events: none;
      }

      /* Dot gridDot grid */
      .cx-dotgrid {
        background-image: radial-gradient(circle, var(--cx-border-dim) 1px, transparent 1px);
        background-size: 24px 24px;
      }

      /* Cursor blink */
      .cx-cursor {
        animation: cx-blink 1s step-end infinite;
      }
      @keyframes cx-blink {
        0%, 100% { opacity: 1; }
        50% { opacity: 0; }
      }

      /* Pulse dot */
      .cx-pulse-dot {
        animation: cx-pulse 2s ease-in-out infinite;
      }
      @keyframes cx-pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.4; }
      }

      /* CTA button */
      .cx-cta-btn {
        transition: transform 100ms, box-shadow 100ms;
      }
      .cx-cta-btn:hover {
        transform: translate(1px, 1px);
        box-shadow: none !important;
      }

      /* Quick link */
      .cx-quick-link {
        transition: border-color 150ms, box-shadow 150ms;
      }
      .cx-quick-link:hover {
        border-color: var(--cx-primary) !important;
        box-shadow: var(--cx-shadow-sm) !important;
      }

      /* Hero animation */
      .cx-hero-title {
        animation: cx-slide-in 0.5s cubic-bezier(0.16, 1, 0.3, 1) both;
      }
      .cx-hero-section p {
        animation: cx-slide-in 0.5s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both;
      }
      .cx-terminal-card {
        animation: cx-slide-in 0.5s cubic-bezier(0.16, 1, 0.3, 1) 0.2s both;
      }
      @keyframes cx-slide-in {
        from { opacity: 0; transform: translateY(18px); }
        to { opacity: 1; transform: translateY(0); }
      }
      .cx-section-reveal {
        opacity: 0;
        transform: translateY(16px);
        animation: cx-slide-in 0.5s cubic-bezier(0.16, 1, 0.3, 1) 0.3s both;
      }

      /* Stats */
      .cx-stats-cell {
        transition: background 150ms;
      }
      .cx-stats-cell:hover {
        background: rgba(51, 255, 51, 0.1) !important;
      }

      /* Responsive */
      @media (max-width: 768px) {
        .cx-hero-grid { grid-template-columns: 1fr !important; }
        .cx-terminal-card { width: 100% !important; }
      }

      /* Sub-nav */
      .cx-subnav {
        background: var(--cx-bg-surface, var(--cx-bg));
        border-bottom: 2px solid var(--cx-border-dim, var(--cx-border));
        position: sticky;
        top: 56px;
        z-index: 49;
      }
      .cx-subnav__inner {
        max-width: 1400px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        gap: 1.5rem;
        padding: 0.5rem 1.25rem;
      }
      .cx-subnav__brand {
        font-family: var(--cx-font-headline);
        font-weight: 900;
        font-size: 1rem;
        color: var(--cx-primary-bright, var(--cx-primary));
        font-style: italic;
        letter-spacing: -0.03em;
      }
      .cx-subnav__link {
        font-family: var(--cx-font-headline);
        font-weight: 700;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        text-decoration: none;
        color: var(--cx-text);
        opacity: 0.6;
        padding-bottom: 2px;
        transition: color 100ms, opacity 100ms;
      }
      .cx-subnav__link:hover {
        opacity: 1;
        color: var(--cx-primary-bright, var(--cx-primary));
      }
      .cx-subnav__link--active {
        color: var(--cx-primary-bright, var(--cx-primary));
        opacity: 1;
        border-bottom: 3px solid var(--cx-primary-bright, var(--cx-primary));
      }
    </style>
  </head>
  <body>
        <!-- Shared top nav -->
    <SharedNav currentSection="codex-cli" />

    <!-- Codex sub-nav -->
    <div class="cx-subnav">
      <div class="cx-subnav__inner">
        <span class="cx-subnav__brand">Codex</span>
        {navLinks.map((link) => (
          <a
            href={link.href}
            class={`cx-subnav__link ${currentPage === link.key ? "cx-subnav__link--active" : ""}`}
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>

    <!-- Main content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer style="border-top: 8px solid var(--cx-primary); background: var(--cx-bg); margin-top: 6rem; padding: 3rem 2rem;">
      <div style="max-width: 1280px; margin: 0 auto; display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; gap: 1.5rem;">
        <div style="display: flex; flex-direction: column; gap: 0.25rem;">
          <span class="cx-headline" style="font-size: 0.65rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.15em; color: var(--cx-text-dim);">
            © {new Date().getFullYear()} changelogs.info / Codex CLI
          </span>
          <span style="font-family: var(--cx-font-mono); font-size: 0.6rem; color: var(--cx-text-muted);">
            DATA FROM OFFICIAL GITHUB RELEASES
          </span>
        </div>
        <div style="display: flex; gap: 2rem; flex-wrap: wrap;">
          {[
            { label: "Hub", href: "/" },
            { label: "Changelog", href: "/codex-cli/changelog/" },
            { label: "Cheatsheet", href: "/codex-cli/cheatsheet/" },
            { label: "Releases", href: "/codex-cli/releases/" },
            { label: "GitHub ↗", href: "https://github.com/openai/codex", external: true },
            { label: "RSS", href: "/feed/all.xml" },
          ].map((link) => (
            <a
              href={link.href}
              target={link.external ? "_blank" : undefined}
              rel={link.external ? "noopener noreferrer" : undefined}
              class="cx-headline"
              style="font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--cx-text-dim); text-decoration: none; transition: color 150ms;"
              onmouseover={`this.style.color='var(--cx-primary-bright)'`}
              onmouseout={`this.style.color='var(--cx-text-dim)'`}
            >
              {link.label}
            </a>
          ))}
        </div>
        <div style="font-family: var(--cx-font-mono); font-size: 0.65rem; color: var(--cx-text-muted); display: flex; align-items: center; gap: 0.5rem;">
          <span style="color: var(--cx-primary);">$</span>
          CODEX-CLI: ~
        </div>
      </div>
    </footer>

    
  </body>
</html>
