---
import "../styles/op-extracted.css";
import "../styles/tool-shared.css";
import "../styles/global.css";
import "../styles/shared-nav.css";
import "../styles/view-transitions.css";
import { ViewTransitions } from "astro:transitions";
import SharedNav from "../components/SharedNav.astro";

interface Props {
  title: string;
  description?: string;
  currentPage?: string;
}

const {
  title,
  description = "Open source AI coding agent for terminal, IDE, and desktop. Multi-session, 75+ LLM providers, LSP support.",
  currentPage = "",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const navLinks = [
  { label: "Changelog", href: "/opencode/changelog/", key: "changelog" },
  { label: "Cheatsheet", href: "/opencode/cheatsheet/", key: "cheatsheet" },
  { label: "Releases", href: "/opencode/releases/", key: "releases" },
];
---

<!doctype html>
<html lang="en" data-layout="opencode">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <ViewTransitions />
    <script defer data-domain="changelogs.info" src="https://plausible.io/js/script.js"></script>

    <style is:global>
      @font-face {
        font-family: 'Space Grotesk Fallback';
        src: local('Arial Black'), local('Arial');
        size-adjust: 107%;
        ascent-override: 95%;
        descent-override: 22%;
        line-gap-override: 0%;
      }
      @font-face {
        font-family: 'Work Sans Fallback';
        src: local('Helvetica Neue'), local('Arial');
        size-adjust: 100%;
        ascent-override: 96%;
        descent-override: 24%;
        line-gap-override: 0%;
      }

      /* OpenCode Sky Blue Neo-Brutalist Theme */
      :root {
        --op-header-bg: rgba(0, 8, 16, 0.92);
        --op-primary: #0EA5E9;
        --op-primary-bright: #38bdf8;
        --op-accent: #7dd3fc;
        --op-bg: #000810;
        --op-bg-card: #001020;
        --op-bg-surface: #001830;
        --op-text: #e0f4ff;
        --op-text-dim: rgba(200, 235, 255, 0.65);
        --op-text-muted: rgba(180, 220, 255, 0.4);
        --op-border: #38bdf8;
        --op-border-dim: rgba(14, 165, 233, 0.25);
        --op-shadow: 6px 6px 0px 0px rgba(14, 165, 233, 0.3);
        --op-shadow-sm: 4px 4px 0px 0px rgba(14, 165, 233, 0.25);
        --op-shadow-lg: 12px 12px 0px 0px rgba(14, 165, 233, 0.15);
        --op-font-headline: "Space Grotesk", "Space Grotesk Fallback", sans-serif;
        --op-font-body: "Work Sans", "Work Sans Fallback", sans-serif;
        --op-font-mono: "JetBrains Mono", ui-monospace, monospace;

        /* Bridge vars for tool-shared.css */
        --tool-primary: var(--op-primary);
        --tool-primary-bright: var(--op-primary-bright);
        --tool-font-mono: var(--op-font-mono);
        --tool-font-headline: var(--op-font-headline);
        --tool-font-body: var(--op-font-body);
        --tool-bg: var(--op-bg);
        --tool-bg-card: var(--op-bg-card);
        --tool-bg-surface: var(--op-bg-surface);
        --tool-text: var(--op-text);
        --tool-border-dim: var(--op-border-dim);
      }

      [data-theme="light"] {
        --op-header-bg: rgba(240, 249, 255, 0.92);
        --op-primary: #0284c7;
        --op-primary-bright: #0369a1;
        --op-bg: #f0f9ff;
        --op-bg-card: #ffffff;
        --op-bg-surface: #e0f2fe;
        --op-text: #001830;
        --op-text-dim: rgba(0, 24, 48, 0.65);
        --op-text-muted: rgba(0, 24, 48, 0.4);
        --op-border: #001830;
        --op-border-dim: rgba(0, 24, 48, 0.2);
        --op-shadow: 6px 6px 0px 0px rgba(0, 0, 0, 1);
        --op-shadow-sm: 4px 4px 0px 0px rgba(0, 0, 0, 1);
        --op-shadow-lg: 12px 12px 0px 0px rgba(0, 0, 0, 0.8);

        --tool-bg-card: var(--op-bg-card);
        --tool-bg-surface: var(--op-bg-surface);
        --tool-text: var(--op-text);
        --tool-border-dim: var(--op-border-dim);
      }

      html[data-layout="opencode"] {
        background: var(--op-bg);
        color: var(--op-text);
      }
      html[data-layout="opencode"] body {
        margin: 0;
        padding: 0;
        background: var(--op-bg);
        color: var(--op-text);
        font-family: var(--op-font-body);
        min-height: 100vh;
      }

      /* Subtle scanline */
      html[data-layout="opencode"] body::before {
        content: '';
        position: fixed;
        top: 0; left: 0; right: 0; bottom: 0;
        background: repeating-linear-gradient(
          0deg,
          rgba(14, 165, 233, 0.012),
          rgba(14, 165, 233, 0.012) 1px,
          transparent 1px,
          transparent 4px
        );
        pointer-events: none;
        z-index: 9998;
        opacity: 0.5;
      }

      .op-headline {
        font-family: var(--op-font-mono);
        font-weight: 900;
      }

      /* CTA button */
      .op-cta-btn {
        transition: transform 100ms, box-shadow 100ms;
      }
      .op-cta-btn:hover {
        transform: translate(1px, 1px);
        box-shadow: none !important;
      }

      .op-quick-link {
        transition: border-color 150ms, box-shadow 150ms;
      }
      .op-quick-link:hover {
        border-color: var(--op-primary) !important;
        box-shadow: var(--op-shadow-sm) !important;
      }

      .op-dotgrid {
        background-image: radial-gradient(circle, var(--op-border-dim) 1px, transparent 1px);
        background-size: 24px 24px;
      }

      .op-cursor {
        animation: op-blink 1s step-end infinite;
      }
      @keyframes op-blink {
        0%, 100% { opacity: 1; }
        50% { opacity: 0; }
      }

      .op-pulse-dot {
        animation: op-pulse 2s ease-in-out infinite;
      }
      @keyframes op-pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.4; }
      }

      .op-hero-title {
        animation: op-slide-in 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
      }
      .op-hero-section p {
        animation: op-slide-in 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both;
      }
      .op-terminal-card {
        animation: op-slide-in 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.2s both;
      }
      @keyframes op-slide-in {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
      }

      .op-section-reveal {
        opacity: 0;
        transform: translateY(16px);
        animation: op-slide-in 0.5s cubic-bezier(0.16, 1, 0.3, 1) 0.3s both;
      }

      .op-stats-cell {
        transition: background 150ms;
      }
      .op-stats-cell:hover {
        background: var(--op-primary) !important;
      }

      @media (max-width: 768px) {
        .op-hero-grid { grid-template-columns: 1fr !important; }
        .op-terminal-card { width: 100% !important; }
      }
    </style>
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "OpenCode",
      "description": "Open source AI coding agent for terminal, IDE, and desktop with 75+ LLM providers",
      "url": "https://github.com/sst/opencode",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "Cross-platform",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      }
    })} />
    <link rel="alternate" type="application/rss+xml" title="changelogs.info RSS" href="/feed/all.xml" />
  </head>
  <body>
    <SharedNav currentSection="opencode" />

    <!-- OpenCode sub-nav -->
    <nav class="tool-subnav" aria-label="OpenCode section navigation">
      <div class="tool-subnav__inner" style="font-family: var(--op-font-mono);">
        <span class="tool-subnav__brand">OpenCode</span>
        {navLinks.map((link) => (
          <a
            href={link.href}
            class={`tool-subnav__link ${currentPage === link.key ? "tool-subnav__link--active" : ""}`}
          >
            {link.label}
          </a>
        ))}
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer style="border-top: 8px solid var(--op-primary); background: var(--op-bg); margin-top: 6rem; padding: 3rem 2rem;">
      <div style="max-width: 1280px; margin: 0 auto; display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; gap: 1.5rem;">
        <div style="display: flex; flex-direction: column; gap: 0.25rem;">
          <span class="op-headline" style="font-size: 0.65rem; font-weight: 900; text-transform: uppercase; letter-spacing: 0.15em; color: var(--op-text-dim);">
            © {new Date().getFullYear()} changelogs.info / OpenCode
          </span>
          <span style="font-family: var(--op-font-mono); font-size: 0.6rem; color: var(--op-text-muted);">
            DATA FROM OFFICIAL GITHUB RELEASES
          </span>
        </div>
        <div style="display: flex; gap: 2rem; flex-wrap: wrap;">
          {[
            { label: "Hub", href: "/" },
            { label: "Changelog", href: "/opencode/changelog/" },
            { label: "Cheatsheet", href: "/opencode/cheatsheet/" },
            { label: "Releases", href: "/opencode/releases/" },
            { label: "GitHub ↗", href: "https://github.com/sst/opencode", external: true },
            { label: "RSS", href: "/feed/all.xml" },
          ].map((link) => (
            <a
              href={link.href}
              target={link.external ? "_blank" : undefined}
              rel={link.external ? "noopener noreferrer" : undefined}
              class="op-headline"
              style="font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--op-text-dim); text-decoration: none; transition: color 150ms;"
              onmouseover={`this.style.color='var(--op-primary-bright)'`}
              onmouseout={`this.style.color='var(--op-text-dim)'`}
            >
              {link.label}
            </a>
          ))}
        </div>
        <div style="font-family: var(--op-font-mono); font-size: 0.65rem; color: var(--op-text-muted); display: flex; align-items: center; gap: 0.5rem;">
          <span style="color: var(--op-primary);">○</span>
          OPENCODE: ~
        </div>
      </div>
    </footer>
  </body>
</html>
