{
  "migrations": [
    {
      "id": "cursor-to-claude-code",
      "source": "cursor",
      "target": "claude-code",
      "title": "Cursor → Claude Code",
      "description": "Switching from the AI-first IDE to terminal-based agentic coding",
      "equivalentCommands": [
        {
          "cursor": "Cmd+K (inline edit)",
          "claudeCode": "claude \"edit this function to...\"",
          "notes": "Claude Code works on entire files via natural language"
        },
        {
          "cursor": "Cmd+L (chat)",
          "claudeCode": "claude \"explain how this code works\"",
          "notes": "Chat is conversational in terminal"
        },
        {
          "cursor": "Composer (Cmd+I)",
          "claudeCode": "claude \"implement feature X\"",
          "notes": "Claude Code can edit multiple files autonomously"
        },
        {
          "cursor": "@codebase search",
          "claudeCode": "Claude Code indexes automatically on first run",
          "notes": "No explicit indexing needed"
        }
      ],
      "configMigration": [
        {
          "step": 1,
          "action": "Export Cursor rules",
          "command": "Copy .cursorrules content",
          "notes": "Cursor stores project rules in .cursorrules"
        },
        {
          "step": 2,
          "action": "Create CLAUDE.md",
          "command": "Create CLAUDE.md in project root",
          "notes": "Paste your .cursorrules content as a starting point"
        },
        {
          "step": 3,
          "action": "Add model preference",
          "command": "Add 'Model: anthropic/claude-sonnet-4' to CLAUDE.md",
          "notes": "Claude Code uses Claude models natively"
        },
        {
          "step": 4,
          "action": "Set up settings",
          "command": "claude config set model claude-sonnet-4",
          "notes": "Configure default model in CLI"
        }
      ],
      "keyDifferences": [
        {
          "aspect": "Interface",
          "source": "Full IDE with editor, terminal, chat panels",
          "target": "Terminal-based, works in your existing editor"
        },
        {
          "aspect": "Context",
          "source": "Visual context from open files",
          "target": "Explicit file/CLI context you provide"
        },
        {
          "aspect": "Multi-file edits",
          "source": "Composer mode with diff preview",
          "target": "Autonomous multi-file edits with git integration"
        },
        {
          "aspect": "Model choice",
          "source": "Multiple providers (Claude, GPT, Gemini)",
          "target": "Claude models only (native integration)"
        }
      ],
      "mentalModelChanges": [
        {
          "from": "Think in UI interactions",
          "to": "Think in natural language commands",
          "example": "Instead of selecting text → Cmd+K, just say 'refactor the auth module'"
        },
        {
          "from": "Preview every change",
          "to": "Trust autonomous edits (with git safety)",
          "example": "Claude commits after each logical change; review via git diff"
        },
        {
          "from": "Context is what you see",
          "to": "Context is what you describe",
          "example": "Be explicit: 'in src/auth/login.ts' rather than relying on open tabs"
        }
      ]
    },
    {
      "id": "codex-to-gemini",
      "source": "codex-cli",
      "target": "gemini-cli",
      "title": "Codex CLI → Gemini CLI",
      "description": "Switching between terminal-based coding agents",
      "equivalentCommands": [
        {
          "codex": "codex \"implement X\"",
          "gemini": "gemini -p \"implement X\"",
          "notes": "Both work as one-shot commands"
        },
        {
          "codex": "codex exec --full-auto",
          "gemini": "gemini -p \"task\" (auto-approves by default)",
          "notes": "Gemini CLI tends to be more autonomous"
        },
        {
          "codex": "codex --writable-root .",
          "gemini": "gemini works in current directory",
          "notes": "Both operate on local files"
        },
        {
          "codex": "codex review",
          "gemini": "gemini -p \"review the changes\"",
          "notes": "Gemini doesn't have dedicated review mode"
        }
      ],
      "configMigration": [
        {
          "step": 1,
          "action": "Export Codex config",
          "command": "cat ~/.codex/config.json",
          "notes": "Check your current settings"
        },
        {
          "step": 2,
          "action": "Set Gemini API key",
          "command": "export GOOGLE_API_KEY=your_key",
          "notes": "Or add to ~/.bashrc or ~/.zshrc"
        },
        {
          "step": 3,
          "action": "Create Gemini config",
          "command": "mkdir -p ~/.gemini && touch ~/.gemini/config.json",
          "notes": "Gemini uses different config structure"
        },
        {
          "step": 4,
          "action": "Copy AGENTS.md",
          "command": "cp AGENTS.md AGENTS.md (no change needed)",
          "notes": "Both tools can read AGENTS.md for project context"
        }
      ],
      "keyDifferences": [
        {
          "aspect": "Default model",
          "source": "GPT-5.4",
          "target": "Gemini 2.5 Pro/Flash"
        },
        {
          "aspect": "Context window",
          "source": "200K tokens",
          "target": "1M+ tokens (Gemini excels here)"
        },
        {
          "aspect": "Sandbox",
          "source": "Built-in sandbox mode",
          "target": "LXC/gVisor sandbox available"
        },
        {
          "aspect": "Review mode",
          "source": "Dedicated 'codex review' command",
          "target": "Use natural language for review tasks"
        }
      ],
      "mentalModelChanges": [
        {
          "from": "GPT-style responses",
          "to": "Gemini-style responses",
          "example": "Gemini tends to be more verbose, better at research tasks"
        },
        {
          "from": "200K context limit",
          "to": "1M+ context opens new possibilities",
          "example": "Can include entire codebases or long documentation"
        },
        {
          "from": "Explicit review command",
          "to": "Review is just another task",
          "example": "Say 'review PR #123' instead of using dedicated mode"
        }
      ]
    },
