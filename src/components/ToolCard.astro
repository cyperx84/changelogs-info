---
import type { Tool, Release } from "../lib/releases";
import { formatDate, relativeTime, getCategoryLabel } from "../lib/releases";

interface Props {
  tool: Tool;
  latestRelease?: Release;
}

const { tool, latestRelease } = Astro.props;

// Freshness calculation
let freshness: "fresh" | "normal" | "stale" = "normal";
if (latestRelease) {
  const now = Date.now();
  const releaseDate = new Date(latestRelease.date).getTime();
  const daysSince = Math.floor((now - releaseDate) / (1000 * 60 * 60 * 24));
  if (daysSince <= 7) freshness = "fresh";
  else if (daysSince > 30) freshness = "stale";
}
---

<a
  href={`/tools/${tool.id}`}
  class="tool-card group block rounded-lg border border-border bg-bg-card transition-all hover:border-green hover:shadow-[0_0_12px_rgba(51,255,51,0.15)]"
>
  <div class="scanline-sweep"></div>
  <!-- Terminal title bar -->
  <div class="border-b border-border px-3 py-2 font-mono text-xs text-text-muted">
    <span class="text-green">●●●</span>
    <span class="ml-2 text-text-muted">~/{tool.id}</span>
  </div>

  <!-- Terminal content -->
  <div class="p-4 sm:p-5">
    <div class="mb-3 flex items-start justify-between gap-2">
      <div class="min-w-0 flex-1">
        <h3 class="font-mono text-base font-semibold text-green transition-all group-hover:text-green-bright group-hover:text-glow-green sm:text-lg">
          {tool.name}
        </h3>
        <p class="mt-1 font-mono text-xs text-text-muted truncate">
          <span class="text-green">~/</span>{tool.repo}
        </p>
      </div>
      <span class="shrink-0 rounded border border-border/50 bg-bg-tertiary px-2 py-0.5 font-mono text-[10px] text-text-muted">
        {getCategoryLabel(tool.category)}
      </span>
    </div>

    <p class="mb-4 font-sans text-xs leading-relaxed text-text-secondary line-clamp-2 sm:text-sm">
      {tool.description}
    </p>

    {latestRelease ? (
      <div class="flex items-center gap-2 rounded border border-border/50 bg-bg-tertiary px-3 py-2 font-mono text-xs sm:gap-3 sm:text-sm">
        <span class="font-medium text-green">{latestRelease.version}</span>
        <span class="text-text-muted">│</span>
        <span class="text-text-muted" title={formatDate(latestRelease.date)}>
          {relativeTime(latestRelease.date)}
        </span>
        {freshness === "fresh" && (
          <>
            <span class="text-text-muted">│</span>
            <span class="flex items-center gap-1">
              <span class="pulse-dot inline-block h-1.5 w-1.5 rounded-full bg-green"></span>
              <span class="text-green text-[10px]">fresh</span>
            </span>
          </>
        )}
        {freshness === "stale" && (
          <>
            <span class="text-text-muted">│</span>
            <span class="flex items-center gap-1">
              <span class="inline-block h-1.5 w-1.5 rounded-full bg-amber"></span>
              <span class="text-amber text-[10px]">stale</span>
            </span>
          </>
        )}
      </div>
    ) : (
      <div class="flex items-center gap-2 rounded border border-border/50 bg-bg-tertiary px-3 py-2 font-mono text-xs">
        <span class="text-red">!</span>
        <span class="text-text-muted">no data</span>
      </div>
    )}
  </div>
</a>
