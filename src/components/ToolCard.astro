---
import type { Tool, Release } from "../lib/releases";
import { formatDate, relativeTime, getCategoryLabel } from "../lib/releases";

interface Props {
  tool: Tool;
  latestRelease?: Release;
}

const { tool, latestRelease } = Astro.props;
---

<a
  href={`/tools/${tool.id}`}
  class="tool-card group block rounded-xl border border-border bg-bg-card p-4 transition-all hover:border-border-hover hover:bg-bg-card-hover sm:p-5"
>
  <div class="mb-3 flex items-start justify-between gap-2">
    <div class="min-w-0 flex-1">
      <h3 class="text-base font-semibold text-text-primary group-hover:text-accent transition-colors sm:text-lg">
        {tool.name}
      </h3>
      <p class="mt-0.5 font-mono text-xs text-text-muted truncate">{tool.repo}</p>
    </div>
    <span class="shrink-0 rounded-full border border-border bg-bg-tertiary px-2 py-0.5 text-xs text-text-secondary sm:px-2.5">
      {getCategoryLabel(tool.category)}
    </span>
  </div>

  <p class="mb-4 text-xs leading-relaxed text-text-secondary line-clamp-2 sm:text-sm">
    {tool.description}
  </p>

  {latestRelease ? (
    <div class="flex items-center gap-2 rounded-lg bg-bg-tertiary px-3 py-2 sm:gap-3">
      <span class="font-mono text-xs font-medium text-green sm:text-sm">{latestRelease.version}</span>
      <span class="text-xs text-text-muted">&middot;</span>
      <span class="text-xs text-text-muted" title={formatDate(latestRelease.date)}>
        {relativeTime(latestRelease.date)}
      </span>
    </div>
  ) : (
    <div class="flex items-center gap-3 rounded-lg bg-bg-tertiary px-3 py-2">
      <span class="text-xs text-text-muted">Run scraper to load releases</span>
    </div>
  )}
</a>
