---
import type { Release } from "../lib/releases";
import { formatDate } from "../lib/releases";

interface Props {
  releases: Release[];
  sectionColor?: string;
  sectionRgb?: string;
  limit?: number;
}

const { releases, sectionColor = "#ff3333", sectionRgb = "255, 51, 51", limit = 5 } = Astro.props;

const breakingPatterns = /BREAKING|breaking change|removed|deprecated|incompatible|breaking:/i;
const breakingReleases = releases.filter((r) => r.body && breakingPatterns.test(r.body)).slice(0, limit);

function extractBreakingLines(body: string): string[] {
  const lines = body.split("\n");
  const result: string[] = [];
  let inBreaking = false;
  for (const line of lines) {
    const trimmed = line.trim();
    if (/breaking/i.test(trimmed) && /^#{1,4}\s/.test(trimmed)) {
      inBreaking = true;
      continue;
    }
    if (inBreaking && /^#{1,4}\s/.test(trimmed)) break;
    if (inBreaking && /^[-*]\s+/.test(trimmed)) {
      let clean = trimmed.replace(/^[-*]\s+/, "").replace(/\*\*/g, "").replace(/`/g, "").trim();
      if (clean.length > 120) clean = clean.slice(0, 117) + "...";
      if (clean.length > 5) result.push(clean);
    }
  }
  if (result.length === 0 && breakingPatterns.test(body)) {
    const bullets = body.split("\n").filter((l) => /^[-*]\s+/.test(l.trim()) && /breaking|removed|deprecated/i.test(l));
    for (const b of bullets.slice(0, 3)) {
      let clean = b.trim().replace(/^[-*]\s+/, "").replace(/\*\*/g, "").replace(/`/g, "").trim();
      if (clean.length > 120) clean = clean.slice(0, 117) + "...";
      result.push(clean);
    }
  }
  return result;
}
---

{breakingReleases.length > 0 && (
  <div class="rounded-lg border border-red/30 bg-red/[0.04]">
    <div class="border-b border-red/20 px-4 py-2.5 font-mono text-xs">
      <span class="text-red font-semibold">BREAKING CHANGES</span>
      <span class="ml-2 text-text-muted">({breakingReleases.length} release{breakingReleases.length > 1 ? "s" : ""})</span>
    </div>
    <div class="divide-y divide-border/30 p-0">
      {breakingReleases.map((r) => {
        const lines = extractBreakingLines(r.body || "");
        return (
          <div class="px-4 py-3">
            <div class="flex items-center gap-2 mb-1.5">
              <span class="font-mono text-sm font-semibold text-red">{r.version}</span>
              <span class="font-mono text-xs text-text-muted">{formatDate(r.date)}</span>
            </div>
            {lines.length > 0 ? (
              <ul class="space-y-1">
                {lines.map((l) => (
                  <li class="flex gap-2 font-mono text-xs text-text-secondary">
                    <span class="shrink-0 text-red/60">!</span>
                    <span>{l}</span>
                  </li>
                ))}
              </ul>
            ) : (
              <p class="font-mono text-xs text-text-muted italic">Contains breaking changes — view full changelog for details</p>
            )}
          </div>
        );
      })}
    </div>
  </div>
)}
