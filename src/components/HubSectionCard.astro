---
import type { Release } from "../lib/releases";
import { relativeTime } from "../lib/releases";

interface Props {
  name: string;
  route: string;
  color: string;
  rgb: string;
  description?: string;
  latestRelease?: Release;
  releaseCount?: number;
  featured?: boolean;
}

const { name, route, color, rgb, description, latestRelease, releaseCount = 0, featured = false } = Astro.props;
---

<a
  href={route}
  class:list={[
    "group flex flex-col rounded-lg border bg-bg-card transition-all duration-200",
    featured ? "p-6 sm:p-8" : "p-4 sm:p-5",
  ]}
  style={`border-color: rgba(${rgb}, 0.2); --glow: ${rgb};`}
>
  <div class="flex items-start justify-between gap-3">
    <div class="flex items-center gap-2.5">
      <span
        class="inline-block h-2.5 w-2.5 rounded-sm transition-shadow duration-200"
        style={`background: ${color}; box-shadow: 0 0 8px rgba(${rgb}, 0.3);`}
      ></span>
      <h3
        class:list={[
          "font-mono font-bold transition-all",
          featured ? "text-xl sm:text-2xl" : "text-base sm:text-lg",
        ]}
        style={`color: ${color};`}
      >
        {name}
      </h3>
    </div>
    <span
      class="font-mono text-xs opacity-0 transition-all duration-200 group-hover:opacity-100 group-hover:translate-x-1"
      style={`color: ${color};`}
    >&rarr;</span>
  </div>

  {description && (
    <p class:list={[
      "mt-2 font-sans text-text-secondary leading-relaxed",
      featured ? "text-sm" : "text-xs",
    ]}>
      {description}
    </p>
  )}

  <div class="mt-auto pt-4 flex items-center gap-3 font-mono text-xs text-text-muted">
    {latestRelease && (
      <>
        <span class="rounded px-2 py-0.5" style={`background: rgba(${rgb}, 0.1); color: ${color};`}>
          {latestRelease.version}
        </span>
        <span>{relativeTime(latestRelease.date)}</span>
      </>
    )}
    {releaseCount > 0 && (
      <span class="ml-auto">{releaseCount} releases</span>
    )}
  </div>
</a>

<style>
  a:hover {
    box-shadow: 0 0 20px rgba(var(--glow), 0.1);
    border-color: rgba(var(--glow), 0.4) !important;
  }
</style>
