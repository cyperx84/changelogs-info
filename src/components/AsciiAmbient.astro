---
// Lightweight Canvas 2D ASCII ambient background — no Three.js
---

<canvas class="ascii-ambient" aria-hidden="true"></canvas>

<script>
  const ambientCanvas = document.querySelector('.ascii-ambient') as HTMLCanvasElement;
  if (ambientCanvas) {
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const isMobile = window.innerWidth < 768;

    if (!prefersReduced && !isMobile) {
      initAsciiAmbient(ambientCanvas);
    }
  }

  function initAsciiAmbient(canvas: HTMLCanvasElement) {
    const parent = canvas.parentElement!;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const chars = ['>', '$', '_', '|', '#', '0', '1'];
    const cellSize = 20;
    let cols: number;
    let rows: number;
    let grid: { char: number; life: number }[];
    let scrollOffset = 0;
    let frame = 0;
    let animId: number;

    function resize() {
      const w = parent.offsetWidth;
      const h = parent.offsetHeight;
      canvas.width = w;
      canvas.height = h;
      cols = Math.ceil(w / cellSize) + 1;
      rows = Math.ceil(h / cellSize) + 2;
      grid = new Array(cols * rows);
      for (let i = 0; i < grid.length; i++) {
        grid[i] = {
          char: Math.floor(Math.random() * chars.length),
          life: Math.floor(Math.random() * 120),
        };
      }
    }

    resize();

    function draw() {
      animId = requestAnimationFrame(draw);
      frame++;
      scrollOffset += 0.3;

      if (scrollOffset >= cellSize) {
        scrollOffset -= cellSize;
        // Shift rows up: copy row 1..end into row 0..end-1, randomize last row
        for (let r = 0; r < rows - 1; r++) {
          for (let c = 0; c < cols; c++) {
            grid[r * cols + c] = grid[(r + 1) * cols + c];
          }
        }
        for (let c = 0; c < cols; c++) {
          grid[(rows - 1) * cols + c] = {
            char: Math.floor(Math.random() * chars.length),
            life: 0,
          };
        }
      }

      // Randomly change some characters
      if (frame % 3 === 0) {
        for (let i = 0; i < grid.length; i++) {
          grid[i].life++;
          if (grid[i].life >= 120) {
            grid[i].char = Math.floor(Math.random() * chars.length);
            grid[i].life = 0;
          }
        }
      }

      ctx.clearRect(0, 0, canvas.width, canvas.height);
      ctx.font = '12px JetBrains Mono, monospace';
      ctx.fillStyle = '#33ff33';

      for (let r = 0; r < rows; r++) {
        for (let c = 0; c < cols; c++) {
          const cell = grid[r * cols + c];
          if (!cell) continue;
          const x = c * cellSize;
          const y = r * cellSize - scrollOffset + cellSize;
          ctx.fillText(chars[cell.char], x, y);
        }
      }
    }

    draw();

    const ro = new ResizeObserver(() => resize());
    ro.observe(parent);

    document.addEventListener('astro:before-swap', () => {
      cancelAnimationFrame(animId);
      ro.disconnect();
    }, { once: true });
  }
</script>

<style>
  .ascii-ambient {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    opacity: 0.04;
  }

  @media (prefers-reduced-motion: reduce) {
    .ascii-ambient {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .ascii-ambient {
      display: none;
    }
  }
</style>
