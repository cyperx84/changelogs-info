---
import type { Section } from "../lib/sections";
import type { Release } from "../lib/releases";

interface Props {
  section: Section;
  latestRelease?: Release;
  description?: string;
  repo?: string;
}

const { section, latestRelease, description, repo } = Astro.props;
---

<section
  class="relative overflow-hidden border-b"
  style={`border-color: rgba(${section.colorRgb}, 0.2); background: linear-gradient(135deg, rgba(${section.colorRgb}, 0.05) 0%, transparent 60%);`}
>
  <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6 sm:py-14">
    <div class="max-w-2xl">
      <div class="mb-3 flex items-center gap-3">
        <span
          class="inline-block h-3 w-3 rounded-sm"
          style={`background: ${section.color}; box-shadow: 0 0 12px ${section.color};`}
        ></span>
        <span class="font-mono text-xs uppercase tracking-widest text-text-muted">section</span>
      </div>
      <h1
        class="font-mono text-3xl font-bold sm:text-4xl"
        style={`color: ${section.color};`}
      >
        {section.name}
      </h1>
      {description && (
        <p class="mt-3 font-sans text-sm leading-relaxed text-text-secondary sm:text-base">
          {description}
        </p>
      )}
      {repo && (
        <p class="mt-2 font-mono text-xs text-text-muted">
          <span style={`color: ${section.color}; opacity: 0.6;`}>~/</span>{repo}
        </p>
      )}
      {latestRelease && (
        <div class="mt-5 inline-flex items-center gap-3 rounded-lg border px-4 py-2.5 font-mono text-sm" style={`border-color: rgba(${section.colorRgb}, 0.3); background: rgba(${section.colorRgb}, 0.08);`}>
          <span style={`color: ${section.color};`}>{latestRelease.version}</span>
          <span class="text-text-muted">|</span>
          <span class="text-text-secondary text-xs">{new Date(latestRelease.date).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}</span>
          {latestRelease.prerelease && (
            <span class="rounded border border-amber/40 bg-amber/10 px-1.5 py-0.5 text-[10px] text-amber">pre</span>
          )}
        </div>
      )}
    </div>
  </div>
</section>
