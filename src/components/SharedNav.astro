---
interface Props {
  currentSection?: string;
}

const { currentSection = "hub" } = Astro.props;

const sections = [
  { label: "OpenClaw", href: "/openclaw/", key: "openclaw", color: "#eb0000" },
  { label: "Claude Code", href: "/claude-code/", key: "claude-code", color: "#d97706" },
  { label: "Codex", href: "/codex-cli/", key: "codex", color: "#10b981" },
  { label: "Gemini", href: "/gemini-cli/", key: "gemini", color: "#3b82f6" },
  { label: "Kilo Code", href: "/kilocode/", key: "kilocode", color: "#CCFF33" },
  { label: "Hermes", href: "/hermes-agent/", key: "hermes-agent", color: "#D97706" },
  { label: "Models", href: "/models/", key: "models", color: "#0091f7" },
  { label: "Dispatches", href: "/blog/", key: "blog", color: "#eb0000" },
];
---

<header class="shared-nav" data-current={currentSection}>
  <div class="shared-nav__inner">
    <a href="/" class="shared-nav__brand">
      changelogs<span class="shared-nav__dot">.</span>info
    </a>

    <nav class="shared-nav__links" id="shared-desktop-nav" aria-label="Main navigation">
      {sections.map((s) => (
        <a
          href={s.href}
          class={`shared-nav__link ${currentSection === s.key ? "shared-nav__link--active" : ""}`}
          style={currentSection === s.key ? `--active-color: ${s.color};` : ""}
        >
          {s.label}
        </a>
      ))}
    </nav>

    <div class="shared-nav__actions">
      <button id="shared-theme-toggle" class="shared-nav__btn" aria-label="Toggle theme">
        <span id="shared-theme-label">◐</span>
      </button>
      <button id="shared-mobile-btn" class="shared-nav__hamburger" aria-label="Menu">
        <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile dropdown -->
  <div id="shared-mobile-menu" class="shared-nav__mobile">
    {sections.map((s) => (
      <a
        href={s.href}
        class={`shared-nav__mobile-link ${currentSection === s.key ? "shared-nav__mobile-link--active" : ""}`}
      >
        {s.label}
      </a>
    ))}
    <button id="shared-mobile-theme" class="shared-nav__mobile-link shared-nav__mobile-theme-btn">
      ◐ Toggle theme
    </button>
  </div>
</header>

<script is:inline>
  function __initSharedNav() {
    var stored = localStorage.getItem("theme");
    if (stored === "light") {
      document.documentElement.setAttribute("data-theme", "light");
    }

    function updateIcon() {
      var label = document.getElementById("shared-theme-label");
      var isLight = document.documentElement.getAttribute("data-theme") === "light";
      if (label) label.textContent = isLight ? "\u2600" : "\u25D0";
      // Also update mobile theme button text
      var mBtn = document.getElementById("shared-mobile-theme");
      if (mBtn) mBtn.textContent = (isLight ? "\u2600" : "\u25D0") + " Toggle theme";
    }
    updateIcon();

    function toggleTheme() {
      var isLight = document.documentElement.getAttribute("data-theme") === "light";
      if (isLight) {
        document.documentElement.removeAttribute("data-theme");
        localStorage.setItem("theme", "dark");
      } else {
        document.documentElement.setAttribute("data-theme", "light");
        localStorage.setItem("theme", "light");
      }
      updateIcon();
    }

    var btn = document.getElementById("shared-theme-toggle");
    if (btn) btn.addEventListener("click", toggleTheme);

    var mobileBtn = document.getElementById("shared-mobile-btn");
    var mobileMenu = document.getElementById("shared-mobile-menu");
    if (mobileBtn && mobileMenu) {
      mobileBtn.addEventListener("click", function() {
        var open = mobileMenu.style.display === "flex";
        mobileMenu.style.display = open ? "none" : "flex";
      });
      mobileMenu.querySelectorAll("a").forEach(function(link) {
        link.addEventListener("click", function() {
          mobileMenu.style.display = "none";
        });
      });
    }

    var mobileThemeBtn = document.getElementById("shared-mobile-theme");
    if (mobileThemeBtn) mobileThemeBtn.addEventListener("click", toggleTheme);
  }

  // Run immediately
  __initSharedNav();

  // Re-run after Astro ViewTransitions page swap
  document.addEventListener("astro:after-swap", __initSharedNav);
</script>
