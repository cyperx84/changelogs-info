---
import type { Release } from "../lib/releases";
import { formatDate, relativeTime } from "../lib/releases";
import { markdownToHtml } from "../lib/markdown";

interface Props {
  release: Release;
  toolId?: string;
}

const { release, toolId } = Astro.props;
const versionSlug = encodeURIComponent(release.version.replace(/^v/, ""));
const bodyHtml = release.body ? markdownToHtml(release.body) : "";
const borderColor = release.prerelease ? "border-l-amber/40" : "border-l-green/40";
const markerColor = release.prerelease ? "bg-amber" : "bg-green";

// Detect breaking changes
const breakingPatterns = /BREAKING|breaking change|removed|deprecated|incompatible|breaking:/i;
const hasBreaking = release.body ? breakingPatterns.test(release.body) : false;
// Consider body "long" if raw markdown exceeds ~600 chars
const isLong = (release.body?.length || 0) > 600;
const entryId = `release-${release.version.replace(/[^a-zA-Z0-9]/g, "-")}`;

// Generate structured summary from release body
function generateSummary(body: string | null) {
  if (!body) return null;

  const text = body.toLowerCase();
  const lines = body.split('\n').filter(l => l.trim());

  // What changed - extract first meaningful feature/fix/change
  let whatChanged = "";
  const featureMatch = body.match(/(?:added?|new|introduces?|implements?|features?)[:\s]+([^\n]+)/i);
  const fixMatch = body.match(/(?:fixed?|fixes?|resolves?|patches?)[:\s]+([^\n]+)/i);
  const changeMatch = body.match(/(?:changed?|updated?|improved?|enhanced?|refactor)[:\s]+([^\n]+)/i);
  
  if (featureMatch) whatChanged = featureMatch[1].trim();
  else if (fixMatch) whatChanged = fixMatch[1].trim();
  else if (changeMatch) whatChanged = changeMatch[1].trim();
  else {
    // Find first bullet point or meaningful line
    const bulletMatch = body.match(/[-*+]\s+([^\n]+)/);
    if (bulletMatch) whatChanged = bulletMatch[1].trim();
    else if (lines.length > 0) whatChanged = lines[0].substring(0, 100).trim();
  }
  
  // Clean up and truncate
  whatChanged = whatChanged.replace(/[#*_`]/g, '').substring(0, 120).trim();
  if (whatChanged.length > 100) whatChanged = whatChanged.substring(0, 97) + '...';

  // Why it matters - look for benefits/improvements
  let whyMatters = "";
  const benefitPatterns = [
    /(?:improves?|enhances?|boosts?|increases?|speeds? up)[:\s]+([^\n]+)/i,
    /(?:allows?|enables?|supports?|makes? it easier)[:\s]+([^\n]+)/i,
    /(?:performance|faster|better|safer|more stable)/i
  ];
  
  for (const pattern of benefitPatterns) {
    const match = body.match(pattern);
    if (match) {
      whyMatters = match[1] ? match[1].trim() : match[0];
      break;
    }
  }
  
  if (!whyMatters) {
    if (text.includes('fix') || text.includes('bug')) whyMatters = "Fixes issues and improves stability";
    else if (text.includes('feature') || text.includes('add')) whyMatters = "Adds new capabilities";
    else if (text.includes('security')) whyMatters = "Addresses security concerns";
    else if (hasBreaking) whyMatters = "Introduces breaking changes requiring updates";
    else whyMatters = "General improvements and updates";
  }
  
  whyMatters = whyMatters.replace(/[#*_`]/g, '').substring(0, 100).trim();

  // Who should care
  let audience = "All users";
  if (text.includes('breaking') || text.includes('api')) audience = "Developers using the API";
  else if (text.includes('cli') || text.includes('command')) audience = "CLI users";
  else if (text.includes('security')) audience = "Security-conscious users";
  else if (text.includes('performance')) audience = "Performance-sensitive users";
  else if (text.includes('bug') || text.includes('fix')) audience = "Users affected by bugs";
  else if (text.includes('docs') || text.includes('documentation')) audience = "Documentation readers";
  else if (release.prerelease) audience = "Early adopters and testers";

  // Action needed
  let actionNeeded = "No";
  if (hasBreaking) actionNeeded = "Yes - migration may be required";
  else if (text.includes('security') && text.includes('fix')) actionNeeded = "Yes - update recommended";
  else if (text.includes('critical') || text.includes('urgent')) actionNeeded = "Yes - update ASAP";
  else if (text.includes('deprecated') && !text.includes('removed')) actionNeeded = "Yes - prepare for future changes";

  return { whatChanged, whyMatters, audience, actionNeeded };
}

const summary = generateSummary(release.body);
const summaryId = `summary-${entryId}`;
---

<article class={`relative border-l-2 ${borderColor} pl-6 pb-8 last:pb-0`}>
  <!-- Terminal timeline marker -->
  <div class={`absolute -left-[5px] top-1 h-2 w-2 rounded-sm ${markerColor}`}></div>

  <div class="mb-3 flex flex-wrap items-center gap-3">
    <span class="font-mono text-lg font-bold text-green">{release.version}</span>
    {release.prerelease && (
      <span class="rounded border border-amber bg-amber/10 px-2 py-0.5 font-mono text-xs text-amber">
        pre
      </span>
    )}
    {hasBreaking && (
      <span class="rounded border border-red-400 bg-red-400/10 px-2 py-0.5 font-mono text-xs text-red-400">
        BREAKING
      </span>
    )}
    <span class="font-mono text-xs text-text-muted" title={formatDate(release.date)}>
      [{formatDate(release.date)}]
    </span>
    <span class="hidden font-mono text-xs text-text-muted sm:inline">
      ({relativeTime(release.date)})
    </span>
    {toolId && (
      <a
        href={`/tools/${toolId}/changelog/${versionSlug}`}
        class="font-mono text-xs text-cyan transition-colors hover:text-cyan/80"
      >
        details →
      </a>
    )}
    <a
      href={release.url}
      target="_blank"
      rel="noopener noreferrer"
      class="ml-auto font-mono text-xs text-accent transition-colors hover:text-accent-hover"
    >
      github →
    </a>
  </div>

  {release.name && release.name !== release.version && (
    <h3 class="mb-3 font-mono text-sm font-medium text-text-primary">
      <span class="text-green">#</span> {release.name}
    </h3>
  )}

  {bodyHtml && (
    <div>
      <div
        id={entryId}
        class:list={["changelog-body text-sm", { "max-h-[300px] overflow-hidden": isLong }]}
        set:html={bodyHtml}
      />
      {isLong && (
        <button
          class="release-toggle mt-2 font-mono text-xs text-cyan transition-colors hover:text-cyan/80"
          data-target={entryId}
          data-collapsed="true"
        >
          show more ▾
        </button>
      )}
    </div>
  )}

  {summary && (
    <div class="mt-4">
      <button
        class="summary-toggle font-mono text-xs text-cyan transition-colors hover:text-cyan/80"
        data-target={summaryId}
        data-collapsed="true"
      >
        <span class="summary-label">📋 Summary ▾</span>
      </button>
      <div id={summaryId} class="mt-2 hidden">
        <div class="rounded border border-text-muted/20 bg-text-muted/5 p-3 text-sm">
          <div class="mb-2">
            <span class="font-mono text-xs text-text-muted">What changed:</span>
            <p class="mt-1 text-text-primary">{summary.whatChanged}</p>
          </div>
          <div class="mb-2">
            <span class="font-mono text-xs text-text-muted">Why it matters:</span>
            <p class="mt-1 text-text-primary">{summary.whyMatters}</p>
          </div>
          <div class="mb-2">
            <span class="font-mono text-xs text-text-muted">Who should care:</span>
            <p class="mt-1 text-text-primary">{summary.audience}</p>
          </div>
          <div>
            <span class="font-mono text-xs text-text-muted">Action needed:</span>
            <p class:list={["mt-1", summary.actionNeeded !== "No" ? "text-amber" : "text-green"]}>
              {summary.actionNeeded}
            </p>
          </div>
        </div>
      </div>
    </div>
  )}
</article>

<script>
  document.querySelectorAll('.release-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const targetId = btn.getAttribute('data-target');
      if (!targetId) return;
      const el = document.getElementById(targetId);
      if (!el) return;
      const collapsed = btn.getAttribute('data-collapsed') === 'true';
      if (collapsed) {
        el.classList.remove('max-h-[300px]', 'overflow-hidden');
        btn.textContent = 'show less ▴';
        btn.setAttribute('data-collapsed', 'false');
      } else {
        el.classList.add('max-h-[300px]', 'overflow-hidden');
        btn.textContent = 'show more ▾';
        btn.setAttribute('data-collapsed', 'true');
      }
    });
  });

  document.querySelectorAll('.summary-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const targetId = btn.getAttribute('data-target');
      if (!targetId) return;
      const el = document.getElementById(targetId);
      if (!el) return;
      const label = btn.querySelector('.summary-label');
      if (!label) return;
      const collapsed = btn.getAttribute('data-collapsed') === 'true';
      if (collapsed) {
        el.classList.remove('hidden');
        label.textContent = '📋 Summary ▴';
        btn.setAttribute('data-collapsed', 'false');
      } else {
        el.classList.add('hidden');
        label.textContent = '📋 Summary ▾';
        btn.setAttribute('data-collapsed', 'true');
      }
    });
  });
</script>
