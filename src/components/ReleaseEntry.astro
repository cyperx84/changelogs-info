---
import type { Release } from "../lib/releases";
import { formatDate, relativeTime } from "../lib/releases";
import { markdownToHtml } from "../lib/markdown";

interface Props {
  release: Release;
  toolId?: string;
}

const { release, toolId } = Astro.props;
const versionSlug = encodeURIComponent(release.version.replace(/^v/, ""));
const bodyHtml = release.body ? markdownToHtml(release.body) : "";
---

<article class="relative border-l-2 border-border pl-6 pb-8 last:pb-0">
  <!-- Timeline dot -->
  <div class="absolute -left-[7px] top-0.5 h-3 w-3 rounded-full border-2 border-accent bg-bg-primary"></div>

  <div class="mb-2 flex flex-wrap items-center gap-3">
    <span class="font-mono text-base font-semibold text-green">{release.version}</span>
    {release.prerelease && (
      <span class="rounded-full border border-amber/30 bg-amber/10 px-2 py-0.5 text-xs text-amber">
        pre-release
      </span>
    )}
    <span class="text-xs text-text-muted" title={formatDate(release.date)}>
      {formatDate(release.date)} ({relativeTime(release.date)})
    </span>
    {toolId && (
      <a
        href={`/tools/${toolId}/changelog/${versionSlug}`}
        class="text-xs text-text-muted transition-colors hover:text-accent"
      >
        Details
      </a>
    )}
    <a
      href={release.url}
      target="_blank"
      rel="noopener noreferrer"
      class="ml-auto text-xs text-text-muted transition-colors hover:text-accent"
    >
      View on GitHub &rarr;
    </a>
  </div>

  {release.name && release.name !== release.version && (
    <h3 class="mb-2 text-sm font-medium text-text-primary">{release.name}</h3>
  )}

  {bodyHtml && (
    <div class="changelog-body text-sm" set:html={bodyHtml} />
  )}
</article>
