---
// SiteAnimations.astro — Site-wide scroll reveal + page transition overlay
// Drop into any layout to enable both features.
// No props needed. Works with Astro ViewTransitions.
---

<style is:global>
  /* ── Scroll Reveal ─────────────────────────────────────── */

  [data-reveal] {
    opacity: 0;
    transform: translateY(28px);
    transition:
      opacity 0.55s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      transform 0.55s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  [data-reveal="left"] {
    transform: translateX(-28px);
  }
  [data-reveal="right"] {
    transform: translateX(28px);
  }
  [data-reveal="scale"] {
    transform: scale(0.94) translateY(8px);
  }
  [data-reveal].is-visible {
    opacity: 1;
    transform: none;
  }

  /* ── Page transition overlay ───────────────────────────── */

  #pt-overlay {
    position: fixed;
    inset: 0;
    z-index: 10000;
    pointer-events: none;
    /* background set dynamically via JS */
    transform: translateX(-101%);
    will-change: transform;
  }

  /* ── Reduced motion ────────────────────────────────────── */

  @media (prefers-reduced-motion: reduce) {
    [data-reveal] {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
    #pt-overlay {
      display: none !important;
    }
  }
</style>

<script>
  // ── helpers ────────────────────────────────────────────────────────────────

  function getPrimaryColor(): string {
    return (
      getComputedStyle(document.documentElement)
        .getPropertyValue("--tool-primary")
        .trim() ||
      getComputedStyle(document.documentElement)
        .getPropertyValue("--section-color")
        .trim() ||
      "#333333"
    );
  }

  function getOverlay(): HTMLElement {
    let el = document.getElementById("pt-overlay");
    if (!el) {
      el = document.createElement("div");
      el.id = "pt-overlay";
      document.body.appendChild(el);
    }
    return el;
  }

  // ── Scroll reveal ──────────────────────────────────────────────────────────

  /**
   * Selectors that get data-reveal auto-applied. No need to touch page templates.
   * Works on both quickstart and tips layouts + any future pages.
   */
  const REVEAL_SELECTORS = [
    ".qs-hero__eyebrow",
    ".qs-hero__title",
    ".qs-hero__desc",
    ".qs-hero__badge",
    ".qs-step",
    ".qs-milestone",
    ".qs-next__title",
    ".qs-next__grid",
    ".tips-hero__eyebrow",
    ".tips-hero__title",
    ".tips-hero__desc",
    ".tips-section__header",
    ".tips-section",
    ".tips-card",
    ".tips-feature",
    ".tips-gotcha",
    ".tips-recipe",
  ];

  function initReveal() {
    // Apply data-reveal to matching elements that don't already have it
    REVEAL_SELECTORS.forEach((sel) => {
      document.querySelectorAll(sel).forEach((el) => {
        if (el.hasAttribute("data-reveal")) return;

        el.setAttribute("data-reveal", "");

        // Stagger siblings: index within parent, capped so last card isn't too late
        const parent = el.parentElement;
        if (parent) {
          const siblingIndex = [...parent.children].indexOf(el as HTMLElement);
          const delay = Math.min(siblingIndex * 75, 450);
          (el as HTMLElement).style.transitionDelay = delay + "ms";
        }
      });
    });

    // Observer: fire once per element as it enters viewport
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.06, rootMargin: "0px 0px -30px 0px" }
    );

    document.querySelectorAll("[data-reveal]").forEach((el) => {
      // Skip elements already visible (e.g. above fold on load)
      const rect = el.getBoundingClientRect();
      if (rect.top < window.innerHeight * 0.95) {
        // In or near viewport — observe with short delay so animation still plays
        observer.observe(el);
      } else {
        observer.observe(el);
      }
    });
  }

  // ── Page transitions ───────────────────────────────────────────────────────

  // Before navigation: slide overlay IN using the CURRENT page's primary color
  document.addEventListener("astro:before-preparation", () => {
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    const color = getPrimaryColor();
    const overlay = getOverlay();
    overlay.style.background = color;

    overlay.animate(
      [{ transform: "translateX(-101%)" }, { transform: "translateX(0%)" }],
      { duration: 280, easing: "cubic-bezier(0.4, 0, 1, 1)", fill: "forwards" }
    );
  });

  // After navigation: update overlay to NEW page color, then slide OUT
  document.addEventListener("astro:page-load", () => {
    // Re-run scroll reveal on new page
    initReveal();

    const overlay = document.getElementById("pt-overlay");
    if (!overlay) return;

    // Switch to new page's color mid-cover (user can't see — overlay is full screen)
    const newColor = getPrimaryColor();
    overlay.style.background = newColor;

    overlay
      .animate(
        [{ transform: "translateX(0%)" }, { transform: "translateX(101%)" }],
        { duration: 380, easing: "cubic-bezier(0, 0, 0.2, 1)", fill: "forwards" }
      )
      .finished.then(() => {
        overlay.style.transform = "translateX(-101%)";
      });
  });
</script>
