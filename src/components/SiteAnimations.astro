---
// SiteAnimations.astro — Site-wide scroll reveal + page transition overlay
// Drop into any layout to enable both features.
// No props needed. Works with Astro ViewTransitions.
---

<style is:global>
  /* ── Scroll Reveal ─────────────────────────────────────── */

  [data-reveal] {
    opacity: 0;
    transform: translateY(28px);
    /* promote to own layer so transition doesn't trigger layout */
    will-change: opacity, transform;
    transition:
      opacity 0.55s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      transform 0.55s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  [data-reveal="left"] {
    transform: translateX(-28px);
  }
  [data-reveal="right"] {
    transform: translateX(28px);
  }
  [data-reveal="scale"] {
    transform: scale(0.94) translateY(8px);
  }
  [data-reveal].is-visible {
    opacity: 1;
    transform: none;
    /* release compositor layer once animation is done */
    will-change: auto;
  }

  /* ── Page transition overlay ───────────────────────────── */

  #pt-overlay {
    position: fixed;
    inset: 0;
    z-index: 10000;
    pointer-events: none;
    opacity: 0;
    mix-blend-mode: color;
    will-change: opacity;
  }

  /* ── Reduced motion ────────────────────────────────────── */

  @media (prefers-reduced-motion: reduce) {
    [data-reveal] {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
    #pt-overlay {
      display: none !important;
    }
  }
</style>

<script>
  // ── helpers ────────────────────────────────────────────────────────────────

  function getPrimaryColor(): string {
    return (
      getComputedStyle(document.documentElement)
        .getPropertyValue("--tool-primary")
        .trim() ||
      getComputedStyle(document.documentElement)
        .getPropertyValue("--section-color")
        .trim() ||
      "#333333"
    );
  }

  function getOverlay(): HTMLElement {
    let el = document.getElementById("pt-overlay");
    if (!el) {
      el = document.createElement("div");
      el.id = "pt-overlay";
      document.body.appendChild(el);
    }
    return el;
  }

  // ── Scroll reveal ──────────────────────────────────────────────────────────

  /**
   * Selectors that get data-reveal auto-applied. No need to touch page templates.
   * Works on both quickstart and tips layouts + any future pages.
   */
  const REVEAL_SELECTORS = [
    ".qs-hero__eyebrow",
    ".qs-hero__title",
    ".qs-hero__desc",
    ".qs-hero__badge",
    ".qs-step",
    ".qs-milestone",
    ".qs-next__title",
    ".qs-next__grid",
    ".tips-hero__eyebrow",
    ".tips-hero__title",
    ".tips-hero__desc",
    ".tips-section__header",
    ".tips-section",
    ".tips-card",
    ".tips-feature",
    ".tips-gotcha",
    ".tips-recipe",
  ];

  function initReveal() {
    // Apply data-reveal to matching elements that don't already have it
    REVEAL_SELECTORS.forEach((sel) => {
      document.querySelectorAll(sel).forEach((el) => {
        if (el.hasAttribute("data-reveal")) return;

        el.setAttribute("data-reveal", "");

        // Stagger siblings: index within parent, capped so last card isn't too late
        const parent = el.parentElement;
        if (parent) {
          const siblingIndex = [...parent.children].indexOf(el as HTMLElement);
          const delay = Math.min(siblingIndex * 75, 450);
          (el as HTMLElement).style.transitionDelay = delay + "ms";
        }
      });
    });

    // Observer: fire once per element as it enters viewport
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.06, rootMargin: "0px 0px -30px 0px" }
    );

    document.querySelectorAll("[data-reveal]").forEach((el) => {
      // Skip elements already visible (e.g. above fold on load)
      const rect = el.getBoundingClientRect();
      if (rect.top < window.innerHeight * 0.95) {
        // In or near viewport — observe with short delay so animation still plays
        observer.observe(el);
      } else {
        observer.observe(el);
      }
    });
  }

  // ── Page transitions ───────────────────────────────────────────────────────
  //
  // Event sequence (Astro ViewTransitions SPA lifecycle):
  //   astro:before-preparation  → nav starts, old page visible  → fade overlay IN
  //   astro:before-swap          → DOM about to swap, overlay at peak → hold
  //   astro:page-load            → new page painted (2x rAF guard) → fade overlay OUT
  //
  // ::view-transition-old/new(root) are suppressed in view-transitions.css
  // so native transitions never fight the overlay.
  //

  let ptAnim: Animation | null = null;
  let transitioning = false;

  // Step 1: Nav starts — fade overlay in quickly to cover old page
  document.addEventListener("astro:before-preparation", () => {
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    transitioning = true;
    const color = getPrimaryColor();
    const overlay = getOverlay();
    overlay.style.backgroundColor = color;

    ptAnim?.cancel();
    // Fast fade-in so overlay covers page before DOM swap happens
    ptAnim = overlay.animate(
      [{ opacity: 0 }, { opacity: 0.6 }],
      { duration: 180, easing: "ease-in", fill: "forwards" }
    );
  });

  // Step 2: DOM about to swap — overlay is covering page, swap is invisible
  // Update bg color NOW so it's already the destination hue when we fade out
  document.addEventListener("astro:before-swap", () => {
    // Nothing to animate — just note we're mid-transition
    // Color update happens in page-load once new CSS vars are active
  });

  // Step 3: New page is loaded — wait for paint, then fade overlay out
  document.addEventListener("astro:page-load", () => {
    // Always re-run scroll reveal
    initReveal();

    if (!transitioning) return;
    transitioning = false;

    const overlay = document.getElementById("pt-overlay");
    if (!overlay) return;

    // New page CSS vars are live — read destination color
    const newColor = getPrimaryColor();
    overlay.style.backgroundColor = newColor;

    // Double rAF: first frame = layout, second frame = paint committed
    // Ensures new page content is fully rendered before we reveal it
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        ptAnim?.cancel();
        ptAnim = overlay.animate(
          [{ opacity: 0.6 }, { opacity: 0 }],
          { duration: 420, easing: "ease-out", fill: "forwards" }
        );
      });
    });
  });
</script>
