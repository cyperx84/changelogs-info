---
// SiteAnimations.astro — Site-wide glitch reveal + cinematic page transitions
// Drop into any layout to enable both features.
// No props needed. Works with Astro ViewTransitions.
---

<style is:global>
  /* ── Glitch Reveal ─────────────────────────────────────── */

  [data-reveal] {
    opacity: 0;
    clip-path: inset(40% 0 40% 0);
    filter: blur(4px);
    will-change: opacity, clip-path, filter;
  }
  [data-reveal].is-visible {
    opacity: 1;
    clip-path: inset(0 0 0 0);
    filter: blur(0);
    will-change: auto;
    transition:
      opacity 0.3s ease forwards,
      clip-path 0.35s steps(6, end) forwards,
      filter 0.4s ease forwards;
  }

  /* Hero elements get extra punch */
  [data-reveal="hero"] {
    opacity: 0;
    clip-path: inset(50% 10% 50% 10%);
    filter: blur(8px) brightness(1.5);
  }
  [data-reveal="hero"].is-visible {
    opacity: 1;
    clip-path: inset(0 0 0 0);
    filter: blur(0) brightness(1);
    transition:
      opacity 0.2s ease forwards,
      clip-path 0.45s steps(8, end) forwards,
      filter 0.6s ease forwards;
  }

  /* Cards / items get a subtle scale glitch */
  [data-reveal="card"] {
    opacity: 0;
    clip-path: inset(20% 20% 20% 20%);
    transform: scale(0.92);
  }
  [data-reveal="card"].is-visible {
    opacity: 1;
    clip-path: inset(0 0 0 0);
    transform: scale(1);
    transition:
      opacity 0.25s ease forwards,
      clip-path 0.3s steps(4, end) forwards,
      transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }

  /* ── Page transition overlay ───────────────────────────── */

  #pt-overlay {
    position: fixed;
    inset: 0;
    z-index: 10000;
    pointer-events: none;
    opacity: 0;
    transform: scale(1.08);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    will-change: opacity, transform;
  }

  /* ── Reduced motion ────────────────────────────────────── */

  @media (prefers-reduced-motion: reduce) {
    [data-reveal] {
      opacity: 1 !important;
      clip-path: none !important;
      filter: none !important;
      transform: none !important;
      transition: none !important;
    }
    #pt-overlay {
      display: none !important;
    }
  }
</style>

<script>
  // ── helpers ────────────────────────────────────────────────────────────────

  function getPrimaryColor(): string {
    return (
      getComputedStyle(document.documentElement)
        .getPropertyValue("--tool-primary")
        .trim() ||
      getComputedStyle(document.documentElement)
        .getPropertyValue("--section-color")
        .trim() ||
      "#333333"
    );
  }

  function getOverlay(): HTMLElement {
    let el = document.getElementById("pt-overlay");
    if (!el) {
      el = document.createElement("div");
      el.id = "pt-overlay";
      document.body.appendChild(el);
    }
    return el;
  }

  // ── Scroll reveal ──────────────────────────────────────────────────────────

  const REVEAL_SELECTORS = [
    { sel: ".qs-hero__eyebrow", mode: "hero" },
    { sel: ".qs-hero__title", mode: "hero" },
    { sel: ".qs-hero__desc", mode: "hero" },
    { sel: ".qs-hero__badge", mode: "hero" },
    { sel: ".guide-hero__title", mode: "hero" },
    { sel: ".guide-hero__body", mode: "hero" },
    { sel: ".qs-step", mode: "card" },
    { sel: ".qs-milestone", mode: "card" },
    { sel: ".qs-next__title", mode: "card" },
    { sel: ".qs-next__grid", mode: "card" },
    { sel: ".tips-hero__eyebrow", mode: "hero" },
    { sel: ".tips-hero__title", mode: "hero" },
    { sel: ".tips-hero__desc", mode: "hero" },
    { sel: ".tips-section__header", mode: "" },
    { sel: ".tips-section", mode: "" },
    { sel: ".tips-card", mode: "card" },
    { sel: ".tips-feature", mode: "card" },
    { sel: ".tips-gotcha", mode: "card" },
    { sel: ".tips-recipe", mode: "card" },
    { sel: ".guide-changelog", mode: "card" },
  ];

  function initReveal() {
    REVEAL_SELECTORS.forEach(({ sel, mode }) => {
      document.querySelectorAll(sel).forEach((el) => {
        if (el.hasAttribute("data-reveal")) return;
        el.setAttribute("data-reveal", mode || "");

        const parent = el.parentElement;
        if (parent) {
          const siblingIndex = [...parent.children].indexOf(el as HTMLElement);
          const delay = Math.min(siblingIndex * 75, 450);
          (el as HTMLElement).style.transitionDelay = delay + "ms";
        }
      });
    });

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.06, rootMargin: "0px 0px -30px 0px" }
    );

    document.querySelectorAll("[data-reveal]").forEach((el) => {
      observer.observe(el);
    });
  }

  // ── Cinematic page transitions ─────────────────────────────────────────────
  //
  // Event sequence (Astro ViewTransitions SPA lifecycle):
  //   astro:before-preparation  → nav starts  → scale in + fade overlay
  //   astro:before-swap          → DOM about to swap → hold
  //   astro:page-load            → new page painted → scale down + fade out
  //

  let ptAnim: Animation | null = null;
  let transitioning = false;

  document.addEventListener("astro:before-preparation", () => {
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    transitioning = true;
    const color = getPrimaryColor();
    const overlay = getOverlay();
    overlay.style.backgroundColor = color;
    overlay.style.backdropFilter = "blur(6px)";

    ptAnim?.cancel();
    // Dramatic scale-up + color wash
    ptAnim = overlay.animate(
      [
        { opacity: 0, transform: "scale(1.08)" },
        { opacity: 0.85, transform: "scale(1.0)" },
      ],
      { duration: 280, easing: "cubic-bezier(0.4, 0, 0.2, 1)", fill: "forwards" }
    );
  });

  document.addEventListener("astro:before-swap", () => {
    // Hold overlay through swap
  });

  document.addEventListener("astro:page-load", () => {
    initReveal();

    if (!transitioning) return;
    transitioning = false;

    const overlay = document.getElementById("pt-overlay");
    if (!overlay) return;

    const newColor = getPrimaryColor();
    overlay.style.backgroundColor = newColor;

    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        ptAnim?.cancel();
        // Cinematic scale-down reveal
        ptAnim = overlay.animate(
          [
            { opacity: 0.85, transform: "scale(1.0)" },
            { opacity: 0, transform: "scale(0.95)" },
          ],
          { duration: 600, easing: "cubic-bezier(0.0, 0, 0.2, 1)", fill: "forwards" }
        );
      });
    });
  });
</script>
