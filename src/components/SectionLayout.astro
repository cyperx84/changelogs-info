---
import type { Section } from "../lib/sections";

interface Props {
  section: Section;
}

const { section } = Astro.props;
---

<div
  class="section-themed"
  style={`--section-color: ${section.color}; --section-accent: ${section.accent}; --section-rgb: ${section.colorRgb};`}
>
  <slot />
</div>
