        "activation_flow": [
          "1. Scan and inject name+description into system prompt (metadata only)",
          "2. Model calls activate_skill when task matches",
          "3. User sees confirmation prompt",
          "4. SKILL.md body + folder structure added to context + file access granted",
          "5. Skill guidance prioritized for session duration"
        ],
        "key_details": [
          "/skills list — show discovered skills",
          "/skills link <path> — symlink skills from directory",
          "/skills disable <name> / enable <name> / reload",
          "gemini skills install https://github.com/org/skills.git",
          "gemini skills install /path/local",
          "gemini skills install https://github.com/org/repo.git --path skills/subfolder",
          "gemini skills uninstall <name> --scope workspace",
          "SKILL.md standard format (compatible with Claude Code, Codex, OpenClaw)"
